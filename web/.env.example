# Environment variables for the Astro web frontend.
# Copy to .env (public values) / .env.local (secrets, git-ignored) as needed.
# All variables have safe fallbacks in src/lib/sanity.ts, so the site builds
# without any of them set.

# Sanity project ID (public). Fallback: n2ynpgty
PUBLIC_SANITY_PROJECT_ID=n2ynpgty

# Sanity dataset (public). Fallback: production
PUBLIC_SANITY_DATASET=production

# Set by Vercel automatically ("production" in the prod environment).
# Controls CDN usage and the published/drafts perspective in src/lib/sanity.ts.
# Leave unset locally.
# PUBLIC_VERCEL_ENV=production

# Sanity read token used locally to preview draft content (belongs in .env.local).
# Never commit the actual token.
# SANITY_PREVIEW_TOKEN=
