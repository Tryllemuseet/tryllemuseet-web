<script>
  // ── Stjernefelt ─────────────────────────────────────────────────
  const container = document.getElementById('stars')
  if (container) {
    for (let i = 0; i < 65; i++) {
      const s = document.createElement('span')
      s.className = 'star'
      const size = Math.random() * 2.5 + 0.8
      s.style.cssText = `left:${Math.random()*100}%;top:${Math.random()*100}%;width:${size}px;height:${size}px;animation-delay:${Math.random()*4}s;animation-duration:${Math.random()*3+2}s;`
      container.appendChild(s)
    }
  }

  // ── Karusell ────────────────────────────────────────────────────
  const track   = document.getElementById('carousel-track') as HTMLElement | null
  const btnPrev = document.getElementById('carousel-prev') as HTMLButtonElement | null
  const btnNext = document.getElementById('carousel-next') as HTMLButtonElement | null

  if (track && btnPrev && btnNext) {
    const getScrollAmount = () => {
      const card = track.querySelector('.magiker-card') as HTMLElement | null
      return card ? card.offsetWidth + 20 : 280
    }
    btnNext.addEventListener('click', () => track.scrollBy({ left:  getScrollAmount(), behavior: 'smooth' }))
    btnPrev.addEventListener('click', () => track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' }))

    const updateBtns = () => {
      const atStart = track.scrollLeft <= 8
      const atEnd   = track.scrollLeft + track.clientWidth >= track.scrollWidth - 8
      btnPrev.style.opacity       = atStart ? '0.25' : '1'
      btnPrev.style.pointerEvents = atStart ? 'none' : 'auto'
      btnNext.style.opacity       = atEnd   ? '0.25' : '1'
      btnNext.style.pointerEvents = atEnd   ? 'none' : 'auto'
    }
    track.addEventListener('scroll', updateBtns, { passive: true })
    updateBtns()
  }

  // ── Partner-popup ────────────────────────────────────────────────
  const popup       = document.getElementById('partner-popup') as HTMLElement | null
  const backdrop    = popup?.querySelector('.partner-popup-backdrop') as HTMLElement | null
  const closeBtn    = popup?.querySelector('.partner-popup-close') as HTMLElement | null
  const popupLogo   = document.getElementById('popup-logo-wrap') as HTMLElement | null
  const popupName   = document.getElementById('popup-name') as HTMLElement | null
  const popupDesc   = document.getElementById('popup-description') as HTMLElement | null
  const popupLink   = document.getElementById('popup-link') as HTMLAnchorElement | null

  let lastFocused: HTMLElement | null = null

  function openPartnerPopup(data: { name: string; description: string; url: string; logo: string }) {
    if (!popup || !popupLogo || !popupName || !popupDesc || !popupLink) return
    popupLogo.innerHTML = data.logo
      ? `<img src="${data.logo}" alt="" class="popup-logo-img" />`
      : `<span class="sponsor-initial sponsor-initial--lg">${data.name.charAt(0)}</span>`
    popupName.textContent = data.name
    popupDesc.textContent = data.description || ''
    if (data.url) {
      popupLink.href = data.url
      popupLink.removeAttribute('hidden')
    } else {
      popupLink.setAttribute('hidden', '')
    }
    popup.removeAttribute('hidden')
    document.body.style.overflow = 'hidden'
    closeBtn?.focus()
  }

  function closePartnerPopup() {
    popup?.setAttribute('hidden', '')
    document.body.style.overflow = ''
    lastFocused?.focus()
  }

  document.querySelectorAll<HTMLElement>('.sponsor-item').forEach(btn => {
    btn.addEventListener('click', () => {
      lastFocused = btn
      openPartnerPopup({
        name:        btn.dataset.name        ?? '',
        description: btn.dataset.description ?? '',
        url:         btn.dataset.url         ?? '',
        logo:        btn.dataset.logo        ?? '',
      })
    })
  })

  backdrop?.addEventListener('click', closePartnerPopup)
  closeBtn?.addEventListener('click', closePartnerPopup)
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && popup && !popup.hasAttribute('hidden')) closePartnerPopup()
  })
</script>

