---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro'
import AnimateIn from '../components/AnimateIn.astro'
import MentionedMagicians from '../components/MentionedMagicians.astro'
import { getAllMagicians, getUpcomingEvents, getHomepage, getSiteConfig, getAllPartners, getLatestPressClipping, getFeaturedMediaAppearance, urlFor } from '../lib/sanity'

const today = new Date().toISOString().split('T')[0]

const mediaTypeLabels: Record<string, string> = {
  avis: 'Avis', nettavis: 'Nettavis', tv: 'TV', radio: 'Radio', podkast: 'Podkast',
}
const [magicians, events, hp, config, partners, latestClipping, featuredMedia] = await Promise.all([
  getAllMagicians(),
  getUpcomingEvents(3),
  getHomepage(),
  getSiteConfig(),
  getAllPartners(),
  getLatestPressClipping(),
  getFeaturedMediaAppearance(today),
])

// ── Fallback-verdier ─────────────────────────────────────────────
const hero = hp?.hero ?? {
  heading:   'Stedet der det',
  headingEm: 'umulige er mulig',
  ingress:   'Norges minste, merkeligste og mest magiske museum.',
  cta1Label: 'Planlegg besøket', cta1Href: '/besok',
  cta2Label: 'Se utstillingen →', cta2Href: '/utstillingen',
}
const infoBadges = hp?.infoBadges ?? [
  { label: 'Gratis inngang' },
  { label: '4000 år med magi' },
  { label: 'Søndager 12–15' },
]
const utstilling = hp?.utstillingsFokus ?? {
  eraLabel: 'Gullalderen 1845–1930',
  heading:  'Møt mesterne',
}
const ibsen = hp?.ibsenSeksjon ?? {
  heading:    'Henrik Ibsen var tryllekunstner',
  ingress:    'Det som få vet, er at lille Henrik som barn hadde trylling som hobby. Han ga forestillinger der han kunne få et ur til å forsvinne fra lommen på én mann og dukke opp hos en annen.',
  sitat:      'Enkelte søndagsaftener fik han lov til at optræde som tryllekunstner i et af husets værelser, og alle omkringboende naboer blev indbudte til at overvære forestillingen.',
  sitatKilde: '— Hedvig Stousland, Ibsens søster, i brev til Henrik Jæger',
  lenkLabel:  'Les mer tryllehistorie',
  lenkHref:   '/tryllehistorie',
}
const kurs = hp?.kursSeksjon ?? {
  heading:    'Tryllekurs for barn',
  ingress:    'Du lærer triks som er enkle å utføre, men som virker meget imponerende. Kursene går over tre ettermiddager annenhver uke.',
  detaljer:   [
    'Aldersgrupper: 6–8 år (kl. 17) · 9–12 år (kl. 18.30) · 13+ år (kl. 20)',
    'Kun 14 plasser per kurs — «først til mølla»',
    'Inkluderer kursmateriell og tryllerekvisitter',
  ],
  pris:       'kr 50',
  prisLabel:  'per kurs',
  fondsBadge: 'Støttet av Oslo kommunes Regionalt kulturfond',
  knappLabel: 'Se kommende kurs',
  knappHref:  '/aktiviteter',
}
const kursSitat = hp?.kursSitat ?? {
  tekst:  'Vil bare takke for et utrolig gøyalt tryllekurs — han koste seg!',
  kilde:  'Mor til kursdeltaker, 8 år · Januar 2026',
}
const barn = hp?.barnSeksjon ?? {
  heading:  'Magi du kan ta på og prøve',
  ingress:  'Den nedre delen av utstillingen er laget spesielt for barn.',
  features: ['Hunder utkledd som løver og tigre', 'Prøv å unnslippe som Houdini', 'Plasma-kule du kan styre med fingrene', 'Ta med en tegning hjem'],
  sitater:  [
    { emoji: '🐕', tekst: 'Adelaide hadde hunder utkledd som løver og tigre i showet sitt!', kilde: 'Fra barnefeltet — Adelaide Herrmann' },
    { emoji: '⚡', tekst: 'Legg hånden mot kulen — ser du at lysstrålene følger fingrene dine?', kilde: 'Fra barnefeltet — Plasma-kulen' },
  ],
}
const medlem = hp?.medlemSeksjon ?? {
  heading:    'Bli medlem!',
  tekst:      'Som medlem støtter du Tryllemuseet og bidrar til å holde magien levende for kommende generasjoner.',
  knappLabel: 'Bli medlem nå →',
  knappUrl:   'https://blimedlem.tryllemuseet.no',
}
const om = hp?.omMuseet ?? {
  heading:    'Fra Munkedamsveien til Årvoll gård',
  tekst:      'Den 9. desember 2001 åpnet daværende Oslo-ordfører Albert Nordengen dørene til Norsk Tryllemuseum i Munkedamsveien. Etter flere flyttinger og mange år på lager ble museet gjenåpnet på Årvoll gård 1. desember 2024 — takket være frivillige ildsjeler som holdt magien i live.\n\nI 2025 feirer Tryllemuseet ett år på Årvoll gård og hele 24 år som museum. Vi holder til i låven, vegg i vegg med kaféen og Fjøset.',
  sitat:      'Det umulige er bare det vi ikke har lært å gjøre ennå.',
  sitatKilde: '— Robert-Houdin',
}

function formatTime(d: string) {
  return new Date(d).toLocaleTimeString('nb-NO', { hour: '2-digit', minute: '2-digit' })
}
---

<BaseLayout
  title="Tryllemuseet — Norges mest magiske museum"
  description="Norges minste, merkeligste og mest magiske museum. Besøk oss på Årvoll i Oslo — søndager 12–15. Gratis inngang."
>

  <!-- ══ HERO ════════════════════════════════════════════════════ -->
  <section class="hero" aria-label="Velkommen til Tryllemuseet">
    <div class="hero-bg" aria-hidden="true">
      {hero.bgImage?.asset?.url ? (
        <img src={hero.bgImage.asset.url} alt="" class="hero-bg-img" />
      ) : (
        <div class="hero-stars" id="stars"></div>
      )}
      <div class="hero-vignette"></div>
    </div>
    <div class="container hero-inner">
      <p class="section-label hero-label">{config.addressShort} · {config.openingHoursShort}</p>
      <h1 class="display-title hero-title">
        {hero.heading}<br/>
        <em class="hero-accent">{hero.headingEm}</em>
      </h1>
      <p class="hero-sub">{hero.ingress}</p>
      <div class="hero-actions">
        <a href={hero.cta1Href} class="btn-primary">{hero.cta1Label}</a>
        <a href={hero.cta2Href} class="btn-ghost">{hero.cta2Label}</a>
      </div>
      <div class="hero-facts" aria-label="Fakta om museet">
        {infoBadges.map((badge, i) => (
          <>
            <div class="fact"><span class="fact-label">{badge.label}</span></div>
            {i < infoBadges.length - 1 && <div class="fact-divider" aria-hidden="true">✦</div>}
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ BESØKSSTRIP ═════════════════════════════════════════════ -->
  <section class="visit-strip" aria-label="Praktisk informasjon">
    <div class="container visit-strip-inner">
      <a href="/besok#apningstider" class="visit-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <div><strong>Åpningstider</strong><span>{config.openingHoursShort}</span></div>
      </a>
      <div class="visit-divider" aria-hidden="true"></div>
      <a href="/besok#adresse" class="visit-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <div><strong>Adresse</strong><span>{config.addressShort}</span></div>
      </a>
      <div class="visit-divider" aria-hidden="true"></div>
      <a href="/besok#priser" class="visit-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <div><strong>Inngang</strong><span>Gratis for alle</span></div>
      </a>
      <div class="visit-divider" aria-hidden="true"></div>
      <a href={config.facebook} target="_blank" rel="noopener noreferrer" class="visit-item visit-item--highlight">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        <div><strong>Følg oss</strong><span>Facebook for oppdateringer →</span></div>
      </a>
    </div>
  </section>

  <!-- ══ ARRANGEMENTER ═══════════════════════════════════════════ -->
  <section class="section events-section" aria-labelledby="events-heading">
    <div class="container">
      <AnimateIn direction="up">
        <div class="section-header">
          <div>
            <p class="section-label">Kalender</p>
            <h2 class="display-title section-title" id="events-heading">Kommende arrangementer</h2>
          </div>
          <a href="/aktiviteter" class="btn-outline">Se alle</a>
        </div>
      </AnimateIn>
      {events.length > 0 ? (
        <AnimateIn direction="up">
        <div class="events-grid">
          {events.map((event) => (
            <article class="event-card">
              <div class="event-date-block">
                <span class="event-day">{new Date(event.date).getDate()}</span>
                <span class="event-month">{new Date(event.date).toLocaleDateString('nb-NO', { month: 'short' })}</span>
              </div>
              <div class="event-body">
                <div class="event-meta">
                  {event.ageGroup && <span class="event-tag">{event.ageGroup}</span>}
                  <span class="event-time">{formatTime(event.date)}</span>
                  {event.price && <span class="event-price">{event.price}</span>}
                </div>
                <h3 class="event-title"><a href="/aktiviteter">{event.title}</a></h3>
                {event.excerpt && <p class="event-excerpt">{event.excerpt}</p>}
              </div>
              {event.bookingUrl && (
                <a href={event.bookingUrl} target="_blank" rel="noopener noreferrer"
                   class="event-book" aria-label={`Meld deg på ${event.title}`}>Meld på →</a>
              )}
            </article>
          ))}
        </div>
        </AnimateIn>
      ) : (
        <AnimateIn direction="up">
        <div class="no-events">
          <p>Ingen kommende arrangementer akkurat nå. Følg oss på
            <a href={config.facebook} target="_blank" rel="noopener noreferrer">Facebook</a> for oppdateringer.
          </p>
        </div>
        </AnimateIn>
      )}
    </div>
  </section>

  <hr class="gold-rule container" />

  <!-- ══ MØT MAGIKERNE — horisontal scroll-karusell ══════════════ -->
  <section class="section magikerne-section" aria-labelledby="magikerne-heading">
    <div class="container">
      <AnimateIn direction="up">
        <div class="section-header">
          <div>
            <p class="section-label">{utstilling.eraLabel}</p>
            <h2 class="display-title section-title" id="magikerne-heading">{utstilling.heading}</h2>
          </div>
          <a href="/utstillingen" class="btn-outline">Hele utstillingen</a>
        </div>
      </AnimateIn>
    </div>
    <div class="carousel-viewport" aria-label="Magikere i utstillingen">
      <div class="carousel-track" id="carousel-track">
        {(hp?.utstillingsFokus?.felt?.length ? hp.utstillingsFokus.felt : magicians).map((m) => {
          const imgUrl = m.posterImage?.asset?._ref
            ? urlFor(m.posterImage.asset).width(600).height(800).fit('crop').format('webp').url()
            : (m.posterImage?.asset?.url ?? null)
          return (
            <a href={`/utstillingen/${m.slug}`} class="magiker-card" aria-label={`Les mer om ${m.title}`}>
              <div class="magiker-img">
                {imgUrl
                  ? <img src={imgUrl} alt={m.posterImage?.alt ?? m.title} loading="lazy" />
                  : <div class="magiker-img-placeholder" aria-hidden="true">🎩</div>
                }
                <div class="magiker-overlay" aria-hidden="true"></div>
              </div>
              <div class="magiker-caption">
                {m.years && <span class="magiker-years">{m.years}</span>}
                <h3 class="magiker-name">{m.title}</h3>
                {m.tagline && <p class="magiker-tagline">«{m.tagline}»</p>}
                <span class="magiker-link-hint">Les mer →</span>
              </div>
            </a>
          )
        })}
      </div>
      <button class="carousel-btn carousel-btn--prev" id="carousel-prev" aria-label="Forrige">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="carousel-btn carousel-btn--next" id="carousel-next" aria-label="Neste">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
    <div class="carousel-fade carousel-fade--left"  aria-hidden="true"></div>
    <div class="carousel-fade carousel-fade--right" aria-hidden="true"></div>
  </section>

  <hr class="gold-rule container" />

  <!-- ══ IBSEN ═══════════════════════════════════════════════════ -->
  <section class="section ibsen-section" aria-labelledby="ibsen-heading">
    <div class="container ibsen-inner">
      <AnimateIn direction="left">
      <div class="ibsen-text">
        <p class="section-label">Visste du at…</p>
        <h2 class="display-title section-title" id="ibsen-heading">{ibsen.heading}</h2>
        <p class="ibsen-ingress">{ibsen.ingress}</p>
        <blockquote class="ibsen-quote">
          <p>«{ibsen.sitat}»</p>
          <cite>{ibsen.sitatKilde}</cite>
        </blockquote>
        <a href={ibsen.lenkHref} class="btn-outline" style="margin-top:1.5rem;display:inline-block">
          {ibsen.lenkLabel}
        </a>
      </div>
      </AnimateIn>
      <AnimateIn direction="right">
      <div class="ibsen-portrait" aria-hidden="true">
        <svg viewBox="0 0 240 360" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M90 360 L80 265 L68 195 L74 152 L120 134 L166 152 L172 195 L160 265 L150 360Z" fill="rgba(107,15,26,0.15)" stroke="rgba(212,168,67,0.3)" stroke-width="1"/>
          <path d="M100 155 L120 185 L140 155" stroke="rgba(212,168,67,0.25)" stroke-width="1" fill="none"/>
          <ellipse cx="120" cy="112" rx="28" ry="34" fill="rgba(107,15,26,0.2)" stroke="rgba(212,168,67,0.35)" stroke-width="1"/>
          <rect x="90" y="80" width="60" height="7" rx="2" fill="rgba(212,168,67,0.45)" stroke="rgba(212,168,67,0.5)" stroke-width="1"/>
          <rect x="96" y="44" width="48" height="38" rx="2" fill="rgba(107,15,26,0.25)" stroke="rgba(212,168,67,0.4)" stroke-width="1"/>
          <path d="M94 118 Q104 124 112 122" stroke="rgba(212,168,67,0.4)" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M128 122 Q136 124 146 118" stroke="rgba(212,168,67,0.4)" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M115 147 L120 165 L125 147" fill="rgba(212,168,67,0.2)" stroke="rgba(212,168,67,0.3)" stroke-width="1"/>
          <path d="M150 210 L174 345 Q176 352 173 355" stroke="rgba(212,168,67,0.3)" stroke-width="2" stroke-linecap="round"/>
          <circle cx="74" cy="52" r="1.5" fill="rgba(212,168,67,0.5)"/>
          <circle cx="166" cy="38" r="2"   fill="rgba(212,168,67,0.45)"/>
          <circle cx="80" cy="32" r="1"   fill="rgba(212,168,67,0.3)"/>
          <circle cx="158" cy="60" r="1"  fill="rgba(212,168,67,0.3)"/>
        </svg>
        <p class="ibsen-portrait-caption">Henrik Ibsen · 1828–1906</p>
      </div>
      </AnimateIn>
    </div>
  </section>

  <hr class="gold-rule container" />

  <!-- ══ UKENS HISTORISKE ARTIKKEL ══════════════════════════════ -->
  {latestClipping && (
    <section class="section press-section" aria-labelledby="press-heading">
      <div class="container press-inner">
        <AnimateIn direction="left">
        <div class="press-text">
          <p class="section-label">Ukens historiske artikkel</p>
          <h2 class="display-title section-title" id="press-heading">{latestClipping.title}</h2>
          {(latestClipping.sourceName || latestClipping.originalDate) && (
            <p class="press-meta">
              {latestClipping.sourceName && <span>{latestClipping.sourceName}</span>}
              {latestClipping.sourceName && latestClipping.originalDate && <span aria-hidden="true"> · </span>}
              {latestClipping.originalDate && <span>{new Date(latestClipping.originalDate).toLocaleDateString('nb-NO', { day: 'numeric', month: 'long', year: 'numeric' })}</span>}
            </p>
          )}
          <p class="press-teaser">{latestClipping.teaser}</p>
          <MentionedMagicians magicians={latestClipping.mentionedMagicians} />
          <div class="press-actions">
            <a href={latestClipping.sourceUrl} target="_blank" rel="noopener" class="btn-primary">
              Les hos Nasjonalbiblioteket →
            </a>
            <a href="/tryllehistorie/historiske-artikler" class="btn-outline">
              Se arkivet
            </a>
          </div>
        </div>
        </AnimateIn>
        {latestClipping.image?.asset?.url && (
          <AnimateIn direction="right">
          <div class="press-image">
            <img
              src={latestClipping.image.asset.url}
              alt={latestClipping.image.alt ?? latestClipping.title}
              loading="lazy"
            />
          </div>
          </AnimateIn>
        )}
      </div>
    </section>
  )}

  {featuredMedia && (
    <>
      <hr class="gold-rule container" />
      <!-- ══ MUSEET I MEDIA ══════════════════════════════════════════ -->
      <section class="section media-section" aria-labelledby="media-heading">
        <div class="container media-inner">
          <AnimateIn direction="left">
          <div class="media-text">
            <p class="section-label">Museet i media</p>
            <span class="media-type-badge">{mediaTypeLabels[featuredMedia.type] ?? featuredMedia.type}</span>
            <h2 class="display-title section-title" id="media-heading">{featuredMedia.title}</h2>
            <p class="media-meta">
              <span>{featuredMedia.sourceName}</span>
              {featuredMedia.publishedAt && (
                <>
                  <span aria-hidden="true"> · </span>
                  <span>{new Date(featuredMedia.publishedAt).toLocaleDateString('nb-NO', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
                </>
              )}
            </p>
            {featuredMedia.quote && (
              <blockquote class="media-quote">
                <p>«{featuredMedia.quote}»</p>
                <cite>— {featuredMedia.sourceName}</cite>
              </blockquote>
            )}
            <p class="media-teaser">{featuredMedia.teaser}</p>
            <div class="media-actions">
              {featuredMedia.sourceUrl && (
                <a href={featuredMedia.sourceUrl} target="_blank" rel="noopener" class="btn-primary">
                  Les artikkelen →
                </a>
              )}
              <a href="/om-oss/i-media" class="btn-outline">Se all pressedekning</a>
            </div>
          </div>
          </AnimateIn>
          <AnimateIn direction="right">
          <div class="media-visual">
            {featuredMedia.videoId ? (
              <div class="media-video-wrap">
                <iframe
                  src={`https://www.youtube.com/embed/${featuredMedia.videoId}`}
                  title={featuredMedia.title}
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                ></iframe>
              </div>
            ) : featuredMedia.image?.asset?.url ? (
              <div class="media-image">
                <img
                  src={featuredMedia.image.asset.url}
                  alt={featuredMedia.image.alt ?? featuredMedia.title}
                  loading="lazy"
                />
              </div>
            ) : null}
          </div>
          </AnimateIn>
        </div>
      </section>
    </>
  )}

  <hr class="gold-rule container" />

  <!-- ══ KURS ════════════════════════════════════════════════════ -->
  <section class="section kurs-section" aria-labelledby="kurs-heading">
    <div class="container kurs-inner">
      <AnimateIn direction="left">
      <div class="kurs-text">
        <p class="section-label">Aktuelt nå</p>
        <h2 class="display-title section-title" id="kurs-heading">{kurs.heading}</h2>
        <p class="kurs-ingress">{kurs.ingress}</p>
        <ul class="kurs-list">
          {kurs.detaljer.map((d: string) => (
            <li><span aria-hidden="true">✦</span> {d}</li>
          ))}
        </ul>
        <div class="kurs-pris">
          <span class="kurs-pris-tall">{kurs.pris}</span>
          <span class="kurs-pris-label">{kurs.prisLabel}</span>
        </div>
        <a href={kurs.knappHref} class="btn-primary" style="display:inline-block;margin-top:0.25rem">
          {kurs.knappLabel}
        </a>
        <p class="kurs-fonds">{kurs.fondsBadge}</p>
      </div>
      </AnimateIn>
      <AnimateIn direction="right">
      <div class="kurs-sitat-wrap">
        <div class="kurs-sitat">
          <p class="kurs-sitat-tekst">«{kursSitat.tekst}»</p>
          <p class="kurs-sitat-kilde">— {kursSitat.kilde}</p>
        </div>
      </div>
      </AnimateIn>
    </div>
  </section>

<!-- ══ SPONSORER ═══════════════════════════════════════════════ -->
{partners.length > 0 && (
  <section class="sponsors-section" aria-label="Støttespillere">
    <div class="container sponsors-inner">
      <AnimateIn direction="up">
      <div class="sponsors-groups">
        {(
          [
            { label: 'Prosjektstøtte',        cats: ['public', 'private'] as const },
            { label: 'Samarbeidspartnere',     cats: ['org']               as const },
            { label: 'Fordeler for medlemmer', cats: ['benefit']           as const },
          ] as { label: string; cats: (typeof partners[0]['category'])[] }[]
        ).map(({ label, cats }) => {
            const gruppe = partners.filter(p => cats.includes(p.category))
            if (!gruppe.length) return null
            return (
              <div class="sponsors-group">
                <p class="sponsors-label">{label}</p>
                <div class="sponsors-logos">
                  {gruppe.map(p => (
                    <button
                      class="sponsor-item"
                      aria-label={`Les mer om ${p.name}`}
                      data-name={p.name}
                      data-description={p.description ?? ''}
                      data-url={p.url ?? ''}
                      data-logo={p.logo?.asset?.url ?? ''}
                    >
                      <div class="sponsor-logo-wrap">
                        {p.logo?.asset?.url
                          ? <img src={p.logo.asset.url} alt="" class="sponsor-logo" loading="lazy" />
                          : <span class="sponsor-initial">{p.name.charAt(0)}</span>
                        }
                      </div>
                      <span class="sponsor-name">{p.name}</span>
                      <span class="sponsor-info-hint" aria-hidden="true">ℹ</span>
                    </button>
                  ))}
                </div>
              </div>
            )
