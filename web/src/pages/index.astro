---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';

// TODO: Bytt ut med ekte Sanity-data når schema er oppe:
// import { getUpcomingEvents, getFeaturedMagicians, getSiteConfig } from '../lib/sanity';
// const events    = await getUpcomingEvents(3);
// const magicians = await getFeaturedMagicians(3);

const events = [
  {
    slug:     'familieforestilling-mai',
    title:    'Familieforestilling',
    date:     new Date('2026-05-11T13:00:00'),
    ageGroup: 'Familier',
    price:    'Kr 80,–',
    excerpt:  'En times magisk forestilling med trylling, humor og store illusjoner for hele familien.',
  },
  {
    slug:     'tryllekurs-juni-6-8',
    title:    'Tryllekurs 6–8 år',
    date:     new Date('2026-06-04T17:30:00'),
    ageGroup: '6–8 år',
    price:    'Kr 50,–',
    excerpt:  'Lær ditt første skikkelige trylletriks! Kurset ledes av erfarne tryllekunstnere.',
  },
  {
    slug:     'tryllekurs-juni-9-12',
    title:    'Tryllekurs 9–12 år',
    date:     new Date('2026-06-04T19:00:00'),
    ageGroup: '9–12 år',
    price:    'Kr 50,–',
    excerpt:  'Bygg videre på triksene du kan, eller start fra scratch. Maks 14 plasser.',
  },
];

const magicians = [
  { slug: 'robert-houdin',  title: 'Robert-Houdin',  years: '1805–1871', tagline: 'Grunnleggeren',          emoji: '🎩' },
  { slug: 'herrmann',       title: 'A. & A. Herrmann',years: '1844–1932', tagline: 'Kongen og dronningen',   emoji: '🐕' },
  { slug: 'houdini',        title: 'Harry Houdini',   years: '1874–1926', tagline: 'Gullalderens klimaks',   emoji: '⛓️' },
];

function formatDate(d: Date) {
  return d.toLocaleDateString('nb-NO', { day: 'numeric', month: 'long', year: 'numeric' });
}
function formatTime(d: Date) {
  return d.toLocaleTimeString('nb-NO', { hour: '2-digit', minute: '2-digit' });
}
---

<BaseLayout
  title="Tryllemuseet — Norges mest magiske museum"
  description="Norges minste, merkeligste og mest magiske museum. Besøk oss på Årvoll i Oslo — søndager 12–16."
>

  <!-- ══════════════════════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════════════════════ -->
  <section class="hero" aria-label="Velkommen til Tryllemuseet">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-stars" id="stars"></div>
      <div class="hero-vignette"></div>
    </div>

    <div class="container hero-inner">
      <p class="section-label hero-label">Årvollveien 35 · Oslo · Søndager 12–16</p>

      <h1 class="display-title hero-title">
        Stedet der det<br/>
        <em class="hero-accent">umulige</em> er mulig
      </h1>

      <p class="hero-sub">
        Norges minste, merkeligste og mest magiske museum —
        fylt med gullalderplakater, tryllehistorie og hemmeligheter
        som venter på å bli avslørt.
      </p>

      <div class="hero-actions">
        <a href="/besok" class="btn btn-primary">Planlegg besøket</a>
        <a href="/utstillingen" class="btn btn-ghost">Se utstillingen →</a>
      </div>

      <div class="hero-facts" aria-label="Fakta om museet">
        <div class="fact">
          <span class="fact-num">7</span>
          <span class="fact-label">Utstillingsfelt</span>
        </div>
        <div class="fact-divider" aria-hidden="true">✦</div>
        <div class="fact">
          <span class="fact-num">150+</span>
          <span class="fact-label">Rekvisitter</span>
        </div>
        <div class="fact-divider" aria-hidden="true">✦</div>
        <div class="fact">
          <span class="fact-num">4000</span>
          <span class="fact-label">År med magi</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════
       BESØKSINFO — RASK OVERSIKT
  ══════════════════════════════════════════════════════════════ -->
  <section class="visit-strip" aria-label="Praktisk informasjon">
    <div class="container visit-strip-inner">
      <a href="/besok#apningstider" class="visit-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <div>
          <strong>Åpningstider</strong>
          <span>Søndager 12–16</span>
        </div>
      </a>
      <div class="visit-divider" aria-hidden="true"></div>
      <a href="/besok#adresse" class="visit-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <div>
          <strong>Adresse</strong>
          <span>Årvollveien 35, Oslo</span>
        </div>
      </a>
      <div class="visit-divider" aria-hidden="true"></div>
      <a href="/besok#priser" class="visit-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        <div>
          <strong>Inngang</strong>
          <span>Gratis inngang for alle</span>
        </div>
      </a>
      <div class="visit-divider" aria-hidden="true"></div>
      <a href="/arrangementer" class="visit-item visit-item--highlight">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <div>
          <strong>Kommende kurs</strong>
          <span>Se alle arrangementer →</span>
        </div>
      </a>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════
       KOMMENDE ARRANGEMENTER
  ══════════════════════════════════════════════════════════════ -->
  <section class="section events-section" aria-labelledby="events-heading">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="section-label">Kalender</p>
          <h2 class="display-title section-title" id="events-heading">Kommende arrangementer</h2>
        </div>
        <a href="/arrangementer" class="btn btn-outline">Se alle</a>
      </div>

      <div class="events-grid">
        {events.map((event) => (
          <article class="event-card">
            <div class="event-date-block" aria-label={`Dato: ${formatDate(event.date)}`}>
              <span class="event-day">{event.date.getDate()}</span>
              <span class="event-month">
                {event.date.toLocaleDateString('nb-NO', { month: 'short' })}
              </span>
            </div>
            <div class="event-body">
              <div class="event-meta">
                <span class="event-tag">{event.ageGroup}</span>
                <span class="event-time">{formatTime(event.date)}</span>
                <span class="event-price">{event.price}</span>
              </div>
              <h3 class="event-title">
                <a href={`/arrangementer/${event.slug}`}>{event.title}</a>
              </h3>
              <p class="event-excerpt">{event.excerpt}</p>
            </div>
            <a href={`/arrangementer/${event.slug}`} class="event-arrow" aria-label={`Les mer om ${event.title}`}>→</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <hr class="gold-rule container" />

  <!-- ══════════════════════════════════════════════════════════════
       UTSTILLINGEN — TEASER
  ══════════════════════════════════════════════════════════════ -->
  <section class="section exhibition-section" aria-labelledby="exhibition-heading">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="section-label">Gullalderen 1845–1930</p>
          <h2 class="display-title section-title" id="exhibition-heading">Møt mesterne</h2>
        </div>
        <a href="/utstillingen" class="btn btn-outline">Hele utstillingen</a>
      </div>

      <div class="magicians-grid">
        {magicians.map((m) => (
          <a href={`/utstillingen/${m.slug}`} class="magician-card">
            <div class="magician-emoji" aria-hidden="true">{m.emoji}</div>
            <div class="magician-info">
              <h3 class="magician-name">{m.title}</h3>
              <span class="magician-years">{m.years}</span>
              <p class="magician-tagline">{m.tagline}</p>
            </div>
            <span class="magician-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>

      <div class="exhibition-cta">
        <p>Pluss: Adelaide Herrmann, Harry Kellar, Howard Thurston, filmene og plasma-kulen</p>
        <a href="/utstillingen" class="btn btn-primary">Se alle syv felt</a>
      </div>
    </div>
  </section>

  <hr class="gold-rule container" />

  <!-- ══════════════════════════════════════════════════════════════
       FOR BARN
  ══════════════════════════════════════════════════════════════ -->
  <section class="section kids-section" aria-labelledby="kids-heading">
    <div class="container kids-inner">
      <div class="kids-text">
        <p class="section-label">For de minste</p>
        <h2 class="display-title section-title" id="kids-heading">
          Magi du kan<br/>ta på og prøve
        </h2>
        <p class="kids-sub">
          Den nedre delen av utstillingen er laget spesielt for barn.
          Her er det barnetekster, aktiviteter og rekvisitter du kan holde i.
          Og selvfølgelig — noe å trylle med.
        </p>
        <ul class="kids-list">
          <li>
            <span class="kids-check" aria-hidden="true">✦</span>
            Hunder utkledd som løver og tigre
          </li>
          <li>
            <span class="kids-check" aria-hidden="true">✦</span>
            Prøv å unnslippe som Houdini
          </li>
          <li>
            <span class="kids-check" aria-hidden="true">✦</span>
            Plasma-kule du kan styre med fingrene
          </li>
          <li>
            <span class="kids-check" aria-hidden="true">✦</span>
            Ta med en tegning av din hund som løve hjem
          </li>
        </ul>
        <a href="/barn" class="btn btn-primary" style="margin-top:1.5rem">Les mer for barn og unge</a>
      </div>

      <div class="kids-visual" aria-hidden="true">
        <div class="kids-card">
          <div class="kids-card-emoji">🐕</div>
          <p class="kids-card-text">
            «Adelaide hadde hunder utkledd som løver og tigre i showet sitt!»
          </p>
          <span class="kids-card-label">Fra barnefeltet — Adelaide Herrmann</span>
        </div>
        <div class="kids-card kids-card--offset">
          <div class="kids-card-emoji">⚡</div>
          <p class="kids-card-text">
            «Legg hånden mot kulen — ser du at lysstrålene følger fingrene dine?»
          </p>
          <span class="kids-card-label">Fra barnefeltet — Plasma-kulen</span>
        </div>
      </div>
    </div>
  </section>

  <hr class="gold-rule container" />

  <!-- ══════════════════════════════════════════════════════════════
       OM MUSEET
  ══════════════════════════════════════════════════════════════ -->
  <section class="section about-strip" aria-labelledby="about-heading">
    <div class="container about-inner">
      <div class="about-text">
        <p class="section-label">Om Tryllemuseet</p>
        <h2 class="display-title section-title" id="about-heading">
          Norges minste,<br/>merkeligste museum
        </h2>
        <p>
          Tryllemuseet er et frivilligdrevet museum viet til tryllekunstens
          historie — fra begerspillet i Egypt for 4000 år siden til
          gullalderens store scenemagikere og norske tryllekunstnere i dag.
        </p>
        <p style="margin-top:1rem">
          Vi holder til på Årvoll i Oslo og er åpne søndager.
          Museet drives med lidenskap av et team av frivillige
          trylleentusiaster.
        </p>
        <div class="about-actions">
          <a href="/om-oss" class="btn btn-outline">Om museet</a>
          <a href="/om-oss/stott-oss" class="btn btn-outline">Støtt oss</a>
        </div>
      </div>
      <div class="about-quote">
        <blockquote>
          <p>
            «Det umulige er bare det vi ikke har lært å gjøre ennå.»
          </p>
          <cite>— Robert-Houdin</cite>
        </blockquote>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // Scatter twinkling stars in hero
  const container = document.getElementById('stars');
  if (container) {
    for (let i = 0; i < 65; i++) {
      const s = document.createElement('span');
      s.className = 'star';
      const size = Math.random() * 2.5 + 0.8;
      s.style.cssText = `
        left:${Math.random()*100}%;
        top:${Math.random()*100}%;
        width:${size}px;
        height:${size}px;
        animation-delay:${Math.random()*4}s;
        animation-duration:${Math.random()*3+2}s;
      `;
      container.appendChild(s);
    }
  }
</script>

<style>
  /* ── HERO ──────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    background: var(--burgundy-dk);
    color: var(--cream);
    padding: 7rem 0 5rem;
    overflow: hidden;
    min-height: 580px;
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-stars { position: absolute; inset: 0; }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 60% 50%, transparent 30%, rgba(74,10,18,0.7) 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 680px;
  }

  .hero-label {
    color: var(--gold-light);
    opacity: 0.8;
    margin-bottom: 1rem;
  }

  .hero-title {
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    color: var(--cream);
    margin-bottom: 1.25rem;
    text-shadow: 0 2px 24px rgba(0,0,0,0.5);
    line-height: 1.1;
  }

  .hero-accent {
    color: var(--gold);
    font-style: italic;
  }

  .hero-sub {
    font-family: var(--font-ui);
    font-size: 1.1rem;
    opacity: 0.85;
    max-width: 500px;
    line-height: 1.65;
    margin-bottom: 2.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3.5rem;
  }

  /* Hero facts */
  .hero-facts {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .fact { display: flex; flex-direction: column; }

  .fact-num {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--gold);
    line-height: 1;
  }

  .fact-label {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.65;
    margin-top: 0.2rem;
  }

  .fact-divider {
    color: var(--gold-dark);
    font-size: 0.6rem;
    opacity: 0.5;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--gold), var(--gold-light), var(--gold), transparent);
  }

  .star {
    position: absolute;
    background: var(--gold-light);
    border-radius: 50%;
    opacity: 0;
    animation: twinkle ease-in-out infinite;
  }
  @keyframes twinkle {
    0%, 100% { opacity: 0; transform: scale(0.4); }
    50%       { opacity: 0.55; transform: scale(1); }
  }

  /* ── BUTTONS ───────────────────────────────────────────────────── */
  .btn {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius);
    letter-spacing: 0.04em;
    transition: all 180ms ease;
  }

  .btn-primary {
    background: var(--gold);
    color: var(--burgundy-dk);
  }
  .btn-primary:hover {
    background: var(--gold-light);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(212,168,67,0.35);
  }

  .btn-ghost {
    border: 1.5px solid rgba(212,168,67,0.55);
    color: var(--gold-light);
  }
  .btn-ghost:hover {
    border-color: var(--gold);
    color: var(--gold);
    background: rgba(212,168,67,0.08);
  }

  .btn-outline {
    border: 1.5px solid var(--grey-light);
    color: var(--ink-mid);
  }
  .btn-outline:hover {
    border-color: var(--gold);
    color: var(--gold-dark);
  }

  /* ── VISIT STRIP ───────────────────────────────────────────────── */
  .visit-strip {
    background: white;
    border-bottom: 1px solid var(--cream-dark);
    box-shadow: var(--shadow);
  }

  .visit-strip-inner {
    display: flex;
    align-items: stretch;
    flex-wrap: wrap;
  }

  .visit-item {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 1.25rem 1.5rem;
    flex: 1;
    min-width: 200px;
    transition: background 180ms ease;
    text-decoration: none;
    color: var(--ink);
  }

  .visit-item:hover { background: var(--cream); }

  .visit-item--highlight { color: var(--burgundy); }
  .visit-item--highlight strong { color: var(--burgundy); }

  .visit-item svg {
    width: 22px; height: 22px;
    flex-shrink: 0;
    color: var(--gold-dark);
  }

  .visit-item div {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }

  .visit-item strong {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-mid);
  }

  .visit-item span {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--grey);
  }

  .visit-divider {
    width: 1px;
    background: var(--cream-dark);
    margin: 0.75rem 0;
    flex-shrink: 0;
  }

  /* ── SECTION COMMON ────────────────────────────────────────────── */
  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .section-title {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    margin-top: 0.4rem;
  }

  /* ── EVENTS ────────────────────────────────────────────────────── */
  .events-section { background: var(--cream); }

  .events-grid {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--cream-dark);
    border: 1px solid var(--cream-dark);
    border-radius: 6px;
    overflow: hidden;
  }

  .event-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
    background: white;
    transition: background 180ms ease;
  }

  .event-card:hover { background: var(--cream); }

  .event-date-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 52px;
    flex-shrink: 0;
    background: var(--burgundy);
    border-radius: 4px;
    padding: 0.4rem 0.2rem;
    color: var(--cream);
  }

  .event-day {
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1;
    color: var(--gold);
  }

  .event-month {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.8;
    margin-top: 0.1rem;
  }

  .event-body { flex: 1; min-width: 0; }

  .event-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.3rem;
    flex-wrap: wrap;
  }

  .event-tag {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--cream-dark);
    color: var(--ink-mid);
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
  }

  .event-time,
  .event-price {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--grey);
  }

  .event-price { color: var(--gold-dark); font-weight: 600; }

  .event-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--ink);
    margin-bottom: 0.25rem;
    letter-spacing: 0.03em;
  }

  .event-title a { color: inherit; }
  .event-title a:hover { color: var(--burgundy); }

  .event-excerpt {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--grey);
    line-height: 1.5;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .event-arrow {
    font-size: 1.25rem;
    color: var(--gold-dark);
    flex-shrink: 0;
    transition: transform 180ms ease;
    text-decoration: none;
  }
  .event-card:hover .event-arrow { transform: translateX(4px); }

  /* ── EXHIBITION TEASER ─────────────────────────────────────────── */
  .magicians-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .magician-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.25rem;
    background: white;
    border: 1px solid var(--cream-dark);
    border-radius: 6px;
    text-decoration: none;
    color: var(--ink);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .magician-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    border-color: var(--gold-light);
  }

  .magician-emoji {
    font-size: 1.75rem;
