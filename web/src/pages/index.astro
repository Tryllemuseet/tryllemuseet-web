---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro'
import { getAllMagicians, getUpcomingEvents } from '../lib/sanity'

const [magicians, events] = await Promise.all([
  getAllMagicians(),
  getUpcomingEvents(3),
])

// Vis de tre første magikerne (rekkefølge fra Sanity)
const featuredMagicians = magicians.slice(0, 3)

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('nb-NO', {
    day: 'numeric', month: 'long', year: 'numeric'
  })
}
function formatTime(d: string) {
  return new Date(d).toLocaleTimeString('nb-NO', {
    hour: '2-digit', minute: '2-digit'
  })
}
---

<BaseLayout
  title="Tryllemuseet — Norges mest magiske museum"
  description="Norges minste, merkeligste og mest magiske museum. Besøk oss på Årvoll i Oslo — søndager 12–15. Gratis inngang."
>

  <!-- ══ HERO ════════════════════════════════════════════════════ -->
  <section class="hero" aria-label="Velkommen til Tryllemuseet">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-stars" id="stars"></div>
      <div class="hero-vignette"></div>
    </div>

    <div class="container hero-inner">
      <p class="section-label hero-label">Årvollveien 35 · Oslo · Søndager 12–15</p>

      <h1 class="display-title hero-title">
        Stedet der det<br/>
        <em class="hero-accent">umulige</em> er mulig
      </h1>

      <p class="hero-sub">
        Norges minste, merkeligste og mest magiske museum —
        fylt med gullalderplakater, tryllehistorie og hemmeligheter
        som venter på å bli avslørt.
      </p>

      <div class="hero-actions">
        <a href="/besok" class="btn-primary">Planlegg besøket</a>
        <a href="/utstillingen" class="btn-ghost">Se utstillingen →</a>
      </div>

      <div class="hero-facts" aria-label="Fakta om museet">
        <div class="fact">
          <span class="fact-num">{magicians.length}</span>
          <span class="fact-label">Utstillingsfelt</span>
        </div>
        <div class="fact-divider" aria-hidden="true">✦</div>
        <div class="fact">
          <span class="fact-num">Gratis</span>
          <span class="fact-label">Inngang</span>
        </div>
        <div class="fact-divider" aria-hidden="true">✦</div>
        <div class="fact">
          <span class="fact-num">4000</span>
          <span class="fact-label">År med magi</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ BESØKSSTRIP ═════════════════════════════════════════════ -->
  <section class="visit-strip" aria-label="Praktisk informasjon">
    <div class="container visit-strip-inner">
      <a href="/besok#apningstider" class="visit-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <div><strong>Åpningstider</strong><span>Søndager 12:00–15:00</span></div>
      </a>
      <div class="visit-divider" aria-hidden="true"></div>
      <a href="/besok#adresse" class="visit-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <div><strong>Adresse</strong><span>Årvollveien 35, Oslo</span></div>
      </a>
      <div class="visit-divider" aria-hidden="true"></div>
      <a href="/besok#priser" class="visit-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <div><strong>Inngang</strong><span>Gratis for alle</span></div>
      </a>
      <div class="visit-divider" aria-hidden="true"></div>
      <a href="/arrangementer" class="visit-item visit-item--highlight">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <div><strong>Kommende kurs</strong><span>Se alle arrangementer →</span></div>
      </a>
    </div>
  </section>

  <!-- ══ ARRANGEMENTER ═══════════════════════════════════════════ -->
  <section class="section events-section" aria-labelledby="events-heading">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="section-label">Kalender</p>
          <h2 class="display-title section-title" id="events-heading">
            Kommende arrangementer
          </h2>
        </div>
        <a href="/arrangementer" class="btn-outline">Se alle</a>
      </div>

      {events.length > 0 ? (
        <div class="events-grid">
          {events.map((event) => (
            <article class="event-card">
              <div class="event-date-block">
                <span class="event-day">{new Date(event.date).getDate()}</span>
                <span class="event-month">
                  {new Date(event.date).toLocaleDateString('nb-NO', { month: 'short' })}
                </span>
              </div>
              <div class="event-body">
                <div class="event-meta">
                  {event.ageGroup && <span class="event-tag">{event.ageGroup}</span>}
                  <span class="event-time">{formatTime(event.date)}</span>
                  {event.price && <span class="event-price">{event.price}</span>}
                </div>
                <h3 class="event-title">
                  <a href={`/arrangementer`}>{event.title}</a>
                </h3>
                {event.excerpt && <p class="event-excerpt">{event.excerpt}</p>}
              </div>
              {event.bookingUrl && (
                <a
                  href={event.bookingUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="event-book"
                  aria-label={`Meld deg på ${event.title}`}
                >
                  Meld på →
                </a>
              )}
            </article>
          ))}
        </div>
      ) : (
        <div class="no-events">
          <p>Ingen kommende arrangementer akkurat nå. Følg oss på
            <a href="https://www.facebook.com/tryllemuseet" target="_blank" rel="noopener noreferrer">Facebook</a> for oppdateringer.
          </p>
        </div>
      )}
    </div>
  </section>

  <hr class="gold-rule container" />

  <!-- ══ UTSTILLINGEN ════════════════════════════════════════════ -->
  <section class="section exhibition-section" aria-labelledby="exhibition-heading">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="section-label">Gullalderen 1845–1930</p>
          <h2 class="display-title section-title" id="exhibition-heading">
            Møt mesterne
          </h2>
        </div>
        <a href="/utstillingen" class="btn-outline">Hele utstillingen</a>
      </div>

      <div class="magicians-grid">
        {featuredMagicians.map((m) => (
          <a href={`/utstillingen/${m.slug}`} class="magician-card">
            {m.posterImage?.asset?.url ? (
              <div class="magician-poster">
                <img
                  src={m.posterImage.asset.url}
                  alt={m.posterImage.alt ?? m.title}
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="magician-poster magician-poster--placeholder" aria-hidden="true">🎩</div>
            )}
            <div class="magician-info">
              <h3 class="magician-name">{m.title}</h3>
              {m.years && <span class="magician-years">{m.years}</span>}
              {m.tagline && <p class="magician-tagline">{m.tagline}</p>}
            </div>
            <span class="magician-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>

      <div class="exhibition-more">
        <p>Pluss {magicians.length - 3} flere felt — inkludert plasma-kulen og filmene</p>
        <a href="/utstillingen" class="btn-primary">Se alle {magicians.length} felt</a>
      </div>
    </div>
  </section>

  <hr class="gold-rule container" />

  <!-- ══ FOR BARN ════════════════════════════════════════════════ -->
  <section class="section kids-section" aria-labelledby="kids-heading">
    <div class="container kids-inner">
      <div class="kids-text">
        <p class="section-label">For de minste</p>
        <h2 class="display-title section-title" id="kids-heading">
          Magi du kan<br/>ta på og prøve
        </h2>
        <p class="kids-sub">
          Den nedre delen av utstillingen er laget spesielt for barn.
          Her er det barnetekster, aktiviteter og rekvisitter du kan holde i.
        </p>
        <ul class="kids-list">
          <li><span aria-hidden="true">✦</span> Hunder utkledd som løver og tigre</li>
          <li><span aria-hidden="true">✦</span> Prøv å unnslippe som Houdini</li>
          <li><span aria-hidden="true">✦</span> Plasma-kule du kan styre med fingrene</li>
          <li><span aria-hidden="true">✦</span> Ta med en tegning hjem</li>
        </ul>
        <a href="/barn" class="btn-primary" style="margin-top:1.5rem; display:inline-block">
          Les mer for barn og unge
        </a>
      </div>

      <div class="kids-cards">
        <div class="kids-card">
          <div class="kids-card-emoji">🐕</div>
          <p>«Adelaide hadde hunder utkledd som løver og tigre i showet sitt!»</p>
          <span>Fra barnefeltet — Adelaide Herrmann</span>
        </div>
        <div class="kids-card kids-card--offset">
          <div class="kids-card-emoji">⚡</div>
          <p>«Legg hånden mot kulen — ser du at lysstrålene følger fingrene dine?»</p>
          <span>Fra barnefeltet — Plasma-kulen</span>
        </div>
      </div>
    </div>
  </section>

  <hr class="gold-rule container" />

  <!-- ══ BLI MEDLEM ══════════════════════════════════════════════ -->
  <section class="section member-section" aria-labelledby="member-heading">
    <div class="container member-inner">
      <div class="member-text">
        <p class="section-label">Støtt museet</p>
        <h2 class="display-title section-title" id="member-heading">
          Bli medlem!
        </h2>
        <p class="member-sub">
          Som medlem støtter du Tryllemuseet og bidrar til å holde magien levende
          for kommende generasjoner. Medlemskapet er enkelt å tegne — og du
          hjelper et lite, frivilligdrevet museum å bestå.
        </p>
      </div>
      <a
        href="https://blimedlem.tryllemuseet.no"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-member"
      >
        Bli medlem nå →
      </a>
    </div>
  </section>

  <!-- ══ OM MUSEET ═══════════════════════════════════════════════ -->
  <section class="section about-section" aria-labelledby="about-heading">
    <div class="container about-inner">
      <div class="about-text">
        <p class="section-label">Om Tryllemuseet</p>
        <h2 class="display-title section-title" id="about-heading">
          Norges minste,<br/>merkeligste museum
        </h2>
        <p>
          Tryllemuseet er et frivilligdrevet museum viet til tryllekunstens
          historie — fra begerspillet i Egypt for 4000 år siden til
          gullalderens store scenemagikere og norske tryllekunstnere i dag.
        </p>
        <p style="margin-top:1rem">
          Vi holder til på Årvoll i Oslo og er åpne søndager 12–15.
          Gratis inngang for alle.
        </p>
        <div class="about-actions">
          <a href="/om-oss" class="btn-outline">Om museet</a>
          <a href="/kontakt" class="btn-outline">Kontakt oss</a>
        </div>
      </div>
      <div class="about-quote">
        <blockquote>
          <p>«Det umulige er bare det vi ikke har lært å gjøre ennå.»</p>
          <cite>— Robert-Houdin</cite>
        </blockquote>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  const container = document.getElementById('stars')
  if (container) {
    for (let i = 0; i < 65; i++) {
      const s = document.createElement('span')
      s.className = 'star'
      const size = Math.random() * 2.5 + 0.8
      s.style.cssText = `left:${Math.random()*100}%;top:${Math.random()*100}%;width:${size}px;height:${size}px;animation-delay:${Math.random()*4}s;animation-duration:${Math.random()*3+2}s;`
      container.appendChild(s)
    }
  }
</script>

<style>
  /* ── HERO ──────────────────────────────────────────────────────── */
  .hero { position:relative; background:var(--burgundy-dk); color:var(--cream); padding:7rem 0 5rem; overflow:hidden; min-height:580px; display:flex; align-items:center; }
  .hero-bg { position:absolute; inset:0; z-index:0; }
  .hero-stars { position:absolute; inset:0; }
  .hero-vignette { position:absolute; inset:0; background:radial-gradient(ellipse at 60% 50%, transparent 30%, rgba(74,10,18,0.7) 100%); }
  .hero-inner { position:relative; z-index:2; max-width:680px; }
  .hero-label { color:var(--gold-light); opacity:0.8; margin-bottom:1rem; }
  .hero-title { font-size:clamp(2.4rem,6vw,4.2rem); color:var(--cream); margin-bottom:1.25rem; text-shadow:0 2px 24px rgba(0,0,0,0.5); line-height:1.1; }
  .hero-accent { color:var(--gold); font-style:italic; }
  .hero-sub { font-family:var(--font-ui); font-size:1.1rem; opacity:0.85; max-width:500px; line-height:1.65; margin-bottom:2.5rem; }
  .hero-actions { display:flex; gap:1rem; flex-wrap:wrap; margin-bottom:3.5rem; }
  .hero-facts { display:flex; align-items:center; gap:1.5rem; flex-wrap:wrap; }
  .fact { display:flex; flex-direction:column; }
  .fact-num { font-family:var(--font-display); font-size:1.75rem; color:var(--gold); line-height:1; }
  .fact-label { font-family:var(--font-ui); font-size:0.7rem; text-transform:uppercase; letter-spacing:0.12em; opacity:0.65; margin-top:0.2rem; }
  .fact-divider { color:var(--gold-dark); font-size:0.6rem; opacity:0.5; }
  .hero::after { content:''; position:absolute; bottom:0; left:0; right:0; height:3px; background:linear-gradient(90deg,transparent,var(--gold),var(--gold-light),var(--gold),transparent); }
  .star { position:absolute; background:var(--gold-light); border-radius:50%; opacity:0; animation:twinkle ease-in-out infinite; }
  @keyframes twinkle { 0%,100%{opacity:0;transform:scale(0.4)} 50%{opacity:0.55;transform:scale(1)} }

  /* ── BUTTONS ───────────────────────────────────────────────────── */
  .btn-primary { display:inline-block; font-family:var(--font-ui); font-size:0.9rem; font-weight:600; padding:0.75rem 1.75rem; border-radius:var(--radius); letter-spacing:0.04em; transition:all 180ms ease; background:var(--gold); color:var(--burgundy-dk); text-decoration:none; }
  .btn-primary:hover { background:var(--gold-light); transform:translateY(-1px); box-shadow:0 4px 20px rgba(212,168,67,0.35); }
  .btn-ghost { display:inline-block; font-family:var(--font-ui); font-size:0.9rem; font-weight:600; padding:0.75rem 1.75rem; border-radius:var(--radius); letter-spacing:0.04em; transition:all 180ms ease; border:1.5px solid rgba(212,168,67,0.55); color:var(--gold-light); text-decoration:none; }
  .btn-ghost:hover { border-color:var(--gold); color:var(--gold); background:rgba(212,168,67,0.08); }
  .btn-outline { display:inline-block; font-family:var(--font-ui); font-size:0.875rem; font-weight:600; padding:0.6rem 1.25rem; border-radius:var(--radius); border:1.5px solid var(--grey-light); color:var(--ink-mid); transition:border-color 180ms,color 180ms; text-decoration:none; }
  .btn-outline:hover { border-color:var(--gold); color:var(--gold-dark); }

  /* ── VISIT STRIP ───────────────────────────────────────────────── */
  .visit-strip { background:white; border-bottom:1px solid var(--cream-dark); box-shadow:var(--shadow); }
  .visit-strip-inner { display:flex; align-items:stretch; flex-wrap:wrap; }
  .visit-item { display:flex; align-items:center; gap:0.9rem; padding:1.25rem 1.5rem; flex:1; min-width:180px; transition:background 180ms; text-decoration:none; color:var(--ink); }
  .visit-item:hover { background:var(--cream); }
  .visit-item--highlight { color:var(--burgundy); }
  .visit-item svg { width:22px; height:22px; flex-shrink:0; color:var(--gold-dark); }
  .visit-item div { display:flex; flex-direction:column; line-height:1.3; }
  .visit-item strong { font-family:var(--font-ui); font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:var(--ink-mid); }
  .visit-item span { font-family:var(--font-ui); font-size:0.875rem; color:var(--grey); }
  .visit-divider { width:1px; background:var(--cream-dark); margin:0.75rem 0; flex-shrink:0; }

  /* ── SECTION COMMON ────────────────────────────────────────────── */
  .section { padding:4rem 0; }
  .section-header { display:flex; align-items:flex-end; justify-content:space-between; gap:1rem; margin-bottom:2.5rem; flex-wrap:wrap; }
  .section-title { font-size:clamp(1.6rem,4vw,2.2rem); margin-top:0.4rem; }

  /* ── EVENTS ────────────────────────────────────────────────────── */
  .events-section { background:var(--cream); }
  .events-grid { display:flex; flex-direction:column; gap:1px; background:var(--cream-dark); border:1px solid var(--cream-dark); border-radius:6px; overflow:hidden; }
  .event-card { display:flex; align-items:center; gap:1.5rem; padding:1.25rem 1.5rem; background:white; transition:background 180ms; }
  .event-card:hover { background:var(--cream); }
  .event-date-block { display:flex; flex-direction:column; align-items:center; width:52px; flex-shrink:0; background:var(--burgundy); border-radius:4px; padding:0.4rem 0.2rem; color:var(--cream); }
  .event-day { font-family:var(--font-display); font-size:1.5rem; line-height:1; color:var(--gold); }
  .event-month { font-family:var(--font-ui); font-size:0.65rem; text-transform:uppercase; letter-spacing:0.1em; opacity:0.8; }
  .event-body { flex:1; min-width:0; }
  .event-meta { display:flex; align-items:center; gap:0.75rem; margin-bottom:0.3rem; flex-wrap:wrap; }
  .event-tag { font-family:var(--font-ui); font-size:0.7rem; font-weight:600; text-transform:uppercase; letter-spacing:0.1em; background:var(--cream-dark); color:var(--ink-mid); padding:0.15rem 0.5rem; border-radius:2px; }
  .event-time { font-family:var(--font-ui); font-size:0.8rem; color:var(--grey); }
  .event-price { font-family:var(--font-ui); font-size:0.8rem; color:var(--gold-dark); font-weight:600; }
  .event-title { font-family:var(--font-display); font-size:1.05rem; color:var(--ink); margin-bottom:0.25rem; letter-spacing:0.03em; }
  .event-title a { color:inherit; text-decoration:none; }
  .event-title a:hover { color:var(--burgundy); }
  .event-excerpt { font-family:var(--font-ui); font-size:0.875rem; color:var(--grey); line-height:1.5; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .event-book { font-family:var(--font-ui); font-size:0.8rem; font-weight:700; color:var(--cream); background:var(--gold); padding:0.4rem 0.8rem; border-radius:3px; text-decoration:none; flex-shrink:0; white-space:nowrap; transition:background 180ms; }
  .event-book:hover { background:var(--gold-light); color:var(--burgundy-dk); }
  .no-events { padding:2rem; text-align:center; background:white; border:1px solid var(--cream-dark); border-radius:6px; font-family:var(--font-ui); font-size:0.95rem; color:var(--ink-mid); }
  .no-events a { color:var(--burgundy); text-decoration:underline; }

  /* ── EXHIBITION ─────────────────────────────────────────────────── */
  .magicians-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; margin-bottom:1.5rem; }
  .magician-card { display:flex; flex-direction:column; background:white; border:1px solid var(--cream-dark); border-radius:6px; overflow:hidden; text-decoration:none; color:var(--ink); transition:transform 180ms,box-shadow 180ms,border-color 180ms; }
  .magician-card:hover { transform:translateY(-2px); box-shadow:var(--shadow-lg); border-color:var(--gold-light); }
  .magician-poster { aspect-ratio:3/4; max-height:220px; overflow:hidden; background:var(--cream-dark); }
  .magician-poster img { width:100%; height:100%; object-fit:cover; transition:transform 300ms; }
  .magician-card:hover .magician-poster img { transform:scale(1.03); }
  .magician-poster--placeholder { display:flex; align-items:center; justify-content:center; font-size:3rem; }
  .magician-info { padding:1rem 1.25rem; flex:1; }
  .magician-name { font-family:var(--font-display); font-size:0.95rem; color:var(--burgundy); letter-spacing:0.03em; margin-bottom:0.15rem; }
  .magician-years { font-family:var(--font-ui); font-size:0.72rem; color:var(--grey); display:block; margin-bottom:0.25rem; }
  .magician-tagline { font-family:var(--font-body); font-size:0.82rem; font-style:italic; color:var(--gold-dark); }
  .magician-arrow { display:none; }
  .exhibition-more { display:flex; align-items:center; justify-content:space-between; gap:1.5rem; padding:1.25rem 1.5rem; background:var(--cream-dark); border-radius:6px; flex-wrap:wrap; }
  .exhibition-more p { font-family:var(--font-ui); font-size:0.875rem; color:var(--ink-mid); font-style:italic; }

  /* ── KIDS ───────────────────────────────────────────────────────── */
  .kids-section { background:var(--cream); }
  .kids-inner { display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center; }
  .kids-sub { font-family:var(--font-ui); font-size:1rem; color:var(--ink-mid); line-height:1.65; margin:1rem 0 1.25rem; }
  .kids-list { list-style:none; display:flex; flex-direction:column; gap:0.6rem; }
  .kids-list li { display:flex; align-items:flex-start; gap:0.6rem; font-family:var(--font-ui); font-size:0.95rem; color:var(--ink-mid); }
  .kids-list span { color:var(--gold); font-size:0.7rem; margin-top:0.3rem; flex-shrink:0; }
  .kids-cards { display:flex; flex-direction:column; gap:1rem; }
  .kids-card { background:white; border:1px solid var(--cream-dark); border-left:3px solid var(--gold); border-radius:6px; padding:1.25rem 1.5rem; box-shadow:var(--shadow); }
  .kids-card--offset { margin-left:1.5rem; }
