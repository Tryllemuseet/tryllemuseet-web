---
// src/pages/ressurser/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Ressurser — Tryllemuseet"
  description="Tryllekatalog, bibliotek, kunstnerregister og magiske ressurser fra Tryllemuseet."
>

  <section class="hero">
    <div class="container">
      <p class="section-label">Tryllemuseet</p>
      <h1 class="display-title">Ressurser</h1>
      <p class="hero-sub">
        Tryllekatalog, bibliotek, kunstnerregister og mer.
      </p>
    </div>
  </section>

  <div class="container page-body">

    <!-- Tilgjengelige ressurser nå -->
    <section class="resources-section">
      <h2 class="section-heading">Tilgjengelig nå</h2>
      <div class="resources-grid">

        <a href="/bibliotek" class="resource-card resource-card--active">
          <div class="resource-icon" aria-hidden="true">📚</div>
          <div class="resource-body">
            <h3>Bibliotek</h3>
            <p>Norske tryllebøker og faglitteratur om illusjonismens kunst.</p>
          </div>
          <span class="resource-arrow" aria-hidden="true">→</span>
        </a>

        <a href="/tryllehistorie/magiens-hvem-er-hvem" class="resource-card resource-card--active">
          <div class="resource-icon" aria-hidden="true">🪄</div>
          <div class="resource-body">
            <h3>Hvem er hvem</h3>
            <p>Biografiregister over norske og nordiske tryllekunstnere.</p>
          </div>
          <span class="resource-arrow" aria-hidden="true">→</span>
        </a>

        <a href="/tryllehistorie/nordisk-tv-magi" class="resource-card resource-card--active">
          <div class="resource-icon" aria-hidden="true">📺</div>
          <div class="resource-body">
            <h3>Nordiske magikere på TV</h3>
            <p>Oversikt over nordiske tryllekunstnere i Got Talent og Penn &amp; Teller: Fool Us.</p>
          </div>
          <span class="resource-arrow" aria-hidden="true">→</span>
        </a>

        <a href="https://www.magiskecirkel.no/tryllekatalogen" class="resource-card resource-card--active" target="_blank" rel="noopener">
          <div class="resource-icon" aria-hidden="true">🎩</div>
          <div class="resource-body">
            <h3>Tryllekatalogen ↗</h3>
            <p>Magiske Cirkel Norges katalog over norske tryllekunstnere.</p>
          </div>
          <span class="resource-arrow" aria-hidden="true">→</span>
        </a>

      </div>
    </section>

    <!-- Kommer snart -->
    <section class="resources-section">
      <h2 class="section-heading">Kommer snart</h2>
      <div class="resources-grid">

        <div class="resource-card resource-card--soon">
          <div class="resource-icon" aria-hidden="true">🎭</div>
          <div class="resource-body">
            <h3>Tryllekunstnere</h3>
            <p>Register over tryllekunstnere tilknyttet museet og MCN.</p>
          </div>
          <span class="soon-badge">Snart</span>
        </div>

        <div class="resource-card resource-card--soon">
          <div class="resource-icon" aria-hidden="true">✨</div>
          <div class="resource-body">
            <h3>Magiske øyeblikk</h3>
            <p>Høydepunkter og øyeblikk fra museets liv og arrangementer.</p>
          </div>
          <span class="soon-badge">Snart</span>
        </div>

        <div class="resource-card resource-card--soon">
          <div class="resource-icon" aria-hidden="true">📰</div>
          <div class="resource-body">
            <h3>Historiske avisartikler</h3>
            <p>Pekere til historiske artikler om norsk tryllekunst fra nb.no og Riksarkivet.</p>
          </div>
          <span class="soon-badge">Snart</span>
        </div>

      </div>
    </section>

  </div>

</BaseLayout>

<style>
  /* ── HERO ──────────────────────────────────────────────────────── */
  .hero {
    background: var(--burgundy-dk);
    padding: 3.5rem 0 2.5rem;
    border-bottom: 2px solid var(--gold-dark);
    color: var(--cream);
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--cream);
    margin: 0.5rem 0 0.75rem;
  }
  .hero-sub {
    font-family: var(--font-ui);
    font-size: 1rem;
    opacity: 0.8;
    max-width: 520px;
  }

  /* ── PAGE BODY ─────────────────────────────────────────────────── */
  .page-body {
    padding: 3rem 1.5rem 5rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* ── SECTION HEADING ───────────────────────────────────────────── */
  .resources-section { display: flex; flex-direction: column; gap: 1.25rem; }
  .section-heading {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--gold-dark);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--cream-dark);
  }

  /* ── GRID ───────────────────────────────────────────────────────── */
  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  /* ── KORT ───────────────────────────────────────────────────────── */
  .resource-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: white;
    border: 1px solid var(--cream-dark);
    border-radius: 6px;
    padding: 1.25rem 1rem;
    text-decoration: none;
    color: var(--ink);
    transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
    position: relative;
  }
  .resource-card--active:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(107,15,26,0.12);
    border-color: var(--gold-light);
  }
  .resource-card--soon {
    opacity: 0.55;
    cursor: default;
  }

  .resource-icon {
    font-size: 1.75rem;
    flex-shrink: 0;
    width: 2.5rem;
    text-align: center;
  }
  .resource-body { flex: 1; min-width: 0; }
  .resource-body h3 {
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--burgundy);
    letter-spacing: 0.03em;
    margin-bottom: 0.2rem;
  }
  .resource-body p {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--ink-mid);
    line-height: 1.5;
  }
  .resource-arrow {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--gold-dark);
    flex-shrink: 0;
    transition: transform 150ms;
  }
  .resource-card--active:hover .resource-arrow { transform: translateX(3px); }

  .soon-badge {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mid);
    border: 1px solid var(--cream-dark);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    flex-shrink: 0;
  }

  @media (max-width: 560px) {
    .page-body { padding: 2rem 1rem 3rem; }
    .resources-grid { grid-template-columns: 1fr; }
  }
</style>
