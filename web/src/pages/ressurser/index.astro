---
// src/pages/ressurser/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getRessurserPage } from '../../lib/sanity'

const page = await getRessurserPage()

const tilgjengelige = page.ressurser.filter(r => !r.soon)
const kommerSnart   = page.ressurser.filter(r =>  r.soon)
---

<BaseLayout
  title="Ressurser — Tryllemuseet"
  description={page.hero.ingress}
>

  <section class="hero">
    <div class="container">
      <p class="section-label">{page.hero.label}</p>
      <h1 class="display-title">{page.hero.heading}</h1>
      <p class="hero-sub">{page.hero.ingress}</p>
    </div>
  </section>

  <div class="container page-body">

    {tilgjengelige.length > 0 && (
      <section class="resources-section">
        <h2 class="section-heading">Tilgjengelig nå</h2>
        <div class="resources-grid">
          {tilgjengelige.map(r => {
            const ekstern = r.href.startsWith('http')
            return (
              <a
                href={r.href}
                class="resource-card resource-card--active"
                target={ekstern ? '_blank' : undefined}
                rel={ekstern ? 'noopener' : undefined}
              >
                <div class="resource-icon" aria-hidden="true">{r.emoji}</div>
                <div class="resource-body">
                  <h3>{r.title}</h3>
                  <p>{r.beskrivelse}</p>
                </div>
                <span class="resource-arrow" aria-hidden="true">→</span>
              </a>
            )
          })}
        </div>
      </section>
    )}

    {kommerSnart.length > 0 && (
      <section class="resources-section">
        <h2 class="section-heading">Kommer snart</h2>
        <div class="resources-grid">
          {kommerSnart.map(r => (
            <div class="resource-card resource-card--soon">
              <div class="resource-icon" aria-hidden="true">{r.emoji}</div>
              <div class="resource-body">
                <h3>{r.title}</h3>
                <p>{r.beskrivelse}</p>
              </div>
              <span class="soon-badge">Snart</span>
            </div>
          ))}
        </div>
      </section>
    )}

  </div>

</BaseLayout>

<style>
  /* ── HERO ──────────────────────────────────────────────────────── */
  .hero {
    background: var(--burgundy-dk);
    padding: 3.5rem 0 2.5rem;
    border-bottom: 2px solid var(--gold-dark);
    color: var(--cream);
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--cream);
    margin: 0.5rem 0 0.75rem;
  }
  .hero-sub {
    font-family: var(--font-ui);
    font-size: 1rem;
    opacity: 0.8;
    max-width: 520px;
  }

  /* ── PAGE BODY ─────────────────────────────────────────────────── */
  .page-body {
    padding-top: 3rem;
    padding-bottom: 5rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* ── SECTION HEADING ───────────────────────────────────────────── */
  .resources-section { display: flex; flex-direction: column; gap: 1.25rem; }
  .section-heading {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--gold-dark);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--cream-dark);
  }

  /* ── GRID ───────────────────────────────────────────────────────── */
  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  /* ── KORT ───────────────────────────────────────────────────────── */
  .resource-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: white;
    border: 1px solid var(--cream-dark);
    border-radius: 6px;
    padding: 1.25rem 1rem;
    text-decoration: none;
    color: var(--ink);
    transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
    position: relative;
  }
  .resource-card--active:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(107,15,26,0.12);
    border-color: var(--gold-light);
  }
  .resource-card--soon {
    opacity: 0.55;
    cursor: default;
  }

  .resource-icon {
    font-size: 1.75rem;
    flex-shrink: 0;
    width: 2.5rem;
    text-align: center;
  }
  .resource-body { flex: 1; min-width: 0; }
  .resource-body h3 {
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--burgundy);
    letter-spacing: 0.03em;
    margin-bottom: 0.2rem;
  }
  .resource-body p {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--ink-mid);
    line-height: 1.5;
  }
  .resource-arrow {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--gold-dark);
    flex-shrink: 0;
    transition: transform 150ms;
  }
  .resource-card--active:hover .resource-arrow { transform: translateX(3px); }

  .soon-badge {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mid);
    border: 1px solid var(--cream-dark);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    flex-shrink: 0;
  }

  @media (max-width: 560px) {
    .page-body { padding-top: 2rem; padding-bottom: 3rem; }
    .resources-grid { grid-template-columns: 1fr; }
  }
</style>
