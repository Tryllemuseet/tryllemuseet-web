---
// src/pages/aktiviteter/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro'
import AnimateIn from '../../components/AnimateIn.astro'
import { getAllEvents } from '../../lib/sanity'
import { getMagiskeCirkelEvents } from '../../lib/icalendar'

interface Activity {
  key:       string
  title:     string
  date:      string
  source:    'tryllemuseet' | 'magiskecirkel'
  location?: string
  url?:      string
  excerpt?:  string
  ageGroup?: string
  price?:    string
}

const [tmEvents, mcEvents] = await Promise.all([
  getAllEvents(),
  getMagiskeCirkelEvents(),
])

const activities: Activity[] = [
  ...tmEvents.map((e): Activity => ({
    key:      e._id,
    title:    e.title,
    date:     e.date,
    source:   'tryllemuseet',
    url:      '/arrangementer',
    excerpt:  e.excerpt,
    ageGroup: e.ageGroup,
    price:    e.price,
  })),
  ...mcEvents.map((e): Activity => ({
    key:      e.uid,
    title:    e.title,
    date:     e.start,
    source:   'magiskecirkel',
    location: e.location,
    url:      e.url ?? 'https://www.magiskecirkel.no/kalender',
  })),
].sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime())

const now = Date.now()
const upcomingCount = activities.filter(a => new Date(a.date).getTime() >= now).length

const sourceLabels: Record<string, string> = {
  tryllemuseet:  'Tryllemuseet',
  magiskecirkel: 'Magiske Cirkel',
}

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('nb-NO', {
    weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
  })
}

function formatTime(d: string) {
  const t = new Date(d).toLocaleTimeString('nb-NO', { hour: '2-digit', minute: '2-digit' })
  return t === '00:00' ? '' : t
}
---

<BaseLayout
  title="Aktiviteter — Tryllemuseet"
  description="Kurs, arrangementer og magiske opplevelser for barn og voksne på Tryllemuseet — og i det norske tryllemiljøet."
>

  <section class="hero">
    <div class="container">
      <p class="section-label">Tryllemuseet</p>
      <h1 class="display-title">Aktiviteter</h1>
      <p class="hero-sub">
        Kurs, arrangementer og magiske opplevelser for barn og voksne —
        på museet og i det norske tryllemiljøet.
      </p>
    </div>
  </section>

  <!-- FILTER ─────────────────────────────────────────────────────── -->
  <div class="filter-bar-wrap">
    <div class="container filter-bar-inner">
      <div class="filter-group filter-group--tabs" role="group" aria-label="Vis kommende eller tidligere">
        <button class="filter-tab active" id="tab-upcoming" data-view="upcoming">Kommende</button>
        <button class="filter-tab" id="tab-past" data-view="past">Tidligere</button>
      </div>
      <div class="filter-group">
        <label class="filter-label" for="filter-source">Kilde</label>
        <select id="filter-source" class="filter-select">
          <option value="">Alle</option>
          <option value="tryllemuseet">Tryllemuseet</option>
          <option value="magiskecirkel">Magiske Cirkel</option>
        </select>
      </div>
      <button class="filter-sort" id="sort-toggle" aria-live="polite">Dato ↑</button>
    </div>
  </div>

  <div class="container">
    <p class="result-count" id="result-count">Viser {upcomingCount} aktiviteter</p>
  </div>

  <main class="container activity-main">

    <div class="activity-list" id="activity-list">
      {activities.map((a) => {
        const time = formatTime(a.date)
        const isPast = new Date(a.date).getTime() < now
        return (
          <article
            class="activity-row"
            style={isPast ? 'display:none' : ''}
            data-source={a.source}
            data-time={new Date(a.date).getTime()}
          >
            <div class="row-date">
              <span class="row-day">{new Date(a.date).getDate()}</span>
              <span class="row-month">{new Date(a.date).toLocaleDateString('nb-NO', { month: 'short' })}</span>
              <span class="row-year">{new Date(a.date).getFullYear()}</span>
            </div>
            <div class="row-body">
              <p class="row-meta">
                <span class:list={['source-badge', `source-badge--${a.source}`]}>
                  {sourceLabels[a.source]}
                </span>
                <span class="row-when">{formatDate(a.date)}{time && ` · kl. ${time}`}</span>
              </p>
              <h2 class="row-title">{a.title}</h2>
              {a.excerpt && <p class="row-excerpt">{a.excerpt}</p>}
              <p class="row-tags">
                {a.ageGroup && <span class="row-tag">{a.ageGroup}</span>}
                {a.price && <span class="row-tag row-tag--price">{a.price}</span>}
                {a.location && <span class="row-tag">📍 {a.location}</span>}
              </p>
            </div>
            {a.url && (
              <a
                href={a.url}
                class="row-link"
                target={a.url.startsWith('http') ? '_blank' : undefined}
                rel={a.url.startsWith('http') ? 'noopener noreferrer' : undefined}
                aria-label={`Mer om ${a.title}`}
              >Mer →</a>
            )}
          </article>
        )
      })}
    </div>

    <div class="no-results" id="no-results" hidden>
      <span class="no-results-icon" aria-hidden="true">🎩</span>
      <p>Ingen aktiviteter i denne visningen akkurat nå.</p>
      <p class="no-results-sub">
        Følg oss på <a href="https://www.facebook.com/tryllemuseet" target="_blank" rel="noopener noreferrer">Facebook</a>
        for å bli varslet om nye kurs og forestillinger.
      </p>
    </div>

    <!-- KREDITERING / LENKER ─────────────────────────────────────── -->
    <AnimateIn direction="up">
    <aside class="sources-strip">
      <div class="sources-item">
        <span class="sources-icon" aria-hidden="true">🎩</span>
        <div>
          <strong>Tryllemuseets egne arrangementer</strong>
          <p>Kurs og forestillinger på Årvoll gård. <a href="/arrangementer">Se detaljer og påmelding</a>.</p>
        </div>
      </div>
      <div class="sources-divider"></div>
      <div class="sources-item">
        <span class="sources-icon" aria-hidden="true">🪄</span>
        <div>
          <strong>Den Magiske Cirkel Norge</strong>
          <p>Aktiviteter i tryllemiljøet hentes fra <a href="https://www.magiskecirkel.no/kalender" target="_blank" rel="noopener noreferrer">magiskecirkel.no/kalender</a>.</p>
        </div>
      </div>
    </aside>
    </AnimateIn>

  </main>

</BaseLayout>

<script>
  const rows      = Array.from(document.querySelectorAll<HTMLElement>('.activity-row'))
  const list      = document.getElementById('activity-list')!
  const noRes     = document.getElementById('no-results')!
  const countEl   = document.getElementById('result-count')!
  const tabUp     = document.getElementById('tab-upcoming')!
  const tabPast   = document.getElementById('tab-past')!
  const selSource = document.getElementById('filter-source') as HTMLSelectElement | null
  const sortBtn   = document.getElementById('sort-toggle')!

  let view: 'upcoming' | 'past' = 'upcoming'
  let ascending = true
  const now = Date.now()

  function apply() {
    const src = selSource?.value ?? ''
    let visible = 0

    // Sort by re-appending in order
    const sorted = [...rows].sort((a, b) => {
      const diff = Number(a.dataset.time) - Number(b.dataset.time)
      return ascending ? diff : -diff
    })
    sorted.forEach(row => list.appendChild(row))

    rows.forEach(row => {
      const isPast  = Number(row.dataset.time) < now
      const inView  = (view === 'past') === isPast
      const inSrc   = !src || row.dataset.source === src
      const show    = inView && inSrc
      row.style.display = show ? '' : 'none'
      if (show) visible++
    })

    noRes.hidden = visible > 0
    countEl.textContent = `Viser ${visible} aktiviteter`
    sortBtn.textContent = ascending ? 'Dato ↑' : 'Dato ↓'
    tabUp.classList.toggle('active', view === 'upcoming')
    tabPast.classList.toggle('active', view === 'past')
  }

  tabUp.addEventListener('click', () => { view = 'upcoming'; ascending = true;  apply() })
  tabPast.addEventListener('click', () => { view = 'past';   ascending = false; apply() })
  selSource?.addEventListener('change', apply)
  sortBtn.addEventListener('click', () => { ascending = !ascending; apply() })

  apply()
</script>

<style>
  /* ── HERO ──────────────────────────────────────────────────────── */
  .hero { background: var(--burgundy-dk); padding: 3.5rem 0 2.5rem; border-bottom: 2px solid var(--gold-dark); color: var(--cream); }
  .hero h1 { font-size: clamp(2rem, 5vw, 3rem); color: var(--cream); margin: 0.5rem 0 0.75rem; }
  .hero-sub { font-family: var(--font-ui); font-size: 1rem; opacity: 0.8; max-width: 560px; line-height: 1.6; }

  /* ── FILTER ────────────────────────────────────────────────────── */
  .filter-bar-wrap { position: sticky; top: var(--header-h); z-index: 50; background: white; border-bottom: 1px solid var(--cream-dark); box-shadow: 0 2px 12px rgba(26,18,8,0.06); }
  .filter-bar-inner { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: flex-end; padding: 0.75rem 1.5rem; }

  .filter-group { display: flex; flex-direction: column; gap: 0.2rem; }
  .filter-group--tabs { flex-direction: row; gap: 0; border: 1.5px solid var(--cream-dark); border-radius: 6px; overflow: hidden; align-self: flex-end; }
  .filter-tab { font-family: var(--font-ui); font-size: 0.875rem; font-weight: 600; color: var(--grey); background: white; padding: 0.45rem 1.1rem; cursor: pointer; transition: background 150ms, color 150ms; }
  .filter-tab.active { background: var(--burgundy); color: var(--cream); }

  .filter-label { font-family: var(--font-ui); font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--grey); }
  .filter-select { font-family: var(--font-ui); font-size: 0.875rem; color: var(--ink); background: var(--cream); border: 1.5px solid var(--cream-dark); border-radius: 6px; padding: 0.45rem 0.75rem; cursor: pointer; min-width: 160px; }
  .filter-sort { font-family: var(--font-ui); font-size: 0.8rem; font-weight: 600; color: var(--grey); border: 1.5px solid var(--cream-dark); border-radius: 6px; padding: 0.45rem 0.9rem; background: white; cursor: pointer; align-self: flex-end; transition: color 150ms, border-color 150ms; }
  .filter-sort:hover { color: var(--burgundy); border-color: var(--gold); }

  .result-count { font-family: var(--font-ui); font-size: 0.8rem; color: var(--grey); padding: 0.75rem 0 0.25rem; }

  /* ── LISTE ─────────────────────────────────────────────────────── */
  .activity-main { padding-bottom: 5rem; }
  .activity-list { display: flex; flex-direction: column; gap: 1rem; padding-top: 0.5rem; }

  .activity-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.25rem;
    align-items: center;
    background: white;
    border: 1px solid var(--cream-dark);
    border-radius: 8px;
    padding: 1.1rem 1.4rem;
    transition: box-shadow 200ms ease, border-color 200ms ease;
  }
  .activity-row:hover { box-shadow: var(--shadow); border-color: var(--gold-light); }

  .row-date { display: flex; flex-direction: column; align-items: center; min-width: 56px; }
  .row-day { font-family: var(--font-display); font-size: 1.8rem; color: var(--burgundy); line-height: 1.1; }
  .row-month { font-family: var(--font-ui); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gold-dark); font-weight: 700; }
  .row-year { font-family: var(--font-ui); font-size: 0.7rem; color: var(--grey); }

  .row-body { min-width: 0; }
  .row-meta { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 0.25rem; }
  .source-badge { font-family: var(--font-ui); font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 0.15rem 0.5rem; border-radius: 3px; }
  .source-badge--tryllemuseet  { background: rgba(107,15,26,0.1);  color: var(--burgundy); }
  .source-badge--magiskecirkel { background: rgba(160,120,32,0.14); color: var(--gold-dark); }
  .row-when { font-family: var(--font-ui); font-size: 0.8rem; color: var(--grey); }

  .row-title { font-family: var(--font-display); font-size: 1.1rem; color: var(--burgundy); letter-spacing: 0.02em; line-height: 1.3; margin: 0 0 0.2rem; }
  .row-excerpt { font-family: var(--font-ui); font-size: 0.875rem; color: var(--ink-mid); line-height: 1.55; margin-bottom: 0.3rem; }

  .row-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .row-tag { font-family: var(--font-ui); font-size: 0.72rem; font-weight: 600; background: var(--cream-dark); color: var(--ink-mid); padding: 0.15rem 0.5rem; border-radius: 3px; }
  .row-tag--price { background: #E8F5E9; color: #2E7D32; }

  .row-link { font-family: var(--font-ui); font-size: 0.825rem; font-weight: 700; color: var(--gold-dark); text-decoration: none; white-space: nowrap; padding: 0.4rem 0.6rem; border-radius: 4px; transition: color 150ms, background 150ms; }
  .row-link:hover { color: var(--burgundy); background: var(--cream); }

  /* ── TOMT RESULTAT ─────────────────────────────────────────────── */
  .no-results { text-align: center; padding: 3.5rem 2rem; background: white; border: 1px solid var(--cream-dark); border-radius: 8px; margin-top: 0.5rem; }
  .no-results-icon { font-size: 2.5rem; display: block; margin-bottom: 0.75rem; }
  .no-results p { font-family: var(--font-ui); font-size: 0.95rem; color: var(--ink-mid); }
  .no-results-sub { font-size: 0.85rem; margin-top: 0.5rem; }
  .no-results-sub a { color: var(--burgundy); text-decoration: underline; }

  /* ── KILDE-STRIPE ──────────────────────────────────────────────── */
  .sources-strip { display: flex; align-items: stretch; background: white; border: 1px solid var(--cream-dark); border-radius: 8px; margin-top: 2.5rem; flex-wrap: wrap; }
  .sources-item { display: flex; align-items: flex-start; gap: 0.9rem; padding: 1.25rem 1.5rem; flex: 1; min-width: 240px; }
  .sources-icon { font-size: 1.4rem; flex-shrink: 0; margin-top: 0.1rem; }
  .sources-item strong { font-family: var(--font-ui); font-size: 0.875rem; font-weight: 700; color: var(--ink); display: block; margin-bottom: 0.2rem; }
  .sources-item p { font-family: var(--font-ui); font-size: 0.825rem; color: var(--grey); line-height: 1.5; }
  .sources-item a { color: var(--burgundy); text-decoration: underline; }
  .sources-divider { width: 1px; background: var(--cream-dark); margin: 0.75rem 0; flex-shrink: 0; }

  /* ── RESPONSIVE ────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .activity-row { grid-template-columns: auto 1fr; }
    .row-link { grid-column: 2; justify-self: start; padding-left: 0; }
    .sources-strip { flex-direction: column; }
    .sources-divider { width: 100%; height: 1px; margin: 0; }
  }
</style>
