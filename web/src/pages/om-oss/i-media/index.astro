---
// src/pages/om-oss/i-media/index.astro
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { getMediaAppearances } from '../../../lib/sanity'
import type { MediaAppearance } from '../../../lib/sanity'
import { typeLabels, typeIcons } from '../../../lib/mediaTypes'

const appearances = await getMediaAppearances()
const total       = appearances.length

const types = [...new Set(appearances.map((a: MediaAppearance) => a.type))]
  .filter(Boolean).sort() as string[]

function formatDate(dateStr?: string): string {
  if (!dateStr) return ''
  return new Date(dateStr).toLocaleDateString('nb-NO', { day: 'numeric', month: 'long', year: 'numeric' })
}
---

<BaseLayout
  title="Tryllemuseet i media — Pressedekning"
  description={`${total} presseoppslag der Tryllemuseet er omtalt — aviser, nettaviser, TV og mer.`}
>

  <section class="hero">
    <div class="container">
      <p class="section-label"><a href="/om-oss" class="breadcrumb-link">Om oss</a></p>
      <h1 class="display-title hero-title">Tryllemuseet i media</h1>
      <p class="hero-sub">
        {total} presseoppslag fra aviser, nettaviser og TV der Tryllemuseet er omtalt.
      </p>
    </div>
  </section>

  <!-- ── Filter bar ──────────────────────────────────────────────── -->
  <div class="filter-bar-wrap">
    <div class="container filter-bar-inner">
      <div class="filter-group">
        <label class="filter-label" for="filter-type">Type</label>
        <select id="filter-type" class="filter-select">
          <option value="">Alle typer</option>
          {types.map((t) => (
            <option value={t}>{typeLabels[t] ?? t}</option>
          ))}
        </select>
      </div>
      <button class="filter-reset" id="filter-reset">Nullstill</button>
    </div>
  </div>

  <div class="container result-bar">
    <p class="result-count" id="result-count">Viser {total} oppslag</p>
  </div>

  <!-- ── Cards grid ────────────────────────────────────────────── -->
  <div class="container media-grid" id="media-grid">
    {appearances.map((a: MediaAppearance) => (
      <article class="media-card" data-type={a.type}>

        <div class="card-media">
          {a.videoId ? (
            <div class="card-video-wrap">
              <iframe
                src={`https://www.youtube.com/embed/${a.videoId}`}
                title={a.title}
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
          ) : a.image?.asset?.url ? (
            <img src={a.image.asset.url} alt={a.image.alt ?? a.title} loading="lazy" />
          ) : (
            <div class="card-media-placeholder" aria-hidden="true">
              {typeIcons[a.type] ?? '📰'}
            </div>
          )}
          <span class="card-type-badge">{typeLabels[a.type] ?? a.type}</span>
        </div>

        <div class="card-body">
          <p class="card-meta">
            <span class="card-source">{a.sourceName}</span>
            {a.publishedAt && <span class="card-date">{formatDate(a.publishedAt)}</span>}
          </p>
          <h2 class="card-title">{a.title}</h2>
          <p class="card-teaser">{a.teaser}</p>

          {a.quote && (
            <blockquote class="card-quote">
              <p>«{a.quote}»</p>
              <cite>— {a.sourceName}</cite>
            </blockquote>
          )}

          <div class="card-actions">
            {a.sourceUrl && (
              <a
                href={a.sourceUrl}
                target="_blank"
                rel="noopener"
                class="card-link-external"
                aria-label={`Les «${a.title}» hos ${a.sourceName} (åpnes i ny fane)`}
              >
                Les artikkelen →
              </a>
            )}
            {a.videoUrl && !a.videoId && (
              <a
                href={a.videoUrl}
                target="_blank"
                rel="noopener"
                class="card-link-video"
                aria-label={`Se video: «${a.title}» (åpnes i ny fane)`}
              >
                Se video →
              </a>
            )}
          </div>
        </div>

      </article>
    ))}
  </div>

  {total === 0 && (
    <div class="container empty-state">
      <p>Ingen presseoppslag publisert ennå.</p>
    </div>
  )}

  <div class="container no-results" id="no-results" hidden>
    <p>Ingen oppslag matcher filteret.</p>
    <button class="filter-reset-inline" id="filter-reset-2">Nullstill filter</button>
  </div>

  <div class="container page-nav">
    <a href="/om-oss">← Om oss</a>
    <a href="/kontakt">Kontakt oss →</a>
  </div>

</BaseLayout>

<script>
  const rows      = Array.from(document.querySelectorAll<HTMLElement>('.media-card'))
  const noRes     = document.getElementById('no-results')!
  const countEl   = document.getElementById('result-count')!
  const selType   = document.getElementById('filter-type') as HTMLSelectElement
  const btnReset  = document.getElementById('filter-reset')!
  const btnReset2 = document.getElementById('filter-reset-2')!

  function applyFilters() {
    const type = selType.value
    let visible = 0
    rows.forEach(row => {
      const match = !type || row.dataset.type === type
      row.hidden = !match
      if (match) visible++
    })
    noRes.hidden = visible > 0
    countEl.textContent = `Viser ${visible} oppslag`
  }

  function resetFilters() { selType.value = ''; applyFilters() }

  selType.addEventListener('change', applyFilters)
  btnReset.addEventListener('click', resetFilters)
  btnReset2.addEventListener('click', resetFilters)
</script>

<style>
  /* ── Hero ──────────────────────────────────────────────────────── */
  .hero { background: var(--burgundy-dk); padding: 3.5rem 0 2.5rem; border-bottom: 2px solid var(--gold-dark); color: var(--cream); }
  .breadcrumb-link { color: var(--gold); text-decoration: none; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; }
  .breadcrumb-link:hover { color: var(--gold-light); }
  .hero-title { font-size: clamp(1.8rem, 5vw, 3rem); color: var(--cream); margin: 0.5rem 0 0.75rem; }
  .hero-sub { font-family: var(--font-ui); font-size: 1rem; opacity: 0.8; max-width: 600px; }

  /* ── Filter bar ────────────────────────────────────────────────── */
  .filter-bar-wrap { position: sticky; top: var(--header-h); z-index: 50; background: white; border-bottom: 1px solid var(--cream-dark); box-shadow: 0 2px 12px rgba(26,18,8,0.06); }
  .filter-bar-inner { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: flex-end; padding: 0.75rem 1.5rem; }
  .filter-group { display: flex; flex-direction: column; gap: 0.2rem; }
  .filter-label { font-family: var(--font-ui); font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--grey); }
  .filter-select { font-family: var(--font-ui); font-size: 0.875rem; color: var(--ink); background: var(--cream); border: 1.5px solid var(--cream-dark); border-radius: 6px; padding: 0.45rem 0.75rem; cursor: pointer; min-width: 160px; }
  .filter-select:focus { outline: none; border-color: var(--gold); }
  .filter-reset { font-family: var(--font-ui); font-size: 0.8rem; font-weight: 600; color: var(--grey); border: 1.5px solid var(--cream-dark); border-radius: 6px; padding: 0.45rem 0.9rem; background: white; align-self: flex-end; }
  .filter-reset:hover { color: var(--burgundy); border-color: var(--gold); }

  /* ── Result count ──────────────────────────────────────────────── */
  .result-bar { padding: 0.65rem 0 0; }
  .result-count { font-family: var(--font-ui); font-size: 0.8rem; color: var(--grey); }

  /* ── Cards grid ────────────────────────────────────────────────── */
  .media-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.75rem; padding-bottom: 1rem; align-items: start; }

  .media-card { border-radius: 6px; overflow: hidden; border: 1px solid var(--cream-dark); background: white; transition: box-shadow 220ms ease, border-color 220ms ease; display: flex; flex-direction: column; }
  .media-card:hover { box-shadow: 0 6px 24px rgba(107,15,26,0.12); border-color: var(--gold-light); }

  /* Card media area (image / video / placeholder) */
  .card-media { position: relative; flex-shrink: 0; background: var(--burgundy-dk); overflow: hidden; }
  .card-media img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; transition: transform 400ms ease; }
  .media-card:hover .card-media img { transform: scale(1.03); }
  .card-media-placeholder { display: flex; align-items: center; justify-content: center; aspect-ratio: 16/9; font-size: 3.5rem; background: linear-gradient(160deg, var(--burgundy-dk), #2a1208); }
  .card-video-wrap { aspect-ratio: 16/9; max-width: 640px; width: 100%; }
  .card-video-wrap iframe { width: 100%; height: 100%; border: none; display: block; }
  .card-type-badge { position: absolute; top: 0.6rem; left: 0.6rem; font-family: var(--font-ui); font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 0.2rem 0.5rem; border-radius: 3px; background: rgba(26,18,8,0.75); color: var(--gold-light); backdrop-filter: blur(4px); }

  /* Card body */
  .card-body { padding: 1.1rem 1.25rem 1.3rem; display: flex; flex-direction: column; gap: 0.4rem; flex: 1; }
  .card-meta { display: flex; flex-wrap: wrap; gap: 0.4rem; font-family: var(--font-ui); font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--gold-dark); }
  .card-date { font-weight: 400; color: var(--grey); text-transform: none; letter-spacing: 0; }
  .card-title { font-family: var(--font-display); font-size: 1.05rem; color: var(--burgundy); letter-spacing: 0.02em; line-height: 1.25; margin-top: 0.1rem; }
  .card-teaser { font-family: var(--font-ui); font-size: 0.875rem; color: var(--ink-mid); line-height: 1.55; }

  .card-quote { border-left: 3px solid var(--gold-light); padding: 0.5rem 0 0.5rem 0.9rem; margin: 0.25rem 0 0; }
  .card-quote p { font-family: var(--font-body); font-size: 0.85rem; font-style: italic; color: var(--ink-mid); line-height: 1.55; }
  .card-quote cite { font-family: var(--font-ui); font-size: 0.7rem; color: var(--grey); font-style: normal; display: block; margin-top: 0.3rem; }

  .card-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: auto; padding-top: 0.75rem; }
  .card-link-external, .card-link-video { font-family: var(--font-ui); font-size: 0.8rem; font-weight: 700; color: var(--gold-dark); text-decoration: none; transition: color 150ms; }
  .card-link-external:hover, .card-link-video:hover { color: var(--burgundy); }
  .card-link-video { color: var(--grey); }

  /* ── Empty / no-results ────────────────────────────────────────── */
  .empty-state { padding: 4rem 0; text-align: center; font-family: var(--font-ui); color: var(--ink-mid); }
  .no-results { padding: 3rem 0; text-align: center; font-family: var(--font-ui); color: var(--ink-mid); }
  .filter-reset-inline { margin-top: 0.75rem; font-family: var(--font-ui); font-size: 0.875rem; font-weight: 600; color: var(--burgundy); background: none; border: 1px solid var(--gold-dark); border-radius: 6px; padding: 0.45rem 1rem; cursor: pointer; }

  /* ── Page nav ──────────────────────────────────────────────────── */
  .page-nav { display: flex; flex-wrap: wrap; gap: 0.75rem; padding: 1.5rem 0 3rem; font-family: var(--font-ui); font-size: 0.875rem; }
  .page-nav a { color: var(--grey); text-decoration: none; border: 1px solid var(--cream-dark); padding: 0.4rem 1rem; border-radius: var(--radius); transition: color 150ms, border-color 150ms; }
  .page-nav a:hover { color: var(--burgundy); border-color: var(--gold); }

  /* ── Mobile ────────────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .media-grid { grid-template-columns: 1fr; gap: 1rem; }
    .filter-bar-inner { padding: 0.65rem 1rem; }
  }
</style>
