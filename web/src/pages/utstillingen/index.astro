---
// src/pages/utstillingen/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getAllMagicians } from '../../lib/sanity'

const magicians = await getAllMagicians()
---

<BaseLayout
  title="Utstillingen — Tryllemuseet"
  description="Møt gullalderens store magikere: Robert-Houdin, Herrmann, Kellar, Thurston, Houdini og mer."
>
  <section class="section container">
    <p class="section-label">Gullalderen 1845–1930</p>
    <h1 class="display-title page-title">Utstillingen</h1>
    <p class="page-intro">
      Syv felt som forteller historien om tryllekunstens gullaldere —
      fra Robert-Houdin som skapte den moderne scenemagien, til Houdini
      som ble et verdensomspennende fenomen.
    </p>
  </section>

  <section class="container grid-section">
    <div class="magicians-grid">
      {magicians.map((m) => (
        <a href={`/utstillingen/${m.slug}`} class="magician-card">
          {m.posterImage?.asset?.url ? (
            <div class="card-image">
              <img src={m.posterImage.asset.url} alt={m.posterImage.alt ?? m.title} loading="lazy" />
            </div>
          ) : (
            <div class="card-image card-image--placeholder">
              <span>🎩</span>
            </div>
          )}
          <div class="card-body">
            <h2 class="card-title">{m.title}</h2>
            {m.years && <p class="card-years">{m.years}</p>}
            <p class="card-tagline">{m.tagline}</p>
            <p class="card-intro">{m.mobileIntro}</p>
            <span class="card-cta">Les mer →</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page-title  { font-size: clamp(2rem, 5vw, 3rem); margin: 0.5rem 0 1rem; }
  .page-intro  { font-family: var(--font-ui); font-size: 1.05rem; color: var(--ink-mid); max-width: 600px; line-height: 1.65; }

  .grid-section { padding-bottom: 5rem; }

  .magicians-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .magician-card {
    display: flex;
    flex-direction: column;
    background: white;
    border: 1px solid var(--cream-dark);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    color: var(--ink);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }
  .magician-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); border-color: var(--gold-light); }

  .card-image { aspect-ratio: 3/4; overflow: hidden; background: var(--cream-dark); max-height: 280px; }
  .card-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 300ms ease; }
  .magician-card:hover .card-image img { transform: scale(1.03); }
  .card-image--placeholder { display: flex; align-items: center; justify-content: center; font-size: 4rem; }

  .card-body   { padding: 1.25rem 1.5rem 1.5rem; display: flex; flex-direction: column; flex: 1; }
  .card-order  { font-family: var(--font-ui); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--gold-dark); margin-bottom: 0.3rem; }
  .card-title  { font-family: var(--font-display); font-size: 1.2rem; color: var(--burgundy); margin-bottom: 0.2rem; letter-spacing: 0.03em; }
  .card-years  { font-family: var(--font-ui); font-size: 0.78rem; color: var(--grey); margin-bottom: 0.4rem; }
  .card-tagline { font-family: var(--font-body); font-size: 0.9rem; font-style: italic; color: var(--gold-dark); margin-bottom: 0.75rem; }
  .card-intro  { font-family: var(--font-ui); font-size: 0.875rem; color: var(--ink-mid); line-height: 1.55; flex: 1; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .card-cta    { font-family: var(--font-ui); font-size: 0.875rem; font-weight: 600; color: var(--burgundy); margin-top: 1rem; transition: color 180ms ease; }
  .magician-card:hover .card-cta { color: var(--gold-dark); }

  @media (max-width: 600px) {
    .magicians-grid { grid-template-columns: 1fr; }
  }
</style>
