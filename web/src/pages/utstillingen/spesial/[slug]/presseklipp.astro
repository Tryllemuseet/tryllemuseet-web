---
// src/pages/utstillingen/spesial/[slug]/presseklipp.astro
import BaseLayout from '../../../../layouts/BaseLayout.astro'
import { sanityClient } from '../../../../lib/sanity'
import type { SpecialExhibition, PressClipping } from '../../../../lib/sanity'

export async function getStaticPaths() {
  // Only generate press clipping pages for exhibitions that have clippings
  const exhibitions: SpecialExhibition[] = await sanityClient.fetch(`
    *[_type == "specialExhibition" && isVisible != false && status in ["active", "archived"]] {
      "slug": slug.current, _id
    }
  `)
  return exhibitions
    .filter(e => e.slug)
    .map(e => ({ params: { slug: e.slug } }))
}

const { slug } = Astro.params

const exhibition: SpecialExhibition | null = await sanityClient.fetch(`
  *[_type == "specialExhibition" && slug.current == $slug && isVisible != false][0] {
    _id, title, "slug": slug.current, status, openDate, closeDate, excerpt
  }
`, { slug })

if (!exhibition || exhibition.status === 'teaser') return Astro.redirect(`/utstillingen/spesial/${slug}`, 302)

const clippings: PressClipping[] = await sanityClient.fetch(`
  *[_type == "pressClipping" && isVisible != false && exhibitionRef._ref == $id]
  | order(originalDate asc) {
    _id, title, "slug": slug.current,
    publishedAt, originalDate, sourceName, sourceUrl,
    image { asset->{ _ref, url }, alt },
    teaser, category
  }
`, { id: exhibition._id })

const categories = [...new Set(clippings.map((c: PressClipping) => c.category).filter(Boolean))]

const categoryLabels: Record<string, string> = {
  artist:        'Artist / tryllekunstner',
  forestilling:  'Forestilling',
  presseomtale:  'Presseomtale',
  annonse:       'Annonse',
  kuriosa:       'Kuriosa',
  annet:         'Annet',
}

function formatYear(d: string | undefined) {
  if (!d) return ''
  return d.slice(0, 4)
}
function formatOriginalDate(d: string | undefined) {
  if (!d) return ''
  return new Date(d).toLocaleDateString('nb-NO', { day: 'numeric', month: 'long', year: 'numeric' })
}
---

<BaseLayout
  title={`Historiske avisartikler — ${exhibition.title} — Tryllemuseet`}
  description={`${clippings.length} historiske avisartikler fra norsk presse om ${exhibition.title}, hentet fra Nasjonalbiblioteket.`}
>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <p class="section-label">
        <a href="/utstillingen" class="breadcrumb-link">Utstillingen</a>
        {' / '}
        <a href={`/utstillingen/spesial/${slug}`} class="breadcrumb-link">{exhibition.title}</a>
      </p>
      <h1 class="display-title hero-title">Historiske avisartikler</h1>
      <p class="hero-sub">
        {clippings.length} artikler fra norsk presse —
        hentet fra <a href="https://www.nb.no" target="_blank" rel="noopener" class="nb-link">Nasjonalbiblioteket</a>
      </p>
    </div>
  </section>

  <!-- FILTER -->
  {categories.length > 1 && (
    <div class="container filter-bar" id="filter-bar">
      <button class="filter-btn active" data-cat="">Alle ({clippings.length})</button>
      {categories.map((cat: string) => {
        const count = clippings.filter((c: PressClipping) => c.category === cat).length
        return (
          <button class="filter-btn" data-cat={cat}>
            {categoryLabels[cat] ?? cat} ({count})
          </button>
        )
      })}
    </div>
  )}

  <!-- COUNT -->
  <div class="container result-count">
    <span id="result-count">Viser {clippings.length} artikler</span>
  </div>

  <!-- CLIPPING LIST -->
  <main class="container clipping-list" id="clipping-list">
    {clippings.map((c: PressClipping) => (
      <article class="clipping-card" data-cat={c.category ?? ''}>
        <div class="clipping-meta">
          <span class="clipping-year">{formatYear(c.originalDate)}</span>
          {c.sourceName && <span class="clipping-source">{c.sourceName}</span>}
          {c.category && (
            <span class="clipping-cat">{categoryLabels[c.category] ?? c.category}</span>
          )}
        </div>
        <div class="clipping-body">
          <h2 class="clipping-title">{c.title}</h2>
          {c.originalDate && (
            <p class="clipping-date">{formatOriginalDate(c.originalDate)}</p>
          )}
          {c.teaser && <p class="clipping-teaser">{c.teaser}</p>}
        </div>
        <a
          href={c.sourceUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="clipping-link"
          aria-label={`Les «${c.title}» på Nasjonalbiblioteket`}
        >
          Les på nb.no →
        </a>
      </article>
    ))}
  </main>

  {clippings.length === 0 && (
    <div class="container empty-state">
      <p>Ingen artikler er lagt til ennå.</p>
    </div>
  )}

  <div class="container page-nav">
    <a href={`/utstillingen/spesial/${slug}`}>← {exhibition.title}</a>
    <a href="/utstillingen">← Utstillingen</a>
  </div>

</BaseLayout>

<script>
  const btns   = document.querySelectorAll<HTMLButtonElement>('.filter-btn')
  const cards  = document.querySelectorAll<HTMLElement>('.clipping-card')
  const count  = document.getElementById('result-count')

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat ?? ''
      btns.forEach(b => b.classList.remove('active'))
      btn.classList.add('active')

      let visible = 0
      cards.forEach(card => {
        const match = !cat || card.dataset.cat === cat
        card.style.display = match ? '' : 'none'
        if (match) visible++
      })
      if (count) count.textContent = `Viser ${visible} artikler`
    })
  })
</script>

<style>
  /* ── Hero ── */
  .hero { background: var(--burgundy-dk); padding: 3.5rem 0 2.5rem; border-bottom: 2px solid var(--gold-dark); color: var(--cream); }
  .breadcrumb-link { color: var(--gold); text-decoration: none; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; }
  .section-label { color: rgba(255,255,255,0.6); margin-bottom: 0.75rem; }
  .hero-title { font-size: clamp(1.8rem, 5vw, 3rem); color: var(--cream); margin: 0.5rem 0 0.75rem; }
  .hero-sub   { font-family: var(--font-ui); font-size: 1rem; opacity: 0.8; }
  .nb-link    { color: var(--gold); }

  /* ── Filter ── */
  .filter-bar { display: flex; flex-wrap: wrap; gap: 0.5rem; padding: 1.5rem 0 0; }
  .filter-btn {
    font-family: var(--font-ui); font-size: 0.8rem; font-weight: 600;
    color: var(--grey); border: 1px solid var(--cream-dark);
    background: white; padding: 0.4rem 1rem; border-radius: 2rem;
    cursor: pointer; transition: color 150ms, border-color 150ms;
  }
  .filter-btn:hover, .filter-btn.active { color: var(--burgundy); border-color: var(--gold); }

  /* ── Count ── */
  .result-count { padding: 0.75rem 0 0; font-family: var(--font-ui); font-size: 0.8rem; color: var(--grey); }

  /* ── List ── */
  .clipping-list { display: flex; flex-direction: column; gap: 0; padding-block: 1rem 3rem; }

  .clipping-card {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    align-items: start;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--cream-dark);
  }
  .clipping-card:first-child { border-top: 1px solid var(--cream-dark); }

  .clipping-meta { display: flex; flex-direction: column; gap: 0.3rem; padding-top: 0.15rem; }
  .clipping-year   { font-family: var(--font-display); font-size: 1.3rem; color: var(--burgundy); line-height: 1; }
  .clipping-source { font-family: var(--font-ui); font-size: 0.7rem; font-weight: 600; color: var(--gold-dark); text-transform: uppercase; letter-spacing: 0.05em; }
  .clipping-cat    { font-family: var(--font-ui); font-size: 0.65rem; color: var(--grey); border: 1px solid var(--cream-dark); padding: 0.15em 0.5em; border-radius: 2rem; }

  .clipping-body { min-width: 0; }
  .clipping-title  { font-family: var(--font-display); font-size: 1rem; color: var(--burgundy); margin-bottom: 0.2rem; line-height: 1.3; }
  .clipping-date   { font-family: var(--font-ui); font-size: 0.75rem; color: var(--grey); margin-bottom: 0.5rem; }
  .clipping-teaser { font-family: var(--font-ui); font-size: 0.875rem; color: var(--ink-mid); line-height: 1.55; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

  .clipping-link {
    font-family: var(--font-ui); font-size: 0.8rem; font-weight: 600;
    color: var(--burgundy); text-decoration: none; white-space: nowrap;
    padding-top: 0.2rem;
    transition: color 150ms;
  }
  .clipping-link:hover { color: var(--gold-dark); }

  /* ── Empty ── */
  .empty-state { padding: 4rem 0; text-align: center; font-family: var(--font-ui); color: var(--grey); }

  /* ── Nav ── */
  .page-nav { display: flex; flex-wrap: wrap; gap: 0.75rem; padding: 1.5rem 0 3rem; font-family: var(--font-ui); font-size: 0.875rem; }
  .page-nav a { color: var(--grey); text-decoration: none; border: 1px solid var(--cream-dark); padding: 0.4rem 1rem; border-radius: var(--radius); transition: color 150ms, border-color 150ms; }
  .page-nav a:hover { color: var(--burgundy); border-color: var(--gold); }

  @media (max-width: 600px) {
    .clipping-card { grid-template-columns: 80px 1fr; }
    .clipping-link { grid-column: 1 / -1; }
    .clipping-year { font-size: 1.1rem; }
  }
</style>
