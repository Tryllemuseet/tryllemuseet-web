---
// src/pages/utstillingen/trylleforeningene/[slug].astro
import BaseLayout from '../../../layouts/BaseLayout.astro'
import {
  getMagicOrganizationBySlug,
  getMagicOrganizationPaths,
  portableTextToHtml,
  urlFor,
} from '../../../lib/sanity'

export async function getStaticPaths() {
  return getMagicOrganizationPaths()
}

const { slug } = Astro.params
const org = await getMagicOrganizationBySlug(slug!)

if (!org) return Astro.redirect('/utstillingen/trylleforeningene', 301)

const bodyHtml = portableTextToHtml(org.body)

const currentLogo = org.logoHistory?.at(-1)?.logo ?? org.logo

// Destructure after the null guard — TS narrowing does not reach into functions
const { foundedYear, dissolutionYear } = org
function yearRange(): string {
  if (foundedYear && dissolutionYear) return `${foundedYear}–${dissolutionYear}`
  if (foundedYear) return `Stiftet ${foundedYear}`
  return ''
}
---

<BaseLayout
  title={`${org.name} — Trylleforeningene`}
  description={org.ingress ?? `Les om ${org.name} på Tryllemuseet`}
>

  <!-- HERO ──────────────────────────────────────────────────────── -->
  <section class="org-hero">
    <div class="container hero-inner">

      {currentLogo?.asset?.url && (
        <figure class="hero-logo">
          <img
            src={urlFor(currentLogo).width(200).format('webp').url()}
            alt={currentLogo.alt ?? `${org.name}-logo`}
          />
        </figure>
      )}

      <div class="hero-text">
        <p class="section-label">
          <a href="/utstillingen/trylleforeningene">Trylleforeningene</a>
        </p>
        <h1 class="display-title hero-name">
          {org.name}
          {org.abbreviation && <span class="hero-abbr">({org.abbreviation})</span>}
        </h1>

        <div class="hero-meta">
          {org.country && <span>{org.country}</span>}
          {yearRange() && <span>{yearRange()}</span>}
          {org.dissolutionYear && <span class="badge-dissolved">Oppløst</span>}
        </div>

        {org.website && (
          <a href={org.website} class="hero-website" target="_blank" rel="noopener noreferrer">
            Offisiell nettside →
          </a>
        )}
      </div>
    </div>
  </section>

  <!-- INGRESS ───────────────────────────────────────────────────── -->
  {org.ingress && (
    <div class="container">
      <p class="org-ingress">{org.ingress}</p>
    </div>
  )}

  <!-- BRØDTEKST ─────────────────────────────────────────────────── -->
  {bodyHtml && (
    <div class="container body-wrap">
      <div class="portable-text" set:html={bodyHtml} />
    </div>
  )}

  <!-- SENTRALE SKIKKELSER ───────────────────────────────────────── -->
  {org.keyPeople && org.keyPeople.length > 0 && (
    <section class="container key-people-section">
      <h2 class="section-heading">Sentrale skikkelser</h2>
      <ul class="key-people-list">
        {org.keyPeople.map((kp) => (
          <li class="key-person">
            <a
              href={`/tryllehistorie/magiens-hvem-er-hvem/${kp.person.slug}`}
              class="key-person-link"
            >
              <span class="key-person-name">{kp.person.name}</span>
              {(kp.role || kp.years) && (
                <span class="key-person-meta">
                  {[kp.role, kp.years].filter(Boolean).join(' · ')}
                </span>
              )}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- UNDERARTIKLER ─────────────────────────────────────────────── -->
  {org.articles && org.articles.length > 0 && (
    <section class="container articles-section">
      {org.articles.map((article) => {
        const articleHtml = portableTextToHtml(article.body)
        return (
          <article class="sub-article">
            <h2 class="sub-article-title">{article.title}</h2>
            {article.ingress && (
              <p class="sub-article-ingress">{article.ingress}</p>
            )}
            {articleHtml && (
              <div class="portable-text" set:html={articleHtml} />
            )}
          </article>
        )
      })}
    </section>
  )}

  <!-- BILDEGALLERI ──────────────────────────────────────────────── -->
  {org.gallery && org.gallery.length > 0 && (
    <section class="container gallery-section">
      <h2 class="section-heading">Bildegalleri</h2>
      <div class="gallery-grid">
        {org.gallery.map((img) => (
          <figure class="gallery-item">
            <img
              src={urlFor(img).width(480).format('webp').url()}
              alt={img.alt ?? ''}
              loading="lazy"
            />
            {(img.caption || img.year) && (
              <figcaption>
                {img.caption}{img.year && img.caption ? ` (${img.year})` : img.year}
              </figcaption>
            )}
          </figure>
        ))}
      </div>
    </section>
  )}

  <!-- LOGOHISTORIKK ─────────────────────────────────────────────── -->
  {org.logoHistory && org.logoHistory.length > 1 && (
    <section class="container logo-history-section">
      <h2 class="section-heading">Logohistorikk</h2>
      <div class="logo-history-grid">
        {org.logoHistory.map((entry) => (
          <figure class="logo-entry">
            {entry.logo?.asset?.url && (
              <img
                src={urlFor(entry.logo).width(160).format('webp').url()}
                alt={entry.logo.alt ?? `Logo ${entry.year ?? ''}`}
                loading="lazy"
              />
            )}
            <figcaption>
              {entry.year ?? 'Ukjent år'}
              {entry.note && <span class="logo-note">{entry.note}</span>}
            </figcaption>
          </figure>
        ))}
      </div>
    </section>
  )}

  <!-- KILDER ────────────────────────────────────────────────────── -->
  {org.sources && org.sources.length > 0 && (
    <section class="container sources-section">
      <h2 class="section-heading">Kilder</h2>
      <ul class="sources-list">
        {org.sources.map((s) => (
          <li>
            {s.url
              ? <a href={s.url} target="_blank" rel="noopener noreferrer">{s.label}</a>
              : <span>{s.label}</span>
            }
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- TILBAKE ───────────────────────────────────────────────────── -->
  <div class="container back-link">
    <a href="/utstillingen/trylleforeningene">← Alle trylleforeninger</a>
  </div>

</BaseLayout>

<style>
  /* ── HERO ──────────────────────────────────────────────────────── */
  .org-hero {
    background: var(--burgundy-dk);
    padding: 3rem 0 2.5rem;
    border-bottom: 2px solid var(--gold-dark);
    color: var(--cream);
  }

  .hero-inner {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
  }

  .hero-logo {
    flex-shrink: 0;
    width: 120px;
    height: 120px;
    background: white;
    border-radius: 8px;
    padding: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .hero-text { flex: 1; }

  .hero-name {
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    color: var(--cream);
    margin: 0.4rem 0 0.5rem;
    line-height: 1.15;
  }

  .hero-abbr {
    font-size: 0.6em;
    font-weight: normal;
    color: var(--gold);
    margin-left: 0.4em;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1rem;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: rgba(255,247,230,0.75);
    margin-bottom: 0.75rem;
  }

  .badge-dissolved {
    background: rgba(255,247,230,0.15);
    color: var(--cream);
    padding: 0.1rem 0.5rem;
    border-radius: 2px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero-website {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--gold);
    text-decoration: none;
    border-bottom: 1px solid var(--gold);
    transition: opacity 150ms;
  }

  .hero-website:hover { opacity: 0.8; }

  /* ── INGRESS ───────────────────────────────────────────────────── */
  .org-ingress {
    font-family: var(--font-ui);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--ink-mid);
    max-width: 72ch;
    padding: 2rem 0 0.5rem;
    border-bottom: 1px solid var(--cream-dark);
    margin-bottom: 0;
  }

  /* ── BRØDTEKST ─────────────────────────────────────────────────── */
  .body-wrap {
    padding: 2rem 0;
    max-width: 72ch;
  }

  .portable-text :global(p)          { margin: 0 0 1em; line-height: 1.75; font-family: var(--font-ui); }
  .portable-text :global(h2)         { font-family: var(--font-display); font-size: 1.4rem; color: var(--burgundy); margin: 2rem 0 0.5rem; }
  .portable-text :global(h3)         { font-family: var(--font-display); font-size: 1.15rem; color: var(--burgundy); margin: 1.5rem 0 0.4rem; }
  .portable-text :global(blockquote) { border-left: 3px solid var(--gold); padding-left: 1rem; color: var(--ink-mid); font-style: italic; margin: 1.5rem 0; }
  .portable-text :global(a)          { color: var(--burgundy); text-underline-offset: 2px; }
  .portable-text :global(a:hover)    { color: var(--gold-dark); }
  .portable-text :global(ul)         { padding-left: 1.4rem; margin: 0 0 1em; }
  .portable-text :global(ol)         { padding-left: 1.4rem; margin: 0 0 1em; }
  .portable-text :global(li)         { margin-bottom: 0.3em; line-height: 1.65; font-family: var(--font-ui); }

  /* ── SENTRALE SKIKKELSER ───────────────────────────────────────── */
  .key-people-section { padding: 2rem 0; border-top: 1px solid var(--cream-dark); }

  .section-heading {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--burgundy);
    margin-bottom: 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--gold-dark);
  }

  .key-people-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--cream-dark);
    border: 1px solid var(--cream-dark);
    border-radius: 6px;
    overflow: hidden;
    max-width: 56ch;
  }

  .key-person { background: white; }
  .key-person:hover { background: var(--cream); }

  .key-person-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem 1rem;
    text-decoration: none;
    color: var(--ink);
    transition: background 150ms;
  }

  .key-person-name {
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--burgundy);
  }

  .key-person-meta {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: var(--grey);
    white-space: nowrap;
  }

  /* ── UNDERARTIKLER ─────────────────────────────────────────────── */
  .articles-section {
    padding: 1.5rem 0;
    border-top: 1px solid var(--cream-dark);
  }

  .sub-article {
    margin-bottom: 3rem;
    max-width: 72ch;
  }

  .sub-article-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--burgundy);
    margin-bottom: 0.5rem;
    padding-bottom: 0.3rem;
    border-bottom: 2px solid var(--gold-dark);
  }

  .sub-article-ingress {
    font-family: var(--font-ui);
    font-size: 0.95rem;
    color: var(--ink-mid);
    line-height: 1.6;
    margin-bottom: 1rem;
    font-style: italic;
  }

  /* ── BILDEGALLERI ──────────────────────────────────────────────── */
  .gallery-section { padding: 2rem 0; border-top: 1px solid var(--cream-dark); }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .gallery-item { margin: 0; }

  .gallery-item img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 4px;
    display: block;
  }

  .gallery-item figcaption {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--grey);
    padding: 0.3rem 0 0;
    line-height: 1.4;
  }

  /* ── LOGOHISTORIKK ─────────────────────────────────────────────── */
  .logo-history-section { padding: 2rem 0; border-top: 1px solid var(--cream-dark); }

  .logo-history-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .logo-entry {
    text-align: center;
    margin: 0;
  }

  .logo-entry img {
    width: 100px;
    height: 100px;
    object-fit: contain;
    border: 1px solid var(--cream-dark);
    border-radius: 4px;
    padding: 6px;
    background: white;
    display: block;
  }

  .logo-entry figcaption {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--grey);
    margin-top: 0.3rem;
  }

  .logo-note {
    display: block;
    font-size: 0.7rem;
    font-style: italic;
  }

  /* ── KILDER ────────────────────────────────────────────────────── */
  .sources-section { padding: 1.5rem 0; border-top: 1px solid var(--cream-dark); }

  .sources-list {
    list-style: disc;
    padding-left: 1.4rem;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--ink-mid);
    line-height: 1.8;
  }

  .sources-list a { color: var(--burgundy); text-underline-offset: 2px; }
  .sources-list a:hover { color: var(--gold-dark); }

  /* ── TILBAKE ───────────────────────────────────────────────────── */
  .back-link {
    padding: 1rem 0 4rem;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    border-top: 1px solid var(--cream-dark);
    margin-top: 1rem;
  }

  .back-link a {
    color: var(--grey);
    text-decoration: none;
    border: 1px solid var(--cream-dark);
    padding: 0.4rem 1rem;
    border-radius: var(--radius);
    transition: color 150ms, border-color 150ms;
  }

  .back-link a:hover { color: var(--burgundy); border-color: var(--gold); }

  /* ── RESPONSIVE ────────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .hero-inner   { flex-direction: column; gap: 1rem; }
    .hero-logo    { width: 80px; height: 80px; }
    .hero-name    { font-size: 1.6rem; }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
