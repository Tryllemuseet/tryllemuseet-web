---
// src/pages/utstillingen/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro'
import LegendBody from '../../components/LegendBody.astro'
import {
  getUtstillingEntryBySlug,
  getUtstillingPaths,
  getBooksByUtstillingSlug,
  urlFor,
} from '../../lib/sanity'

export async function getStaticPaths() {
  return getUtstillingPaths()
}

const { slug } = Astro.params
const entry = await getUtstillingEntryBySlug(slug!)

if (!entry) return Astro.redirect('/utstillingen', 301)

const books = await getBooksByUtstillingSlug(slug!)
const stations = entry.stations ?? []

const posterUrl = entry.mainImage?.asset
  ? urlFor(entry.mainImage).width(800).format('webp').url()
  : null

const availabilityLabel: Record<string, string> = {
  inPrint:           'Tilgjengelig',
  freeDownload:      'Gratis nedlast',
  checkAvailability: 'Sjekk tilgjengelighet',
  rare:              'Sjelden / antikvarisk',
}
---

<BaseLayout
  title={`${entry.title} — Tryllemuseet`}
  description={entry.detailIntro ?? entry.tagline ?? `Les om ${entry.title} på Tryllemuseet`}
>

  <!-- HERO ────────────────────────────────────────────────────── -->
  <section class="entry-hero">
    <div class="container hero-inner">
      {posterUrl && (
        <div class="poster-wrap">
          <img
            src={posterUrl}
            alt={entry.mainImage?.alt ?? entry.title}
            class="poster-img"
          />
        </div>
      )}
      <div class="hero-text">
        {stations.length > 0 && <p class="hero-kicker">Utstilling</p>}
        <h1 class="display-title hero-title">{entry.title}</h1>
        {entry.years   && <p class="hero-years">{entry.years}</p>}
        {entry.tagline && <p class="hero-tagline">«{entry.tagline}»</p>}
      </div>
    </div>
  </section>

  <LegendBody entry={entry}>
    <Fragment slot="extra">
      {books.length > 0 && (
        <section class="books-section" aria-label={`Bøker av ${entry.title}`}>
          <h2 class="section-heading">Bøker</h2>
          <ul class="books-list">
            {books.map((book: any) => {
              const thumb = book.thumbnailUrl ?? book.coverImage ?? null
              const yearDisplay = book.yearNote ?? book.year?.toString() ?? ''
              const avail = book.availability ?? ''
              return (
                <li class="book-item">
                  {thumb && (
                    <div class="book-thumb">
                      <img src={thumb} alt={`Forsidebilde: ${book.title}`} loading="lazy" />
                    </div>
                  )}
                  <div class="book-meta">
                    <span class="book-title">{book.title}</span>
                    {yearDisplay && <span class="book-year">{yearDisplay}</span>}
                    {avail && (
                      <span class={`avail-badge avail-badge--${avail}`}>
                        {availabilityLabel[avail] ?? avail}
                      </span>
                    )}
                    {book.externalUrl && (
                      <a
                        href={book.externalUrl}
                        target="_blank"
                        rel="noopener"
                        class="book-link"
                      >
                        Last ned PDF
                        <svg viewBox="0 0 12 12" fill="none" aria-hidden="true">
                          <path d="M2 10L10 2M10 2H5M10 2V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                      </a>
                    )}
                  </div>
                </li>
              )
            })}
          </ul>
          <p class="books-more">
            <a href="/ressurser/bibliotek">Se alle bøker i biblioteket →</a>
          </p>
        </section>
      )}
    </Fragment>

    <nav class="entry-nav" aria-label="Naviger i utstillingen">
      <a href="/utstillingen" class="btn-nav">← Utstillingen</a>
    </nav>
  </LegendBody>

</BaseLayout>

<style>
  /* ── HERO ──────────────────────────────────────────────────────── */
  .entry-hero {
    background: var(--burgundy-dk);
    padding: 3.5rem 0 3rem;
    border-bottom: 2px solid var(--gold-dark);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 3rem;
    align-items: start;
  }

  .poster-wrap {
    width: 200px;
    flex-shrink: 0;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    border: 2px solid var(--gold-dark);
  }
  .poster-img { width: 100%; display: block; }

  .hero-text    { color: var(--cream); }
  .hero-kicker {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }
  .hero-title   { font-size: clamp(1.8rem, 4vw, 3rem); color: var(--cream); margin-bottom: 0.4rem; }
  .hero-years   { font-family: var(--font-ui); font-size: 0.9rem; color: var(--gold-light); opacity: 0.75; margin-bottom: 0.4rem; }
  .hero-tagline { font-family: var(--font-body); font-size: 1.1rem; font-style: italic; color: var(--gold); }

  /* ── BØKER ─────────────────────────────────────────────────────── */
  .books-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--cream-dark);
    border: 1px solid var(--cream-dark);
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }

  .book-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: white;
    padding: 0.75rem 1rem;
    transition: background 150ms;
  }
  .book-item:hover { background: var(--cream); }

  .book-thumb {
    width: 48px;
    height: 64px;
    flex-shrink: 0;
    border-radius: 2px;
    overflow: hidden;
    background: var(--cream-dark);
  }
  .book-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .book-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    flex: 1;
  }

  .book-title {
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--burgundy);
    letter-spacing: 0.02em;
    flex: 1;
    min-width: 200px;
  }

  .book-year {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-style: italic;
    color: var(--grey);
  }

  .avail-badge {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
    border: 1px solid;
  }
  .avail-badge--inPrint {
    color: #1a6b3a; border-color: rgba(26,107,58,0.35); background: rgba(26,107,58,0.07);
  }
  .avail-badge--freeDownload {
    color: #185fa5; border-color: rgba(24,95,165,0.35); background: rgba(24,95,165,0.07);
  }
  .avail-badge--checkAvailability {
    color: var(--ink-mid); border-color: var(--cream-dark); background: var(--cream-dark);
  }
  .avail-badge--rare {
    color: #8b4513; border-color: rgba(139,69,19,0.35); background: rgba(139,69,19,0.07);
  }

  .book-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--burgundy);
    border: 1.5px solid var(--cream-dark);
    border-radius: 4px;
    padding: 0.2rem 0.55rem;
    transition: border-color 150ms, color 150ms;
  }
  .book-link:hover { border-color: var(--gold); color: var(--gold-dark); }
  .book-link svg { width: 10px; height: 10px; }

  .books-more {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    text-align: right;
  }
  .books-more a {
    color: var(--burgundy);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 150ms;
  }
  .books-more a:hover { color: var(--gold-dark); }

  .section-heading {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--burgundy);
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--cream-dark);
    letter-spacing: 0.04em;
  }

  /* ── NAVIGASJON ─────────────────────────────────────────────────── */
  .entry-nav { padding-top: 1.5rem; border-top: 1px solid var(--cream-dark); }
  .btn-nav {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--burgundy);
    padding: 0.5rem 1rem;
    border: 1.5px solid var(--cream-dark);
    border-radius: var(--radius);
    transition: border-color 180ms, color 180ms;
    display: inline-block;
  }
  .btn-nav:hover { border-color: var(--gold); color: var(--gold-dark); }

  /* ── RESPONSIVE ─────────────────────────────────────────────────── */
  @media (max-width: 700px) {
    .hero-inner  { grid-template-columns: 1fr; gap: 1.5rem; }
    .poster-wrap { width: 140px; }
  }
</style>
