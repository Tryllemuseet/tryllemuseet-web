---
// src/pages/kontakt.astro
import BaseLayout from '../layouts/BaseLayout.astro'
import AnimateIn from '../components/AnimateIn.astro'
import { getSiteConfig, getKontaktPage } from '../lib/sanity'

const [site, page] = await Promise.all([getSiteConfig(), getKontaktPage()])
---

<BaseLayout
  title="Kontakt oss — Tryllemuseet"
  description={page.hero.ingress}
>

  <section class="kontakt-hero">
    <div class="container">
      <p class="section-label">{page.hero.label}</p>
      <h1 class="display-title kontakt-title">{page.hero.heading}</h1>
      <p class="kontakt-sub">
        {page.hero.ingress}{' '}
        <a href={`mailto:${site.email}`}>{site.email}</a>.
      </p>
    </div>
  </section>

  <div class="container kontakt-grid">

    <!-- VENSTRE: Skjema ── -->
    <AnimateIn direction="left">
    <div class="form-col">
      <div class="form-card">
        <h2 class="form-heading">Send oss en melding</h2>
        <div class="iframe-wrap">
          <iframe
            src={page.skjemaUrl}
            frameborder="0"
            marginwidth="0"
            marginheight="0"
            allowfullscreen
            title="Kontaktskjema Tryllemuseet"
          ></iframe>
        </div>
      </div>
    </div>
    </AnimateIn>

    <!-- HØYRE: Info ── -->
    <AnimateIn direction="right">
    <div class="info-col">

      <div class="contact-card">
        <h2 class="contact-card-heading">Kontaktinformasjon</h2>

        <div class="contact-item">
          <span aria-hidden="true">✉️</span>
          <div>
            <p class="contact-label">E-post</p>
            <a href={`mailto:${site.email}`} class="contact-value">{site.email}</a>
          </div>
        </div>

        <div class="contact-item">
          <span aria-hidden="true">📍</span>
          <div>
            <p class="contact-label">Besøksadresse</p>
            <p class="contact-value">{site.addressShort}</p>
            <a href={site.mapUrl} target="_blank" rel="noopener noreferrer" class="contact-sub-link">Åpne i Google Maps →</a>
          </div>
        </div>

        <div class="contact-item">
          <span aria-hidden="true">🕐</span>
          <div>
            <p class="contact-label">Åpningstider</p>
            <p class="contact-value">{site.openingHoursShort}</p>
            <a href="/besok" class="contact-sub-link">Mer om besøket →</a>
          </div>
        </div>
      </div>

      <div class="contact-card">
        <h2 class="contact-card-heading">Følg oss</h2>
        <div class="social-links">
          {site.facebook && (
            <a href={site.facebook} target="_blank" rel="noopener noreferrer" class="social-link social-fb">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="20" height="20"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              Facebook
            </a>
          )}
          {site.instagram && (
            <a href={site.instagram} target="_blank" rel="noopener noreferrer" class="social-link social-ig">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" width="20" height="20"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/></svg>
              Instagram
            </a>
          )}
        </div>
      </div>

      {page.faq.length > 0 && (
        <div class="contact-card">
          <h2 class="contact-card-heading">Ofte stilte spørsmål</h2>
          <div class="faq-list">
            {page.faq.map(item => (
              <details class="faq-item">
                <summary>{item.sporsmal}</summary>
                <p>{item.svar}</p>
              </details>
            ))}
          </div>
        </div>
      )}

    </div>
    </AnimateIn>
  </div>

</BaseLayout>

<style>
  .kontakt-hero { background: var(--burgundy-dk); padding: 3.5rem 0 2.5rem; border-bottom: 2px solid var(--gold-dark); color: var(--cream); }
  .kontakt-title { font-size: clamp(2rem,5vw,3rem); color: var(--cream); margin: 0.5rem 0 0.75rem; }
  .kontakt-sub { font-family: var(--font-ui); font-size: 1rem; opacity: 0.82; line-height: 1.6; }
  .kontakt-sub a { color: var(--gold-light); text-decoration: underline; }

  .kontakt-grid { display: grid; grid-template-columns: 3fr 2fr; gap: 2rem; padding: 2.5rem 0 5rem; align-items: start; }

  /* ── Skjema ── */
  .form-card { background: white; border: 1px solid var(--cream-dark); border-radius: 6px; padding: 2rem; }
  .form-heading { font-family: var(--font-display); font-size: 1.2rem; color: var(--burgundy); margin-bottom: 1.5rem; letter-spacing: 0.04em; }
  .iframe-wrap { border-radius: 4px; overflow: hidden; }
  .iframe-wrap iframe { width: 100%; height: 600px; border: none; display: block; }

  /* ── Kontaktkort ── */
  .contact-card { background: white; border: 1px solid var(--cream-dark); border-radius: 6px; padding: 1.5rem; margin-bottom: 1.25rem; }
  .contact-card:last-child { margin-bottom: 0; }
  .contact-card-heading { font-family: var(--font-display); font-size: 1rem; color: var(--burgundy); letter-spacing: 0.04em; margin-bottom: 1.25rem; }
  .contact-item { display: flex; align-items: flex-start; gap: 0.9rem; margin-bottom: 1.25rem; padding-bottom: 1.25rem; border-bottom: 1px solid var(--cream-dark); font-size: 1.2rem; }
  .contact-item:last-child { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
  .contact-label { font-family: var(--font-ui); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--grey); margin-bottom: 0.2rem; }
  .contact-value { font-family: var(--font-ui); font-size: 0.9rem; color: var(--ink); line-height: 1.5; text-decoration: none; }
  a.contact-value:hover { color: var(--burgundy); text-decoration: underline; }
  .contact-sub-link { display: block; font-family: var(--font-ui); font-size: 0.8rem; color: var(--burgundy); text-decoration: underline; margin-top: 0.3rem; }

  /* ── Sosiale medier ── */
  .social-links { display: flex; flex-direction: column; gap: 0.6rem; }
  .social-link { display: flex; align-items: center; gap: 0.75rem; padding: 0.65rem 0.9rem; border-radius: 5px; text-decoration: none; color: white; font-family: var(--font-ui); font-weight: 600; font-size: 0.9rem; transition: opacity 150ms; }
  .social-link:hover { opacity: 0.9; }
  .social-fb { background: #1877F2; }
  .social-ig { background: linear-gradient(135deg,#f09433,#e6683c 25%,#dc2743 50%,#cc2366 75%,#bc1888); }

  /* ── FAQ ── */
  .faq-list { display: flex; flex-direction: column; }
  .faq-item { border-bottom: 1px solid var(--cream-dark); }
  .faq-item:last-child { border-bottom: none; }
  .faq-item summary { font-family: var(--font-ui); font-size: 0.875rem; font-weight: 600; color: var(--ink); padding: 0.75rem 0; cursor: pointer; list-style: none; display: flex; justify-content: space-between; gap: 0.5rem; }
  .faq-item summary::after { content: '+'; font-size: 1.2rem; color: var(--gold-dark); flex-shrink: 0; transition: transform 200ms; }
  .faq-item[open] summary::after { transform: rotate(45deg); }
  .faq-item p { font-family: var(--font-ui); font-size: 0.875rem; color: var(--ink-mid); line-height: 1.6; padding-bottom: 0.75rem; }

  /* ── Responsive ── */
  @media (max-width: 800px) {
    .kontakt-grid { grid-template-columns: 1fr; }
    .iframe-wrap iframe { height: 500px; }
  }
</style>
