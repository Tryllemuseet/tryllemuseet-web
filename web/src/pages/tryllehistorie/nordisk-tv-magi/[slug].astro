---
// src/pages/tryllehistorie/nordisk-tv-magi/[slug].astro
// Redirect til riktig seksjon basert på slug
const { slug } = Astro.params

// Hent show-type fra Sanity for å sende til riktig underseksjon
import { sanityClient } from '../../../lib/sanity'
const doc = await sanityClient.fetch(
  `*[_type == "tvAppearance" && slug.current == $slug][0]{ show }`,
  { slug }
)

const base = doc?.show === 'fool-us'
  ? '/tryllehistorie/fool-us'
  : '/tryllehistorie/got-talent'

return Astro.redirect(`${base}/${slug}`, 301)
---
