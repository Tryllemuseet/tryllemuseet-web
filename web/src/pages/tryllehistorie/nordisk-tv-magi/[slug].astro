---
// src/pages/tryllehistorie/nordisk-tv-magi/[slug].astro
import { sanityClient } from '../../../lib/sanity'

export async function getStaticPaths() {
  const docs = await sanityClient.fetch(`
    *[_type == "tvAppearance"] {
      "slug": slug.current,
      show
    }
  `)
  return docs.map((d: { slug: string; show: string }) => ({
    params: { slug: d.slug },
    props:  { show: d.show },
  }))
}

const { show } = Astro.props
const { slug } = Astro.params

const base = show === 'fool-us'
  ? '/tryllehistorie/fool-us'
  : '/tryllehistorie/got-talent'

return Astro.redirect(`${base}/${slug}`, 301)
---
