---
// src/pages/tryllehistorie/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getTryllehistoriePage } from '../../lib/sanity'

const page = await getTryllehistoriePage()
---

<BaseLayout
  title="Tryllehistorie — Tryllemuseet"
  description={page.hero.ingress}
>

  <!-- HERO ──────────────────────────────────────────────────────── -->
  <section class="th-hero">
    <div class="container">
      <p class="section-label">{page.hero.label}</p>
      <h1 class="display-title th-title">{page.hero.heading}</h1>
      <p class="th-sub">{page.hero.ingress}</p>
    </div>
  </section>

  <!-- SEKSJONER ───────────────────────────────────────────────────── -->
  <main class="container th-grid-wrap">
    <div class="th-grid">
      {page.seksjoner.map(s => (
        <a
          href={s.soon ? undefined : s.href}
          class:list={['th-card', { 'th-card--soon': s.soon }]}
          aria-disabled={s.soon ? 'true' : undefined}
        >
          <div class="th-card-top">
            <span class="th-emoji" aria-hidden="true">{s.emoji}</span>
            <span class:list={['th-badge', { 'th-badge--soon': s.soon }]}>
              {s.badge}
            </span>
          </div>

          <div class="th-card-body">
            <p class="th-sub-label">{s.sub}</p>
            <h2 class="th-card-title">{s.title}</h2>
            <p class="th-card-desc">{s.desc}</p>
          </div>

          {!s.soon && (
            <span class="th-arrow" aria-hidden="true">→</span>
          )}
        </a>
      ))}
    </div>

    <!-- TIDSLINJE-TEASER ────────────────────────────────────────── -->
    <aside class="timeline-teaser">
      <h2 class="display-title timeline-title">{page.tidslinjeHeading}</h2>
      <div class="timeline">
        {page.tidslinje.map(item => (
          <div class:list={['tl-item', { 'tl-item--last': item.siste }]}>
            <span class="tl-year">{item.aar}</span>
            <span class="tl-event">{item.hendelse}</span>
          </div>
        ))}
      </div>
    </aside>

  </main>

</BaseLayout>

<style>
  /* ── HERO ──────────────────────────────────────────────────────── */
  .th-hero {
    background: var(--burgundy-dk);
    padding: 3.5rem 0 2.5rem;
    border-bottom: 2px solid var(--gold-dark);
    color: var(--cream);
  }

  .th-title { font-size: clamp(2rem, 5vw, 3.2rem); color: var(--cream); margin: 0.5rem 0 0.75rem; }
  .th-sub   { font-family: var(--font-ui); font-size: 1rem; opacity: 0.82; max-width: 580px; line-height: 1.6; }

  /* ── GRID ──────────────────────────────────────────────────────── */
  .th-grid-wrap { padding: 3rem 0 5rem; }

  .th-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
    margin-bottom: 4rem;
  }

  /* ── KORT ──────────────────────────────────────────────────────── */
  .th-card {
    display: flex;
    flex-direction: column;
    background: white;
    border: 1px solid var(--cream-dark);
    border-radius: 6px;
    padding: 1.5rem;
    text-decoration: none;
    color: var(--ink);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
    position: relative;
  }

  .th-card:not(.th-card--soon):hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    border-color: var(--gold-light);
  }

  .th-card--soon {
    opacity: 0.65;
    cursor: default;
  }

  .th-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .th-emoji {
    font-size: 2rem;
    line-height: 1;
  }

  .th-badge {
    font-family: var(--font-ui);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--burgundy);
    color: var(--gold-light);
    padding: 0.2rem 0.55rem;
    border-radius: 3px;
  }

  .th-badge--soon {
    background: var(--cream-dark);
    color: var(--grey);
  }

  .th-sub-label {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gold-dark);
    margin-bottom: 0.3rem;
  }

  .th-card-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--burgundy);
    margin-bottom: 0.6rem;
    letter-spacing: 0.03em;
    line-height: 1.3;
  }

  .th-card-desc {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--ink-mid);
    line-height: 1.6;
    flex: 1;
  }

  .th-arrow {
    display: block;
    text-align: right;
    color: var(--gold-dark);
    font-size: 1.1rem;
    margin-top: 1rem;
    transition: transform 180ms ease;
  }

  .th-card:hover .th-arrow { transform: translateX(4px); }

  /* ── TIDSLINJE ─────────────────────────────────────────────────── */
  .timeline-teaser {
    background: var(--burgundy-dk);
    border-radius: 8px;
    padding: 2.5rem 2.5rem 2rem;
    color: var(--cream);
  }

  .timeline-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: var(--gold);
    margin-bottom: 2rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 88px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: rgba(212,168,67,0.25);
  }

  .tl-item {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 1.25rem;
    padding: 0.6rem 0 0.6rem 0;
    position: relative;
  }

  .tl-item::before {
    content: '';
    position: absolute;
    left: 83px;
    top: 50%;
    transform: translateY(-50%);
    width: 10px;
    height: 10px;
    background: var(--gold);
    border-radius: 50%;
    border: 2px solid var(--burgundy-dk);
  }

  .tl-item--last::before { background: var(--gold-light); }

  .tl-year {
    font-family: var(--font-display);
    font-size: 0.78rem;
    color: var(--gold);
    text-align: right;
    padding-right: 1.5rem;
    line-height: 1.4;
    padding-top: 0.1rem;
  }

  .tl-event {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--cream);
    opacity: 0.85;
    line-height: 1.5;
    padding-left: 1rem;
  }

  /* ── RESPONSIVE ────────────────────────────────────────────────── */
  @media (max-width: 700px) {
    .th-grid { grid-template-columns: 1fr; }

    .timeline::before { left: 70px; }
    .tl-item { grid-template-columns: 70px 1fr; }
    .tl-item::before { left: 65px; }

    .timeline-teaser { padding: 1.5rem 1.25rem; }
  }
</style>
