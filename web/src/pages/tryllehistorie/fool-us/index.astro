---
// src/pages/tryllehistorie/fool-us/index.astro
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { sanityClient, resultLabels } from '../../../lib/sanity'

const appearances = await sanityClient.fetch(`
  *[_type == "tvAppearance" && show == "fool-us"] | order(year desc, season asc, episode asc) {
    _id,
    "slug": slug.current,
    year, season, episode, episodeTitle,
    result,
    featuredImage { asset->{ url }, alt },
    magician-> {
      _id, name, "slug": slug.current,
      artistName, nationality,
      mainImage { asset->{ url }, alt }
    }
  }
`)

const countries = [...new Set(appearances.map((a: any) => a.magician?.nationality))].filter(Boolean).sort()
const total = appearances.length
const fooled = appearances.filter((a: any) => a.result === 'fooled').length
---

<BaseLayout
  title="Penn & Teller: Fool Us — Nordiske magikere — Tryllemuseet"
  description={`${total} nordiske opptredener i Penn & Teller: Fool Us. ${fooled} klarte å lure duoen.`}
>

  <section class="hero">
    <div class="container">
      <p class="section-label"><a href="/tryllehistorie" class="breadcrumb-link">Tryllehistorie</a></p>
      <h1 class="display-title hero-title">Penn &amp; Teller: Fool Us</h1>
      <p class="hero-sub">
        {total} nordiske opptredener i den prestisjetunge fagduellen fra Las Vegas.
        {fooled} klarte å lure Penn &amp; Teller fullstendig.
      </p>
    </div>
    <div class="container hero-stats">
      <div class="stat">
        <span class="stat-num">{total}</span>
        <span class="stat-label">Opptredener</span>
      </div>
      <div class="stat">
        <span class="stat-num" style="color: #86efac">{fooled}</span>
        <span class="stat-label">Fooled Us ✅</span>
      </div>
      <div class="stat">
        <span class="stat-num">{total - fooled}</span>
        <span class="stat-label">Not Fooled</span>
      </div>
    </div>
  </section>

  <div class="filter-bar-wrap">
    <div class="container filter-bar-inner">
      <div class="filter-group">
        <label class="filter-label" for="filter-country">Land</label>
        <select id="filter-country" class="filter-select">
          <option value="">Alle land</option>
          {countries.map((c: string) => <option value={c}>{c}</option>)}
        </select>
      </div>
      <div class="filter-group">
        <label class="filter-label" for="filter-result">Resultat</label>
        <select id="filter-result" class="filter-select">
          <option value="">Alle resultater</option>
          <option value="fooled">✅ Fooled Us</option>
          <option value="not_fooled">✖️ Not Fooled</option>
        </select>
      </div>
      <button class="filter-reset" id="filter-reset">Nullstill</button>
    </div>
  </div>

  <div class="container">
    <p class="result-count" id="result-count">Viser {total} opptredener</p>
  </div>

  <main class="container appearances-list" id="appearances-grid">
    {appearances.map((a: any) => (
      <article
        class="appearance-row"
        data-country={a.magician?.nationality ?? ''}
        data-result={a.result}
      >
        <a href={`/tryllehistorie/fool-us/${a.slug}`} class="row-link">

          <div class="row-img">
            {a.featuredImage?.asset?.url ? (
              <img src={a.featuredImage.asset.url} alt={a.featuredImage.alt ?? ''} loading="lazy" />
            ) : a.magician?.mainImage?.asset?.url ? (
              <img src={a.magician.mainImage.asset.url} alt="" loading="lazy" />
            ) : (
              <div class="row-img-placeholder" aria-hidden="true">🎯</div>
            )}
          </div>

          <div class="row-body">
            <p class="row-meta">
              {a.year && <span>Sesong {a.season ?? '?'}</span>}
              {a.episode && <span>Ep. {a.episode}</span>}
              {a.year && <span>{a.year}</span>}
              {a.magician?.nationality && <span>{a.magician.nationality}</span>}
            </p>
            <h2 class="row-name">{a.magician?.artistName ?? a.magician?.name ?? '(ukjent)'}</h2>
            {a.magician?.artistName && a.magician.name !== a.magician.artistName && (
              <p class="row-fullname">{a.magician.name}</p>
            )}
            {a.episodeTitle && <p class="row-episode">«{a.episodeTitle}»</p>}
          </div>

          <div class="row-result">
            <span class="result-pill" data-result={a.result}>
              {resultLabels[a.result] ?? a.result}
            </span>
            <span class="row-arrow" aria-hidden="true">→</span>
          </div>

        </a>
      </article>
    ))}
  </main>

  <div class="container no-results" id="no-results" hidden>
    <p>Ingen opptredener matcher filteret.</p>
    <button class="filter-reset-inline" id="filter-reset-2">Nullstill filter</button>
  </div>

  <div class="container page-nav">
    <a href="/tryllehistorie/got-talent">Got Talent →</a>
    <a href="/tryllehistorie/historiske-opptak">Historiske opptak →</a>
    <a href="/tryllehistorie">← Tryllehistorie</a>
  </div>

</BaseLayout>

<script>
  const rows       = Array.from(document.querySelectorAll<HTMLElement>('.appearance-row'))
  const noResults  = document.getElementById('no-results')!
  const countEl    = document.getElementById('result-count')!
  const selCountry = document.getElementById('filter-country') as HTMLSelectElement
  const selResult  = document.getElementById('filter-result')  as HTMLSelectElement
  const btnReset   = document.getElementById('filter-reset')!
  const btnReset2  = document.getElementById('filter-reset-2')!

  function applyFilters() {
    const country = selCountry.value, result = selResult.value
    let visible = 0
    rows.forEach(row => {
      const match =
        (!country || row.dataset.country === country) &&
        (!result  || row.dataset.result  === result)
      row.hidden = !match
      if (match) visible++
    })
    noResults.hidden = visible > 0
    countEl.textContent = `Viser ${visible} opptreden${visible !== 1 ? 'er' : ''}`
  }
  function resetFilters() { selCountry.value = ''; selResult.value = ''; applyFilters() }
  selCountry.addEventListener('change', applyFilters)
  selResult.addEventListener('change', applyFilters)
  btnReset.addEventListener('click', resetFilters)
  btnReset2.addEventListener('click', resetFilters)
</script>

<style>
  .hero { background: var(--burgundy-dk); padding: 3rem 0 2rem; border-bottom: 2px solid var(--gold-dark); color: var(--cream); }
  .breadcrumb-link { color: var(--gold); text-decoration: none; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; }
  .hero-title { font-size: clamp(1.8rem, 5vw, 3rem); color: var(--cream); margin: 0.5rem 0 0.75rem; }
  .hero-sub { font-family: var(--font-ui); font-size: 1rem; opacity: 0.8; max-width: 600px; margin-bottom: 1.5rem; }
  .hero-stats { display: flex; gap: 2rem; padding-bottom: 2rem; }
  .stat { display: flex; flex-direction: column; gap: 0.1rem; }
  .stat-num { font-family: var(--font-display); font-size: 2rem; color: var(--gold); letter-spacing: 0.04em; line-height: 1; }
  .stat-label { font-family: var(--font-ui); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--cream); opacity: 0.6; }

  .filter-bar-wrap { position: sticky; top: var(--header-h); z-index: 50; background: white; border-bottom: 1px solid var(--cream-dark); box-shadow: 0 2px 12px rgba(26,18,8,0.06); }
  .filter-bar-inner { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: flex-end; padding: 0.75rem 1.5rem; }
  .filter-group { display: flex; flex-direction: column; gap: 0.2rem; }
  .filter-label { font-family: var(--font-ui); font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--grey); }
  .filter-select { font-family: var(--font-ui); font-size: 0.875rem; color: var(--ink); background: var(--cream); border: 1.5px solid var(--cream-dark); border-radius: 6px; padding: 0.45rem 0.75rem; cursor: pointer; min-width: 180px; }
  .filter-reset { font-family: var(--font-ui); font-size: 0.8rem; font-weight: 600; color: var(--grey); border: 1.5px solid var(--cream-dark); border-radius: 6px; padding: 0.45rem 0.9rem; background: white; cursor: pointer; align-self: flex-end; }
  .filter-reset:hover { color: var(--burgundy); border-color: var(--gold); }

  .result-count { font-family: var(--font-ui); font-size: 0.8rem; color: var(--grey); padding: 0.75rem 0 0.25rem; }

  /* Liste-layout for Fool Us — mer kompakt enn grid */
  .appearances-list { display: flex; flex-direction: column; gap: 1px; background: var(--cream-dark); border: 1px solid var(--cream-dark); border-radius: 8px; overflow: hidden; margin-bottom: 1rem; }
  .appearance-row { background: white; transition: background 150ms; }
  .appearance-row:hover { background: var(--cream); }

  .row-link { display: grid; grid-template-columns: 72px 1fr auto; align-items: center; gap: 1rem; padding: 0.875rem 1rem; text-decoration: none; color: var(--ink); }
  .row-img { width: 72px; height: 56px; border-radius: 4px; overflow: hidden; background: var(--burgundy-dk); flex-shrink: 0; }
  .row-img img { width: 100%; height: 100%; object-fit: cover; }
  .row-img-placeholder { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; font-size: 1.5rem; }

  .row-meta { font-family: var(--font-ui); font-size: 0.7rem; color: var(--grey); display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.2rem; }
  .row-meta span + span::before { content: '·'; margin-right: 0.4rem; }
  .row-name { font-family: var(--font-display); font-size: 0.95rem; color: var(--burgundy); letter-spacing: 0.02em; }
  .row-fullname { font-family: var(--font-ui); font-size: 0.75rem; color: var(--grey); font-style: italic; }
  .row-episode { font-family: var(--font-body); font-size: 0.78rem; font-style: italic; color: var(--ink-mid); margin-top: 0.15rem; }

  .row-result { display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; flex-shrink: 0; }
  .result-pill { font-family: var(--font-ui); font-size: 0.7rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 99px; white-space: nowrap; background: rgba(26,18,8,0.08); color: var(--ink-mid); }
  .result-pill[data-result="fooled"] { background: rgba(22,101,52,0.15); color: #166534; }
  .row-arrow { font-size: 0.85rem; color: var(--gold-dark); opacity: 0; transition: opacity 150ms, transform 150ms; }
  .appearance-row:hover .row-arrow { opacity: 1; transform: translateX(3px); }

  .no-results { padding: 3rem 0; text-align: center; font-family: var(--font-ui); color: var(--ink-mid); }
  .filter-reset-inline { margin-top: 0.75rem; font-family: var(--font-ui); font-size: 0.875rem; font-weight: 600; color: var(--burgundy); background: none; border: 1px solid var(--gold-dark); border-radius: 6px; padding: 0.45rem 1rem; cursor: pointer; }

  .page-nav { display: flex; flex-wrap: wrap; gap: 0.75rem; padding: 1.5rem 0 3rem; font-family: var(--font-ui); font-size: 0.875rem; }
  .page-nav a { color: var(--grey); text-decoration: none; border: 1px solid var(--cream-dark); padding: 0.4rem 1rem; border-radius: var(--radius); transition: color 150ms, border-color 150ms; }
  .page-nav a:hover { color: var(--burgundy); border-color: var(--gold); }

  @media (max-width: 560px) {
    .row-link { grid-template-columns: 56px 1fr; }
    .row-result { display: none; }
    .hero-stats { gap: 1.25rem; }
    .stat-num { font-size: 1.5rem; }
  }
</style>
