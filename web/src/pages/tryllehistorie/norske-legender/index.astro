---
// src/pages/tryllehistorie/norske-legender/index.astro
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { getAllLegends } from '../../../lib/sanity'
import type { Legend } from '../../../lib/sanity'

const legends = await getAllLegends()
const total = legends.length
---

<BaseLayout
  title="Norske legender — Tryllemuseet"
  description={`${total} artikler om de store navnene i norsk tryllekunst — fra pionerer til internasjonale stjerner.`}
>

  <!-- HERO ──────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container">
      <p class="section-label"><a href="/tryllehistorie" class="breadcrumb-link">Tryllehistorie</a></p>
      <h1 class="display-title hero-title">Norske legender</h1>
      <p class="hero-sub">
        {total} artikler om de store navnene i norsk tryllekunst —
        fra pionerer til internasjonale stjerner.
      </p>
    </div>
  </section>

  <!-- KORTLISTE ──────────────────────────────────────────────────── -->
  <main class="container legend-grid" id="legend-grid">
    {legends.map((leg: Legend) => {
      const bio = leg.biographyRef
      const img = leg.mainImage ?? bio?.mainImage
      const navn = bio?.name ?? leg.title
      const years = bio?.years ?? (bio?.birthDate ? bio.birthDate.slice(0, 4) : '')
      return (
        <article class="legend-card">
          <a href={`/tryllehistorie/norske-legender/${leg.slug}`} class="legend-link">

            <div class="legend-img">
              {img?.asset?.url ? (
                <img
                  src={img.asset.url}
                  alt={img.alt ?? navn}
                  loading="lazy"
                />
              ) : (
                <div class="legend-img-placeholder" aria-hidden="true">⭐</div>
              )}
            </div>

            <div class="legend-body">
              <h2 class="legend-title">{leg.title}</h2>
              {years && <p class="legend-years">{years}</p>}
              {leg.excerpt && <p class="legend-excerpt">{leg.excerpt}</p>}
              {leg.tags && leg.tags.length > 0 && (
                <div class="legend-tags">
                  {leg.tags.filter((t: string) => t !== 'norske-legender').slice(0, 3).map((tag: string) => (
                    <span class="legend-tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>

            <span class="legend-arrow" aria-hidden="true">→</span>
          </a>
        </article>
      )
    })}
  </main>

  {total === 0 && (
    <div class="container empty-state">
      <p>Ingen artikler er publisert ennå. Kom tilbake snart.</p>
    </div>
  )}

  <div class="container page-nav">
    <a href="/tryllehistorie/magiens-hvem-er-hvem">← Hvem er hvem</a>
    <a href="/tryllehistorie">← Tryllehistorie</a>
  </div>

</BaseLayout>

<style>
  /* ── Hero ── */
  .hero { background: var(--burgundy-dk); padding: 3.5rem 0 2.5rem; border-bottom: 2px solid var(--gold-dark); color: var(--cream); }
  .breadcrumb-link { color: var(--gold); text-decoration: none; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; }
  .hero-title { font-size: clamp(1.8rem, 5vw, 3rem); color: var(--cream); margin: 0.5rem 0 0.75rem; }
  .hero-sub { font-family: var(--font-ui); font-size: 1rem; opacity: 0.8; max-width: 600px; }

  /* ── Grid ── */
  .legend-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
    padding-block: 3rem;
  }

  /* ── Kort ── */
  .legend-card { background: white; border: 1px solid var(--cream-dark); border-radius: 8px; overflow: hidden; transition: box-shadow 150ms, border-color 150ms; }
  .legend-card:hover { box-shadow: 0 4px 20px rgba(26,18,8,0.1); border-color: var(--gold); }

  .legend-link { display: flex; flex-direction: column; text-decoration: none; color: var(--ink); height: 100%; }

  .legend-img { width: 100%; aspect-ratio: 16/9; overflow: hidden; background: var(--burgundy-dk); flex-shrink: 0; }
  .legend-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 300ms; }
  .legend-card:hover .legend-img img { transform: scale(1.03); }
  .legend-img-placeholder { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; font-size: 3rem; background: linear-gradient(160deg, var(--burgundy-dk), #2a1208); }

  .legend-body { padding: 1.25rem 1.25rem 1rem; flex: 1; display: flex; flex-direction: column; gap: 0.4rem; }
  .legend-title { font-family: var(--font-display); font-size: 1.1rem; color: var(--burgundy); line-height: 1.3; }
  .legend-years { font-family: var(--font-ui); font-size: 0.75rem; color: var(--gold-dark); font-weight: 600; letter-spacing: 0.05em; }
  .legend-excerpt { font-family: var(--font-body); font-size: 0.875rem; color: #555; line-height: 1.6; margin-top: 0.25rem; }
  .legend-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: auto; padding-top: 0.75rem; }
  .legend-tag { font-family: var(--font-ui); font-size: 0.65rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--burgundy); background: var(--cream); border: 1px solid rgba(107,15,26,0.15); padding: 0.2em 0.6em; border-radius: 3px; }

  .legend-arrow { display: none; }

  /* ── Tomt ── */
  .empty-state { padding: 4rem 0; text-align: center; font-family: var(--font-ui); color: var(--grey); }

  /* ── Navigasjon ── */
  .page-nav { display: flex; flex-wrap: wrap; gap: 0.75rem; padding: 1.5rem 0 3rem; font-family: var(--font-ui); font-size: 0.875rem; }
  .page-nav a { color: var(--grey); text-decoration: none; border: 1px solid var(--cream-dark); padding: 0.4rem 1rem; border-radius: var(--radius); transition: color 150ms, border-color 150ms; }
  .page-nav a:hover { color: var(--burgundy); border-color: var(--gold); }

  @media (max-width: 560px) {
    .legend-grid { grid-template-columns: 1fr; gap: 1rem; padding-block: 1.5rem; }
  }
</style>
