---
// src/pages/tryllehistorie/historiske-opptak/index.astro
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { sanityClient } from '../../../lib/sanity'

const clips = await sanityClient.fetch(`
  *[_type == "historicalClip"] | order(year asc) {
    _id,
    "slug": slug.current,
    title, year, broadcaster, show, category,
    featuredImage { asset->{ url }, alt },
    magician-> {
      _id, name, "slug": slug.current,
      artistName, nationality,
      mainImage { asset->{ url }, alt }
    }
  }
`)

const broadcasters = [...new Set(clips.map((c: any) => c.broadcaster))].filter(Boolean).sort()
const magicians    = [...new Set(clips.map((c: any) => c.magician?.artistName ?? c.magician?.name))].filter(Boolean).sort()
const total        = clips.length

const categoryLabels: Record<string, string> = {
  tv_show:      'TV-opptreden',
  entertainment:'Underholdningsprogram',
  children:     'Barneprogram',
  news:         'Nyheter / reportasje',
  competition:  'Mesterskap',
  historical:   'Historisk begivenhet',
  show:         'Konsert / show',
}

const broadcasterLabels: Record<string, string> = {
  nrk:        'NRK',
  tv2:        'TV 2',
  filmavisen: 'Filmavisen',
  annet:      'Annet',
  ukjent:     'Ukjent',
}
---

<BaseLayout
  title="Historiske TV-opptak — Norsk tryllekunst — Tryllemuseet"
  description={`${total} historiske TV-opptak av norske tryllekunstnere fra NRK, Filmavisen og andre arkiver.`}
>

  <section class="hero">
    <div class="container">
      <p class="section-label"><a href="/tryllehistorie" class="breadcrumb-link">Tryllehistorie</a></p>
      <h1 class="display-title hero-title">Historiske TV-opptak</h1>
      <p class="hero-sub">
        {total} opptak fra NRK, Filmavisen og private arkiver — norsk tryllekunst
        dokumentert på film fra 1955 til i dag.
      </p>
      <p class="hero-credit">
        Mange opptak er digitalisert og bevart av <strong>Egil «Egelo» Berg</strong>
        via <a href="https://www.youtube.com/@Egelosvideosamling" target="_blank" rel="noopener" class="hero-link">@Egelosvideosamling</a>.
      </p>
    </div>
  </section>

  <div class="filter-bar-wrap">
    <div class="container filter-bar-inner">
      <div class="filter-group">
        <label class="filter-label" for="filter-broadcaster">Kanal</label>
        <select id="filter-broadcaster" class="filter-select">
          <option value="">Alle kanaler</option>
          {broadcasters.map((b: string) => (
            <option value={b}>{broadcasterLabels[b] ?? b}</option>
          ))}
        </select>
      </div>
      <div class="filter-group">
        <label class="filter-label" for="filter-magician">Magiker</label>
        <select id="filter-magician" class="filter-select">
          <option value="">Alle magikere</option>
          {magicians.map((m: string) => <option value={m}>{m}</option>)}
        </select>
      </div>
      <button class="filter-reset" id="filter-reset">Nullstill</button>
    </div>
  </div>

  <div class="container">
    <p class="result-count" id="result-count">Viser {total} opptak</p>
  </div>

  <main class="container appearances-grid" id="clips-grid">
    {clips.map((c: any) => (
      <article
        class="appearance-card"
        data-broadcaster={c.broadcaster ?? ''}
        data-magician={c.magician?.artistName ?? c.magician?.name ?? ''}
      >
        <a href={`/tryllehistorie/historiske-opptak/${c.slug}`} class="card-link">
          <div class="card-img">
            {c.featuredImage?.asset?.url ? (
              <img src={c.featuredImage.asset.url} alt={c.featuredImage.alt ?? ''} loading="lazy" />
            ) : c.magician?.mainImage?.asset?.url ? (
              <img src={c.magician.mainImage.asset.url} alt="" loading="lazy" />
            ) : (
              <div class="card-img-placeholder" aria-hidden="true">📼</div>
            )}
            <div class="card-img-overlay" aria-hidden="true"></div>
            {c.year && <span class="card-year-badge">{c.year}</span>}
          </div>
          <div class="card-body">
            <p class="card-meta">
              {c.broadcaster && <span>{broadcasterLabels[c.broadcaster] ?? c.broadcaster}</span>}
              {c.category && <span class="card-cat">{categoryLabels[c.category] ?? c.category}</span>}
            </p>
            <h2 class="card-title">{c.title}</h2>
            {c.magician && (
              <p class="card-magician">{c.magician.artistName ?? c.magician.name}</p>
            )}
            <span class="card-arrow" aria-hidden="true">Se opptak →</span>
          </div>
        </a>
      </article>
    ))}
  </main>

  <div class="container no-results" id="no-results" hidden>
    <p>Ingen opptak matcher filteret.</p>
    <button class="filter-reset-inline" id="filter-reset-2">Nullstill filter</button>
  </div>

  <div class="container page-nav">
    <a href="/tryllehistorie/got-talent">Got Talent →</a>
    <a href="/tryllehistorie/fool-us">Fool Us →</a>
    <a href="/tryllehistorie">← Tryllehistorie</a>
  </div>

</BaseLayout>

<script>
  const rows     = Array.from(document.querySelectorAll<HTMLElement>('.clip-row'))
  const noRes    = document.getElementById('no-results')!
  const countEl  = document.getElementById('result-count')!
  const selBcast = document.getElementById('filter-broadcaster') as HTMLSelectElement
  const selMag   = document.getElementById('filter-magician')    as HTMLSelectElement
  const btnReset = document.getElementById('filter-reset')!
  const btnReset2= document.getElementById('filter-reset-2')!

  function applyFilters() {
    const bc = selBcast.value, mag = selMag.value
    let visible = 0
    rows.forEach(row => {
      const match =
        (!bc  || row.dataset.broadcaster === bc) &&
        (!mag || row.dataset.magician    === mag)
      row.hidden = !match
      if (match) visible++
    })
    noRes.hidden = visible > 0
    countEl.textContent = `Viser ${visible} opptak`
  }
  function resetFilters() { selBcast.value = ''; selMag.value = ''; applyFilters() }
  selBcast.addEventListener('change', applyFilters)
  selMag.addEventListener('change', applyFilters)
  btnReset.addEventListener('click', resetFilters)
  btnReset2.addEventListener('click', resetFilters)
</script>

<style>
  .hero { background: var(--burgundy-dk); padding: 3.5rem 0 2.5rem; border-bottom: 2px solid var(--gold-dark); color: var(--cream); }
  .breadcrumb-link { color: var(--gold); text-decoration: none; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; }
  .hero-title { font-size: clamp(1.8rem, 5vw, 3rem); color: var(--cream); margin: 0.5rem 0 0.75rem; }
  .hero-sub { font-family: var(--font-ui); font-size: 1rem; opacity: 0.8; max-width: 600px; margin-bottom: 0.5rem; }
  .hero-credit { font-family: var(--font-ui); font-size: 0.85rem; opacity: 0.65; }
  .hero-credit strong { color: var(--gold-light); opacity: 1; font-weight: 600; }
  .hero-link { color: var(--gold-light); }

  .filter-bar-wrap { position: sticky; top: var(--header-h); z-index: 50; background: white; border-bottom: 1px solid var(--cream-dark); box-shadow: 0 2px 12px rgba(26,18,8,0.06); }
  .filter-bar-inner { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: flex-end; padding: 0.75rem 1.5rem; }
  .filter-group { display: flex; flex-direction: column; gap: 0.2rem; }
  .filter-label { font-family: var(--font-ui); font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--grey); }
  .filter-select { font-family: var(--font-ui); font-size: 0.875rem; color: var(--ink); background: var(--cream); border: 1.5px solid var(--cream-dark); border-radius: 6px; padding: 0.45rem 0.75rem; cursor: pointer; min-width: 180px; }
  .filter-reset { font-family: var(--font-ui); font-size: 0.8rem; font-weight: 600; color: var(--grey); border: 1.5px solid var(--cream-dark); border-radius: 6px; padding: 0.45rem 0.9rem; background: white; cursor: pointer; align-self: flex-end; }
  .filter-reset:hover { color: var(--burgundy); border-color: var(--gold); }

  .result-count { font-family: var(--font-ui); font-size: 0.8rem; color: var(--grey); padding: 0.75rem 0 0.25rem; }

  .appearances-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.5rem; padding-bottom: 1rem; }
  .appearance-card { border-radius: 6px; overflow: hidden; border: 1px solid var(--cream-dark); background: white; transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease; }
  .appearance-card:hover { transform: translateY(-4px); box-shadow: 0 8px 28px rgba(107,15,26,0.14); border-color: var(--gold-light); }
  .card-link { display: flex; flex-direction: column; text-decoration: none; color: var(--ink); height: 100%; }

  .card-img { position: relative; aspect-ratio: 3/2; overflow: hidden; background: var(--burgundy-dk); flex-shrink: 0; }
  .card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 400ms ease; }
  .appearance-card:hover .card-img img { transform: scale(1.04); }
  .card-img-placeholder { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; font-size: 3rem; background: linear-gradient(160deg, var(--burgundy-dk), #2a1208); }
  .card-img-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 50%, rgba(26,18,8,0.5) 100%); pointer-events: none; }
  .card-year-badge { position: absolute; top: 0.6rem; right: 0.6rem; font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.06em; padding: 0.2rem 0.5rem; border-radius: 3px; background: rgba(26,18,8,0.75); color: var(--gold-light); backdrop-filter: blur(4px); }

  .card-body { padding: 1rem 1.1rem 1.2rem; display: flex; flex-direction: column; gap: 0.15rem; flex: 1; }
  .card-meta { font-family: var(--font-ui); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gold-dark); display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .card-cat { font-weight: 400; font-style: italic; color: var(--grey); text-transform: none; letter-spacing: 0; }
  .card-title { font-family: var(--font-display); font-size: 1rem; color: var(--burgundy); letter-spacing: 0.02em; line-height: 1.25; }
  .card-magician { font-family: var(--font-ui); font-size: 0.75rem; color: var(--grey); }
  .card-arrow { font-family: var(--font-ui); font-size: 0.72rem; font-weight: 700; color: var(--gold-dark); margin-top: auto; padding-top: 0.6rem; opacity: 0; transition: opacity 180ms; }
  .appearance-card:hover .card-arrow { opacity: 1; }

  .no-results { padding: 3rem 0; text-align: center; font-family: var(--font-ui); color: var(--ink-mid); }
  .filter-reset-inline { margin-top: 0.75rem; font-family: var(--font-ui); font-size: 0.875rem; font-weight: 600; color: var(--burgundy); background: none; border: 1px solid var(--gold-dark); border-radius: 6px; padding: 0.45rem 1rem; cursor: pointer; }

  .page-nav { display: flex; flex-wrap: wrap; gap: 0.75rem; padding: 1.5rem 0 3rem; font-family: var(--font-ui); font-size: 0.875rem; }
  .page-nav a { color: var(--grey); text-decoration: none; border: 1px solid var(--cream-dark); padding: 0.4rem 1rem; border-radius: var(--radius); transition: color 150ms, border-color 150ms; }
  .page-nav a:hover { color: var(--burgundy); border-color: var(--gold); }

  @media (max-width: 700px) { .appearances-grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 1rem; } }
</style>
