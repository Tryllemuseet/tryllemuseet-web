---
// src/pages/tryllehistorie/historiske-opptak/[slug].astro
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { getHistoricalClipPaths, getHistoricalClipBySlug, getOtherHistoricalClips, portableTextToHtml } from '../../../lib/sanity'

export async function getStaticPaths() {
  return getHistoricalClipPaths()
}

const { slug } = Astro.params

const c = await getHistoricalClipBySlug(slug!)

if (!c) return Astro.redirect('/tryllehistorie/historiske-opptak')

// Andre opptak av samme magiker
const otherClips = c.magician ? await getOtherHistoricalClips(slug!, c.magician._id) : []

function youtubeEmbedUrl(url: string): string | null {
  const m = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&?]+)/)
  return m ? `https://www.youtube-nocookie.com/embed/${m[1]}` : null
}
const embedUrl    = c.videoUrl ? youtubeEmbedUrl(c.videoUrl) : null
const embedUrlAlt = c.videoUrlAlt ? youtubeEmbedUrl(c.videoUrlAlt) : null

const broadcasterLabels: Record<string, string> = {
  nrk: 'NRK', tv2: 'TV 2', filmavisen: 'Filmavisen', annet: 'Annet', ukjent: 'Ukjent'
}

const description   = c.description ?? []
const magicianTags  = c.magician?.tags ?? []
const magicianLinks = c.magician?.links ?? []
---

<BaseLayout
  title={`${c.title}${c.year ? ` (${c.year})` : ''} — Tryllemuseet`}
  description={`${c.title}${c.year ? `, ${c.year}` : ''}${c.magician ? ` — ${c.magician.artistName ?? c.magician.name}` : ''}.`}
>

  <nav class="breadcrumb container">
    <a href="/tryllehistorie">Tryllehistorie</a>
    <span>›</span>
    <a href="/tryllehistorie/historiske-opptak">Historiske opptak</a>
    <span>›</span>
    <span aria-current="page">{c.title}</span>
  </nav>

  <section class="detail-hero">
    {(c.featuredImage?.asset?.url || c.magician?.mainImage?.asset?.url) && (
      <div class="hero-img-wrap">
        <img src={c.featuredImage?.asset?.url ?? c.magician?.mainImage?.asset?.url} alt="" class="hero-img" />
        <div class="hero-img-overlay"></div>
      </div>
    )}
    <div class="container hero-content">
      <p class="section-label hero-section">Historiske TV-opptak</p>
      <h1 class="display-title hero-title">{c.title}</h1>
      <div class="hero-meta">
        {c.year && <span class="meta-year">{c.year}</span>}
        {c.broadcaster && <span class="meta-item">{broadcasterLabels[c.broadcaster] ?? c.broadcaster}</span>}
        {c.show && <span class="meta-item">{c.show}</span>}
      </div>
    </div>
  </section>

  <div class="container detail-body">
    <div class="detail-main">

      {description.length > 0 && (
        <section class="detail-section">
          <h2 class="detail-heading">Om opptaket</h2>
          <div class="prose" set:html={portableTextToHtml(description)} />
        </section>
      )}

      {embedUrl && (
        <section class="detail-section">
          <h2 class="detail-heading">Se opptaket</h2>
          <div class="video-wrap">
            <iframe src={embedUrl} title={c.title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen loading="lazy"></iframe>
          </div>
          {c.featuredImage?.caption && (
            <p class="video-caption">{c.featuredImage.caption}</p>
          )}
        </section>
      )}

      {embedUrlAlt && (
        <section class="detail-section">
          <h2 class="detail-heading">Alternativt opptak</h2>
          <div class="video-wrap">
            <iframe src={embedUrlAlt} title={`${c.title} (alternativ)`}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen loading="lazy"></iframe>
          </div>
        </section>
      )}

      {!embedUrl && c.videoUrl && (
        <section class="detail-section">
          <a href={c.videoUrl} class="video-link" target="_blank" rel="noopener">▶ Se opptaket ↗</a>
        </section>
      )}

      {c.source && (
        <section class="detail-section">
          <h2 class="detail-heading">Kilde</h2>
          <p class="source-text">
            {c.source.startsWith('http') ? (
              <a href={c.source} target="_blank" rel="noopener" class="source-link">{c.source} ↗</a>
            ) : c.source}
          </p>
        </section>
      )}

      {otherClips.length > 0 && (
        <section class="detail-section">
          <h2 class="detail-heading">
            Andre opptak av {c.magician?.artistName ?? c.magician?.name}
          </h2>
          <ul class="other-list">
            {otherClips.map((o: any) => (
              <li>
                <a href={`/tryllehistorie/historiske-opptak/${o.slug}`} class="other-link">
                  <span class="other-title">{o.title}</span>
                  {o.year && <span class="other-year">{o.year}</span>}
                  <span class="other-arrow">→</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>

    <aside class="detail-sidebar">
      {c.magician && (
        <>
          {c.magician.mainImage?.asset?.url && (
            <div class="sidebar-img-wrap">
              <img src={c.magician.mainImage.asset.url} alt={c.magician.mainImage.alt ?? c.magician.name} class="sidebar-img" />
            </div>
          )}
          <div class="sidebar-card">
            <h2 class="sidebar-name">{c.magician.artistName ?? c.magician.name}</h2>
            {c.magician.artistName && c.magician.name !== c.magician.artistName && (
              <p class="sidebar-fullname">{c.magician.name}</p>
            )}
            {c.magician.nationality && (
              <p class="sidebar-meta">{c.magician.nationality}{c.magician?.years ? ` · ${c.magician.years}` : ''}</p>
            )}
            {c.magician.shortBio && <p class="sidebar-bio">{c.magician.shortBio}</p>}
            {magicianTags.length > 0 && (
              <div class="sidebar-tags">
                {magicianTags.map((tag: string) => <span class="sidebar-tag">{tag}</span>)}
              </div>
            )}
            {magicianLinks.length > 0 && (
              <ul class="sidebar-links">
                {magicianLinks.filter((l: any) => l.url).map((link: any) => (
                  <li>
                    <a href={link.url} class="sidebar-link" target="_blank" rel="noopener">
                      {link.label} ↗
                    </a>
                  </li>
                ))}
              </ul>
            )}
            <a href={`/tryllehistorie/magiens-hvem-er-hvem/${c.magician.slug}`} class="sidebar-profile-link">
              Se full profil →
            </a>
          </div>
        </>
      )}

      {!c.magician && (
        <div class="sidebar-card sidebar-card--neutral">
          <p class="sidebar-bio">Dette opptaket er knyttet til en historisk begivenhet uten én navngitt utøver.</p>
        </div>
      )}
    </aside>
  </div>

  <div class="container back-nav">
    <a href="/tryllehistorie/historiske-opptak">← Tilbake til historiske opptak</a>
  </div>

</BaseLayout>

<style>
  .breadcrumb { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; padding-top: 1rem; font-family: var(--font-ui); font-size: 0.78rem; color: var(--grey); }
  .breadcrumb a { color: var(--grey); text-decoration: none; } .breadcrumb a:hover { color: var(--burgundy); }
  .breadcrumb span[aria-current] { color: var(--ink-mid); }

  .detail-hero { position: relative; background: var(--burgundy-dk); color: var(--cream); padding: 3rem 0 2.5rem; border-bottom: 2px solid var(--gold-dark); overflow: hidden; }
  .hero-img-wrap { position: absolute; inset: 0; z-index: 0; }
  .hero-img { width: 100%; height: 100%; object-fit: cover; object-position: center; opacity: 0.2; }
  .hero-img-overlay { position: absolute; inset: 0; background: linear-gradient(to right, var(--burgundy-dk) 40%, transparent 100%); }
  .hero-content { position: relative; z-index: 1; max-width: 680px; }
  .hero-section { color: var(--gold); margin-bottom: 0.5rem; }
  .hero-title { font-size: clamp(1.5rem, 4vw, 2.5rem); color: var(--cream); margin-bottom: 0.75rem; line-height: 1.2; }
  .hero-meta { display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem; }
  .meta-year { font-family: var(--font-display); font-size: 1.1rem; color: var(--gold); letter-spacing: 0.06em; }
  .meta-item { font-family: var(--font-ui); font-size: 0.8rem; color: var(--cream); opacity: 0.7; }

  .detail-body { display: grid; grid-template-columns: 1fr 300px; gap: 3rem; padding-top: 2.5rem; padding-bottom: 4rem; align-items: start; }
  .detail-section { margin-bottom: 2.5rem; }
  .detail-heading { font-family: var(--font-display); font-size: 1.1rem; color: var(--burgundy); letter-spacing: 0.04em; margin-bottom: 1rem; padding-bottom: 0.4rem; border-bottom: 1px solid var(--cream-dark); }
  .prose { font-family: var(--font-body); font-size: 1rem; line-height: 1.75; color: var(--ink-mid); }
  .prose p { margin-bottom: 0.75rem; }

  .video-wrap { position: relative; aspect-ratio: 16/9; border-radius: 6px; overflow: hidden; background: var(--burgundy-dk); }
  .video-wrap iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: none; }
  .video-caption { font-family: var(--font-ui); font-size: 0.8rem; color: var(--grey); font-style: italic; margin-top: 0.5rem; }
  .video-link { display: inline-flex; align-items: center; gap: 0.4rem; font-family: var(--font-ui); font-size: 0.9rem; font-weight: 600; color: var(--burgundy); border: 1.5px solid var(--gold-dark); padding: 0.6rem 1.25rem; border-radius: 6px; text-decoration: none; }

  .source-text { font-family: var(--font-ui); font-size: 0.875rem; color: var(--ink-mid); }
  .source-link { color: var(--burgundy); }

  .other-list { list-style: none; display: flex; flex-direction: column; gap: 1px; background: var(--cream-dark); border: 1px solid var(--cream-dark); border-radius: 6px; overflow: hidden; }
  .other-link { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; background: white; text-decoration: none; color: var(--ink); font-family: var(--font-ui); font-size: 0.875rem; transition: background 150ms; }
  .other-link:hover { background: var(--cream); }
  .other-title { flex: 1; color: var(--burgundy); font-weight: 600; }
  .other-year { color: var(--grey); font-size: 0.8rem; }
  .other-arrow { color: var(--gold-dark); margin-left: auto; }

  .sidebar-img-wrap { border-radius: 6px; overflow: hidden; aspect-ratio: 3/4; margin-bottom: 1rem; }
  .sidebar-img { width: 100%; height: 100%; object-fit: cover; }
  .sidebar-card { background: white; border: 1px solid var(--cream-dark); border-radius: 6px; padding: 1.25rem; }
  .sidebar-card--neutral { opacity: 0.7; }
  .sidebar-name { font-family: var(--font-display); font-size: 1.1rem; color: var(--burgundy); letter-spacing: 0.03em; margin-bottom: 0.15rem; }
  .sidebar-fullname { font-family: var(--font-ui); font-size: 0.8rem; color: var(--grey); font-style: italic; }
  .sidebar-meta { font-family: var(--font-ui); font-size: 0.8rem; color: var(--grey); margin-bottom: 0.75rem; }
  .sidebar-bio { font-family: var(--font-body); font-size: 0.875rem; color: var(--ink-mid); line-height: 1.6; margin-bottom: 0.75rem; }
  .sidebar-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-bottom: 1rem; }
  .sidebar-tag { font-family: var(--font-ui); font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; background: var(--cream-dark); color: var(--ink-mid); padding: 0.1rem 0.4rem; border-radius: 2px; }
  .sidebar-links { list-style: none; display: flex; flex-direction: column; gap: 0.25rem; margin-bottom: 1rem; border-top: 1px solid var(--cream-dark); padding-top: 0.75rem; }
  .sidebar-link { font-family: var(--font-ui); font-size: 0.8rem; color: var(--burgundy); text-decoration: none; }
  .sidebar-link:hover { color: var(--gold-dark); }
  .sidebar-profile-link { display: block; text-align: center; font-family: var(--font-ui); font-size: 0.8rem; font-weight: 600; color: var(--cream); background: var(--burgundy); padding: 0.6rem 1rem; border-radius: 4px; text-decoration: none; margin-top: 0.5rem; }
  .sidebar-profile-link:hover { background: var(--burgundy-dk); }

  .back-nav { padding: 0 0 3rem; font-family: var(--font-ui); font-size: 0.875rem; }
  .back-nav a { color: var(--grey); text-decoration: none; border: 1px solid var(--cream-dark); padding: 0.4rem 1rem; border-radius: var(--radius); }
  .back-nav a:hover { color: var(--burgundy); border-color: var(--gold); }

  @media (max-width: 900px) {
    .detail-body { grid-template-columns: 1fr; gap: 2rem; }
    .detail-sidebar { order: -1; display: grid; grid-template-columns: 160px 1fr; gap: 1rem; }
    .sidebar-img-wrap { margin-bottom: 0; }
  }
  @media (max-width: 560px) {
    .detail-sidebar { grid-template-columns: 1fr; }
    .sidebar-img-wrap { display: none; }
  }
</style>
