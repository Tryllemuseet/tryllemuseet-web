---
// src/pages/tryllehistorie/historiske-artikler/index.astro
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { getHistoriskKlippArchive } from '../../../lib/sanity'
import MentionedMagicians from '../../../components/MentionedMagicians.astro'
import type { HistoriskKlippNb } from '../../../lib/sanity'

const clippings = await getHistoriskKlippArchive()
const total     = clippings.length

const categoryLabels: Record<string, string> = {
  artist:       'Artist / tryllekunstner',
  forestilling: 'Forestilling',
  presseomtale: 'Presseomtale',
  annonse:      'Annonse',
  kuriosa:      'Kuriosa',
  annet:        'Annet',
}

const categories = [...new Set(clippings.map((c: HistoriskKlippNb) => c.category))]
  .filter(Boolean).sort() as string[]

const sources = [...new Set(clippings.map((c: HistoriskKlippNb) => c.sourceName))]
  .filter(Boolean).sort() as string[]

function getDecade(dateStr?: string): string {
  if (!dateStr) return ''
  return String(Math.floor(new Date(dateStr).getFullYear() / 10) * 10)
}

const decades = [...new Set(clippings.map((c: HistoriskKlippNb) => getDecade(c.originalDate)))]
  .filter(Boolean).sort() as string[]

function formatDate(dateStr?: string): string {
  if (!dateStr) return ''
  return new Date(dateStr).toLocaleDateString('nb-NO', { day: 'numeric', month: 'long', year: 'numeric' })
}

const modalDataRaw = clippings.map((c: HistoriskKlippNb) => ({
  id:          c._id,
  title:       c.title,
  originalKicker:    c.originalKicker ?? null,
  originalMainTitle: c.originalMainTitle ?? null,
  originalIngress:   c.originalIngress ?? null,
  originalDate: c.originalDate ?? null,
  sourceName:  c.sourceName ?? null,
  sourceUrl:   c.sourceUrl,
  // Images are already copyright-gated in the GROQ projection (70-year rule
  // or editor override) — an empty array means "show no facsimile", never
  // fall back to anything.
  images:      (c.images ?? [])
    .filter(img => img.asset?.url)
    .map(img => ({
      url:     img.asset.url,
      alt:     img.alt ?? c.title,
      caption: img.caption ?? null,
    })),
  teaser:      c.teaser,
  rewrittenText: c.rewrittenText ?? null,
  commentary:  c.commentary ?? null,
  category:    c.category ?? null,
  magicians:   (c.mentionedMagicians ?? []).map(m => ({
    name: m.artistName ?? m.name,
    slug: m.slug,
  })),
}))

const escapedJson = JSON.stringify(modalDataRaw)
  .replace(/<\/script>/gi, '<\\/script>')
  .replace(/<!--/g, '<\\!--')
---

<BaseLayout
  title="Historiske avisartikler — Tryllemuseet"
  description={`${total} historiske avisartikler om norsk tryllekunst fra Nasjonalbibliotekets digitaliserte aviser.`}
>

  <section class="hero">
    <div class="container">
      <p class="section-label"><a href="/tryllehistorie" class="breadcrumb-link">Tryllehistorie</a></p>
      <h1 class="display-title hero-title">Historiske avisartikler</h1>
      <p class="hero-sub">
        {total} artikler fra norske aviser om tryllekunst — digitalisert og bevart av
        <a href="https://www.nb.no" target="_blank" rel="noopener" class="hero-link">Nasjonalbiblioteket</a>.
      </p>
    </div>
  </section>

  <!-- ── Filter bar ──────────────────────────────────────────────── -->
  <div class="filter-bar-wrap">
    <div class="container filter-bar-inner">

      <div class="filter-search-group">
        <label class="filter-label" for="filter-search">Søk</label>
        <div class="search-wrap">
          <svg class="search-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true" width="14" height="14">
            <circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.75"/>
            <path d="M13 13l3.5 3.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
          </svg>
          <input
            id="filter-search"
            type="search"
            class="filter-search"
            placeholder="Tittel, kilde, innhold …"
            autocomplete="off"
            spellcheck="false"
          />
        </div>
      </div>

      <div class="filter-group">
        <label class="filter-label" for="filter-category">Kategori</label>
        <select id="filter-category" class="filter-select">
          <option value="">Alle kategorier</option>
          {categories.map((cat) => (
            <option value={cat}>{categoryLabels[cat] ?? cat}</option>
          ))}
        </select>
      </div>

      {sources.length > 1 && (
        <div class="filter-group">
          <label class="filter-label" for="filter-source">Avis / kilde</label>
          <select id="filter-source" class="filter-select">
            <option value="">Alle aviser</option>
            {sources.map((src) => (
              <option value={src}>{src}</option>
            ))}
          </select>
        </div>
      )}

      {decades.length > 1 && (
        <div class="filter-group">
          <label class="filter-label" for="filter-decade">Tiår</label>
          <select id="filter-decade" class="filter-select">
            <option value="">Alle tiår</option>
            {decades.map((d) => (
              <option value={d}>{d}-tallet</option>
            ))}
          </select>
        </div>
      )}

      <button class="filter-reset" id="filter-reset" aria-label="Nullstill alle filtre">Nullstill</button>
    </div>
  </div>

  <div class="container result-bar">
    <p class="result-count" id="result-count">Viser {total} artikler</p>
  </div>

  <!-- ── Article grid ────────────────────────────────────────────── -->
  <div class="container articles-grid" id="articles-grid">
    {clippings.map((c: HistoriskKlippNb) => (
      <article
        class="article-card"
        data-id={c._id}
        data-category={c.category ?? ''}
        data-source={c.sourceName ?? ''}
        data-decade={getDecade(c.originalDate)}
        data-search={[c.title, c.teaser, c.sourceName, c.commentary].filter(Boolean).join(' ').toLowerCase()}
      >
        <div class="card-img">
          {c.images?.[0]?.asset?.url ? (
            <img src={c.images[0].asset.url} alt={c.images[0].alt ?? c.title} loading="lazy" />
          ) : (
            <div class="card-img-placeholder" aria-hidden="true">📰</div>
          )}
          {c.category && (
            <span class="card-cat-badge">{categoryLabels[c.category] ?? c.category}</span>
          )}
        </div>
        <div class="card-body">
          <p class="card-meta">
            {c.sourceName && <span class="card-source">{c.sourceName}</span>}
            {c.originalDate && <span class="card-date">{formatDate(c.originalDate)}</span>}
          </p>
          <h2 class="card-title">{c.title}</h2>
          <p class="card-teaser">{c.teaser}</p>
          {c.commentary && <p class="card-commentary">{c.commentary}</p>}
          <MentionedMagicians magicians={c.mentionedMagicians} />
          <button class="card-open-btn" data-id={c._id} aria-label={`Les mer om «${c.title}»`}>
            Les mer →
          </button>
        </div>
      </article>
    ))}
  </div>

  {total === 0 && (
    <div class="container empty-state">
      <p>Ingen artikler publisert ennå.</p>
    </div>
  )}

  <div class="container no-results" id="no-results" hidden>
    <p>Ingen artikler matcher søket.</p>
    <button class="filter-reset-inline" id="filter-reset-2">Nullstill filter</button>
  </div>

  <!-- ── Article detail modal ────────────────────────────────────── -->
  <dialog id="article-modal" class="article-modal">
    <div class="modal-inner">

      <div class="modal-topbar">
        <div class="modal-topbar-meta">
          <span class="modal-cat-badge" id="modal-cat-badge" hidden></span>
          <span class="modal-source-meta" id="modal-source-meta"></span>
        </div>
        <button class="modal-close" id="modal-close" aria-label="Lukk">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" aria-hidden="true">
            <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <div class="modal-scroll">

        <h2 class="modal-title" id="modal-title"></h2>

        <div class="modal-original-title" id="modal-original-title" hidden>
          <span class="modal-original-label">Slik sto det i avisen</span>
          <p class="modal-original-kicker" id="modal-original-kicker" hidden></p>
          <p class="modal-original-main" id="modal-original-main" hidden></p>
          <p class="modal-original-ingress" id="modal-original-ingress" hidden></p>
        </div>

        <div class="modal-gallery" id="modal-gallery" hidden></div>

        <p class="modal-teaser" id="modal-teaser"></p>

        <div class="modal-body-text" id="modal-body-text" hidden></div>

        <blockquote class="modal-commentary" id="modal-commentary" hidden></blockquote>

        <div class="modal-magicians" id="modal-magicians" hidden>
          <span class="modal-magicians-label">Omtalt:</span>
          <span id="modal-magicians-list"></span>
        </div>

        <div class="modal-nb-section">
          <div class="modal-nb-actions">
            <a
              class="btn-nb-external"
              id="modal-nb-link"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg viewBox="0 0 20 20" width="14" height="14" fill="none" aria-hidden="true">
                <path d="M11 3h6v6M17 3l-8 8M8 5H4a1 1 0 00-1 1v10a1 1 0 001 1h10a1 1 0 001-1v-4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Åpne hos Nasjonalbiblioteket
            </a>
            <button class="btn-nb-embed" id="modal-iframe-btn">
              <svg viewBox="0 0 20 20" width="14" height="14" fill="none" aria-hidden="true">
                <rect x="2" y="4" width="16" height="12" rx="1.5" stroke="currentColor" stroke-width="1.75"/>
                <path d="M7 8l-3 2 3 2M13 8l3 2-3 2" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Vis innebygd leser
            </button>
          </div>
          <div class="modal-iframe-wrap" id="modal-iframe-wrap" hidden>
            <div class="modal-iframe-loading" id="modal-iframe-loading">
              <span class="spinner" aria-hidden="true"></span>
              Laster Nasjonalbibliotekets leser …
            </div>
            <iframe
              id="modal-iframe"
              title="Nasjonalbiblioteket — avisleser"
              sandbox="allow-scripts allow-same-origin allow-popups allow-forms"
            ></iframe>
          </div>
        </div>

      </div>
    </div>
  </dialog>

  <div class="container page-nav">
    <a href="/tryllehistorie/fordypninger">Fordypninger →</a>
    <a href="/tryllehistorie">← Tryllehistorie</a>
  </div>

  <script type="application/json" id="modal-data" set:html={escapedJson}></script>

</BaseLayout>

<script>
  // ── Types ──────────────────────────────────────────────────────────
  interface ModalImage {
    url: string
    alt: string
    caption: string | null
  }

  interface ModalClipping {
    id: string
    title: string
    originalKicker: string | null
    originalMainTitle: string | null
    originalIngress: string | null
    originalDate: string | null
    sourceName: string | null
    sourceUrl: string
    images: ModalImage[]
    teaser: string
    rewrittenText: string | null
    commentary: string | null
    category: string | null
    magicians: { name: string; slug: string }[]
  }

  // ── Data ──────────────────────────────────────────────────────────
  const allClippings: ModalClipping[] = JSON.parse(
    document.getElementById('modal-data')?.textContent ?? '[]'
  )
  const byId = new Map(allClippings.map(c => [c.id, c]))

  const CAT_LABELS: Record<string, string> = {
    artist:       'Artist / tryllekunstner',
    forestilling: 'Forestilling',
    presseomtale: 'Presseomtale',
    annonse:      'Annonse',
    kuriosa:      'Kuriosa',
    annet:        'Annet',
  }

  // ── Filter refs ───────────────────────────────────────────────────
  const rows        = Array.from(document.querySelectorAll<HTMLElement>('.article-card'))
  const noRes       = document.getElementById('no-results')!
  const countEl     = document.getElementById('result-count')!
  const inputSearch = document.getElementById('filter-search')  as HTMLInputElement
  const selCat      = document.getElementById('filter-category') as HTMLSelectElement
  const selSource   = document.getElementById('filter-source')   as HTMLSelectElement | null
  const selDecade   = document.getElementById('filter-decade')   as HTMLSelectElement | null
  const btnReset    = document.getElementById('filter-reset')!
  const btnReset2   = document.getElementById('filter-reset-2')!

  // ── Filtering ─────────────────────────────────────────────────────
  function applyFilters() {
    const query  = inputSearch.value.trim().toLowerCase()
    const cat    = selCat.value
    const src    = selSource?.value ?? ''
    const decade = selDecade?.value ?? ''
    let visible  = 0
    rows.forEach(row => {
      const match =
        (!cat    || row.dataset.category === cat)    &&
        (!src    || row.dataset.source   === src)    &&
        (!decade || row.dataset.decade   === decade) &&
        (!query  || (row.dataset.search  ?? '').includes(query))
      row.hidden = !match
      if (match) visible++
    })
    noRes.hidden = visible > 0
    countEl.textContent = `Viser ${visible} artikler`
  }

  function resetFilters() {
    inputSearch.value = ''
    selCat.value = ''
    if (selSource) selSource.value = ''
    if (selDecade) selDecade.value = ''
    applyFilters()
  }

  inputSearch.addEventListener('input', applyFilters)
  selCat.addEventListener('change', applyFilters)
  selSource?.addEventListener('change', applyFilters)
  selDecade?.addEventListener('change', applyFilters)
  btnReset.addEventListener('click', resetFilters)
  btnReset2.addEventListener('click', resetFilters)

  // ── Modal refs ────────────────────────────────────────────────────
  const modal           = document.getElementById('article-modal') as HTMLDialogElement
  const elClose         = document.getElementById('modal-close')!
  const elCatBadge      = document.getElementById('modal-cat-badge') as HTMLElement
  const elSourceMeta    = document.getElementById('modal-source-meta')!
  const elTitle         = document.getElementById('modal-title')!
  const elOrigWrap      = document.getElementById('modal-original-title') as HTMLElement
  const elOrigKicker    = document.getElementById('modal-original-kicker') as HTMLElement
  const elOrigMain      = document.getElementById('modal-original-main') as HTMLElement
  const elOrigIngress   = document.getElementById('modal-original-ingress') as HTMLElement
  const elGallery       = document.getElementById('modal-gallery') as HTMLElement
  const elTeaser        = document.getElementById('modal-teaser')!
  const elBodyText      = document.getElementById('modal-body-text') as HTMLElement
  const elCommentary    = document.getElementById('modal-commentary') as HTMLElement
  const elMagWrap       = document.getElementById('modal-magicians') as HTMLElement
  const elMagList       = document.getElementById('modal-magicians-list')!
  const elNbLink        = document.getElementById('modal-nb-link') as HTMLAnchorElement
  const elIframeBtn     = document.getElementById('modal-iframe-btn') as HTMLButtonElement
  const elIframeWrap    = document.getElementById('modal-iframe-wrap') as HTMLElement
  const elIframeLoading = document.getElementById('modal-iframe-loading')!
  const elIframe        = document.getElementById('modal-iframe') as HTMLIFrameElement

  // ── Modal open / close ────────────────────────────────────────────
  function formatDate(s: string | null): string {
    if (!s) return ''
    return new Date(s).toLocaleDateString('nb-NO', { day: 'numeric', month: 'long', year: 'numeric' })
  }

  function openModal(id: string) {
    const c = byId.get(id)
    if (!c) return

    // Reset iframe state
    elIframe.src = ''
    elIframeWrap.hidden = true
    elIframeBtn.hidden = false
    elIframeLoading.hidden = false

    // Category badge
    if (c.category) {
      elCatBadge.textContent = CAT_LABELS[c.category] ?? c.category
      elCatBadge.removeAttribute('hidden')
    } else {
      elCatBadge.hidden = true
    }

    // Source + date meta
    elSourceMeta.textContent = [c.sourceName, formatDate(c.originalDate)].filter(Boolean).join(' · ')

    // Title
    elTitle.textContent = c.title

    // Original newspaper heading: kicker (small) → main title → ingress box
    const origParts: [HTMLElement, string | null][] = [
      [elOrigKicker,  c.originalKicker],
      [elOrigMain,    c.originalMainTitle],
      [elOrigIngress, c.originalIngress],
    ]
    let hasOriginal = false
    origParts.forEach(([el, value]) => {
      if (value) {
        el.textContent = value
        el.removeAttribute('hidden')
        hasOriginal = true
      } else {
        el.hidden = true
      }
    })
    if (hasOriginal) {
      elOrigWrap.removeAttribute('hidden')
    } else {
      elOrigWrap.hidden = true
    }

    // Facsimile gallery (safe DOM building, no innerHTML with user content)
    elGallery.innerHTML = ''
    if (c.images.length > 0) {
      elGallery.classList.toggle('is-multi', c.images.length > 1)
      c.images.forEach(imgData => {
        const fig = document.createElement('figure')
        fig.className = 'gallery-item'
        const img = document.createElement('img')
        img.src = imgData.url
        img.alt = imgData.alt
        img.loading = 'lazy'
        fig.appendChild(img)
        if (imgData.caption) {
          const cap = document.createElement('figcaption')
          cap.textContent = imgData.caption
          fig.appendChild(cap)
        }
        elGallery.appendChild(fig)
      })
      elGallery.removeAttribute('hidden')
    } else {
      elGallery.hidden = true
    }

    // Teaser
    elTeaser.textContent = c.teaser

    // Rewritten article text (editorial retelling — paragraph per blank line)
    elBodyText.innerHTML = ''
    if (c.rewrittenText) {
      c.rewrittenText
        .split(/\n\s*\n/)
        .map(p => p.trim())
        .filter(Boolean)
        .forEach(paragraph => {
          const p = document.createElement('p')
          p.textContent = paragraph
          elBodyText.appendChild(p)
        })
      elBodyText.removeAttribute('hidden')
    } else {
      elBodyText.hidden = true
    }

    // Museum commentary
    if (c.commentary) {
      elCommentary.textContent = c.commentary
      elCommentary.removeAttribute('hidden')
    } else {
      elCommentary.hidden = true
    }

    // Mentioned magicians (safe DOM building, no innerHTML with user content)
    elMagList.innerHTML = ''
    if (c.magicians.length > 0) {
      c.magicians.forEach((m, i) => {
        const a = document.createElement('a')
        a.href = `/tryllehistorie/magiens-hvem-er-hvem/${encodeURIComponent(m.slug)}`
        a.className = 'modal-magician-link'
        a.textContent = m.name
        elMagList.appendChild(a)
        if (i < c.magicians.length - 1) {
          const sep = document.createElement('span')
          sep.setAttribute('aria-hidden', 'true')
          sep.textContent = ', '
          elMagList.appendChild(sep)
        }
      })
      elMagWrap.removeAttribute('hidden')
    } else {
      elMagWrap.hidden = true
    }

    // NB external link
    elNbLink.href = c.sourceUrl

    // Scroll modal content to top, then open
    modal.querySelector<HTMLElement>('.modal-scroll')!.scrollTop = 0
    modal.showModal()
    document.body.style.overflow = 'hidden'
  }

  function closeModal() {
    modal.close()
    document.body.style.overflow = ''
    elIframe.src = ''
  }

  // ── Card click delegation ─────────────────────────────────────────
  // Whole card is clickable; links inside still navigate normally
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement
    if (target.closest('a'))              return  // let links work
    if (target.closest('#article-modal')) return  // modal handles its own events
    const card = target.closest<HTMLElement>('.article-card[data-id]')
    if (card?.dataset.id) openModal(card.dataset.id)
  })

  // ── Iframe embed toggle ───────────────────────────────────────────
  elIframeBtn.addEventListener('click', () => {
    elIframeWrap.removeAttribute('hidden')
    elIframeBtn.hidden = true
    elIframeLoading.removeAttribute('hidden')
    elIframe.src = elNbLink.href
    elIframe.addEventListener('load', () => {
      elIframeLoading.hidden = true
    }, { once: true })
  })

  // ── Close handlers ────────────────────────────────────────────────
  elClose.addEventListener('click', closeModal)
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal()   // click outside modal-inner
  })
  modal.addEventListener('cancel', closeModal)  // ESC key
</script>

<style>
  /* ── Hero ──────────────────────────────────────────────────────── */
  .hero { background: var(--burgundy-dk); padding: 3.5rem 0 2.5rem; border-bottom: 2px solid var(--gold-dark); color: var(--cream); }
  .breadcrumb-link { color: var(--gold); text-decoration: none; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; }
  .hero-title { font-size: clamp(1.8rem, 5vw, 3rem); color: var(--cream); margin: 0.5rem 0 0.75rem; }
  .hero-sub { font-family: var(--font-ui); font-size: 1rem; opacity: 0.8; max-width: 600px; }
  .hero-link { color: var(--gold-light); }

  /* ── Filter bar ────────────────────────────────────────────────── */
  .filter-bar-wrap { position: sticky; top: var(--header-h); z-index: 50; background: white; border-bottom: 1px solid var(--cream-dark); box-shadow: 0 2px 12px rgba(26,18,8,0.06); }
  .filter-bar-inner { display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; align-items: flex-end; padding: 0.75rem 1.5rem; }
  .filter-group, .filter-search-group { display: flex; flex-direction: column; gap: 0.2rem; }
  .filter-label { font-family: var(--font-ui); font-size: 0.62rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--grey); }
  .filter-select { font-family: var(--font-ui); font-size: 0.875rem; color: var(--ink); background: var(--cream); border: 1.5px solid var(--cream-dark); border-radius: 6px; padding: 0.45rem 0.75rem; cursor: pointer; min-width: 160px; }
  .filter-select:focus { outline: none; border-color: var(--gold-dark); }

  .search-wrap { position: relative; display: flex; align-items: center; }
  .search-icon { position: absolute; left: 0.65rem; color: var(--grey); pointer-events: none; flex-shrink: 0; }
  .filter-search { font-family: var(--font-ui); font-size: 0.875rem; color: var(--ink); background: var(--cream); border: 1.5px solid var(--cream-dark); border-radius: 6px; padding: 0.45rem 0.75rem 0.45rem 2.1rem; min-width: 200px; }
  .filter-search:focus { outline: none; border-color: var(--gold-dark); }
  .filter-search::-webkit-search-cancel-button { cursor: pointer; }

  .filter-reset { font-family: var(--font-ui); font-size: 0.8rem; font-weight: 600; color: var(--grey); border: 1.5px solid var(--cream-dark); border-radius: 6px; padding: 0.45rem 0.9rem; background: white; align-self: flex-end; }
  .filter-reset:hover { color: var(--burgundy); border-color: var(--gold); }

  /* ── Result count ──────────────────────────────────────────────── */
  .result-bar { padding: 0.65rem 0 0; }
  .result-count { font-family: var(--font-ui); font-size: 0.8rem; color: var(--grey); }

  /* ── Cards ─────────────────────────────────────────────────────── */
  .articles-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; padding-bottom: 1rem; align-items: stretch; }

  .article-card { border-radius: 6px; overflow: hidden; border: 1px solid var(--cream-dark); background: white; transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease; display: flex; flex-direction: column; cursor: pointer; }
