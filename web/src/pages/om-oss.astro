---
// src/pages/om-oss.astro
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Om oss – Tryllemuseet";
const description = "Tryllemuseet er Norges eneste museum viet til tryllekunstens historie. Les om oss, vårt styre og hvordan du kan støtte museet.";

const styret = [
  { navn: "Navn Navnesen", rolle: "Styreleder" },
  { navn: "Navn Navnesen", rolle: "Nestleder" },
  { navn: "Navn Navnesen", rolle: "Kasserer" },
  { navn: "Navn Navnesen", rolle: "Styremedlem" },
  { navn: "Navn Navnesen", rolle: "Styremedlem" },
];

const medlemskap = [
  {
    type: "Støttemedlem",
    pris: "kr 200 / år",
    fordeler: [
      "Støtter bevaring av tryllekunstens historie",
      "Nyhetsbrev fra museet",
      "Invitasjon til åpne arrangementer",
    ],
  },
  {
    type: "Aktivt medlem",
    pris: "kr 400 / år",
    fordeler: [
      "Alt i støttemedlem",
      "Fri inngang for deg og én gjest",
      "Rabatt på kurs og workshops",
      "Stemmerett på årsmøtet",
    ],
    anbefalt: true,
  },
  {
    type: "Bedriftsmedlem",
    pris: "kr 2 000 / år",
    fordeler: [
      "Logoplassering på nettsiden",
      "Fri inngang for inntil 5 ansatte",
      "Nevnt i årsberetningen",
      "Invitasjon til private arrangementer",
    ],
  },
];
---

<BaseLayout title={title} description={description}>

  <!-- Hero -->
  <section class="om-hero">
    <div class="om-hero-deco"></div>
    <div class="container om-hero-inner">
      <div class="om-hero-tekst">
        <span class="etikett">Om Tryllemuseet</span>
        <h1>Norges eneste museum<br/><em>for tryllekunstens historie</em></h1>
        <p>Tryllemuseet er dedikert til å bevare, formidle og feire tryllekunstens rike arv i Norge og verden — for publikum av alle aldre.</p>
      </div>
      <div class="om-hero-ornament">
        <div class="ornament-ring">
          <span>✦</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Om museet -->
  <section class="om-museet section-pad">
    <div class="container om-tekst-layout">
      <div class="om-tekst-hoved">
        <h2>Vår historie</h2>
        <p>Tryllemuseet ble stiftet av entusiaster med lidenskap for tryllekunsten og dens plass i kulturhistorien. Fra en liten samling rekvisitter og plakater har museet vokst til å bli en unik formidlingsarena for magiens verden.</p>
        <p>Museet drives i all hovedsak på frivillig innsats, og er tilknyttet Den Magiske Ring og Magikernes Centralforbund Norge (MCN). Vi er en viktig møteplass for både utøvere og publikum som deler fascinasjonen for illusjonenes kunst.</p>
        <h2>Formål</h2>
        <p>Tryllemuseets formål er å samle, bevare og formidle gjenstander, dokumenter og kunnskap knyttet til tryllekunstens historie i Norge og internasjonalt — og gjøre denne arven tilgjengelig for fremtiden.</p>
      </div>
      <aside class="om-fakta-boks">
        <h3>Kort om oss</h3>
        <dl>
          <dt>Stiftet</dt>
          <dd>[Årstall]</dd>
          <dt>Organisasjonsform</dt>
          <dd>Ideell forening</dd>
          <dt>Tilknytning</dt>
          <dd>Den Magiske Ring / MCN</dd>
          <dt>Adresse</dt>
          <dd>[Adresse, by]</dd>
          <dt>E-post</dt>
          <dd><a href="mailto:post@tryllemuseet.no">post@tryllemuseet.no</a></dd>
          <dt>Org.nr</dt>
          <dd>[Organisasjonsnummer]</dd>
        </dl>
      </aside>
    </div>
  </section>

  <!-- Styret -->
  <section class="styret-seksjon section-pad bg-cream">
    <div class="container">
      <h2 class="section-title">Styret</h2>
      <p class="section-ingress">Museet ledes av et styre valgt på årsmøtet. Ta gjerne kontakt med oss på <a href="mailto:post@tryllemuseet.no">post@tryllemuseet.no</a>.</p>
      <div class="styre-grid">
        {styret.map(s => (
          <div class="styre-kort">
            <div class="styre-avatar">
              <span>✦</span>
            </div>
            <h3>{s.navn}</h3>
            <p class="styre-rolle">{s.rolle}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Medlemskap -->
  <section class="medlemskap-seksjon section-pad">
    <div class="container">
      <h2 class="section-title">Bli medlem</h2>
      <p class="section-ingress">Ditt medlemskap bidrar direkte til å bevare tryllekunstens arv og holde museet levende. Velg det nivået som passer deg.</p>
      <div class="medlemskap-grid">
        {medlemskap.map(m => (
          <div class={`medlemskap-kort ${m.anbefalt ? 'anbefalt' : ''}`}>
            {m.anbefalt && <div class="anbefalt-badge">Populær</div>}
            <h3>{m.type}</h3>
            <div class="pris">{m.pris}</div>
            <ul>
              {m.fordeler.map(f => (
                <li>{f}</li>
              ))}
            </ul>
            <a href="/kontakt" class="btn btn-meld-inn">Meld deg inn</a>
          </div>
        ))}
      </div>

      <div class="vipps-boks">
        <p>Du kan også støtte oss direkte via Vipps:</p>
        <div class="vipps-nummer">
          <span class="vipps-label">Vipps-nummer</span>
          <span class="vipps-tall">[XXXXX]</span>
        </div>
        <p class="vipps-info">Merk betalingen med «Støtte» eller «Medlemskap + ditt navn»</p>
      </div>
    </div>
  </section>

  <!-- Presse -->
  <section class="presse-seksjon section-pad bg-cream">
    <div class="container presse-layout">
      <div>
        <span class="etikett">For journalister og media</span>
        <h2>Pressekontakt</h2>
        <p>Er du journalist, blogger eller innholdsprodusent og ønsker å skrive om Tryllemuseet? Vi stiller gjerne opp for intervjuer, omvisninger og bilder.</p>
        <p>Kontakt oss på <a href="mailto:post@tryllemuseet.no">post@tryllemuseet.no</a> — merk e-posten «Presse».</p>
        <a href="/kontakt" class="btn btn-primary" style="margin-top: 1rem; display: inline-block;">Send pressehenvendelse</a>
      </div>
      <div class="logo-nedlasting">
        <h3>Last ned</h3>
        <div class="nedlastings-liste">
          <div class="nedlastings-kort">
            <span>🎩</span>
            <div>
              <strong>Logoer</strong>
              <p>PNG og SVG — mørk og lys variant</p>
            </div>
            <span class="nedlast-pil">↓</span>
          </div>
          <div class="nedlastings-kort">
            <span>📷</span>
            <div>
              <strong>Pressebilder</strong>
              <p>Høyoppløselige bilder fra museet</p>
            </div>
            <span class="nedlast-pil">↓</span>
          </div>
        </div>
        <p class="nedlastings-notat">Filer leveres på forespørsel via e-post</p>
      </div>
    </div>
  </section>

  <!-- Samarbeidspartnere -->
  <section class="partnere-seksjon section-pad">
    <div class="container">
      <h2 class="section-title">Samarbeidspartnere</h2>
      <div class="partnere-rad">
        <div class="partner-kort">
          <strong>Den Magiske Ring</strong>
          <p>Norsk magiforbund</p>
        </div>
        <div class="partner-kort">
          <strong>MCN</strong>
          <p>Magikernes Centralforbund Norge</p>
        </div>
        <div class="partner-kort partner-graa">
          <strong>Din organisasjon?</strong>
          <p><a href="/kontakt">Ta kontakt</a></p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ── */
  .om-hero {
    background: var(--burgundy);
    padding-block: 5rem;
    position: relative;
    overflow: hidden;
  }

  .om-hero-deco {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 80% 50%, rgba(212,168,67,0.1) 0%, transparent 60%),
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 60px,
        rgba(212,168,67,0.03) 60px,
        rgba(212,168,67,0.03) 61px
      );
  }

  .om-hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
  }

  .om-hero-tekst {
    max-width: 620px;
  }

  .etikett {
    display: inline-block;
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    border-bottom: 1px solid var(--gold);
    padding-bottom: 0.2em;
    margin-bottom: 1rem;
  }

  .om-hero-tekst h1 {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--cream);
    line-height: 1.2;
    margin-bottom: 1.2rem;
  }

  .om-hero-tekst h1 em {
    font-style: normal;
    color: var(--gold);
  }

  .om-hero-tekst p {
    font-family: 'Lora', serif;
    font-size: 1.05rem;
    color: rgba(251,247,239,0.8);
    line-height: 1.7;
  }

  .ornament-ring {
    width: 160px;
    height: 160px;
    border: 2px solid rgba(212,168,67,0.3);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
  }

  .ornament-ring::before {
    content: '';
    position: absolute;
    inset: 12px;
    border: 1px solid rgba(212,168,67,0.2);
    border-radius: 50%;
  }

  .ornament-ring span {
    font-size: 2.5rem;
    color: var(--gold);
    opacity: 0.6;
  }

  @media (max-width: 640px) {
    .om-hero-ornament { display: none; }
  }

  /* ── Sections ── */
  .section-pad { padding-block: 5rem; }
  .bg-cream { background: var(--cream); }

  .container {
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  .section-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    color: var(--burgundy);
    text-align: center;
    margin-bottom: 1rem;
    position: relative;
  }

  .section-title::after {
    content: '';
    display: block;
    width: 50px;
    height: 2px;
    background: var(--gold);
    margin: 0.6rem auto 0;
  }

  .section-ingress {
    text-align: center;
    font-family: 'Lora', serif;
    font-size: 1rem;
    color: #555;
    max-width: 560px;
    margin-inline: auto;
    margin-bottom: 3rem;
    line-height: 1.7;
  }

  /* ── Om museet ── */
  .om-tekst-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 4rem;
    align-items: start;
  }

  @media (max-width: 768px) {
    .om-tekst-layout { grid-template-columns: 1fr; }
  }

  .om-tekst-hoved h2 {
    font-family: 'Cinzel', serif;
    font-size: 1.3rem;
    color: var(--burgundy);
    margin: 2rem 0 0.75rem;
  }

  .om-tekst-hoved h2:first-child { margin-top: 0; }

  .om-tekst-hoved p {
    font-family: 'Lora', serif;
    font-size: 1rem;
    color: #444;
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .om-fakta-boks {
    background: var(--cream);
    border: 1px solid rgba(107,15,26,0.1);
    border-top: 3px solid var(--gold);
    padding: 2rem;
    border-radius: 2px;
  }

  .om-fakta-boks h3 {
    font-family: 'Cinzel', serif;
    font-size: 0.95rem;
    color: var(--burgundy);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1.2rem;
  }

  .om-fakta-boks dl { margin: 0; }

  .om-fakta-boks dt {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    margin-top: 1rem;
  }

  .om-fakta-boks dt:first-of-type { margin-top: 0; }

  .om-fakta-boks dd {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.95rem;
    color: #333;
    margin: 0.2rem 0 0;
  }

  .om-fakta-boks a {
    color: var(--burgundy);
    text-decoration: underline;
  }

  /* ── Styret ── */
  .styre-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1.5rem;
  }

  .styre-kort {
    text-align: center;
    padding: 2rem 1.5rem;
    background: white;
    border-radius: 4px;
    border: 1px solid rgba(107,15,26,0.08);
  }

  .styre-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--burgundy);
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
    font-size: 1.2rem;
  }

  .styre-kort h3 {
    font-family: 'Source Sans 3', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    color: #222;
    margin-bottom: 0.3rem;
  }

  .styre-rolle {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.8rem;
    color: var(--gold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0;
  }

  /* ── Medlemskap ── */
  .medlemskap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .medlemskap-kort {
    padding: 2.5rem 2rem;
    border: 1px solid rgba(107,15,26,0.12);
    border-radius: 4px;
    background: white;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .medlemskap-kort.anbefalt {
    border-color: var(--gold);
    box-shadow: 0 4px 24px rgba(212,168,67,0.15);
  }

  .anbefalt-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--gold);
    color: var(--burgundy);
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3em 1em;
    border-radius: 20px;
    white-space: nowrap;
  }

  .medlemskap-kort h3 {
    font-family: 'Cinzel', serif;
    font-size: 1.1rem;
    color: var(--burgundy);
    margin-bottom: 0.5rem;
  }

  .pris {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--gold);
    margin-bottom: 1.5rem;
  }

  .medlemskap-kort ul {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    flex: 1;
  }

  .medlemskap-kort li {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.9rem;
    color: #444;
    padding: 0.45em 0 0.45em 1.5em;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    position: relative;
  }

  .medlemskap-kort li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-size: 0.6rem;
    top: 0.6em;
  }

  .btn-meld-inn {
    display: block;
    text-align: center;
    padding: 0.75em 1em;
    background: var(--burgundy);
    color: var(--cream);
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.2s;
  }

  .anbefalt .btn-meld-inn {
    background: var(--gold);
    color: var(--burgundy);
  }

  .btn-meld-inn:hover {
    opacity: 0.9;
  }

  .vipps-boks {
    text-align: center;
    padding: 2.5rem;
    background: var(--cream);
    border-radius: 4px;
    border: 1px dashed rgba(107,15,26,0.2);
  }

  .vipps-boks > p:first-child {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.9rem;
    color: #555;
    margin-bottom: 1rem;
  }

  .vipps-nummer {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    margin-bottom: 0.75rem;
  }

  .vipps-label {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #888;
  }

  .vipps-tall {
    font-family: 'Cinzel', serif;
    font-size: 2rem;
    color: var(--burgundy);
    letter-spacing: 0.1em;
  }

  .vipps-info {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.8rem;
    color: #888;
    margin: 0;
  }

  /* ── Presse ── */
  .presse-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  @media (max-width: 768px) {
    .presse-layout { grid-template-columns: 1fr; }
  }

  .presse-layout h2 {
    font-family: 'Cinzel', serif;
    font-size: 1.6rem;
    color: var(--burgundy);
    margin: 0.5rem 0 1rem;
  }

  .presse-layout p {
    font-family: 'Lora', serif;
    font-size: 1rem;
    color: #444;
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .presse-layout a {
    color: var(--burgundy);
  }

  .logo-nedlasting h3 {
    font-family: 'Cinzel', serif;
    font-size: 1rem;
    color: var(--burgundy);
    margin-bottom: 1rem;
  }

  .nedlastings-liste {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .nedlastings-kort {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    background: white;
    border: 1px solid rgba(107,15,26,0.1);
    border-radius: 3px;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .nedlastings-kort:hover {
    border-color: var(--gold);
  }

  .nedlastings-kort > span:first-child {
    font-size: 1.5rem;
  }

  .nedlastings-kort div strong {
    display: block;
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    color: #222;
  }

  .nedlastings-kort div p {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.8rem;
    color: #777;
    margin: 0;
    line-height: 1.4;
  }

  .nedlast-pil {
    margin-left: auto;
    color: var(--gold);
    font-size: 1.2rem;
  }

  .nedlastings-notat {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.8rem;
    color: #999;
    font-style: italic;
  }

  /* ── Partnere ── */
  .partnere-rad {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .partner-kort {
    padding: 2rem 2.5rem;
    border: 1px solid rgba(107,15,26,0.12);
    border-radius: 4px;
    text-align: center;
    background: white;
    min-width: 200px;
  }

  .partner-graa {
    border-style: dashed;
    background: transparent;
  }

  .partner-kort strong {
    display: block;
    font-family: 'Cinzel', serif;
    font-size: 1rem;
    color: var(--burgundy);
    margin-bottom: 0.3rem;
  }

  .partner-kort p {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.85rem;
    color: #777;
    margin: 0;
  }

  .partner-kort a {
    color: var(--gold);
    text-decoration: none;
  }

  /* ── Buttons ── */
  .btn {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.75em 1.8em;
    border-radius: 2px;
    transition: all 0.2s ease;
    display: inline-block;
  }

  .btn-primary {
    background: var(--gold);
    color: var(--burgundy);
  }

  .btn-primary:hover {
    background: #e8bc52;
  }
</style>
