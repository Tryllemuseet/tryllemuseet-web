---
// src/pages/om-oss.astro
import BaseLayout from '../layouts/BaseLayout.astro'
import AnimateIn from '../components/AnimateIn.astro'
import { getOmOssPage, getAllPartners, getSiteConfig } from '../lib/sanity'
import { toHTML } from '@portabletext/to-html'

const [p, partnerDocs, site] = await Promise.all([getOmOssPage(), getAllPartners(), getSiteConfig()])

const hero = p?.hero ?? {
  label: 'Om Tryllemuseet',
  heading: 'Norges eneste museum',
  headingEm: 'for tryllekunstens historie',
  ingress: 'Tryllemuseet er dedikert til å bevare, formidle og feire tryllekunstens rike arv.',
}
const om       = p?.omMuseet   ?? { historieHeading: 'Vår historie', historieTekst: [], formalHeading: 'Formål', formalTekst: '' }
const fakta    = p?.faktaboks  ?? { stiftet: '', organisasjonsform: '', tilknytning: '', adresse: '', epost: '', orgnr: '' }
const styret   = p?.styret     ?? { heading: 'Styret', ingress: '', medlemmer: [] }
const medlem   = p?.medlemskap ?? { heading: 'Bli medlem', ingress: '', motivasjonsTekst: '', nivaaer: [], vippsNummer: '', vippsInfo: '' }
const presse   = p?.presse     ?? { label: '', heading: 'Pressekontakt', tekst: '', knappLabel: 'Send pressehenvendelse', knappHref: '/kontakt' }
const partnere = p?.partnere   ?? { heading: 'Samarbeidspartnere', liste: [] }

const historieHtml = om.historieTekst?.length ? toHTML(om.historieTekst) : ''
---

<BaseLayout
  title="Om oss — Tryllemuseet"
  description="Tryllemuseet er Norges eneste museum viet til tryllekunstens historie. Les om oss, vårt styre og hvordan du kan støtte museet."
>

  <!-- ── HERO ─────────────────────────────────────────────────── -->
  <section class="om-hero">
    <div class="om-hero-deco"></div>
    <div class="container om-hero-inner">
      <AnimateIn direction="left">
        <div class="om-hero-tekst">
          <span class="etikett">{hero.label}</span>
          <h1>{hero.heading}<br/><em>{hero.headingEm}</em></h1>
          <p>{hero.ingress}</p>
        </div>
      </AnimateIn>
      <AnimateIn direction="right">
        <div class="om-hero-ornament">
          <img
            src="/Logosirkel_m_tekst.jpg"
            alt="Norges minste, merkeligste og mest magiske museum"
            class="hero-sirkel-img"
          />
        </div>
      </AnimateIn>
    </div>
  </section>

  <!-- ── OM MUSEET ────────────────────────────────────────────── -->
  <section class="om-museet section-pad">
    <div class="container om-tekst-layout">
      <AnimateIn direction="left">
      <div class="om-tekst-hoved">
        <h2>{om.historieHeading}</h2>
        {historieHtml
          ? <div class="prose" set:html={historieHtml} />
          : null
        }
        {om.formalHeading && <h2>{om.formalHeading}</h2>}
        {om.formalTekst && <p>{om.formalTekst}</p>}
      </div>
      </AnimateIn>
      <AnimateIn direction="right">
      <aside class="om-fakta-boks">
        <h3>Kort om oss</h3>
        <dl>
          {fakta.stiftet            && <><dt>Stiftet</dt><dd>{fakta.stiftet}</dd></>}
          {fakta.organisasjonsform  && <><dt>Organisasjonsform</dt><dd>{fakta.organisasjonsform}</dd></>}
          {fakta.tilknytning        && <><dt>Tilknytning</dt><dd>{fakta.tilknytning}</dd></>}
          {fakta.adresse            && <><dt>Adresse</dt><dd>{fakta.adresse}</dd></>}
          {fakta.epost              && <><dt>E-post</dt><dd><a href={`mailto:${fakta.epost}`}>{fakta.epost}</a></dd></>}
          {fakta.orgnr              && <><dt>Org.nr</dt><dd>{fakta.orgnr}</dd></>}
        </dl>
      </aside>
      </AnimateIn>
    </div>
  </section>

  <!-- ── STYRET ───────────────────────────────────────────────── -->
  <section class="styret-seksjon section-pad bg-cream">
    <div class="container">
      <h2 class="section-title">{styret.heading}</h2>
      {styret.ingress && (
        <p class="section-ingress" set:html={styret.ingress.replace(site.email, `<a href="mailto:${site.email}">${site.email}</a>`)} />
      )}
      <AnimateIn direction="up">
      <div class="styre-grid">
        {styret.medlemmer.map(s => (
          <div class="styre-kort">
            <div class="styre-avatar"><span>✦</span></div>
            <h3>{s.navn}</h3>
            <p class="styre-rolle">{s.rolle}</p>
          </div>
        ))}
      </div>
      </AnimateIn>
    </div>
  </section>

  <!-- ── MEDLEMSKAP ───────────────────────────────────────────── -->
  <section class="medlemskap-seksjon section-pad">
    <div class="container">
      <h2 class="section-title">{medlem.heading}</h2>
      {medlem.ingress && <p class="section-ingress">{medlem.ingress}</p>}

      {medlem.motivasjonsTekst && (
        <AnimateIn direction="up">
        <div class="motivasjon-boks">
          {medlem.motivasjonsTekst.split('\n\n').map(avsnitt => (
            <p>{avsnitt}</p>
          ))}
        </div>
        </AnimateIn>
      )}

      <AnimateIn direction="up">
      <div class="medlemskap-grid">
        {medlem.nivaaer.map(m => (
          <div class:list={['medlemskap-kort', { anbefalt: m.anbefalt }]}>
            {m.anbefalt && <div class="anbefalt-badge">Populær</div>}
            <h3>{m.type}</h3>
            <div class="pris">{m.pris}</div>
            <ul>
              {m.fordeler.map(f => <li>{f}</li>)}
            </ul>
            <a href={m.knappUrl} target="_blank" rel="noopener noreferrer" class="btn-meld-inn">
              {m.knappLabel}
            </a>
          </div>
        ))}
      </div>
      </AnimateIn>

      {medlem.vippsNummer && (
        <div class="vipps-boks">
          <p>Du kan også støtte oss direkte via Vipps:</p>
          <div class="vipps-nummer">
            <span class="vipps-label">Vipps-nummer</span>
            <span class="vipps-tall">{medlem.vippsNummer}</span>
          </div>
          {medlem.vippsInfo && <p class="vipps-info">{medlem.vippsInfo}</p>}
        </div>
      )}
    </div>
  </section>

  <!-- ── PRESSE ───────────────────────────────────────────────── -->
  <section class="presse-seksjon section-pad bg-cream">
    <div class="container presse-layout">
      <AnimateIn direction="left">
      <div>
        {presse.label && <span class="etikett">{presse.label}</span>}
        <h2>{presse.heading}</h2>
        {presse.tekst.split('\n').map(linje => <p>{linje}</p>)}
        <a href={presse.knappHref} class="btn btn-primary" style="margin-top:1rem; display:inline-block">
          {presse.knappLabel}
        </a>
      </div>
      </AnimateIn>
      <AnimateIn direction="right">
      <div class="logo-nedlasting">
        <h3>Last ned</h3>
        <div class="nedlastings-liste">
          <div class="nedlastings-kort">
            <span>🎩</span>
            <div><strong>Logoer</strong><p>PNG og SVG — mørk og lys variant</p></div>
            <span class="nedlast-pil">↓</span>
          </div>
          <div class="nedlastings-kort">
            <span>📷</span>
            <div><strong>Pressebilder</strong><p>Høyoppløselige bilder fra museet</p></div>
            <span class="nedlast-pil">↓</span>
          </div>
        </div>
        <p class="nedlastings-notat">Filer leveres på forespørsel via e-post</p>
      </div>
      </AnimateIn>
    </div>
  </section>

  <!-- ── PARTNERE ─────────────────────────────────────────────── -->
  {(partnerDocs.length > 0 || partnere.liste.length > 0) && (
    <section class="partnere-seksjon section-pad">
      <div class="container">
        <AnimateIn direction="up">
        <h2 class="section-title">{partnere.heading}</h2>
      </AnimateIn>
      <AnimateIn direction="up">
        {partnerDocs.length > 0 ? (
          <div class="partnere-grupper">
            {(['public', 'private', 'org'] as const).map(cat => {
              const gruppe = partnerDocs.filter(pd => pd.category === cat)
              if (!gruppe.length) return null
              const labels = { public: 'Offentlig støtte', private: 'Privat støtte', org: 'Faglig samarbeid' }
              return (
                <div class="partner-gruppe">
                  <p class="partner-gruppe-label">{labels[cat]}</p>
                  <div class="partnere-rad">
                    {gruppe.map(pd => {
                      const innhold = (
                        <>
                          {pd.logo?.asset?.url && <img src={pd.logo.asset.url} alt={pd.name} class="partner-logo" loading="lazy" />}
                          <strong>{pd.name}</strong>
                          {pd.description && <p>{pd.description}</p>}
                        </>
                      )
                      return pd.url
                        ? <a href={pd.url} target="_blank" rel="noopener noreferrer" class="partner-kort" aria-label={pd.name}>{innhold}</a>
                        : <div class="partner-kort" aria-label={pd.name}>{innhold}</div>
                    })}
                  </div>
                </div>
              )
            })}
            <div class="partnere-rad">
              <div class="partner-kort partner-graa">
                <strong>Din organisasjon?</strong>
                <p><a href="/kontakt">Ta kontakt</a></p>
              </div>
            </div>
          </div>
        ) : (
          <div class="partnere-rad">
            {partnere.liste.map(p => (
              <div class="partner-kort">
                <strong>{p.navn}</strong>
                <p>{p.beskrivelse}</p>
                {p.url && <a href={p.url} target="_blank" rel="noopener noreferrer">Les mer</a>}
              </div>
            ))}
            <div class="partner-kort partner-graa">
              <strong>Din organisasjon?</strong>
              <p><a href="/kontakt">Ta kontakt</a></p>
            </div>
          </div>
        )}
      </AnimateIn>
      </div>
    </section>
  )}

</BaseLayout>

<style>
  /* ── Hero ── */
  .om-hero { background: var(--burgundy); padding-block: 5rem; position: relative; overflow: hidden; }
  .om-hero-deco {
    position: absolute; inset: 0;
    background-image:
      radial-gradient(circle at 80% 50%, rgba(212,168,67,0.1) 0%, transparent 60%),
      repeating-linear-gradient(-45deg, transparent, transparent 60px, rgba(212,168,67,0.03) 60px, rgba(212,168,67,0.03) 61px);
  }
  .om-hero-inner { position: relative; z-index: 1; display: flex; align-items: center; justify-content: space-between; gap: 3rem; }
  .om-hero-tekst { max-width: 620px; }
  .etikett {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    border-bottom: 1px solid var(--gold);
    padding-bottom: 0.2em;
    margin-bottom: 1rem;
  }
  .om-hero-tekst h1 { font-family: var(--font-display); font-size: clamp(1.8rem, 4vw, 2.8rem); color: var(--cream); line-height: 1.2; margin-bottom: 1.2rem; }
  .om-hero-tekst h1 em { font-style: normal; color: var(--gold); }
  .om-hero-tekst p  { font-family: var(--font-body); font-size: 1.05rem; color: rgba(251,247,239,0.8); line-height: 1.7; }
  .hero-sirkel-img {
    width: 300px; height: 300px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    flex-shrink: 0;
    border: 2px solid rgba(212,168,67,0.35);
    box-shadow: 0 0 0 12px rgba(212,168,67,0.07), 0 8px 40px rgba(0,0,0,0.25);
  }
  @media (max-width: 640px) { .om-hero-ornament { display: none; } }

  /* ── Sections ── */
  .section-pad { padding-block: 5rem; }
  .bg-cream { background: var(--cream); }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    color: var(--burgundy);
    text-align: center;
    margin-bottom: 1rem;
  }
  .section-title::after { content: ''; display: block; width: 50px; height: 2px; background: var(--gold); margin: 0.6rem auto 0; }
  .section-ingress { text-align: center; font-family: var(--font-body); font-size: 1rem; color: #555; max-width: 560px; margin-inline: auto; margin-bottom: 3rem; line-height: 1.7; }

  /* ── Om museet ── */
  .om-tekst-layout { display: grid; grid-template-columns: 1fr 300px; gap: 4rem; align-items: start; }
  @media (max-width: 768px) { .om-tekst-layout { grid-template-columns: 1fr; } }
  .om-tekst-hoved h2 { font-family: var(--font-display); font-size: 1.3rem; color: var(--burgundy); margin: 2rem 0 0.75rem; }
  .om-tekst-hoved h2:first-child { margin-top: 0; }
  .om-tekst-hoved p, .prose p { font-family: var(--font-body); font-size: 1rem; color: #444; line-height: 1.75; margin-bottom: 1rem; }
  .om-fakta-boks {
    background: var(--cream);
    border: 1px solid rgba(107,15,26,0.1);
    border-top: 3px solid var(--gold);
    padding: 2rem; border-radius: 2px;
  }
  .om-fakta-boks h3 { font-family: var(--font-display); font-size: 0.95rem; color: var(--burgundy); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 1.2rem; }
  .om-fakta-boks dl { margin: 0; }
  .om-fakta-boks dt { font-family: var(--font-ui); font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); margin-top: 1rem; }
  .om-fakta-boks dt:first-of-type { margin-top: 0; }
  .om-fakta-boks dd { font-family: var(--font-ui); font-size: 0.95rem; color: #333; margin: 0.2rem 0 0; }
  .om-fakta-boks a { color: var(--burgundy); text-decoration: underline; }

  /* ── Styret ── */
  .styre-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1.5rem; }
  .styre-kort { text-align: center; padding: 2rem 1.5rem; background: white; border-radius: 4px; border: 1px solid rgba(107,15,26,0.08); }
  .styre-avatar { width: 64px; height: 64px; border-radius: 50%; background: var(--burgundy); margin: 0 auto 1rem; display: flex; align-items: center; justify-content: center; color: var(--gold); font-size: 1.2rem; }
  .styre-kort h3 { font-family: var(--font-ui); font-weight: 600; font-size: 0.95rem; color: #222; margin-bottom: 0.3rem; }
  .styre-rolle { font-family: var(--font-ui); font-size: 0.8rem; color: var(--gold); letter-spacing: 0.08em; text-transform: uppercase; margin: 0; }

  /* ── Motivasjon ── */
  .motivasjon-boks {
    max-width: 720px;
    margin: 0 auto 3rem;
    background: var(--cream);
    border-left: 3px solid var(--gold);
    padding: 2rem 2.5rem;
    border-radius: 2px;
  }
  .motivasjon-boks p { font-family: var(--font-body); font-size: 1rem; color: #444; line-height: 1.75; margin-bottom: 0.75rem; }
  .motivasjon-boks p:last-child { margin-bottom: 0; }

  /* ── Medlemskap ── */
  .medlemskap-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 2rem; margin-bottom: 3rem; }
  .medlemskap-kort { padding: 2.5rem 2rem; border: 1px solid rgba(107,15,26,0.12); border-radius: 4px; background: white; position: relative; display: flex; flex-direction: column; }
  .medlemskap-kort.anbefalt { border-color: var(--gold); box-shadow: 0 4px 24px rgba(212,168,67,0.15); }
  .anbefalt-badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--gold); color: var(--burgundy); font-family: var(--font-ui); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.3em 1em; border-radius: 20px; white-space: nowrap; }
  .medlemskap-kort h3 { font-family: var(--font-display); font-size: 1.1rem; color: var(--burgundy); margin-bottom: 0.5rem; }
  .pris { font-family: var(--font-ui); font-size: 1.3rem; font-weight: 700; color: var(--gold); margin-bottom: 1.5rem; }
  .medlemskap-kort ul { list-style: none; padding: 0; margin: 0 0 2rem; flex: 1; }
  .medlemskap-kort li { font-family: var(--font-ui); font-size: 0.9rem; color: #444; padding: 0.45em 0 0.45em 1.5em; border-bottom: 1px solid rgba(0,0,0,0.05); position: relative; }
  .medlemskap-kort li::before { content: '✦'; position: absolute; left: 0; color: var(--gold); font-size: 0.6rem; top: 0.6em; }
  .btn-meld-inn { display: block; text-align: center; padding: 0.75em 1em; background: var(--burgundy); color: var(--cream); font-family: var(--font-ui); font-size: 0.85rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; text-decoration: none; border-radius: 2px; transition: background 0.2s; }
  .anbefalt .btn-meld-inn { background: var(--gold); color: var(--burgundy); }
  .btn-meld-inn:hover { opacity: 0.9; }

  /* ── Vipps ── */
  .vipps-boks { text-align: center; padding: 2.5rem; background: var(--cream); border-radius: 4px; border: 1px dashed rgba(107,15,26,0.2); }
  .vipps-boks > p:first-child { font-family: var(--font-ui); font-size: 0.9rem; color: #555; margin-bottom: 1rem; }
  .vipps-nummer { display: inline-flex; flex-direction: column; align-items: center; gap: 0.3rem; margin-bottom: 0.75rem; }
  .vipps-label { font-family: var(--font-ui); font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: #888; }
  .vipps-tall { font-family: var(--font-display); font-size: 2rem; color: var(--burgundy); letter-spacing: 0.1em; }
  .vipps-info { font-family: var(--font-ui); font-size: 0.8rem; color: #888; margin: 0; }

  /* ── Presse ── */
  .presse-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  @media (max-width: 768px) { .presse-layout { grid-template-columns: 1fr; } }
  .presse-layout h2 { font-family: var(--font-display); font-size: 1.6rem; color: var(--burgundy); margin: 0.5rem 0 1rem; }
  .presse-layout p { font-family: var(--font-body); font-size: 1rem; color: #444; line-height: 1.7; margin-bottom: 0.75rem; }
  .presse-layout a { color: var(--burgundy); }
  .logo-nedlasting h3 { font-family: var(--font-display); font-size: 1rem; color: var(--burgundy); margin-bottom: 1rem; }
  .nedlastings-liste { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 1rem; }
  .nedlastings-kort { display: flex; align-items: center; gap: 1rem; padding: 1rem 1.2rem; background: white; border: 1px solid rgba(107,15,26,0.1); border-radius: 3px; }
  .nedlastings-kort:hover { border-color: var(--gold); }
  .nedlastings-kort > span:first-child { font-size: 1.5rem; }
  .nedlastings-kort div strong { display: block; font-family: var(--font-ui); font-size: 0.9rem; font-weight: 600; color: #222; }
  .nedlastings-kort div p { font-family: var(--font-ui); font-size: 0.8rem; color: #777; margin: 0; line-height: 1.4; }
  .nedlast-pil { margin-left: auto; color: var(--gold); font-size: 1.2rem; }
  .nedlastings-notat { font-family: var(--font-ui); font-size: 0.8rem; color: #999; font-style: italic; }

  /* ── Partnere ── */
  .partnere-grupper { display: flex; flex-direction: column; gap: 2.5rem; }
  .partner-gruppe-label { font-family: var(--font-ui); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--gold-dark, #A07820); text-align: center; margin-bottom: 1rem; }
  .partnere-rad { display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap; }
  .partner-kort { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem 2.5rem; border: 1px solid rgba(107,15,26,0.12); border-radius: 4px; text-align: center; background: white; min-width: 200px; text-decoration: none; transition: box-shadow 200ms ease, border-color 200ms ease; }
  a.partner-kort:hover { box-shadow: 0 4px 16px rgba(26,18,8,0.08); border-color: var(--gold, #D4A843); }
  .partner-logo { max-height: 64px; max-width: 180px; object-fit: contain; margin-bottom: 0.75rem; }
  .partner-kort { max-width: 280px; }
  .partner-graa { border-style: dashed; background: transparent; }
  .partner-kort strong { display: block; font-family: var(--font-display); font-size: 1rem; color: var(--burgundy); margin-bottom: 0.3rem; }
  .partner-kort p { font-family: var(--font-ui); font-size: 0.85rem; color: #777; margin: 0; }
  .partner-kort a { color: var(--gold); text-decoration: none; }

  /* ── Buttons ── */
  .btn { font-family: var(--font-ui); font-size: 0.85rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; text-decoration: none; padding: 0.75em 1.8em; border-radius: 2px; transition: all 0.2s ease; display: inline-block; }
  .btn-primary { background: var(--gold); color: var(--burgundy); }
  .btn-primary:hover { background: var(--gold-light); }
</style>
