---
// src/pages/barn/laer-et-triks/[slug].astro
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { getTrickBySlug, getTrickPaths, portableTextToHtml } from '../../../lib/sanity'

export async function getStaticPaths() {
  return getTrickPaths()
}

const { slug } = Astro.params
const t = await getTrickBySlug(slug!)

if (!t) return Astro.redirect('/barn/laer-et-triks')

const DIFFICULTY_LABELS: Record<string, string> = {
  enkel: 'Enkel',
  middels: 'Litt vanskeligere',
}

function youtubeEmbedUrl(url?: string): string | null {
  if (!url) return null
  const m = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&?]+)/)
  return m ? `https://www.youtube-nocookie.com/embed/${m[1]}` : null
}

const embedUrl = youtubeEmbedUrl(t.videoUrl)
---

<BaseLayout
  title={`${t.title} — Tryllemuseet`}
  description={t.shortDescription}
>

  <nav class="breadcrumb container">
    <a href="/barn">Barn & unge</a>
    <span>›</span>
    <a href="/barn/laer-et-triks">Lær et triks</a>
    <span>›</span>
    <span aria-current="page">{t.title}</span>
  </nav>

  <section class="triks-hero">
    <div class="container triks-hero-inner">
      {t.mainImage?.asset?.url && (
        <div class="hero-img">
          <img src={t.mainImage.asset.url} alt={t.mainImage.alt ?? t.title} />
          {t.mainImage.caption && <p class="hero-img-caption">{t.mainImage.caption}</p>}
        </div>
      )}
      <div class="hero-text">
        <span class={`vanskelighet vanskelighet-${t.difficulty}`}>
          {DIFFICULTY_LABELS[t.difficulty] ?? t.difficulty}
        </span>
        <h1>{t.title}</h1>
        <p class="hero-ingress">{t.shortDescription}</p>
      </div>
    </div>
  </section>

  <section class="triks-innhold section-pad">
    <div class="container triks-innhold-grid">

      <div class="triks-hovedinnhold">
        {embedUrl && (
          <div class="triks-video-wrap">
            <iframe
              src={embedUrl}
              title={`Video: ${t.title}`}
              loading="lazy"
              allow="accelerometer; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        )}

        {!embedUrl && t.externalUrl && (
          <a href={t.externalUrl} target="_blank" rel="noopener" class="triks-ekstern-lenke">
            Se trikset →
          </a>
        )}

        {t.instructions && t.instructions.length > 0 && (
          <div class="prose triks-instruksjoner" set:html={portableTextToHtml(t.instructions)} />
        )}

        {t.gallery && t.gallery.length > 0 && (
          <div class="triks-galleri">
            {t.gallery.map(img => (
              <figure class="triks-galleri-bilde">
                <img src={img.asset.url} alt={img.alt ?? t.title} loading="lazy" />
                {img.caption && <figcaption>{img.caption}</figcaption>}
              </figure>
            ))}
          </div>
        )}

        {t.links && t.links.length > 0 && (
          <div class="triks-lenker">
            <span class="lenker-label">Flere ressurser</span>
            <ul>
              {t.links.map(l => (
                <li>
                  {l.url ? <a href={l.url} target="_blank" rel="noopener">{l.label}</a> : l.label}
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      {t.materials && t.materials.length > 0 && (
        <aside class="triks-materialer">
          <span class="materialer-label">Du trenger</span>
          <ul>
            {t.materials.map(m => <li>{m}</li>)}
          </ul>
        </aside>
      )}

    </div>

    <div class="container page-nav">
      <a href="/barn/laer-et-triks">← Alle triks</a>
      <a href="/barn">← Barn & unge</a>
    </div>
  </section>

</BaseLayout>

<style>
  .breadcrumb {
    padding-block: 1.5rem 0;
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: #777;
  }
  .breadcrumb a { color: var(--burgundy); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .breadcrumb span[aria-current] { color: #999; }

  .triks-hero { padding-block: 2.5rem 2rem; background: var(--cream); }
  .triks-hero-inner { display: grid; grid-template-columns: minmax(0, 340px) 1fr; gap: 2.5rem; align-items: center; }

  .hero-img img { width: 100%; border-radius: 6px; box-shadow: 0 4px 20px rgba(0,0,0,0.12); }
  .hero-img-caption { font-family: var(--font-ui); font-size: 0.8rem; color: #777; margin-top: 0.5rem; }

  .vanskelighet {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.3em 0.7em;
    border-radius: 12px;
    margin-bottom: 0.75rem;
  }
  .vanskelighet-enkel { background: rgba(76,175,80,0.12); color: #2e7d32; }
  .vanskelighet-middels { background: rgba(212,168,67,0.18); color: #8a6a10; }

  .triks-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    color: var(--burgundy);
    margin-bottom: 0.75rem;
  }
  .hero-ingress {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: #555;
    line-height: 1.7;
  }

  .section-pad { padding-block: 3rem 3rem; }

  .triks-innhold-grid {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 3rem;
    align-items: start;
  }

  .triks-video-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 1.5rem;
    background: #000;
  }
  .triks-video-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .triks-ekstern-lenke {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--burgundy);
    text-decoration: none;
    border-bottom: 1px solid var(--gold);
    padding-bottom: 0.1em;
    margin-bottom: 1.5rem;
  }
  .triks-ekstern-lenke:hover { color: var(--gold-dark, var(--gold)); }

  .triks-instruksjoner {
    font-family: var(--font-body);
    font-size: 1rem;
    color: #444;
    line-height: 1.75;
  }
  .triks-instruksjoner :global(img) { width: 100%; border-radius: 6px; margin-block: 1rem; }

  .triks-galleri {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.25rem;
    margin-top: 2rem;
  }
  .triks-galleri-bilde img { width: 100%; border-radius: 6px; }
  .triks-galleri-bilde figcaption { font-family: var(--font-ui); font-size: 0.78rem; color: #777; margin-top: 0.4rem; }

  .triks-lenker { margin-top: 2rem; }
  .lenker-label {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }
  .triks-lenker ul { margin: 0; padding-left: 1.2rem; font-family: var(--font-body); font-size: 0.95rem; }
  .triks-lenker a { color: var(--burgundy); }

  .triks-materialer {
    background: var(--cream);
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
    position: sticky;
    top: 6rem;
  }
  .materialer-label {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }
  .triks-materialer ul {
    margin: 0;
    padding-left: 1.2rem;
    font-family: var(--font-body);
    font-size: 0.92rem;
    color: #444;
  }
  .triks-materialer li { margin-bottom: 0.2rem; }

  .page-nav { display: flex; flex-wrap: wrap; gap: 0.75rem; padding-top: 2rem; border-top: 1px solid var(--cream-dark); font-family: var(--font-ui); font-size: 0.875rem; }
  .page-nav a { color: var(--grey); text-decoration: none; border: 1px solid var(--cream-dark); padding: 0.4rem 1rem; border-radius: var(--radius); transition: color 150ms, border-color 150ms; }
  .page-nav a:hover { color: var(--burgundy); border-color: var(--gold); }

  @media (max-width: 720px) {
    .triks-hero-inner { grid-template-columns: 1fr; }
    .triks-innhold-grid { grid-template-columns: 1fr; }
    .triks-materialer { position: static; }
  }
</style>
