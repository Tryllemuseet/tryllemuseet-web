    async function ghPlay() {
      const log = $('gh-log')
      log.innerHTML = ''
      $('gh-pick').hidden = true
      for (let i = 0; i < GH_BEATS.length; i++) {
        const li = document.createElement('li')
        li.textContent = GH_BEATS[i]
