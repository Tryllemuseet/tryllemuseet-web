    // ═══ TEATERET ════════════════════════════════════════════════
    interface TeAction { key: string; label: string; step?: number; wrongText?: string }
    const TE_ACTIONS: TeAction[] = [
      { key: 'lokk',   label: 'Dytt lokket med all kraft',
        wrongText: 'Låst utenfra — selvsagt. Hele salen så hengelåsen klikke.' },
      { key: 'rop',    label: 'Rop om hjelp',
        wrongText: 'Orkesteret spiller bare høyere. Ingen redder en utbryter.' },
      { key: 'som',    label: 'Kjenn langs sømmen i kistens kortside', step: 1 },
      { key: 'knott',  label: 'Vri knotten en halv omdreining', step: 2 },
      { key: 'panel',  label: 'Skyv panelet til side og smyg deg ut', step: 3 },
      { key: 'morse',  label: 'Bank SOS i bunnplaten',
        wrongText: 'Morse imponerer ingen når du er alene om å høre det.' },
    ]
    const TE_STEP_TEXT: Record<number, string> = {
      1: 'Fingrene finner en forsenket knott i sømmen — en som ikke synes fra salen.',
      2: 'Noe gir etter med et mykt klikk: sidepanelet er løst.',
      3: 'Panelet glir til side. Du ruller ut i kulissene, bak kisten — usett.',
    }
    let tePath = state.path['teateret'] || ''
    let teHintsUsed = 0
    let teWrong = 0
    let teStep = 0
    let teDone = false

    const TE_HINTS = [
      'Effekten selges i kveld — metoden ble kjøpt i går, i verkstedet.',
      'Ikke lokket. Publikum ser lokket. Tenk på det de ikke ser.',
      'Kortsiden. Sømmen. En knott som ikke synes fra salen.',
    ]
    wireHints('te-hint-btn', 'te-hints', TE_HINTS, () => { teHintsUsed++ })

    function teRender() {
      const box = $('te-actions')
      box.innerHTML = ''
      for (const a of TE_ACTIONS) {
        const btn = document.createElement('button')
        btn.className = 'mp-cup'
        btn.textContent = a.label
        btn.disabled = teDone || (a.step !== undefined && a.step <= teStep)
        btn.addEventListener('click', () => teAct(a))
        box.appendChild(btn)
      }
    }

    function teAct(a: TeAction) {
      if (teDone) return
      const log = $('te-log')
      const li = document.createElement('li')
      if (a.step === undefined) {
        teWrong++
        li.textContent = a.wrongText!
        log.appendChild(li)
        $('te-msg').textContent = 'Publikum teller videre. Prøv noe annet.'
      } else if (a.step === teStep + 1) {
        teStep = a.step
        li.textContent = TE_STEP_TEXT[a.step]
        log.appendChild(li)
        $('te-msg').textContent = ''
        if (teStep === 3) {
          teDone = true
          const gild = tePath === 'mester' && teHintsUsed === 0 && teWrong === 0
          awardCard(7, 'spar', 'Sigillet fra Teateret')
          if (gild && !state.gilded.includes('7-spar')) {
            state.gilded.push('7-spar')
            save()
          }
          renderFacts('te-facts', 'teateret')
          $('te-solved').hidden = false
          $('te-solved').scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'nearest' })
        }
      } else {
        teWrong++
        li.textContent = a.step === 2
          ? 'Hvilken knott? Du famler i blinde mot glatt treverk.'
          : 'Panelet sitter bom fast. Noe må løsne først.'
        log.appendChild(li)
      }
      teRender()
    }

    document.querySelectorAll<HTMLButtonElement>('.path-btn[data-scene="te"]').forEach(btn =>
      btn.addEventListener('click', () => {
        tePath = btn.dataset.path || 'laerling'
        state.path['teateret'] = tePath
        save()
        $('te-pathchoice').hidden = true
        $('te-game').hidden = false
        $('te-pretext').textContent = tePath === 'laerling'
          ? 'Direktørens stemme, tett ved øret ditt enda han umulig kan være der: «En utbryter går aldri inn i noe han ikke kjenner. Kisten ble gjort klar for deg — let etter det som ble gjort klart.»'
          : 'Mørke. Varme. Applausen utenfor stilner til taktfast klapping.'
        teRender()
      })
    )

    $('te-ticket').addEventListener('click', () => {
