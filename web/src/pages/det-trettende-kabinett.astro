      goTo('lerretet')
    })

    // ═══ ÅNDEN PÅ LERRETET (SPEILGANGEN: ETTERBILDE) ═════════════
    // NB: the stare needs real seconds regardless of prefers-reduced-motion —
    // this is exposure time for the eyes, not animation.
    const LE_STARE_MS = 12000
    let leLit = false

    function leSetFigure(on: boolean) {
      ;(document.getElementById('le-figure') as unknown as SVGGElement).style.display = on ? '' : 'none'
      ;(document.getElementById('le-blank-text') as unknown as SVGTextElement).style.display = on ? 'none' : ''
    }

    $('le-light').addEventListener('click', () => {
      if (leLit) return
      leLit = true
      ;($('le-light') as HTMLButtonElement).disabled = true
      leSetFigure(true)
      let left = LE_STARE_MS / 1000
      $('le-msg').textContent = `Stirr på den hvite prikken … ${left}`
      const timer = window.setInterval(() => {
        left--
        if (left > 0) {
          $('le-msg').textContent = `Stirr på den hvite prikken … ${left}`
        } else {
          window.clearInterval(timer)
          leSetFigure(false)
          leLit = false
          ;($('le-light') as HTMLButtonElement).disabled = false
          ;($('le-light') as HTMLButtonElement).textContent = 'Tenn lampen igjen 🕯️'
          $('le-msg').textContent = 'Lampen slukker. Se på det tomme lerretet — hva ser du?'
          $('le-after').hidden = false
        }
      }, 1000)
    })

    function leFinish(sawIt: boolean) {
      $('le-after').hidden = true
      $('le-controls').hidden = true
      $('le-msg').textContent = sawIt
        ? 'Direktøren smiler i mørket. «Der. Kabinettets billigste spøkelse — og det bor i deg.»'
        : 'Direktøren nikker. «Noen øyne er mer lettlurte enn andre. Her er det du ville sett:»'
      awardCard(6, 'ruter', 'Illusjonskortet fra Ånden på lerretet')
      renderFacts('le-facts', 'lerretet')
      $('le-reveal').hidden = false
      ;($('le-continue') as HTMLButtonElement).hidden = false
    }

    $('le-saw').addEventListener('click', () => leFinish(true))
    let leNothingCount = 0
    $('le-nothing').addEventListener('click', () => {
      leNothingCount++
      if (leNothingCount < 2) {
        $('le-after').hidden = true
        $('le-msg').textContent = 'Direktøren: «Tenn lampen igjen — og hold blikket helt, helt stille på prikken.»'
      } else {
        leFinish(false)
      }
    })
    $('le-skip').addEventListener('click', () => leFinish(false))
    $('le-continue').addEventListener('click', () => goTo('verkstedet'))

