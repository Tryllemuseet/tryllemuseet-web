    let srPos = [0, 1, 2]        // srPos[cupIdx] = visual position
    let srHintsUsed = 0
    let srWrong = 0
    let srPath = state.path['sandrommet'] || ''

    const SR_HINTS = lang === 'en' ? [
      'You followed the cups, apprentice. But did you follow the magician?',
      'The ball left the table before the first swap.',
      'Look at the hand “resting” on the edge of the table.',
    ] : [
      'Du fulgte koppene, lærling. Men fulgte du magikeren?',
