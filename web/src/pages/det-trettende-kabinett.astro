      { text: 'I stummende mørke letter bordet — og alle rundt det kjenner det.', room: 'seanse' },
      { text: 'På lerretet svever helten til værs — uten et klipp å se.', room: 'kino' },
      { text: 'Utbryteren lar salen «velge» kisten han skal låses inn i.', room: 'teater' },
    ]
