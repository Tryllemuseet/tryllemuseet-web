    if (lang === 'en') {
      for (const [sel, html] of STATIC_EN) {
        document.querySelectorAll(sel).forEach(el => { el.innerHTML = html })
      }
      for (const [sel, attr, value] of ATTR_EN) {
        document.querySelectorAll(sel).forEach(el => el.setAttribute(attr, value))
      }
      document.getElementById('game-root')?.setAttribute('lang', 'en')
      document.getElementById('game-hero')?.setAttribute('lang', 'en')
      if (data.hero) {
        const heroTitle = document.querySelector('#game-hero .display-title')
        const heroSub = document.querySelector('#game-hero .hero-sub')
        if (heroTitle) heroTitle.textContent = data.hero.en.title
        if (heroSub) heroSub.textContent = data.hero.en.intro
      }
    }

    // Room copy (headings/intros) is server-rendered in Norwegian; rewrite
    // from the payload in English mode, and insert the editors' room images
    // in both languages.
    for (const [key, room] of Object.entries(data.rooms)) {
      const scene = document.getElementById(`sc-${key}`)
      if (!scene) continue
      if (lang === 'en') {
        const heading = scene.querySelector('.scene-heading')
        if (heading) heading.textContent = room.en.title
        const intro = scene.querySelector('.scene-intro')
        if (intro) intro.innerHTML = room.en.introHtml
      }
      if (room.imageUrl) {
        const intro = scene.querySelector('.scene-intro')
        if (intro) {
          const fig = document.createElement('figure')
          fig.className = 'scene-image'
          const img = document.createElement('img')
          img.src = room.imageUrl
          img.alt = (lang === 'en' ? room.imageAltEn : room.imageAlt) || ''
          img.loading = 'lazy'
          img.decoding = 'async'
          fig.appendChild(img)
          intro.insertAdjacentElement('afterend', fig)
        }
      }
    }

