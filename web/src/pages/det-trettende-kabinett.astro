    interface VhRoom { key: string; name: string; principle: string }
    const VH_ROOMS: VhRoom[] = [
      { key: 'sand',   name: 'Sandrommet',     principle: 'oppmerksomheten styres' },
      { key: 'marked', name: 'Markedsplassen', principle: 'språket er misdireksjon' },
      { key: 'salong', name: 'Salongen',       principle: 'teknologi utkledd som magi' },
      { key: 'seanse', name: 'Seansen',        principle: 'troen gjør halve trikset' },
      { key: 'teater', name: 'Teateret',       principle: 'metoden kjøpes før effekten selges' },
      { key: 'kino',   name: 'Kinoen',         principle: 'klippet er forsvinningsnummeret' },
    ]
    const VH_SCENARIOS = [
      { text: 'En «tenkende maskin» slår alle i sjakk på verdensutstillingen.', room: 'salong' },
      { text: 'I stummende mørke letter bordet — og alle rundt det kjenner det.', room: 'seanse' },
      { text: 'På lerretet svever helten til værs — uten et klipp å se.', room: 'kino' },
      { text: 'Utbryteren lar salen «velge» kisten han skal låses inn i.', room: 'teater' },
    ]
    let vhPath = state.path['vinterhagen'] || ''
    let vhHintsUsed = 0
    let vhWrong = 0
    let vhSelected = -1
    let vhMatched: number[] = []

    const VH_HINTS = [
      'To av rommene på listen hører ikke hjemme i noen av fortellingene.',
      'Maskinen som tenker … hvem satt inni skapet i Salongen?',
      'Kisten som «velges fritt» ble valgt lenge før forestillingen — som i Teateret.',
    ]
    wireHints('vh-hint-btn', 'vh-hints', VH_HINTS, () => { vhHintsUsed++ })

    function vhRender() {
      const sc = $('vh-scen')
      const rm = $('vh-rooms')
      sc.innerHTML = ''
      rm.innerHTML = ''
      VH_SCENARIOS.forEach((s, i) => {
        const btn = document.createElement('button')
        btn.className = 'match-item'
        btn.textContent = s.text
        btn.disabled = vhMatched.includes(i)
        if (vhMatched.includes(i)) btn.classList.add('match-item--done')
        if (vhSelected === i) btn.classList.add('match-item--selected')
        btn.addEventListener('click', () => {
          vhSelected = vhSelected === i ? -1 : i
          vhRender()
        })
        sc.appendChild(btn)
      })
      for (const room of VH_ROOMS) {
        const used = VH_SCENARIOS.findIndex((s, i) => s.room === room.key && vhMatched.includes(i)) >= 0
        const btn = document.createElement('button')
        btn.className = 'match-item match-item--secret'
        btn.innerHTML = vhPath === 'mester'
          ? room.name
          : `${room.name}<br><small>${room.principle}</small>`
        btn.disabled = used
        if (used) btn.classList.add('match-item--done')
        btn.addEventListener('click', () => {
          if (vhSelected < 0) {
            $('vh-msg').textContent = 'Velg en fortelling først — så rommet den hører hjemme i.'
            return
          }
          if (VH_SCENARIOS[vhSelected].room === room.key) {
            vhMatched.push(vhSelected)
            vhSelected = -1
            $('vh-msg').textContent = vhMatched.length < VH_SCENARIOS.length
              ? 'Riktig — nordlyset bølger anerkjennende over glasstaket.'
              : ''
            vhRender()
            if (vhMatched.length === VH_SCENARIOS.length) vhSolve()
          } else {
            vhWrong++
            vhSelected = -1
            $('vh-msg').textContent = 'Isrosene på ruten tetner. Det paret hører ikke sammen.'
            vhRender()
          }
        })
        rm.appendChild(btn)
      }
    }

