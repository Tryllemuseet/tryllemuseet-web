    function renderPorten() {
      const values = new Set(state.cards.map(c => parseInt(c)))
      let all12 = true
      for (let v = 1; v <= 12; v++) if (!values.has(v)) all12 = false
      if (all12) {
        $('po-msg').textContent = t(
          'Søkket i treverket har nøyaktig stokkens form. Døren venter.',
          'The recess in the woodwork has exactly the shape of your deck. The door waits.',
        )
        ;($('po-place') as HTMLButtonElement).disabled = false
      } else {
        $('po-msg').textContent = t(
          'Døren teller tolv verdier — og stokken din mangler noen. Rommene husker deg; en ny natt kan samle resten.',
          'The door counts twelve values — and your deck is missing some. The rooms remember you; a new night can gather the rest.',
        )
        ;($('po-place') as HTMLButtonElement).disabled = true
      }
    }

    $('po-place').addEventListener('click', async () => {
      $('po-place-row').hidden = true
      const box = $('po-cards')
      box.innerHTML = ''
      for (const v of [10, 11, 12]) {
        state.cards.includes(cardCode(v, 'ruter')) || state.cards.push(cardCode(v, 'ruter'))
        box.appendChild(miniCard(v, 'ruter'))
      }
      save()
      updateDeckCount()
      toast(t('🃏 Tre nye kort: <strong>de siste ruterne</strong> — dørens gave', '🃏 Three new cards: <strong>the last diamonds</strong> — the door’s gift'))
      const full = state.cards.filter(c => parseInt(c) <= 12).length === TOTAL_ACT4
      $('po-door-msg').textContent = full
        ? t(
            'Døren gir etter med noe som ligner en akkord: hel stokk, hel dør. Den svinger opp uten en lyd.',
            'The door gives way with something like a chord: whole deck, whole door. It swings open without a sound.',
          )
        : t(
            'Døren gir etter, tung og langsom. Den teller det som teller — og du har det med deg.',
            'The door gives way, heavy and slow. It counts what counts — and you carry it with you.',
          )
      await sleep(400)
      $('po-lesson').hidden = false
    })

    $('po-enter').addEventListener('click', () => goTo('kabinettet'))

    // ═══ DET TRETTENDE KABINETTET ════════════════════════════════
    interface KbChoice { key: string; label: string; line: string }
    const KB_EFFECTS: KbChoice[] = lang === 'en' ? [
      { key: 'forsvinner', label: 'Something vanishes',
        line: 'make the museum’s old lantern vanish into thin air' },
      { key: 'svever', label: 'Something floats',
        line: 'let the mirror from the Mirror Passage float freely over the edge of the stage' },
      { key: 'tanker', label: 'A mind is read',
        line: 'read the mind of a stranger in the house — right on the first try' },
      { key: 'heles', label: 'Something broken is made whole',
        line: 'smash the Director’s pocket watch and hand it back whole' },
    ] : [
      { key: 'forsvinner', label: 'Noe forsvinner',
        line: 'lar museets gamle lykt forsvinne i løse luften' },
      { key: 'svever', label: 'Noe svever',
        line: 'lar speilet fra Speilgangen sveve fritt over scenekanten' },
      { key: 'tanker', label: 'Tankene leses',
        line: 'leser tanken til en fremmed i salen — riktig på første forsøk' },
      { key: 'heles', label: 'Noe knust heles',
        line: 'knuser Direktørens lommeur og gir det tilbake helt' },
    ]
    const KB_METHODS: KbChoice[] = lang === 'en' ? [
      { key: 'forberedt', label: 'Prepared long before the performance',
        line: 'the method was bought yesterday, as the Theatre taught you' },
      { key: 'teknikk', label: 'Hidden in the mechanics',
        line: 'a craft of cogwheels and counterweights, inherited from the Salon and the Workshop' },
      { key: 'sprak', label: 'Hidden in the words',
        line: 'the secret is shouted aloud in the patter, as the conjurer did on the Market Square' },
      { key: 'klipp', label: 'Placed in the moment no one sees',
        line: 'the move itself happens in a blink, like the Cinema’s cut and the Gallery’s swap' },
    ] : [
      { key: 'forberedt', label: 'Forberedt lenge før forestillingen',
        line: 'metoden ble kjøpt i går, slik Teateret lærte deg' },
      { key: 'teknikk', label: 'Skjult i mekanikken',
        line: 'et håndverk av tannhjul og motvekter, arvet fra Salongen og Verkstedet' },
      { key: 'sprak', label: 'Gjemt i ordene',
        line: 'hemmeligheten ropes høyt i patteren, slik gjøgleren gjorde på Markedsplassen' },
      { key: 'klipp', label: 'Lagt i øyeblikket ingen ser',
        line: 'selve grepet skjer i et blunk, som Kinoens klipp og Galleriets bytte' },
    ]
    const KB_MISDIRECTIONS: KbChoice[] = lang === 'en' ? [
      { key: 'hvile', label: 'The resting hand',
        line: 'while every eye follows what moves, the calm hand does the work — the Sand Room’s oldest lesson' },
      { key: 'valg', label: 'The free choice',
        line: 'the audience’s “free” choices lead them to the outcome themselves, as the Mirror Passage showed you' },
      { key: 'tro', label: 'The darkness and the belief',
        line: 'the house believes before it sees, and belief does half the trick — the Séance’s lesson' },
      { key: 'ramme', label: 'The frame',
        line: 'you show them exactly where to look, and never where not to — as the Studio framed the gaze' },
    ] : [
      { key: 'hvile', label: 'Den hvilende hånden',
        line: 'mens alle øyne følger det som beveger seg, gjør den rolige hånden jobben — Sandrommets eldste lekse' },
      { key: 'valg', label: 'Det frie valget',
        line: 'publikums «frie» valg leder dem selv til utfallet, slik Speilgangen viste deg' },
      { key: 'tro', label: 'Mørket og troen',
        line: 'salen tror før den ser, og troen gjør halve trikset — Seansens lærdom' },
      { key: 'ramme', label: 'Rammen',
        line: 'du viser dem nøyaktig hvor de skal se, og aldri hvor de ikke skal — slik Studioet rammet inn blikket' },
    ]
    const kbPicked: Record<string, KbChoice | null> = { effect: null, method: null, mis: null }

    function kbRenderGroup(containerId: string, choices: KbChoice[], slot: 'effect' | 'method' | 'mis') {
      const box = $(containerId)
      box.innerHTML = ''
      for (const c of choices) {
        const btn = document.createElement('button')
        btn.className = 'mp-cup' + (kbPicked[slot]?.key === c.key ? ' mp-cup--picked' : '')
        btn.textContent = c.label
        btn.addEventListener('click', () => {
          kbPicked[slot] = kbPicked[slot]?.key === c.key ? null : c
          kbRenderAll()
        })
        box.appendChild(btn)
      }
    }

    function kbRenderAll() {
      kbRenderGroup('kb-effects', KB_EFFECTS, 'effect')
      kbRenderGroup('kb-methods', KB_METHODS, 'method')
      kbRenderGroup('kb-misdirections', KB_MISDIRECTIONS, 'mis')
      ;($('kb-perform') as HTMLButtonElement).disabled = !(kbPicked.effect && kbPicked.method && kbPicked.mis)
    }

    $('kb-perform').addEventListener('click', () => {
      if (!(kbPicked.effect && kbPicked.method && kbPicked.mis)) return
      const name = (state.stageName || t('Den navnløse', 'The Nameless')).toUpperCase()
      $('kb-act').innerHTML = lang === 'en'
        ? `The work light dies. One heartbeat of darkness — then the stage blazes up. ON STAGE: <strong>${name}</strong>! ` +
          `For an audience that does not exist yet, you ${kbPicked.effect.line}. ` +
          `Nobody in the house suspects that ${kbPicked.method.line}. ` +
          `And nobody sees it — because ${kbPicked.mis.line}.`
        : `Arbeidslyset dør. Ett hjerteslag av mørke — så flammer scenen opp. PÅ SCENEN: <strong>${name}</strong>! ` +
          `For et publikum som ikke finnes ennå, ${kbPicked.effect.line}. ` +
          `Ingen i salen aner at ${kbPicked.method.line}. ` +
          `Og ingen ser det — for ${kbPicked.mis.line}.`
      const kingsBox = $('kb-kings')
      kingsBox.innerHTML = ''
      for (const suit of SUIT_ORDER) {
        state.cards.includes(cardCode(13, suit)) || state.cards.push(cardCode(13, suit))
        kingsBox.appendChild(miniCard(13, suit))
      }
      save()
      updateDeckCount()
      toast(t('🃏 Fire nye kort: <strong>kongene</strong> — Kabinettets siste gave', '🃏 Four new cards: <strong>the kings</strong> — the Cabinet’s final gift'))
      renderFacts('kb-facts', 'kabinettet')
      $('kb-compose').hidden = true
      $('kb-performance').hidden = false
      window.scrollTo({ top: 0, behavior: reducedMotion ? 'auto' : 'smooth' })
    })

    $('kb-continue').addEventListener('click', () => goTo('daggry'))

    // ═══ DAGGRY ══════════════════════════════════════════════════
    function daggryRank(): string {
      const n = state.cards.length
      if (n >= TOTAL_DECK) return t('Kabinettets mester', 'Master of the Cabinet')
      if (n >= TOTAL_DECK - 3) return t('Direktørens fortrolige', 'The Director’s Confidant')
      return t('Direktørens lærling', 'The Director’s Apprentice')
    }

    function renderDaggry() {
      const n = state.cards.length
      let txt = lang === 'en'
        ? `You step out into the morning light with ${n} of ${TOTAL_DECK} cards`
        : `Du går ut i morgenlyset med ${n} av ${TOTAL_DECK} kort`
      txt += gildedPhrase(state.gilded.length)
      txt += n >= TOTAL_DECK
        ? t('En hel stokk. Direktøren sier ingenting — han bukker.', 'A complete deck. The Director says nothing — he bows.')
        : t(
            'Det som mangler, venter i rommene: kuriositetene gjemmer seg fortsatt for den som begynner en ny natt.',
            'What is missing waits in the rooms: the curiosities are still hiding for whoever begins a new night.',
          )
      $('dg-deck-summary').textContent = txt
      $('dg-rank-line').innerHTML = lang === 'en'
        ? `Your letter of apprenticeship has been made out with the title <strong>${daggryRank()}</strong>.`
        : `Lærlingbrevet ditt er skrevet ut med tittelen <strong>${daggryRank()}</strong>.`
      renderFacts('dg-facts', 'daggry')
    }

    function diplomaSvg(name: string, rank: string, cards: number): string {
      const n = escapeXml(name.toUpperCase())
      const r = escapeXml(rank)
      return `<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="900" viewBox="0 0 1200 900">
        <rect width="1200" height="900" fill="#F5EBD8"/>
        <rect x="30" y="30" width="1140" height="840" fill="none" stroke="#8a6a15" stroke-width="6"/>
        <rect x="48" y="48" width="1104" height="804" fill="none" stroke="#8a6a15" stroke-width="2"/>
        <text x="600" y="130" text-anchor="middle" fill="#8a6a15" font-family="Georgia, serif" font-size="30" letter-spacing="10">${t('DET TRETTENDE KABINETT', 'THE THIRTEENTH CABINET')}</text>
        <text x="600" y="230" text-anchor="middle" fill="#3D0E15" font-family="Georgia, serif" font-size="72" font-weight="bold">${t('LÆRLINGBREV', 'LETTER OF APPRENTICESHIP')}</text>
        <text x="600" y="320" text-anchor="middle" fill="#2b1a12" font-family="Georgia, serif" font-size="28" font-style="italic">${t('Det bevitnes herved at', 'This is to certify that')}</text>
        <text x="600" y="410" text-anchor="middle" fill="#3D0E15" font-family="Georgia, serif" font-size="56" font-weight="bold">${n}</text>
        <text x="600" y="490" text-anchor="middle" fill="#2b1a12" font-family="Georgia, serif" font-size="26">${t(`har vandret gjennom Kabinettets tretten rom, samlet ${cards} av 52 kort,`, `has wandered the Cabinet’s thirteen rooms, collected ${cards} of 52 cards,`)}</text>
        <text x="600" y="530" text-anchor="middle" fill="#2b1a12" font-family="Georgia, serif" font-size="26">${t('og opptas i lauget med tittelen', 'and is admitted to the guild with the title')}</text>
        <text x="600" y="610" text-anchor="middle" fill="#3D0E15" font-family="Georgia, serif" font-size="44" font-weight="bold" font-style="italic">${r}</text>
        <text x="600" y="700" text-anchor="middle" fill="#8a6a15" font-family="Georgia, serif" font-size="34">♠ ♥ ♦ ♣</text>
        <text x="600" y="770" text-anchor="middle" fill="#2b1a12" font-family="Georgia, serif" font-size="24" font-style="italic">${t('gitt i daggryet, mellom natt og dag — Direktøren', 'given at dawn, between night and day — the Director')}</text>
        <text x="600" y="820" text-anchor="middle" fill="#8a6a15" font-family="Georgia, serif" font-size="20" letter-spacing="4">TRYLLEMUSEET · ÅRVOLL GÅRD</text>
      </svg>`
    }

    function downloadDiploma() {
      const svg = diplomaSvg(state.stageName || t('Den navnløse', 'The Nameless'), daggryRank(), state.cards.length)
      const blob = new Blob([svg], { type: 'image/svg+xml;charset=utf-8' })
      const url = URL.createObjectURL(blob)
      const img = new Image()
      img.onload = () => {
        const canvas = document.createElement('canvas')
        canvas.width = 1200
        canvas.height = 900
        canvas.getContext('2d')!.drawImage(img, 0, 0)
        URL.revokeObjectURL(url)
        const a = document.createElement('a')
        a.href = canvas.toDataURL('image/png')
        a.download = 'det-trettende-kabinett-laerlingbrev.png'
        a.click()
      }
      img.onerror = () => {
        URL.revokeObjectURL(url)
        const a = document.createElement('a')
        a.href = 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(svg)
        a.download = 'det-trettende-kabinett-laerlingbrev.svg'
        a.click()
      }
      img.src = url
    }

    $('dg-diploma').addEventListener('click', downloadDiploma)
    $('dg-poster').addEventListener('click', downloadPoster)
    $('dg-deck').addEventListener('click', () => { renderDeck(); deckModal.showModal() })

    // ── Init ─────────────────────────────────────────────────────
    updateDeckCount()
    sgRenderStep1()
    gaRender()
    seRender()
    fvRender()
    kbRenderAll()
    if (state.stage !== 'brevet') {
      // Resume: rebuild the small bits of scene state the stages need
      if (state.stageName) $('fj-book-line').textContent = `~ ${state.stageName} ~`
      goTo(state.stage, true)
      // Re-enter puzzle rooms via the path choice so their state is fresh
      if (state.stage === 'sandrommet') {
        $('sr-pathchoice').hidden = false
        $('sr-game').hidden = true
      }
      if (state.stage === 'markedsplassen') {
        $('mp-pathchoice').hidden = false
        $('mp-game').hidden = true
      }
      if (state.stage === 'biblioteket') {
        $('bl-pathchoice').hidden = false
        $('bl-game').hidden = true
      }
      if (state.stage === 'salongen') {
        $('sl-pathchoice').hidden = false
        $('sl-game').hidden = true
      }
      if (state.stage === 'seansen') {
        $('se-pathchoice').hidden = false
        $('se-game').hidden = true
      }
      if (state.stage === 'teateret') {
        $('te-pathchoice').hidden = false
        $('te-game').hidden = true
      }
      if (state.stage === 'kinoen') {
        $('ki-pathchoice').hidden = false
        $('ki-game').hidden = true
      }
      if (state.stage === 'verkstedet') {
        $('vs-pathchoice').hidden = false
        $('vs-game').hidden = true
      }
      if (state.stage === 'studioet') {
        $('st-pathchoice').hidden = false
        $('st-game').hidden = true
      }
      if (state.stage === 'gatehjornet') {
        $('gh-pathchoice').hidden = false
        $('gh-game').hidden = true
      }
      if (state.stage === 'vinterhagen') {
        $('vh-pathchoice').hidden = false
        $('vh-game').hidden = true
      }
      toast(lang === 'en'
        ? `Welcome back${state.stageName ? ', ' + state.stageName : ''} — the Cabinet remembers you. 🕯️`
        : `Velkommen tilbake${state.stageName ? ', ' + state.stageName : ''} — Kabinettet husker deg. 🕯️`)
    } else {
      goTo('brevet', true)
    }
  }
</script>

<style>
  /* ── HERO ──────────────────────────────────────────────────────── */
  .hero { background: var(--burgundy-dk); padding: 3.5rem 0 2.5rem; border-bottom: 2px solid var(--gold-dark); color: var(--cream); transition: padding 250ms ease; }
  .hero h1 { font-size: clamp(2rem, 5vw, 3rem); color: var(--cream); margin: 0.5rem 0 0.75rem; transition: font-size 250ms ease; }
  .hero-sub { font-family: var(--font-ui); font-size: 1rem; opacity: 0.8; max-width: 560px; line-height: 1.6; }

  /* Once the game is underway the hero shrinks to a slim bar; clicking
     (or Enter/Space) toggles the full intro back. */
  .hero--playing { cursor: pointer; }
  .hero--playing h1::after { content: ' ▴'; font-size: 0.55em; opacity: 0.55; }
  .hero--compact { padding: 0.8rem 0 0.7rem; }
  .hero--compact h1 { font-size: 1.05rem; margin: 0; }
  .hero--compact h1::after { content: ' ▾'; }
  .hero--compact .section-label, .hero--compact .hero-sub { display: none; }

  .game-main { padding: 2.5rem 1.5rem 5rem; max-width: 760px; }

  /* ── SPILL-LINJE ───────────────────────────────────────────────── */
  .gamebar { display: flex; justify-content: space-between; align-items: center; gap: 0.75rem; margin-bottom: 1.25rem; flex-wrap: wrap; }
  .gamebar-group { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .gamebar-btn { font-family: var(--font-ui); font-size: 0.85rem; font-weight: 700; color: var(--cream); background: var(--burgundy); border: 1.5px solid var(--gold-dark); border-radius: 999px; padding: 0.5rem 1.1rem; transition: background 150ms; }
  .gamebar-btn:hover { background: var(--burgundy-dk); }
  .gamebar-btn--quiet { background: transparent; color: var(--grey); border-color: var(--cream-dark); }
  .gamebar-btn--quiet:hover { color: var(--burgundy); background: transparent; }

  /* ── SCENER ────────────────────────────────────────────────────── */
  .scene-label { font-family: var(--font-ui); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--gold-dark); margin-bottom: 0.35rem; }
  .scene-heading { font-family: var(--font-display); font-size: clamp(1.6rem, 4vw, 2.2rem); color: var(--burgundy); margin-bottom: 0.75rem; }
  .scene-intro { font-family: var(--font-body); font-size: 1.05rem; line-height: 1.65; color: var(--ink-mid); margin-bottom: 1.5rem; max-width: 62ch; }
  /* :global — the intro HTML comes from set:html (rich text from Sanity)
     and gets no Astro scope attributes; same for the JS-inserted figures. */
  .scene-intro :global(p) { margin-bottom: 0.75em; }
  .scene-intro :global(p:last-child) { margin-bottom: 0; }
  .scene-intro :global(a) { color: var(--burgundy); text-decoration: underline; }
  :global(body.kabinett-natt) .scene-intro :global(a) { color: var(--gold); }
  .scene-intro :global(.pt-image) { margin: 1rem 0; }
  .scene-intro :global(.pt-image img) { max-width: 100%; height: auto; border-radius: 8px; border: 3px solid var(--gold-dark); box-shadow: var(--shadow); }
  :global(.scene-image) { margin: 0 0 1.5rem; max-width: 62ch; }
  :global(.scene-image img) { max-width: 100%; height: auto; border-radius: 8px; border: 3px solid var(--gold-dark); box-shadow: var(--shadow); display: block; }

  .panel { position: relative; background: var(--burgundy-dk); color: var(--cream); border: 1px solid var(--gold-dark); border-radius: 10px; padding: 1.75rem 1.5rem; box-shadow: var(--shadow); margin-bottom: 1.25rem; }
  .panel--solved { background: white; color: var(--ink); }

  .field-label { font-family: var(--font-ui); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--gold); margin-bottom: 0.5rem; }
  .panel--solved .field-label { color: var(--gold-dark); }

  .btn-gold { display: inline-block; font-family: var(--font-ui); font-size: 0.95rem; font-weight: 700; color: var(--burgundy-dk); background: var(--gold); border-radius: 6px; padding: 0.7rem 1.5rem; transition: background 150ms; text-align: center; }
  .btn-gold:hover { background: var(--gold-light); }
  .btn-quiet { font-family: var(--font-ui); font-size: 0.875rem; font-weight: 600; color: var(--grey); padding: 0.7rem 1rem; border-radius: 6px; transition: color 150ms; }
  .panel .btn-quiet { color: var(--cream); opacity: 0.75; }
  .panel .btn-quiet:hover { opacity: 1; }
  .btn-row { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 1rem; }

  .game-msg { font-family: var(--font-ui); font-size: 0.95rem; line-height: 1.6; margin: 0.9rem 0; }
  .game-msg--good { color: var(--gold-light, var(--gold)); }
  .game-msg--dim { opacity: 0.65; font-size: 0.85rem; }
  .game-msg--think { font-style: italic; opacity: 0.85; }

  /* ── BREVET ────────────────────────────────────────────────────── */
  /* display:flex would otherwise beat the hidden attribute's display:none */
  .scene--letter { display: flex; justify-content: center; }
  .scene--letter[hidden] { display: none; }
  .letter { background: var(--cream); border: 1px solid var(--gold-dark); border-radius: 6px; padding: 2.5rem 2rem; max-width: 520px; text-align: center; box-shadow: var(--shadow); }
  .letter-seal { font-size: 2.5rem; margin-bottom: 0.75rem; }
  .letter-heading { font-family: var(--font-display); font-size: 1.5rem; color: var(--burgundy); margin-bottom: 1rem; }
  .letter-body { font-family: var(--font-body); font-style: italic; line-height: 1.7; color: var(--ink); margin-bottom: 1rem; }
  .letter-sign { font-family: var(--font-ui); font-size: 0.8rem; color: var(--grey); margin-bottom: 1.75rem; }

  /* ── FOAJEEN ───────────────────────────────────────────────────── */
  .guestbook { background: var(--cream); color: var(--ink); border-radius: 6px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border: 1px solid var(--gold-dark); }
  .guestbook-label { font-family: var(--font-ui); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--gold-dark); margin-bottom: 0.4rem; }
  .guestbook-line { font-family: var(--font-display); font-size: 1.4rem; font-style: italic; color: var(--burgundy); border-bottom: 1px solid var(--cream-dark); min-height: 1.8rem; }
  .field-row { display: flex; gap: 0.6rem; flex-wrap: wrap; }
  .field-row input { flex: 1 1 200px; font-family: var(--font-ui); font-size: 1rem; padding: 0.65rem 0.9rem; border: 1.5px solid var(--gold-dark); border-radius: 6px; background: var(--cream); color: var(--ink); }

  .lookaway { position: fixed; inset: 0; z-index: 100; background: #0a0507f2; color: var(--cream); display: flex; align-items: center; justify-content: center; text-align: center; padding: 2rem; font-family: var(--font-display); font-size: clamp(1.1rem, 3vw, 1.6rem); font-style: italic; }
  .lookaway[hidden] { display: none; }

  /* ── KORT ──────────────────────────────────────────────────────── */
  /* :global() on everything the game engine creates at runtime — scoped
     selectors only match elements stamped with the Astro scope attribute,
     which JS-created nodes never get. */
  :global(.card-row) { display: flex; gap: 0.5rem; flex-wrap: wrap; margin: 1rem 0; }
  :global(.pcard) { display: inline-flex; flex-direction: column; align-items: center; justify-content: center; width: 52px; height: 74px; background: white; color: #1a1a1a; border: 1px solid #00000033; border-radius: 6px; font-family: var(--font-display); box-shadow: 0 2px 5px #00000040; }
  :global(.pcard--big) { width: 64px; height: 92px; }
  :global(.pcard--red) { color: #B0342C; }
  :global(.pcard--empty) { background: #ffffff14; color: var(--cream); border-style: dashed; border-color: var(--gold-dark); opacity: 0.7; }
  :global(.pcard--gilded) { box-shadow: 0 0 0 2px var(--gold), 0 2px 8px #c9a22766; }
  :global(.pcard-face) { font-size: 1.3rem; font-weight: 700; line-height: 1; }
  :global(.pcard-suit) { font-size: 1.15rem; line-height: 1.2; }

