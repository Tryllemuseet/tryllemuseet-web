    // ═══ DET FRIE VALGET (SPEILGANGEN: EQUIVOQUE) ════════════════
    const FV_ITEMS = lang === 'en' ? [
      { key: 'lykt',   icon: '🏮', name: 'The lantern' },
      { key: 'speil',  icon: '🪞', name: 'The mirror' },
      { key: 'kort',   icon: '🃏', name: 'The deck of cards' },
    ] : [
      { key: 'lykt',   icon: '🏮', name: 'Lykten' },
      { key: 'speil',  icon: '🪞', name: 'Speilet' },
      { key: 'kort',   icon: '🃏', name: 'Kortstokken' },
    ]
    const FV_TARGET = 'speil'
    let fvPhase: 'pickTwo' | 'pickOne' | 'done' = 'pickTwo'
    let fvPicked: string[] = []
    let fvRemaining = FV_ITEMS.map(i => i.key)
    let fvReceipts: string[] = []

    function fvName(key: string) { return FV_ITEMS.find(i => i.key === key)!.name }

    function fvRender() {
      const box = $('fv-items')
      box.innerHTML = ''
      for (const item of FV_ITEMS) {
        if (!fvRemaining.includes(item.key)) continue
        const btn = document.createElement('button')
        btn.className = 'fv-item' + (fvPicked.includes(item.key) ? ' fv-item--picked' : '')
        btn.innerHTML = `<span class="fv-icon" aria-hidden="true">${item.icon}</span><span>${item.name}</span>`
        btn.disabled = fvPhase === 'done'
        btn.addEventListener('click', () => fvPick(item.key))
        box.appendChild(btn)
      }
    }

    function fvLogLine(text: string) {
      const li = document.createElement('li')
      li.textContent = text
      $('fv-log').appendChild(li)
    }

    async function fvPick(key: string) {
      if (fvPhase === 'pickTwo') {
        if (fvPicked.includes(key)) {
          fvPicked = fvPicked.filter(k => k !== key)
          fvRender()
          return
        }
        fvPicked.push(key)
        fvRender()
        if (fvPicked.length < 2) return
        const keepPair = fvPicked.includes(FV_TARGET)
        const other = FV_ITEMS.map(i => i.key).find(k => !fvPicked.includes(k))!
        if (keepPair) {
          fvLogLine(lang === 'en'
            ? `You pointed at ${fvName(fvPicked[0]).toLowerCase()} and ${fvName(fvPicked[1]).toLowerCase()}. “Those two we keep,” says the Director — and clears away ${fvName(other).toLowerCase()}.`
            : `Du pekte på ${fvName(fvPicked[0]).toLowerCase()} og ${fvName(fvPicked[1]).toLowerCase()}. «De to beholder vi,» sier Direktøren — og rydder bort ${fvName(other).toLowerCase()}.`)
          fvReceipts.push(t(
            'Paret ditt inneholdt speilet → valget ble tolket som «behold».',
            'Your pair contained the mirror → the choice was interpreted as “keep”.',
          ))
          fvRemaining = [...fvPicked]
        } else {
          fvLogLine(lang === 'en'
            ? `You pointed at ${fvName(fvPicked[0]).toLowerCase()} and ${fvName(fvPicked[1]).toLowerCase()}. “Those two we clear away,” says the Director.`
            : `Du pekte på ${fvName(fvPicked[0]).toLowerCase()} og ${fvName(fvPicked[1]).toLowerCase()}. «De to rydder vi bort,» sier Direktøren.`)
          fvReceipts.push(t(
            'Paret ditt inneholdt ikke speilet → valget ble tolket som «fjern».',
            'Your pair did not contain the mirror → the choice was interpreted as “remove”.',
          ))
          fvRemaining = [other]
        }
        fvPicked = []
        await sleep(300)
        if (fvRemaining.length === 2) {
          fvPhase = 'pickOne'
          $('fv-msg').innerHTML = t(
            'To gjenstander igjen. <strong>Pek på én av dem</strong> — fortsatt helt fritt.',
            'Two objects left. <strong>Point at one of them</strong> — still entirely freely.',
          )
        } else {
          fvFinish()
        }
        fvRender()
      } else if (fvPhase === 'pickOne') {
        if (key === FV_TARGET) {
          fvLogLine(t(
            'Du pekte på speilet. «Det beholder du,» sier Direktøren — og rydder bort det siste.',
            'You pointed at the mirror. “That one you keep,” says the Director — and clears away the last one.',
          ))
          fvReceipts.push(t(
            'Du pekte på speilet → valget ble tolket som «behold».',
            'You pointed at the mirror → the choice was interpreted as “keep”.',
          ))
          fvRemaining = [FV_TARGET]
        } else {
          fvLogLine(lang === 'en'
            ? `You pointed at ${fvName(key).toLowerCase()}. “That one we clear away,” says the Director.`
            : `Du pekte på ${fvName(key).toLowerCase()}. «Det rydder vi bort,» sier Direktøren.`)
          fvReceipts.push(t(
            'Du pekte på noe annet enn speilet → valget ble tolket som «fjern».',
            'You pointed at something other than the mirror → the choice was interpreted as “remove”.',
          ))
          fvRemaining = [FV_TARGET]
        }
        fvFinish()
        fvRender()
      }
    }

    function fvFinish() {
      fvPhase = 'done'
      $('fv-msg').textContent = t('Én gjenstand står igjen på bordet: speilet.', 'One object remains on the table: the mirror.')
      $('fv-envelope').innerHTML = t(
        '✉️ <em>Direktøren bryter seglet og leser høyt: «Lærlingen velger fritt — og ender med speilet. Slik måtte det gå.»</em>',
        '✉️ <em>The Director breaks the seal and reads aloud: “The apprentice chooses freely — and ends up with the mirror. It had to go this way.”</em>',
      )
      $('fv-verdict').textContent = t('Spådommen stemmer. Selvfølgelig gjør den det.', 'The prediction is correct. Of course it is.')
      awardCard(5, 'ruter', t('Illusjonskortet fra Det frie valget', 'The illusion card of the Free Choice'))
      $('fv-result').hidden = false
    }

