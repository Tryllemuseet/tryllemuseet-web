        awardCard(6, 'spar', 'Sigillet fra Seansen')
        if (gild && !state.gilded.includes('6-spar')) {
          state.gilded.push('6-spar')
          save()
        }
        renderFacts('se-facts', 'seansen')
        $('se-solved').hidden = false
