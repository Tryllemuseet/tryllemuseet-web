<script>
  interface GFact { text: string; linkUrl?: string; linkLabel?: string; imageUrl?: string; imageAlt?: string }
  interface GRoomLang { title: string; introHtml: string; facts: GFact[] }
  interface GRoom { nb: GRoomLang; en: GRoomLang; imageUrl?: string; imageAlt?: string; imageAltEn?: string }
  interface GHeroLang { title: string; intro: string }
  interface GData {
    rooms: Record<string, GRoom>
    museumAddress?: string
    englishEnabled?: boolean
    hero?: { nb: GHeroLang; en: GHeroLang }
  }

  const dataEl = document.getElementById('kabinett-data')
  if (dataEl) {
    const data: GData = JSON.parse(dataEl.textContent ?? '{}')

    const $ = (id: string) => document.getElementById(id)!
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const sleep = (ms: number) => new Promise(r => setTimeout(r, reducedMotion ? Math.min(ms, 120) : ms))

    // ── Språk ────────────────────────────────────────────────────
    // The whole game runs in one language per page load; switching
    // reloads the page (progress lives in localStorage anyway).
    const englishEnabled = data.englishEnabled === true
    let storedLang: string | null = null
    try { storedLang = localStorage.getItem('kabinett-lang') } catch { /* ignore */ }
    const lang: 'nb' | 'en' = englishEnabled && storedLang === 'en' ? 'en' : 'nb'
    const t = (nb: string, en: string) => (lang === 'en' ? en : nb)
    const R = (key: string): GRoomLang | undefined => {
      const r = data.rooms[key]
      return r ? (lang === 'en' ? r.en : r.nb) : undefined
    }
    const roomTitle = (key: string) => R(key)?.title || key

    const langBtn = $('lang-btn') as HTMLButtonElement
    if (englishEnabled) {
      langBtn.hidden = false
      langBtn.textContent = lang === 'en' ? 'På norsk' : 'In English'
      langBtn.setAttribute('lang', lang === 'en' ? 'no' : 'en')
      langBtn.addEventListener('click', () => {
        try { localStorage.setItem('kabinett-lang', lang === 'en' ? 'nb' : 'en') } catch { /* ignore */ }
        location.reload()
      })
    }

