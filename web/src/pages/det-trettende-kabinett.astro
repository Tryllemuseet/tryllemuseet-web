    // ── Toppteksten: krymper når spillet er i gang, trykk veksler ─
    const heroEl = document.getElementById('game-hero')
    function updateHero(collapse: boolean) {
      if (!heroEl) return
      const playing = state.stage !== 'brevet'
      // Night falls over the whole page once the apprentice steps inside
      document.body.classList.toggle('kabinett-natt', playing)
      heroEl.classList.toggle('hero--playing', playing)
      heroEl.classList.toggle('hero--compact', playing && collapse)
      if (playing) {
        heroEl.setAttribute('role', 'button')
        heroEl.setAttribute('tabindex', '0')
        heroEl.setAttribute('aria-label', 'Vis eller skjul introduksjonen til spillet')
        heroEl.setAttribute('aria-expanded', String(!heroEl.classList.contains('hero--compact')))
      } else {
        heroEl.removeAttribute('role')
        heroEl.removeAttribute('tabindex')
        heroEl.removeAttribute('aria-label')
        heroEl.removeAttribute('aria-expanded')
      }
    }
    if (heroEl) {
      const toggleHero = () => {
        if (!heroEl.classList.contains('hero--playing')) return
        heroEl.classList.toggle('hero--compact')
        heroEl.setAttribute('aria-expanded', String(!heroEl.classList.contains('hero--compact')))
      }
      heroEl.addEventListener('click', toggleHero)
      heroEl.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleHero() }
      })
    }

    // ── Rom-overganger ───────────────────────────────────────────
    const transitionEl = $('room-transition')
    const MIRROR_STAGES: Stage[] = ['speilgangen', 'galleriet', 'oyet', 'frievalget', 'lerretet', 'minnet', 'trekanten', 'fargene']
    let transitioning = false

    function showScene(stage: Stage) {
      for (const [key, el] of Object.entries(SCENES)) el.hidden = key !== stage
      // Re-trigger the slide-in animation for the scene's blocks
      const scene = SCENES[stage]
      scene.classList.remove('scene-enter')
      void scene.offsetWidth
      scene.classList.add('scene-enter')
      if (stage === 'epilog') renderEpilog()
      if (stage === 'epilog2') renderEpilog2()
      if (stage === 'epilog3') renderEpilog3()
      if (stage === 'epilog4') renderEpilog4()
      if (stage === 'porten') renderPorten()
      if (stage === 'daggry') renderDaggry()
      updateHero(true)
    }

    async function goTo(stage: Stage, instant = false) {
      state.stage = stage
      save()
      if (instant || reducedMotion || transitioning) {
        showScene(stage)
        window.scrollTo({ top: 0, behavior: 'auto' })
        return
      }
      transitioning = true
      try {
        const mirror = MIRROR_STAGES.includes(stage)
        transitionEl.classList.toggle('room-transition--mirror', mirror)
        $('room-transition-icon').textContent = mirror ? '🪞' : '🚪'
        $('room-transition-kicker').textContent = mirror
          ? (stage === 'speilgangen' ? 'Mellomrommet venter' : 'Ut i Speilgangen')
          : 'Kabinettet åpner en ny dør'
        $('room-transition-title').textContent = data.rooms[stage]?.title || ''
        transitionEl.hidden = false
        void transitionEl.offsetWidth // reflow so the opacity transition runs
        transitionEl.classList.add('room-transition--visible')
        await sleep(520)
        if (state.stage === stage) {
          showScene(stage)
          window.scrollTo({ top: 0, behavior: 'auto' })
        }
        await sleep(950)
        transitionEl.classList.remove('room-transition--visible')
        await sleep(520)
      } finally {
        transitionEl.hidden = true
        transitioning = false
      }
    }

    // ── Kortstokken (modal) ──────────────────────────────────────
    const deckModal = $('deck-modal') as HTMLDialogElement
    function renderDeck() {
      const grid = $('deck-grid')
      grid.innerHTML = ''
      for (const value of DECK_VALUES) {
        const row = document.createElement('div')
        row.className = 'deck-row'
        const label = document.createElement('p')
        label.className = 'deck-row-label'
        label.textContent = `${VALUES[value].label} · ${VALUES[value].room}`
        row.appendChild(label)
        const slots = document.createElement('div')
        slots.className = 'deck-slots'
        for (const suit of SUIT_ORDER) {
          const code = cardCode(value, suit as Suit)
          if (state.cards.includes(code)) {
            slots.appendChild(miniCard(value, suit as Suit, state.gilded.includes(code)))
          } else {
            const empty = document.createElement('span')
            empty.className = 'pcard pcard--empty'
            const lockedFinale = (value === 10 || value === 11 || value === 12) && suit === 'ruter'
            const lockedKing = value === 13
            empty.setAttribute('role', 'img')
            empty.setAttribute('aria-label', lockedKing
              ? 'Konge — venter bak den siste døren'
              : lockedFinale
                ? `${VALUES[value].label} i ruter — kommer i finalen`
                : `Mangler: ${VALUES[value].label} i ${SUITS[suit as Suit].name}. ${SUITS[suit as Suit].earn}.`)
            empty.innerHTML = `<span class="pcard-face">?</span><span class="pcard-suit">${SUITS[suit as Suit].sym}</span>`
            empty.title = lockedKing ? 'Bak den siste døren' : lockedFinale ? 'Kommer i finalen' : SUITS[suit as Suit].earn
            slots.appendChild(empty)
          }
        }
        row.appendChild(slots)
        grid.appendChild(row)
      }
      $('deck-ghost-line').hidden = state.cards.includes('13-spar')
      const posterBtn = $('poster-download') as HTMLButtonElement
      posterBtn.hidden = !state.cards.some(c => c.endsWith('-hjerter'))
    }
