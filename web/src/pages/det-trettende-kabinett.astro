const overrides = new Map(chapters.map(c => [c.key, c]))

// What the game engine receives per room and language.
interface RoomFact { text: string; linkUrl?: string; linkLabel?: string; imageUrl?: string; imageAlt?: string }
interface RoomLang { title: string; introHtml: string; facts: RoomFact[] }
interface RoomPayload { nb: RoomLang; en: RoomLang; imageUrl?: string; imageAlt?: string; imageAltEn?: string }

// Fact texts are matched against the code defaults to inherit source links
// (the seeded room documents carry the default texts without the newer
// links) and to pair overridden facts with their English defaults. The
// seeded documents predate the «begre og kuler» → «begerspillet» rename,
// so normalize before matching.
const factKey = (t: string) => t.replace(/begre og kuler/gi, 'begerspillet')

const factImage = (img: GameImage | undefined, en: boolean) =>
  img?.asset
    ? {
        imageUrl: urlFor(img).width(640).format('webp').url(),
        imageAlt: (en ? img.altEn || img.alt : img.alt) || '',
      }
    : {}

const rooms: Record<string, RoomPayload> = {}
for (const [key, def] of Object.entries(DEFAULT_ROOMS)) {
  const o = overrides.get(key)
  const defByText = new Map(def.facts.map(f => [factKey(f.text), f]))
  const defEnByText = new Map(def.facts.map((f, i) => [factKey(f.text), def.en.facts[i]]))

  const factsNb: RoomFact[] = o?.facts?.length
    ? o.facts.map(f => {
        const d = !f.linkUrl ? defByText.get(factKey(f.text)) : undefined
        const base: RoomFact = { text: f.text, linkUrl: f.linkUrl, linkLabel: f.linkLabel, ...factImage(f.image, false) }
        return d?.linkUrl ? { ...base, linkUrl: d.linkUrl, linkLabel: f.linkLabel || d.linkLabel } : base
      })
    : def.facts.map(f => ({ ...f }))

  // English facts mirror the (possibly overridden) Norwegian list: an
  // explicit textEn wins; a fact that still matches a code default falls
  // back to that default's English; otherwise the Norwegian text is shown.
  const factsEn: RoomFact[] = o?.facts?.length
    ? o.facts.map(f => {
        const dEn = f.textEn ? undefined : defEnByText.get(factKey(f.text))
        const d = !f.linkUrl ? defByText.get(factKey(f.text)) : undefined
        return {
          text: f.textEn || dEn?.text || f.text,
          linkUrl: f.linkUrl || d?.linkUrl,
          linkLabel: f.linkLabelEn || dEn?.linkLabel || f.linkLabel || d?.linkLabel,
          ...factImage(f.image, true),
        }
      })
    : def.en.facts.map(f => ({ ...f }))

  // Custom Norwegian copy without an English counterpart falls back to the
  // game's built-in English rather than showing Norwegian in English mode.
  const introNbHtml = richToHtml(o?.introRich) || plainToHtml(o?.intro || def.intro)
  const introEnHtml =
    richToHtml(o?.introRichEn) || plainToHtml(o?.introEn || def.en.intro)

  rooms[key] = {
    nb: { title: o?.title || def.title, introHtml: introNbHtml, facts: factsNb },
    en: { title: o?.titleEn || def.en.title, introHtml: introEnHtml, facts: factsEn },
    ...(o?.image?.asset
      ? {
          imageUrl: urlFor(o.image).width(760).format('webp').url(),
          imageAlt: o.image.alt || '',
          imageAltEn: o.image.altEn || o.image.alt || '',
        }
      : {}),
  }
}

const englishEnabled = config?.englishEnabled === true
const gameTitleEn = config?.titleEn || 'Det trettende kabinett'
const gameIntroEn = config?.introEn ||
  'A magic museum that only exists between midnight and dawn. The Director takes on one apprentice per generation — and tonight, the doors stand open.'

const museumAddress = siteConfig?.address || 'Årvoll gård, Årvollveien 35\n0590 Oslo'
const payload = {
  rooms,
  museumAddress,
  englishEnabled,
  hero: {
    nb: { title: gameTitle, intro: gameIntro },
    en: { title: gameTitleEn, intro: gameIntroEn },
  },
}
// <-escape so a literal "</script>" in content can never break the page
const payloadJson = JSON.stringify(payload).replace(/</g, '\\u003c')
---

<BaseLayout
  title={`${gameTitle} — Tryllemuseet`}
  description="Et tryllemuseum som bare finnes om natten. Løs gåtene, samle kortstokken og bli Direktørens lærling — Tryllemuseets historiespill."
>

  <section class="hero" id="game-hero">
    <div class="container">
      <p class="section-label">Tryllemuseet presenterer</p>
      <h1 class="display-title">{gameTitle}</h1>
      <p class="hero-sub">{gameIntro}</p>
    </div>
  </section>

  {!isActive ? (
    <main class="container game-main">
      <div class="coming-soon">
        <span class="coming-soon-icon" aria-hidden="true">🚪🕯️</span>
        <h2>{comingSoonTitle}</h2>
        <p>{comingSoonText}</p>
        <a href="/utstillingen" class="btn-gold">Utforsk utstillingen →</a>
      </div>
    </main>
  ) : (
    <main class="container game-main" id="game-root">
      <noscript>
        <div class="coming-soon">
          <h2>Kabinettet trenger JavaScript</h2>
          <p>Spillet er en interaktiv opplevelse og krever at JavaScript er slått på i nettleseren.</p>
        </div>
      </noscript>

      <!-- ── SPILL-LINJE ─────────────────────────────────────────── -->
      <div class="gamebar">
        <div class="gamebar-group">
          <button class="gamebar-btn" id="deck-btn" aria-haspopup="dialog">🃏 Kortstokken <span id="deck-count">0/12</span></button>
          <button class="gamebar-btn" id="help-btn" aria-haspopup="dialog">❔ Hjelp</button>
          <button class="gamebar-btn" id="lang-btn" hidden>In English</button>
        </div>
        <button class="gamebar-btn gamebar-btn--quiet" id="restart-btn">Begynn på nytt</button>
      </div>

      <!-- ── SCENE: BREVET ───────────────────────────────────────── -->
      <section class="scene scene--letter" id="sc-brevet" aria-labelledby="brevet-heading">
        <div class="letter">
          <p class="letter-seal" aria-hidden="true">🕯️</p>
          <h2 id="brevet-heading" class="letter-heading">Et forseglet brev</h2>
          <p class="letter-body">
            «Til den som finner dette: Kabinettet åpner i natt, mellom midnatt og daggry.
            Direktøren tar opp én lærling per generasjon. Tolv rom kjenner vi.
            Det trettende har ingen lærling noensinne funnet.
            Ta med deg et navn du tør å skrive, og bank tre ganger.»
          </p>
          <p class="letter-sign">— uleselig signatur, men blekket er ferskt</p>
          <button class="btn-gold" id="btn-knock">Bank på porten 🚪</button>
        </div>
      </section>

      <!-- ── SCENE: FOAJEEN ──────────────────────────────────────── -->
      <section class="scene" id="sc-foajeen" hidden aria-labelledby="fj-heading">
        <p class="scene-label">Første rom · Essene</p>
        <h2 class="scene-heading" id="fj-heading">{rooms.foajeen.nb.title}</h2>
        <div class="scene-intro" set:html={rooms.foajeen.nb.introHtml} />

        <div class="panel">
          <div class="guestbook" id="fj-book" aria-live="polite">
            <p class="guestbook-label">Gjesteboken</p>
            <p class="guestbook-line" id="fj-book-line">&nbsp;</p>
          </div>

          <form id="fj-form">
            <label class="field-label" for="fj-name">Scenenavnet ditt</label>
            <div class="field-row">
              <input type="text" id="fj-name" maxlength="24" autocomplete="off" placeholder="Den store …" required />
              <button type="submit" class="btn-gold" id="fj-write">Skriv med fjærpennen ✒️</button>
            </div>
          </form>

          <p class="game-msg" id="fj-msg" aria-live="polite" hidden></p>
          <button class="btn-gold" id="fj-lookaway" hidden>Se bort et øyeblikk 👀</button>

          <div id="fj-aces" hidden>
            <p class="game-msg game-msg--good">Boken tar imot navnet ditt. Fra et sted bak talerstolen rekker Direktøren deg fire kort — <strong>essene</strong>. «Resten av stokken må du gjøre deg fortjent til.»</p>
            <div class="card-row" id="fj-aces-cards" aria-label="Fire ess"></div>
            <button class="btn-gold" id="fj-continue">Ta imot kortene og gå videre →</button>
          </div>
        </div>
      </section>

      <!-- ── SCENE: SANDROMMET ───────────────────────────────────── -->
      <section class="scene" id="sc-sandrommet" hidden aria-labelledby="sr-heading">
        <p class="scene-label">Andre rom · Toerne</p>
        <h2 class="scene-heading" id="sr-heading">{rooms.sandrommet.nb.title}</h2>
        <div class="scene-intro" set:html={rooms.sandrommet.nb.introHtml} />

        <div class="panel" id="sr-pathchoice">
          <p class="field-label">Velg din vei gjennom rommet</p>
          <div class="path-row">
            <button class="path-btn" data-scene="sr" data-path="laerling">
