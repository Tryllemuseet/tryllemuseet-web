// Concept: docs/det-trettende-kabinett-concept.md. Puzzle logic lives here;
// editors override room copy via the gameChapter documents in Sanity.
// All room copy exists in Norwegian and English; the English version is
// exposed in-game once gameConfig.englishEnabled is on.
import BaseLayout from '../layouts/BaseLayout.astro'
import { getGameConfig, getAllGameChapters, getSiteConfig, urlFor, portableTextToHtml } from '../lib/sanity'
import type { GameImage } from '../lib/sanity'

const [config, chapters, siteConfig] = await Promise.all([
  getGameConfig(),
  getAllGameChapters(),
  getSiteConfig(),
])

const isActive = config?.isActive === true

const comingSoonTitle = config?.comingSoonTitle ?? 'Dørene er ennå låst …'
const comingSoonText  = config?.comingSoonText  ??
  'Det trettende kabinett åpner snart for sin neste lærling. Kom tilbake litt senere — eller besøk oss på Årvoll gård i mellomtiden!'

const gameTitle = config?.title ?? 'Det trettende kabinett'
const gameIntro = config?.intro ??
  'Et tryllemuseum som bare finnes mellom midnatt og daggry. Direktøren tar opp én lærling per generasjon — og i natt står dørene åpne.'

// ── Text helpers ──────────────────────────────────────────────────
const escapeHtml = (s: string) =>
  s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')

// Plain text (the simple intro fields) → paragraphs.
const plainToHtml = (s: string) =>
  s
    .split(/\n{2,}/)
    .filter(p => p.trim())
    .map(p => `<p>${escapeHtml(p).replace(/\n/g, '<br>')}</p>`)
    .join('')

// Portable Text (the rich intro fields) → HTML with links and inline images.
// portableTextToHtml() (lib/sanity.ts) now handles both — kept as a thin
// alias here so call sites below don't need to change.
const richToHtml = portableTextToHtml

