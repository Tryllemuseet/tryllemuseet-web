    // ── Toppteksten: krymper når spillet er i gang, trykk veksler ─
    const heroEl = document.getElementById('game-hero')
    function updateHero(collapse: boolean) {
      if (!heroEl) return
      const playing = state.stage !== 'brevet'
      // Night falls over the whole page once the apprentice steps inside
      document.body.classList.toggle('kabinett-natt', playing)
      heroEl.classList.toggle('hero--playing', playing)
      heroEl.classList.toggle('hero--compact', playing && collapse)
      if (playing) {
        heroEl.setAttribute('role', 'button')
        heroEl.setAttribute('tabindex', '0')
        heroEl.setAttribute('aria-label', t('Vis eller skjul introduksjonen til spillet', 'Show or hide the game introduction'))
        heroEl.setAttribute('aria-expanded', String(!heroEl.classList.contains('hero--compact')))
      } else {
        heroEl.removeAttribute('role')
        heroEl.removeAttribute('tabindex')
        heroEl.removeAttribute('aria-label')
        heroEl.removeAttribute('aria-expanded')
      }
    }
    if (heroEl) {
      const toggleHero = () => {
        if (!heroEl.classList.contains('hero--playing')) return
        heroEl.classList.toggle('hero--compact')
        heroEl.setAttribute('aria-expanded', String(!heroEl.classList.contains('hero--compact')))
      }
      heroEl.addEventListener('click', toggleHero)
      heroEl.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleHero() }
      })
    }

    // ── Rom-overganger ───────────────────────────────────────────
    const transitionEl = $('room-transition')
    const MIRROR_STAGES: Stage[] = ['speilgangen', 'galleriet', 'oyet', 'frievalget', 'lerretet', 'minnet', 'trekanten', 'fargene']
    let transitioning = false

    function showScene(stage: Stage) {
      for (const [key, el] of Object.entries(SCENES)) el.hidden = key !== stage
      // Re-trigger the slide-in animation for the scene's blocks
      const scene = SCENES[stage]
      scene.classList.remove('scene-enter')
      void scene.offsetWidth
      scene.classList.add('scene-enter')
      if (stage === 'epilog') renderEpilog()
      if (stage === 'epilog2') renderEpilog2()
      if (stage === 'epilog3') renderEpilog3()
      if (stage === 'epilog4') renderEpilog4()
      if (stage === 'porten') renderPorten()
      if (stage === 'daggry') renderDaggry()
      updateHero(true)
    }

    async function goTo(stage: Stage, instant = false) {
      state.stage = stage
      save()
      if (instant || reducedMotion || transitioning) {
        showScene(stage)
        window.scrollTo({ top: 0, behavior: 'auto' })
        return
      }
      transitioning = true
      try {
        const mirror = MIRROR_STAGES.includes(stage)
        transitionEl.classList.toggle('room-transition--mirror', mirror)
        $('room-transition-icon').textContent = mirror ? '🪞' : '🚪'
        $('room-transition-kicker').textContent = mirror
          ? (stage === 'speilgangen' ? t('Mellomrommet venter', 'The passage awaits') : t('Ut i Speilgangen', 'Into the Mirror Passage'))
          : t('Kabinettet åpner en ny dør', 'The Cabinet opens a new door')
        $('room-transition-title').textContent = R(stage)?.title || ''
        transitionEl.hidden = false
        void transitionEl.offsetWidth // reflow so the opacity transition runs
        transitionEl.classList.add('room-transition--visible')
        await sleep(520)
        if (state.stage === stage) {
          showScene(stage)
          window.scrollTo({ top: 0, behavior: 'auto' })
        }
        await sleep(950)
        transitionEl.classList.remove('room-transition--visible')
        await sleep(520)
      } finally {
        transitionEl.hidden = true
        transitioning = false
      }
    }

    // ── Kortstokken (modal) ──────────────────────────────────────
    const deckModal = $('deck-modal') as HTMLDialogElement
    function renderDeck() {
      const grid = $('deck-grid')
      grid.innerHTML = ''
      for (const value of DECK_VALUES) {
        const row = document.createElement('div')
        row.className = 'deck-row'
        const label = document.createElement('p')
        label.className = 'deck-row-label'
        label.textContent = `${VALUES[value].label} · ${roomTitle(VALUES[value].roomKey)}`
        row.appendChild(label)
        const slots = document.createElement('div')
        slots.className = 'deck-slots'
        for (const suit of SUIT_ORDER) {
          const code = cardCode(value, suit as Suit)
          if (state.cards.includes(code)) {
            slots.appendChild(miniCard(value, suit as Suit, state.gilded.includes(code)))
          } else {
            const empty = document.createElement('span')
            empty.className = 'pcard pcard--empty'
            const lockedFinale = (value === 10 || value === 11 || value === 12) && suit === 'ruter'
            const lockedKing = value === 13
            empty.setAttribute('role', 'img')
            empty.setAttribute('aria-label', lockedKing
              ? t('Konge — venter bak den siste døren', 'King — waiting behind the last door')
              : lockedFinale
                ? `${VALUES[value].label} ${t('i ruter — kommer i finalen', 'of diamonds — comes in the finale')}`
                : `${t('Mangler', 'Missing')}: ${VALUES[value].label} ${t('i', 'of')} ${SUITS[suit as Suit].name}. ${SUITS[suit as Suit].earn}.`)
            empty.innerHTML = `<span class="pcard-face">?</span><span class="pcard-suit">${SUITS[suit as Suit].sym}</span>`
            empty.title = lockedKing
              ? t('Bak den siste døren', 'Behind the last door')
              : lockedFinale ? t('Kommer i finalen', 'Comes in the finale') : SUITS[suit as Suit].earn
            slots.appendChild(empty)
          }
        }
        row.appendChild(slots)
        grid.appendChild(row)
      }
      $('deck-ghost-line').hidden = state.cards.includes('13-spar')
      const posterBtn = $('poster-download') as HTMLButtonElement
      posterBtn.hidden = !state.cards.some(c => c.endsWith('-hjerter'))
    }
    $('deck-btn').addEventListener('click', () => { renderDeck(); deckModal.showModal() })
    $('deck-close').addEventListener('click', () => deckModal.close())
    deckModal.addEventListener('click', e => { if (e.target === deckModal) deckModal.close() })

    // ── Hjelp (modal) ────────────────────────────────────────────
    const helpModal = $('help-modal') as HTMLDialogElement
    $('help-btn').addEventListener('click', () => helpModal.showModal())
    $('help-close').addEventListener('click', () => helpModal.close())
    helpModal.addEventListener('click', e => { if (e.target === helpModal) helpModal.close() })

    $('restart-btn').addEventListener('click', () => {
      if (!confirm(t('Begynne helt på nytt? Kortene og fremdriften din slettes.', 'Start over completely? Your cards and progress will be deleted.'))) return
      state = blank()
      save()
      updateDeckCount()
      location.reload()
    })

    // ── Plakaten (SVG → PNG) ─────────────────────────────────────
    function escapeXml(s: string) {
      return s.replace(/[<>&'"]/g, c => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;', "'": '&apos;', '"': '&quot;' }[c] as string))
    }
    // The logo must be inlined as a data URI: SVG rendered via <img> (for the
    // canvas PNG export) is not allowed to load external resources. The source
    // PNG has an opaque white background, so fade near-white pixels to
    // transparent to get clean line art on the dark poster.
    let logoDataUri: string | null = null
    async function loadPosterLogo(): Promise<string> {
      if (logoDataUri !== null) return logoDataUri
      try {
        const img = new Image()
        img.src = '/Tryllemuseet_logo_hatt.png'
        await img.decode()
        const c = document.createElement('canvas')
        c.width = img.naturalWidth
        c.height = img.naturalHeight
        const ctx = c.getContext('2d')!
        ctx.drawImage(img, 0, 0)
        const px = ctx.getImageData(0, 0, c.width, c.height)
        const d = px.data
        for (let i = 0; i < d.length; i += 4) {
          const lightness = Math.min(d[i], d[i + 1], d[i + 2])
          if (lightness > 200) {
            d[i + 3] = Math.min(d[i + 3], Math.round(255 * (255 - lightness) / 55))
          }
        }
        ctx.putImageData(px, 0, 0)
        logoDataUri = c.toDataURL('image/png')
      } catch {
        logoDataUri = '' // render the poster without a logo if loading fails
      }
      return logoDataUri
    }
    function posterSvg(name: string, subtitle: string, logo: string): string {
      const n = escapeXml(name.toUpperCase())
      const sub = escapeXml(subtitle)
      const address = escapeXml(
        (data.museumAddress || 'Årvoll gård, Årvollveien 35\n0590 Oslo').trim().replace(/\s*\n+\s*/g, ' · '),
      )
      // Logo PNG is 316x287; keep the aspect ratio
      const logoImg = logo
        ? `<image x="384" y="80" width="132" height="120" href="${logo}"/>`
        : ''
      const titleLine1 = t('DET TRETTENDE', 'THE THIRTEENTH')
      const titleLine2 = t('KABINETT', 'CABINET')
      return `<svg xmlns="http://www.w3.org/2000/svg" width="900" height="1200" viewBox="0 0 900 1200">
        <rect width="900" height="1200" fill="#3D0E15"/>
        <rect x="30" y="30" width="840" height="1140" fill="none" stroke="#C9A227" stroke-width="6"/>
        <rect x="50" y="50" width="800" height="1100" fill="none" stroke="#C9A227" stroke-width="2"/>
        ${logoImg}
        <text x="450" y="255" text-anchor="middle" fill="#C9A227" font-family="Georgia, serif" font-size="34" letter-spacing="8">${t('TRYLLEMUSEET PRESENTERER', 'TRYLLEMUSEET PRESENTS')}</text>
        <text x="450" y="395" text-anchor="middle" fill="#F5EBD8" font-family="Georgia, serif" font-size="76" font-weight="bold">${titleLine1}</text>
        <text x="450" y="485" text-anchor="middle" fill="#F5EBD8" font-family="Georgia, serif" font-size="76" font-weight="bold">${titleLine2}</text>
        <text x="450" y="580" text-anchor="middle" fill="#C9A227" font-family="Georgia, serif" font-size="30" font-style="italic">${sub}</text>
        <text x="450" y="685" text-anchor="middle" fill="#C9A227" font-family="Georgia, serif" font-size="30" letter-spacing="6">${t('MED DEN LOVENDE LÆRLINGEN', 'FEATURING THE PROMISING APPRENTICE')}</text>
        <text x="450" y="780" text-anchor="middle" fill="#F5EBD8" font-family="Georgia, serif" font-size="60" font-weight="bold">${n}</text>
        <text x="450" y="858" text-anchor="middle" fill="#C9A227" font-family="Georgia, serif" font-size="26" font-style="italic">${t('opptatt av Direktøren selv', 'taken on by the Director himself')}</text>
        <text x="450" y="945" text-anchor="middle" fill="#F5EBD8" font-family="Georgia, serif" font-size="42">♠ ♥ ♦ ♣</text>
        <text x="450" y="1028" text-anchor="middle" fill="#C9A227" font-family="Georgia, serif" font-size="24" letter-spacing="4">${t('KUN ÉN FORESTILLING', 'ONE PERFORMANCE ONLY')}</text>
        <text x="450" y="1070" text-anchor="middle" fill="#C9A227" font-family="Georgia, serif" font-size="24" letter-spacing="4">${t('MELLOM MIDNATT OG DAGGRY', 'BETWEEN MIDNIGHT AND DAWN')}</text>
        <text x="450" y="1122" text-anchor="middle" fill="#F5EBD8" font-family="Georgia, serif" font-size="20" font-style="italic">${address}</text>
      </svg>`
    }
    async function downloadPoster() {
      const inFinale = state.cards.some(c => parseInt(c) === 13)
        || ['porten', 'kabinettet', 'daggry'].includes(state.stage)
      const inActFour = state.cards.some(c => parseInt(c) >= 10)
        || ['minnet', 'studioet', 'trekanten', 'gatehjornet', 'fargene', 'vinterhagen', 'epilog4'].includes(state.stage)
      const inActThree = state.cards.some(c => parseInt(c) >= 7)
        || ['frievalget', 'teateret', 'kinoen', 'lerretet', 'verkstedet', 'epilog3'].includes(state.stage)
      const inActTwo = state.cards.some(c => parseInt(c) >= 4)
        || ['galleriet', 'biblioteket', 'oyet', 'salongen', 'seansen', 'epilog2'].includes(state.stage)
      const subtitle = inFinale
        ? t('— alle tretten rom: natten som ble dag —', '— all thirteen rooms: the night that became day —')
        : inActFour
        ? t('— akt I–IV: den nest siste natten —', '— acts I–IV: the second-to-last night —')
        : inActThree
          ? t('— akt I–III: nettene som aldri tok slutt —', '— acts I–III: the nights that never ended —')
          : inActTwo
            ? t('— akt I–II: nettene bak forhenget —', '— acts I–II: the nights behind the curtain —')
            : t('— akt I: natten da porten gikk opp —', '— act I: the night the gate swung open —')
      const logo = await loadPosterLogo()
      const svg = posterSvg(state.stageName || t('Den navnløse', 'The Nameless'), subtitle, logo)
      const blob = new Blob([svg], { type: 'image/svg+xml;charset=utf-8' })
      const url = URL.createObjectURL(blob)
      const img = new Image()
      img.onload = () => {
        const canvas = document.createElement('canvas')
        canvas.width = 900
        canvas.height = 1200
        canvas.getContext('2d')!.drawImage(img, 0, 0)
        URL.revokeObjectURL(url)
        const a = document.createElement('a')
        a.href = canvas.toDataURL('image/png')
        a.download = 'det-trettende-kabinett-plakat.png'
        a.click()
      }
      img.onerror = () => {
        URL.revokeObjectURL(url)
        // Fallback: offer the SVG itself
        const a = document.createElement('a')
        a.href = 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(svg)
        a.download = 'det-trettende-kabinett-plakat.svg'
        a.click()
      }
      img.src = url
    }
    $('poster-download').addEventListener('click', downloadPoster)

    // ── Hint-hjelper ─────────────────────────────────────────────
    function wireHints(btnId: string, listId: string, hints: string[], onUse: () => void) {
      const btn = $(btnId) as HTMLButtonElement
      const list = $(listId)
      let idx = 0
      btn.addEventListener('click', () => {
        if (idx >= hints.length) return
        const li = document.createElement('li')
        li.textContent = lang === 'en' ? `“${hints[idx]}”` : `«${hints[idx]}»`
        list.appendChild(li)
        idx++
        onUse()
        if (idx >= hints.length) btn.disabled = true
      })
    }

