          </div>
        </div>

        <div class="panel" id="ki-game" hidden>
          <p class="game-msg" id="ki-pretext"></p>
          <div id="ki-phase1">
            <p class="game-msg">Fem filmbiter ligger hulter til bulter. <strong>Trykk på dem i riktig rekkefølge</strong> — fra første til siste bilde.</p>
            <div class="ki-strips" id="ki-strips"></div>
          </div>
          <div id="ki-phase2" hidden>
            <p class="game-msg game-msg--good">Filmen løper: damen forsvinner — og salen gisper. Men Direktøren lener seg frem: <strong>«Hvor stanset kameraet første gang?»</strong></p>
            <div class="mp-cups" id="ki-gaps"></div>
          </div>
          <button class="curiosity" id="ki-clip" aria-label="En avklippet filmbit ligger på gulvet">🎞️</button>
          <p class="game-msg" id="ki-msg" aria-live="polite"></p>

          <div class="hintbox">
            <button class="btn-quiet" id="ki-hint-btn">Direktørens hvisken (hint) 🤫</button>
            <ul class="hint-list" id="ki-hints"></ul>
          </div>
        </div>

        <div class="panel panel--solved" id="ki-solved" hidden>
          <p class="solved-title">✨ Gåten er løst</p>
          <p class="principle">«<strong>Klippet er forsvinningsnummeret</strong>, lærling. Det umulige skjer aldri mens du ser på — det skjer mellom to bilder, der kameraet sto stille og verden fikk ordne seg. Méliès skjønte det før noen andre: filmen er en tryllekunstner som aldri blir avslørt av første rad.»</p>
          <div class="facts" id="ki-facts"></div>
          <button class="btn-gold" id="ki-complete">Fullfør rommet →</button>
        </div>
      </section>

      <!-- ── SCENE: ÅNDEN PÅ LERRETET (SPEILGANGEN) ──────────────── -->
      <section class="scene" id="sc-lerretet" hidden aria-labelledby="le-heading">
        <p class="scene-label">Mellomrommet · Ruter seks</p>
        <h2 class="scene-heading" id="le-heading">{rooms.lerretet.title}</h2>
        <p class="scene-intro">{rooms.lerretet.intro}</p>

        <div class="panel">
          <div class="le-stage" id="le-stage">
            <svg viewBox="0 0 400 220" role="img" aria-label="Et lerret. Når lampen tennes, vises en sterkt rosa lykt med en hvit prikk i midten.">
              <rect x="0" y="0" width="400" height="220" fill="#241019" rx="6"/>
              <g id="le-figure" style="display:none">
                <circle cx="200" cy="105" r="62" fill="#ff2fa0"/>
                <rect x="188" y="30" width="24" height="26" fill="#ff2fa0"/>
                <rect x="170" y="166" width="60" height="14" fill="#ff2fa0"/>
                <circle cx="200" cy="105" r="4" fill="#ffffff"/>
              </g>
              <text id="le-blank-text" x="200" y="112" text-anchor="middle" fill="#6b5560" font-family="Georgia, serif" font-size="15" font-style="italic">— lerretet er tomt —</text>
            </svg>
          </div>
          <p class="game-msg" id="le-msg" aria-live="polite">Når lampen tennes: <strong>stirr på den hvite prikken i midten</strong> uten å flytte blikket, helt til lyset slukker.</p>
          <div class="btn-row" id="le-controls">
            <button class="btn-gold" id="le-light">Tenn lampen 🕯️</button>
            <button class="btn-quiet" id="le-skip">Fortell meg hva jeg ville sett</button>
          </div>
          <div class="btn-row" id="le-after" hidden>
            <button class="btn-gold" id="le-saw">Jeg ser det — et blekt gjenferd! 👻</button>
            <button class="btn-quiet" id="le-nothing">Jeg ser ingenting</button>
          </div>
          <div class="reveal" id="le-reveal" hidden>
            <p id="le-reveal-text">Gjenferdet på lerretet er <strong>ditt eget syn som dikter</strong>: synscellene som stirret på det rosa lyset er «slitne», og når lyset forsvinner, svarer de med komplementærfargen — et blekgrønt etterbilde av lykten, på et lerret som hele tiden var tomt. «Husk det,» sier Direktøren. «Publikum trenger ikke se noe for å se noe.»</p>
            <div class="facts" id="le-facts"></div>
          </div>
          <button class="btn-gold" id="le-continue" hidden>Videre til Verkstedet →</button>
        </div>
      </section>

      <!-- ── SCENE: VERKSTEDET ───────────────────────────────────── -->
      <section class="scene" id="sc-verkstedet" hidden aria-labelledby="vs-heading">
        <p class="scene-label">Niende rom · Nierne</p>
        <h2 class="scene-heading" id="vs-heading">{rooms.verkstedet.title}</h2>
        <p class="scene-intro">{rooms.verkstedet.intro}</p>

        <div class="panel" id="vs-pathchoice">
          <p class="field-label">Velg din vei gjennom rommet</p>
          <div class="path-row">
            <button class="path-btn" data-scene="vs" data-path="laerling">
              <strong>Lærlingens vei</strong>
              <span>Delene er merket med byggmesterens rene ord</span>
            </button>
            <button class="path-btn" data-scene="vs" data-path="mester">
              <strong>Mesterens vei</strong>
              <span>Bare verkstedets stikkord — løser du gåten uten hint, gylles sparkortet ditt</span>
            </button>
          </div>
        </div>

        <div class="panel" id="vs-game" hidden>
          <blockquote class="verse">
            <p>Bestilling: «Den svevende damen».</p>
            <p>Damen svever midt på åpen scene.</p>
            <p>En ring føres langs hele kroppen hennes.</p>
            <p>Salen ser henne hele tiden.</p>
          </blockquote>
          <p class="game-msg">Seks deler ligger på bordet — <strong>bare tre hører hjemme i illusjonen.</strong> Velg dem, og bygg.</p>
          <ul class="se-list" id="vs-parts"></ul>
          <div class="btn-row">
            <button class="btn-gold" id="vs-submit">Bygg illusjonen 🔨</button>
          </div>
          <button class="curiosity" id="vs-screw" aria-label="En blank messingskrue ligger i sagflisen">🔩</button>
          <p class="game-msg" id="vs-msg" aria-live="polite"></p>

          <div class="hintbox">
            <button class="btn-quiet" id="vs-hint-btn">Direktørens hvisken (hint) 🤫</button>
            <ul class="hint-list" id="vs-hints"></ul>
          </div>
        </div>

        <div class="panel panel--solved" id="vs-solved" hidden>
          <p class="solved-title">✨ Gåten er løst</p>
          <p class="principle">«Stålarmen bærer, motvekten holder, draperiet skjuler — og ringen glir langs den s-formede armen som om ingenting var der. <strong>Effekten tegnes baklengs fra salens stol</strong>, lærling: byggmesteren setter seg der publikum sitter, og fjerner alt de kan se.»</p>
          <div class="facts" id="vs-facts"></div>
          <button class="btn-gold" id="vs-complete">Fullfør rommet →</button>
        </div>
      </section>

      <!-- ── SCENE: EPILOG AKT III ───────────────────────────────── -->
      <section class="scene" id="sc-epilog3" hidden aria-labelledby="ep3-heading">
        <p class="scene-label">Akt III er fullført</p>
        <h2 class="scene-heading" id="ep3-heading">{rooms.epilog3.title}</h2>
        <p class="scene-intro">{rooms.epilog3.intro}</p>

        <div class="panel">
          <p class="game-msg" id="ep3-deck-summary" aria-live="polite"></p>
          <p class="game-msg">«Og når du savner nettene, lærling: Kabinettet står i dagslys på Årvoll gård. Der heter det <strong>Tryllemuseet</strong> — og dørene der trenger ingen full kortstokk.»</p>
          <div class="btn-row">
            <button class="btn-gold" id="ep3-poster">Last ned plakaten din 🖼️</button>
            <a class="btn-gold" href="/besok">Besøk museet i dagslys →</a>
            <button class="btn-quiet" id="ep3-deck">Se kortstokken 🃏</button>
          </div>
          <p class="game-msg game-msg--dim">Akt IV — med Studioet, Gatehjørnet, Vinterhagen og porten til det trettende rommet — venter bak neste natt.</p>
        </div>
      </section>

      <!-- ── OVERLEGG: SE BORT ───────────────────────────────────── -->
      <div class="lookaway" id="look-away-overlay" hidden aria-hidden="true">
        <p>Du ser bort. Bak deg skraper en penn mot papir …</p>
      </div>

      <!-- ── KORTSTOKK-MODAL ─────────────────────────────────────── -->
      <dialog class="deck-modal" id="deck-modal" aria-labelledby="deck-heading">
        <div class="deck-head">
          <h2 id="deck-heading">Kortstokken din</h2>
          <button class="btn-quiet" id="deck-close" aria-label="Lukk kortstokken">✕ Lukk</button>
        </div>
        <p class="deck-sub">Tretten rom, fire kort i hvert — en hel kortstokk er nøkkelen til det trettende rommet. I Akt I–III kan du samle de ni første verdiene.</p>
        <div id="deck-grid"></div>
        <p class="deck-ghost">10–13 · konger inkludert — venter i Akt IV og finalen …</p>
        <div class="btn-row">
          <button class="btn-gold" id="poster-download" hidden>Last ned plakaten din 🖼️</button>
        </div>
      </dialog>

      <div class="toast" id="toast" role="status" aria-live="polite" hidden></div>

      <script type="application/json" id="kabinett-data" set:html={payloadJson} />
    </main>
  )}

</BaseLayout>

<script>
  interface GFact { text: string; linkUrl?: string; linkLabel?: string }
  interface GRoom { title: string; intro: string; facts: GFact[] }
  interface GData { rooms: Record<string, GRoom> }

  const dataEl = document.getElementById('kabinett-data')
  if (dataEl) {
    const data: GData = JSON.parse(dataEl.textContent ?? '{}')

    const $ = (id: string) => document.getElementById(id)!
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const sleep = (ms: number) => new Promise(r => setTimeout(r, reducedMotion ? Math.min(ms, 120) : ms))

    // ── Kort og tilstand ─────────────────────────────────────────
    const SUITS = {
      spar:    { sym: '♠', name: 'spar',    red: false, earn: 'Løs rommets gåte' },
      hjerter: { sym: '♥', name: 'hjerter', red: true,  earn: 'Fullfør rommet' },
      ruter:   { sym: '♦', name: 'ruter',   red: true,  earn: 'Opplev Speilgangen' },
      klover:  { sym: '♣', name: 'kløver',  red: false, earn: 'Finn rommets kuriositet' },
    } as const
    type Suit = keyof typeof SUITS
    const SUIT_ORDER: Suit[] = ['spar', 'hjerter', 'ruter', 'klover']
    const VALUES: Record<number, { label: string; face: string; room: string }> = {
      1: { label: 'Ess',  face: 'A', room: 'Foajeen' },
      2: { label: 'To',   face: '2', room: 'Sandrommet' },
      3: { label: 'Tre',  face: '3', room: 'Markedsplassen' },
      4: { label: 'Fire', face: '4', room: 'Biblioteket' },
      5: { label: 'Fem',  face: '5', room: 'Salongen' },
      6: { label: 'Seks', face: '6', room: 'Seansen' },
      7: { label: 'Sju',  face: '7', room: 'Teateret' },
      8: { label: 'Åtte', face: '8', room: 'Kinoen' },
      9: { label: 'Ni',   face: '9', room: 'Verkstedet' },
    }
    const DECK_VALUES = [1, 2, 3, 4, 5, 6, 7, 8, 9]
    const TOTAL_ACT1 = 12
    const TOTAL_ACT2 = 24
    const TOTAL_DECK = 36

    type Stage = 'brevet' | 'foajeen' | 'sandrommet' | 'speilgangen' | 'markedsplassen' | 'epilog'
      | 'galleriet' | 'biblioteket' | 'oyet' | 'salongen' | 'seansen' | 'epilog2'
      | 'frievalget' | 'teateret' | 'kinoen' | 'lerretet' | 'verkstedet' | 'epilog3'
    interface SaveState {
      v: number
      stageName: string
      stage: Stage
      cards: string[]
      gilded: string[]
      path: Record<string, string>
    }
    const STORAGE_KEY = 'kabinett-v1'
    const LEGACY_KEY  = 'kabinett-akt1-v1'
    const blank = (): SaveState => ({ v: 1, stageName: '', stage: 'brevet', cards: [], gilded: [], path: {} })

    let state = blank()
    try {
      const raw = localStorage.getItem(STORAGE_KEY) ?? localStorage.getItem(LEGACY_KEY)
      if (raw) {
        const parsed = JSON.parse(raw)
        if (parsed && parsed.v === 1) state = { ...blank(), ...parsed }
      }
      localStorage.removeItem(LEGACY_KEY)
    } catch { /* private mode etc. — play without saving */ }

    function save() {
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)) } catch { /* ignore */ }
    }

    // ── Felles UI ────────────────────────────────────────────────
    const toastEl = $('toast')
    let toastTimer = 0
    function toast(html: string) {
      toastEl.innerHTML = html
      toastEl.hidden = false
      window.clearTimeout(toastTimer)
      toastTimer = window.setTimeout(() => { toastEl.hidden = true }, 4200)
    }

    function cardCode(value: number, suit: Suit) { return `${value}-${suit}` }

    function awardCard(value: number, suit: Suit, note: string) {
      const code = cardCode(value, suit)
      if (state.cards.includes(code)) return
      state.cards.push(code)
      save()
      updateDeckCount()
      const s = SUITS[suit]
      toast(`🃏 Nytt kort: <strong>${VALUES[value].face}${s.sym}</strong> — ${note}`)
    }

    function miniCard(value: number, suit: Suit, gilded = false): HTMLElement {
      const s = SUITS[suit]
      const el = document.createElement('span')
      el.className = 'pcard' + (s.red ? ' pcard--red' : '') + (gilded ? ' pcard--gilded' : '')
      el.setAttribute('role', 'img')
      el.setAttribute('aria-label', `${VALUES[value].label} i ${s.name}${gilded ? ' (gylt)' : ''}`)
      el.innerHTML = `<span class="pcard-face">${VALUES[value].face}</span><span class="pcard-suit">${s.sym}</span>`
      return el
    }

    function updateDeckCount() {
      $('deck-count').textContent = `${state.cards.length}/${TOTAL_DECK}`
    }

    function renderFacts(containerId: string, roomKey: string) {
      const box = $(containerId)
      box.innerHTML = ''
      const facts = data.rooms[roomKey]?.facts ?? []
      for (const f of facts) {
        const p = document.createElement('p')
        p.className = 'fact'
        p.textContent = `Visste du at … ${f.text}`
        if (f.linkUrl) {
          const a = document.createElement('a')
          a.href = f.linkUrl
          a.textContent = ` ${f.linkLabel || 'Les mer'} →`
          p.appendChild(a)
        }
        box.appendChild(p)
      }
    }

    // ── Scener ───────────────────────────────────────────────────
    const SCENES: Record<Stage, HTMLElement> = {
      brevet:         $('sc-brevet'),
      foajeen:        $('sc-foajeen'),
      sandrommet:     $('sc-sandrommet'),
      speilgangen:    $('sc-speilgangen'),
      markedsplassen: $('sc-markedsplassen'),
      epilog:         $('sc-epilog'),
      galleriet:      $('sc-galleriet'),
      biblioteket:    $('sc-biblioteket'),
      oyet:           $('sc-oyet'),
      salongen:       $('sc-salongen'),
      seansen:        $('sc-seansen'),
      epilog2:        $('sc-epilog2'),
      frievalget:     $('sc-frievalget'),
      teateret:       $('sc-teateret'),
      kinoen:         $('sc-kinoen'),
      lerretet:       $('sc-lerretet'),
      verkstedet:     $('sc-verkstedet'),
      epilog3:        $('sc-epilog3'),
    }

    function goTo(stage: Stage) {
      state.stage = stage
      save()
      for (const [key, el] of Object.entries(SCENES)) el.hidden = key !== stage
      window.scrollTo({ top: 0, behavior: reducedMotion ? 'auto' : 'smooth' })
      if (stage === 'epilog') renderEpilog()
      if (stage === 'epilog2') renderEpilog2()
      if (stage === 'epilog3') renderEpilog3()
    }

    // ── Kortstokken (modal) ──────────────────────────────────────
    const deckModal = $('deck-modal') as HTMLDialogElement
    function renderDeck() {
      const grid = $('deck-grid')
      grid.innerHTML = ''
      for (const value of DECK_VALUES) {
        const row = document.createElement('div')
        row.className = 'deck-row'
        const label = document.createElement('p')
        label.className = 'deck-row-label'
        label.textContent = `${VALUES[value].label} · ${VALUES[value].room}`
        row.appendChild(label)
        const slots = document.createElement('div')
        slots.className = 'deck-slots'
        for (const suit of SUIT_ORDER) {
          const code = cardCode(value, suit as Suit)
          if (state.cards.includes(code)) {
            slots.appendChild(miniCard(value, suit as Suit, state.gilded.includes(code)))
          } else {
            const empty = document.createElement('span')
            empty.className = 'pcard pcard--empty'
            const locked = (value === 7 || value === 8 || value === 9) && suit === 'ruter'
            empty.setAttribute('role', 'img')
            empty.setAttribute('aria-label', locked
              ? `${VALUES[value].label} i ruter — kommer i Akt IV`
              : `Mangler: ${VALUES[value].label} i ${SUITS[suit as Suit].name}. ${SUITS[suit as Suit].earn}.`)
            empty.innerHTML = `<span class="pcard-face">?</span><span class="pcard-suit">${SUITS[suit as Suit].sym}</span>`
            empty.title = locked ? 'Kommer i Akt IV' : SUITS[suit as Suit].earn
            slots.appendChild(empty)
          }
        }
        row.appendChild(slots)
        grid.appendChild(row)
      }
      const posterBtn = $('poster-download') as HTMLButtonElement
      posterBtn.hidden = !state.cards.some(c => c.endsWith('-hjerter'))
    }
    $('deck-btn').addEventListener('click', () => { renderDeck(); deckModal.showModal() })
    $('deck-close').addEventListener('click', () => deckModal.close())
    deckModal.addEventListener('click', e => { if (e.target === deckModal) deckModal.close() })

    $('restart-btn').addEventListener('click', () => {
      if (!confirm('Begynne helt på nytt? Kortene og fremdriften din slettes.')) return
      state = blank()
      save()
      updateDeckCount()
      location.reload()
    })

    // ── Plakaten (SVG → PNG) ─────────────────────────────────────
    function escapeXml(s: string) {
      return s.replace(/[<>&'"]/g, c => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;', "'": '&apos;', '"': '&quot;' }[c] as string))
    }
    function posterSvg(name: string, subtitle: string): string {
      const n = escapeXml(name.toUpperCase())
      const sub = escapeXml(subtitle)
      return `<svg xmlns="http://www.w3.org/2000/svg" width="900" height="1200" viewBox="0 0 900 1200">
        <rect width="900" height="1200" fill="#3D0E15"/>
        <rect x="30" y="30" width="840" height="1140" fill="none" stroke="#C9A227" stroke-width="6"/>
        <rect x="50" y="50" width="800" height="1100" fill="none" stroke="#C9A227" stroke-width="2"/>
        <text x="450" y="170" text-anchor="middle" fill="#C9A227" font-family="Georgia, serif" font-size="34" letter-spacing="8">TRYLLEMUSEET PRESENTERER</text>
        <text x="450" y="330" text-anchor="middle" fill="#F5EBD8" font-family="Georgia, serif" font-size="76" font-weight="bold">DET TRETTENDE</text>
        <text x="450" y="420" text-anchor="middle" fill="#F5EBD8" font-family="Georgia, serif" font-size="76" font-weight="bold">KABINETT</text>
        <text x="450" y="530" text-anchor="middle" fill="#C9A227" font-family="Georgia, serif" font-size="30" font-style="italic">${sub}</text>
        <text x="450" y="660" text-anchor="middle" fill="#C9A227" font-family="Georgia, serif" font-size="30" letter-spacing="6">MED DEN LOVENDE LÆRLINGEN</text>
        <text x="450" y="770" text-anchor="middle" fill="#F5EBD8" font-family="Georgia, serif" font-size="60" font-weight="bold">${n}</text>
        <text x="450" y="870" text-anchor="middle" fill="#C9A227" font-family="Georgia, serif" font-size="26" font-style="italic">opptatt av Direktøren selv</text>
        <text x="450" y="1000" text-anchor="middle" fill="#F5EBD8" font-family="Georgia, serif" font-size="42">♠ ♥ ♦ ♣</text>
        <text x="450" y="1100" text-anchor="middle" fill="#C9A227" font-family="Georgia, serif" font-size="24" letter-spacing="4">KUN ÉN FORESTILLING · MELLOM MIDNATT OG DAGGRY</text>
      </svg>`
    }
    function downloadPoster() {
      const inActThree = state.cards.some(c => parseInt(c) >= 7)
        || ['frievalget', 'teateret', 'kinoen', 'lerretet', 'verkstedet', 'epilog3'].includes(state.stage)
      const inActTwo = state.cards.some(c => parseInt(c) >= 4)
        || ['galleriet', 'biblioteket', 'oyet', 'salongen', 'seansen', 'epilog2'].includes(state.stage)
      const subtitle = inActThree
        ? '— akt I–III: nettene som aldri tok slutt —'
        : inActTwo
          ? '— akt I–II: nettene bak forhenget —'
          : '— akt I: natten da porten gikk opp —'
      const svg = posterSvg(state.stageName || 'Den navnløse', subtitle)
      const blob = new Blob([svg], { type: 'image/svg+xml;charset=utf-8' })
      const url = URL.createObjectURL(blob)
      const img = new Image()
      img.onload = () => {
        const canvas = document.createElement('canvas')
        canvas.width = 900
        canvas.height = 1200
        canvas.getContext('2d')!.drawImage(img, 0, 0)
        URL.revokeObjectURL(url)
        const a = document.createElement('a')
        a.href = canvas.toDataURL('image/png')
        a.download = 'det-trettende-kabinett-plakat.png'
        a.click()
      }
      img.onerror = () => {
        URL.revokeObjectURL(url)
        // Fallback: offer the SVG itself
        const a = document.createElement('a')
        a.href = 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(svg)
        a.download = 'det-trettende-kabinett-plakat.svg'
        a.click()
      }
      img.src = url
    }
    $('poster-download').addEventListener('click', downloadPoster)

    // ── Hint-hjelper ─────────────────────────────────────────────
    function wireHints(btnId: string, listId: string, hints: string[], onUse: () => void) {
      const btn = $(btnId) as HTMLButtonElement
      const list = $(listId)
      let idx = 0
      btn.addEventListener('click', () => {
        if (idx >= hints.length) return
        const li = document.createElement('li')
        li.textContent = `«${hints[idx]}»`
        list.appendChild(li)
        idx++
        onUse()
        if (idx >= hints.length) btn.disabled = true
      })
    }

    // ═══ FOAJEEN ═════════════════════════════════════════════════
    const fjForm = $('fj-form') as HTMLFormElement
    const fjName = $('fj-name') as HTMLInputElement
    const fjMsg = $('fj-msg')
    let fjTriedOnce = false

    $('btn-knock').addEventListener('click', () => goTo('foajeen'))

    fjForm.addEventListener('submit', e => {
      e.preventDefault()
      const name = fjName.value.trim()
      if (!name) return
      state.stageName = name
      save()
      if (!fjTriedOnce) {
        fjTriedOnce = true
        fjMsg.textContent = 'Blekket renner av arket og samler seg i en liten, fornærmet dam. Gjesteboken vil tydeligvis ikke bli sett på mens den tar imot navn.'
        fjMsg.hidden = false
        $('fj-lookaway').hidden = false
      } else {
        fjMsg.textContent = 'Samme resultat. Boken er sta — og sjenert.'
        fjMsg.hidden = false
      }
