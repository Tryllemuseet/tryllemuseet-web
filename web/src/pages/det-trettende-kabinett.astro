        await sleep(ghPath === 'mester' ? 650 : 1000)
      }
      const beats = $('gh-beats')
      beats.innerHTML = ''
      GH_BEATS.forEach((_, i) => {
        const btn = document.createElement('button')
        btn.className = 'mp-cup'
        btn.textContent = t(`Øyeblikk ${i + 1}`, `Moment ${i + 1}`)
        btn.addEventListener('click', () => ghGuess(i))
        beats.appendChild(btn)
      })
      $('gh-pick').hidden = false
    }

    function ghGuess(i: number) {
      if (ghSolved) return
      if (i === GH_CORRECT) {
        ghSolved = true
        document.querySelectorAll<HTMLButtonElement>('#gh-beats .mp-cup').forEach(b => { b.disabled = true })
        $('gh-msg').textContent = t(
          'Gatekunstneren stopper midt i bukket og ser på deg. Så åpner han høyrehånden: mynten. Den lå der hele tiden.',
