// same key overrides title/intro and replaces the facts list; missing
// English fields fall back to these defaults.
interface DefaultFact { text: string; linkUrl?: string; linkLabel?: string }
interface DefaultRoomLang { title: string; intro: string; facts: DefaultFact[] }
interface RoomCopy extends DefaultRoomLang { en: DefaultRoomLang }

