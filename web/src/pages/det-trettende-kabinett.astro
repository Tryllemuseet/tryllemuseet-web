    ]
    const VH_SCENARIOS = lang === 'en' ? [
      { text: 'A “thinking machine” beats everyone at chess at the world exhibition.', room: 'salong' },
      { text: 'In pitch darkness the table lifts — and everyone around it feels it.', room: 'seanse' },
      { text: 'On the screen, the hero floats into the air — with no cut to be seen.', room: 'kino' },
      { text: 'The escape artist lets the house “choose” the trunk he will be locked into.', room: 'teater' },
    ] : [
