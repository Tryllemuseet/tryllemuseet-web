    function renderEpilog2() {
      const n = state.cards.filter(c => parseInt(c) <= 6).length
      const gilded = state.gilded.length
      let txt = `Etter to netter i Kabinettet har du ${n} av ${TOTAL_ACT2} kort i kortstokken`
      txt += gilded > 0 ? ` — ${gilded === 1 ? 'ett av dem gylt' : `${gilded} av dem gylte`}. ` : '. '
      txt += n >= TOTAL_ACT2 - 2
        ? 'Direktøren nikker langsomt: «En samler. Det lover godt for det trettende rommet.»'
        : 'Rommene husker deg — det som ennå mangler, kan finnes en annen natt.'
      $('ep2-deck-summary').textContent = txt
    }
