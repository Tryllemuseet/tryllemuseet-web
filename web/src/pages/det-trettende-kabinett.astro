    function renderEpilog4() {
      const n = state.cards.filter(c => parseInt(c) <= 12).length
      let txt = lang === 'en'
        ? `After four nights in the Cabinet you have ${n} of ${TOTAL_ACT4} cards in your deck`
        : `Etter fire netter i Kabinettet har du ${n} av ${TOTAL_ACT4} kort i kortstokken`
      txt += gildedPhrase(state.gilded.length)
      txt += n >= TOTAL_ACT4 - 3
        ? t(
            'Direktøren legger hånden mot døren uten håndtak. Innenfra svarer det — ett bank. «Den hører deg, lærling.»',
            'The Director lays a hand on the door without a handle. From inside comes an answer — a single knock. “It hears you, apprentice.”',
          )
        : t(
            'Døren uten håndtak tier ennå. Det som mangler i stokken, kan finnes en annen natt — rommene husker deg.',
            'The door without a handle is still silent. What is missing from the deck can be found another night — the rooms remember you.',
          )
      $('ep4-deck-summary').textContent = txt
    }
