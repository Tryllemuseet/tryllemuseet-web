      cards: string[]
      gilded: string[]
      path: Record<string, string>
    }
    const STORAGE_KEY = 'kabinett-v1'
    const LEGACY_KEY  = 'kabinett-akt1-v1'
    const blank = (): SaveState => ({ v: 1, stageName: '', stage: 'brevet', cards: [], gilded: [], path: {} })

    let state = blank()
    try {
      const raw = localStorage.getItem(STORAGE_KEY) ?? localStorage.getItem(LEGACY_KEY)
      if (raw) {
        const parsed = JSON.parse(raw)
        if (parsed && parsed.v === 1) state = { ...blank(), ...parsed }
      }
      localStorage.removeItem(LEGACY_KEY)
    } catch { /* private mode etc. — play without saving */ }

    function save() {
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)) } catch { /* ignore */ }
    }

    // ── Felles UI ────────────────────────────────────────────────
    const toastEl = $('toast')
    let toastTimer = 0
    function toast(html: string) {
      toastEl.innerHTML = html
      toastEl.hidden = false
      window.clearTimeout(toastTimer)
      toastTimer = window.setTimeout(() => { toastEl.hidden = true }, 4200)
    }

    function cardCode(value: number, suit: Suit) { return `${value}-${suit}` }

    function awardCard(value: number, suit: Suit, note: string) {
      const code = cardCode(value, suit)
      if (state.cards.includes(code)) return
      state.cards.push(code)
      save()
      updateDeckCount()
      const s = SUITS[suit]
      toast(`🃏 ${t('Nytt kort', 'New card')}: <strong>${VALUES[value].face}${s.sym}</strong> — ${note}`)
    }

    function miniCard(value: number, suit: Suit, gilded = false): HTMLElement {
      const s = SUITS[suit]
      const el = document.createElement('span')
      el.className = 'pcard' + (s.red ? ' pcard--red' : '') + (gilded ? ' pcard--gilded' : '')
      el.setAttribute('role', 'img')
      el.setAttribute('aria-label', `${VALUES[value].label} ${t('i', 'of')} ${s.name}${gilded ? t(' (gylt)', ' (gilded)') : ''}`)
      el.innerHTML = `<span class="pcard-face">${VALUES[value].face}</span><span class="pcard-suit">${s.sym}</span>`
      return el
    }

    function updateDeckCount() {
      $('deck-count').textContent = `${state.cards.length}/${TOTAL_DECK}`
    }

    // Facts render as clickable cards; the full text + source link opens in a
    // small popup, nudging players onward to the site or an external source.
    const factModal = $('fact-modal') as HTMLDialogElement
    function openFactModal(f: GFact) {
      // The heading already reads «Visste du at …»; the text continues it
      $('fact-modal-text').textContent = `… ${f.text}`
      const figure = $('fact-modal-figure')
      const img = $('fact-modal-img') as HTMLImageElement
      if (f.imageUrl) {
        img.src = f.imageUrl
        img.alt = f.imageAlt || ''
        figure.hidden = false
      } else {
        img.removeAttribute('src')
        figure.hidden = true
      }
      const link = $('fact-modal-link') as HTMLAnchorElement
      const note = $('fact-modal-note')
      if (f.linkUrl) {
        const external = /^https?:\/\//i.test(f.linkUrl)
        link.href = f.linkUrl
        link.textContent = `${f.linkLabel || t('Les mer', 'Read more')} ${external ? '↗' : '→'}`
        if (external) {
          link.target = '_blank'
          link.rel = 'noopener noreferrer'
        } else {
          link.removeAttribute('target')
          link.removeAttribute('rel')
        }
        link.hidden = false
        note.hidden = !external
      } else {
        link.hidden = true
        note.hidden = true
      }
      factModal.showModal()
    }
    $('fact-close').addEventListener('click', () => factModal.close())
    factModal.addEventListener('click', e => { if (e.target === factModal) factModal.close() })

    function renderFacts(containerId: string, roomKey: string) {
      const box = $(containerId)
      box.innerHTML = ''
      const facts = R(roomKey)?.facts ?? []
      for (const f of facts) {
        const btn = document.createElement('button')
        btn.type = 'button'
        btn.className = 'fact-card'
        const teaser = f.text.length > 96 ? f.text.slice(0, 96).trimEnd() + ' …' : f.text
        const kicker = document.createElement('span')
        kicker.className = 'fact-card-kicker'
        kicker.textContent = t('✦ Visste du at …', '✦ Did you know …')
        const body = document.createElement('span')
        body.className = 'fact-card-teaser'
        body.textContent = teaser
        const more = document.createElement('span')
        more.className = 'fact-card-more'
        more.textContent = f.linkUrl
          ? t('Les hele — og finn kilden →', 'Read it all — and find the source →')
          : t('Les hele →', 'Read it all →')
        btn.append(kicker, body, more)
        btn.addEventListener('click', () => openFactModal(f))
        box.appendChild(btn)
      }
    }

