    function vhRender() {
      const sc = $('vh-scen')
      const rm = $('vh-rooms')
      sc.innerHTML = ''
      rm.innerHTML = ''
      VH_SCENARIOS.forEach((s, i) => {
        const btn = document.createElement('button')
        btn.className = 'match-item'
        btn.textContent = s.text
        btn.disabled = vhMatched.includes(i)
        if (vhMatched.includes(i)) btn.classList.add('match-item--done')
        if (vhSelected === i) btn.classList.add('match-item--selected')
        btn.addEventListener('click', () => {
          vhSelected = vhSelected === i ? -1 : i
          vhRender()
        })
        sc.appendChild(btn)
      })
      for (const room of VH_ROOMS) {
        const used = VH_SCENARIOS.findIndex((s, i) => s.room === room.key && vhMatched.includes(i)) >= 0
        const btn = document.createElement('button')
        btn.className = 'match-item match-item--secret'
        btn.innerHTML = vhPath === 'mester'
          ? room.name
          : `${room.name}<br><small>${room.principle}</small>`
        btn.disabled = used
        if (used) btn.classList.add('match-item--done')
        btn.addEventListener('click', () => {
          if (vhSelected < 0) {
            $('vh-msg').textContent = t('Velg en fortelling først — så rommet den hører hjemme i.', 'Choose a tale first — then the room it belongs to.')
            return
          }
          if (VH_SCENARIOS[vhSelected].room === room.key) {
            vhMatched.push(vhSelected)
            vhSelected = -1
            $('vh-msg').textContent = vhMatched.length < VH_SCENARIOS.length
              ? t('Riktig — nordlyset bølger anerkjennende over glasstaket.', 'Right — the northern lights ripple approvingly across the glass roof.')
              : ''
            vhRender()
            if (vhMatched.length === VH_SCENARIOS.length) vhSolve()
          } else {
            vhWrong++
            vhSelected = -1
            $('vh-msg').textContent = t('Isrosene på ruten tetner. Det paret hører ikke sammen.', 'The frost roses on the pane thicken. That pair does not belong together.')
            vhRender()
          }
        })
        rm.appendChild(btn)
      }
    }

