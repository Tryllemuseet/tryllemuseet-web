    // ═══ TEATERET ════════════════════════════════════════════════
    interface TeAction { key: string; label: string; step?: number; wrongText?: string }
    const TE_ACTIONS: TeAction[] = lang === 'en' ? [
      { key: 'lokk',   label: 'Push the lid with all your strength',
        wrongText: 'Locked from the outside — of course. The whole house saw the padlock click.' },
      { key: 'rop',    label: 'Shout for help',
        wrongText: 'The orchestra just plays louder. Nobody rescues an escape artist.' },
      { key: 'som',    label: 'Feel along the seam in the trunk’s short side', step: 1 },
      { key: 'knott',  label: 'Turn the catch half a turn', step: 2 },
      { key: 'panel',  label: 'Slide the panel aside and slip out', step: 3 },
      { key: 'morse',  label: 'Knock SOS on the bottom board',
        wrongText: 'Morse impresses nobody when you are the only one who hears it.' },
    ] : [
      { key: 'lokk',   label: 'Dytt lokket med all kraft',
        wrongText: 'Låst utenfra — selvsagt. Hele salen så hengelåsen klikke.' },
      { key: 'rop',    label: 'Rop om hjelp',
        wrongText: 'Orkesteret spiller bare høyere. Ingen redder en utbryter.' },
      { key: 'som',    label: 'Kjenn langs sømmen i kistens kortside', step: 1 },
      { key: 'knott',  label: 'Vri knotten en halv omdreining', step: 2 },
      { key: 'panel',  label: 'Skyv panelet til side og smyg deg ut', step: 3 },
      { key: 'morse',  label: 'Bank SOS i bunnplaten',
        wrongText: 'Morse imponerer ingen når du er alene om å høre det.' },
    ]
    const TE_STEP_TEXT: Record<number, string> = lang === 'en' ? {
      1: 'Your fingers find a recessed catch in the seam — one that cannot be seen from the house.',
      2: 'Something gives way with a soft click: the side panel is loose.',
      3: 'The panel slides aside. You roll out into the wings, behind the trunk — unseen.',
    } : {
      1: 'Fingrene finner en forsenket knott i sømmen — en som ikke synes fra salen.',
      2: 'Noe gir etter med et mykt klikk: sidepanelet er løst.',
      3: 'Panelet glir til side. Du ruller ut i kulissene, bak kisten — usett.',
    }
    let tePath = state.path['teateret'] || ''
    let teHintsUsed = 0
    let teWrong = 0
    let teStep = 0
    let teDone = false

    const TE_HINTS = lang === 'en' ? [
      'The effect is sold tonight — the method was bought yesterday, in the workshop.',
      'Not the lid. The audience see the lid. Think of what they don’t see.',
      'The short side. The seam. A catch that cannot be seen from the house.',
    ] : [
      'Effekten selges i kveld — metoden ble kjøpt i går, i verkstedet.',
      'Ikke lokket. Publikum ser lokket. Tenk på det de ikke ser.',
      'Kortsiden. Sømmen. En knott som ikke synes fra salen.',
    ]
    wireHints('te-hint-btn', 'te-hints', TE_HINTS, () => { teHintsUsed++ })

    function teRender() {
      const box = $('te-actions')
      box.innerHTML = ''
      for (const a of TE_ACTIONS) {
        const btn = document.createElement('button')
        btn.className = 'mp-cup'
        btn.textContent = a.label
        btn.disabled = teDone || (a.step !== undefined && a.step <= teStep)
        btn.addEventListener('click', () => teAct(a))
        box.appendChild(btn)
      }
    }

    function teAct(a: TeAction) {
      if (teDone) return
      const log = $('te-log')
      const li = document.createElement('li')
      if (a.step === undefined) {
        teWrong++
        li.textContent = a.wrongText!
        log.appendChild(li)
        $('te-msg').textContent = t('Publikum teller videre. Prøv noe annet.', 'The audience keep counting. Try something else.')
      } else if (a.step === teStep + 1) {
        teStep = a.step
        li.textContent = TE_STEP_TEXT[a.step]
        log.appendChild(li)
        $('te-msg').textContent = ''
        if (teStep === 3) {
          teDone = true
          const gild = tePath === 'mester' && teHintsUsed === 0 && teWrong === 0
          awardCard(7, 'spar', t('Sigillet fra Teateret', 'The seal of the Theatre'))
          if (gild && !state.gilded.includes('7-spar')) {
            state.gilded.push('7-spar')
            save()
          }
          renderFacts('te-facts', 'teateret')
          $('te-solved').hidden = false
          $('te-solved').scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'nearest' })
        }
      } else {
        teWrong++
        li.textContent = a.step === 2
          ? t('Hvilken knott? Du famler i blinde mot glatt treverk.', 'What catch? You fumble blindly against smooth wood.')
          : t('Panelet sitter bom fast. Noe må løsne først.', 'The panel is stuck fast. Something must come loose first.')
        log.appendChild(li)
      }
      teRender()
    }

    document.querySelectorAll<HTMLButtonElement>('.path-btn[data-scene="te"]').forEach(btn =>
      btn.addEventListener('click', () => {
        tePath = btn.dataset.path || 'laerling'
        state.path['teateret'] = tePath
        save()
        $('te-pathchoice').hidden = true
        $('te-game').hidden = false
        $('te-pretext').textContent = tePath === 'laerling'
          ? t(
              'Direktørens stemme, tett ved øret ditt enda han umulig kan være der: «En utbryter går aldri inn i noe han ikke kjenner. Kisten ble gjort klar for deg — let etter det som ble gjort klart.»',
              'The Director’s voice, close by your ear though he cannot possibly be there: “An escape artist never enters anything he does not know. The trunk was made ready for you — look for what was made ready.”',
            )
          : t(
              'Mørke. Varme. Applausen utenfor stilner til taktfast klapping.',
              'Darkness. Heat. The applause outside settles into rhythmic clapping.',
            )
        teRender()
      })
    )

    $('te-ticket').addEventListener('click', () => {
      $('te-ticket').hidden = true
      awardCard(7, 'klover', t('Kuriositeten: teaterbilletten i kistens fôr', 'The curiosity: the theatre ticket in the trunk’s lining'))
    })

    $('te-complete').addEventListener('click', () => {
      awardCard(7, 'hjerter', t('Plakatkortet fra Teateret er trykket', 'The Theatre poster card is printed'))
      goTo('kinoen')
    })

    // ═══ KINOEN ══════════════════════════════════════════════════
    const KI_STRIPS = lang === 'en' ? [
      'The lady takes her seat in the chair',
      'The cloth is spread over her',
      'The cloth is whipped away — the chair is empty',
      'The magician conjures — a skeleton sits in the chair!',
      'The lady is back, and bows to the house',
    ] : [
      'Damen tar plass i stolen',
      'Kledet bres over henne',
      'Kledet rives bort — stolen er tom',
      'Magikeren maner — et skjelett sitter i stolen!',
      'Damen er tilbake, og bukker mot salen',
    ]
    const KI_SHUFFLE = [2, 4, 0, 3, 1]  // fixed scramble of strip indices
    let kiPath = state.path['kinoen'] || ''
    let kiHintsUsed = 0
    let kiWrong = 0
    let kiNext = 0
    let kiPhase = 1

    const KI_HINTS = lang === 'en' ? [
      'The story is simple: a lady, a cloth, a chair. Start there.',
      'The impossible never happens while you watch it. It happens between two frames.',
      'The camera stopped the first time while the cloth lay over the chair.',
    ] : [
      'Historien er enkel: en dame, et klede, en stol. Begynn der.',
      'Det umulige skjer aldri mens du ser det. Det skjer mellom to bilder.',
      'Kameraet stanset første gang i det kledet lå over stolen.',
    ]
    wireHints('ki-hint-btn', 'ki-hints', KI_HINTS, () => { kiHintsUsed++ })

    function kiRenderStrips() {
      const box = $('ki-strips')
      box.innerHTML = ''
      for (const idx of KI_SHUFFLE) {
        const btn = document.createElement('button')
        btn.className = 'ki-strip'
        btn.innerHTML = `<span class="ki-frame" aria-hidden="true">🎞️</span><span>${KI_STRIPS[idx]}</span><span class="ki-order">${idx < kiNext ? idx + 1 : ''}</span>`
        btn.disabled = idx < kiNext
        if (idx < kiNext) btn.classList.add('ki-strip--placed')
        btn.addEventListener('click', () => {
          if (idx === kiNext) {
            kiNext++
            $('ki-msg').textContent = kiNext === KI_STRIPS.length ? '' : t('Riktig — filmen vokser.', 'Right — the film is growing.')
            kiRenderStrips()
            if (kiNext === KI_STRIPS.length) kiStartPhase2()
          } else {
            kiWrong++
            $('ki-msg').textContent = t('Prosjektoren hakker: den biten hører ikke hjemme der.', 'The projector stutters: that strip does not belong there.')
          }
        })
        box.appendChild(btn)
      }
    }

    function kiStartPhase2() {
      kiPhase = 2
      $('ki-phase1').hidden = true
      const gaps = $('ki-gaps')
      gaps.innerHTML = ''
      for (let i = 0; i < KI_STRIPS.length - 1; i++) {
        const btn = document.createElement('button')
        btn.className = 'mp-cup'
        btn.textContent = t(`Mellom ${i + 1} og ${i + 2}`, `Between ${i + 1} and ${i + 2}`)
        btn.addEventListener('click', () => {
          if (i === 1) {
            document.querySelectorAll<HTMLButtonElement>('#ki-gaps .mp-cup').forEach(b => { b.disabled = true })
            $('ki-msg').textContent = t(
              'Riktig: kledet lå over stolen, kameraet stanset — og damen gikk rolig ut av bildet.',
              'Right: the cloth lay over the chair, the camera stopped — and the lady calmly walked out of frame.',
            )
            const gild = kiPath === 'mester' && kiHintsUsed === 0 && kiWrong === 0
            awardCard(8, 'spar', t('Sigillet fra Kinoen', 'The seal of the Cinema'))
            if (gild && !state.gilded.includes('8-spar')) {
              state.gilded.push('8-spar')
              save()
            }
            renderFacts('ki-facts', 'kinoen')
            $('ki-solved').hidden = false
            $('ki-solved').scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'nearest' })
          } else {
            kiWrong++
            $('ki-msg').textContent = t(
              'Direktøren rister på hodet: «Der skjer det noe i bildet. Klippet gjemmer seg der ingenting ser ut til å skje.»',
              'The Director shakes his head: “Something happens in the frame there. The cut hides where nothing seems to happen.”',
            )
          }
        })
        gaps.appendChild(btn)
      }
      $('ki-phase2').hidden = false
    }

    document.querySelectorAll<HTMLButtonElement>('.path-btn[data-scene="ki"]').forEach(btn =>
      btn.addEventListener('click', () => {
        kiPath = btn.dataset.path || 'laerling'
        state.path['kinoen'] = kiPath
        save()
        $('ki-pathchoice').hidden = true
        $('ki-game').hidden = false
        $('ki-pretext').textContent = kiPath === 'laerling'
          ? t(
              'Direktøren hvisker: «Fortell historien slik salen skal se den: damen kommer, damen forsvinner, noe umulig — og så triumfen.»',
              'The Director whispers: “Tell the story as the house is meant to see it: the lady arrives, the lady vanishes, something impossible — and then the triumph.”',
            )
          : t('Prosjektoren surrer utålmodig. Filmbitene ligger som de falt.', 'The projector hums impatiently. The film strips lie as they fell.')
        kiRenderStrips()
      })
    )

    $('ki-clip').addEventListener('click', () => {
      $('ki-clip').hidden = true
      awardCard(8, 'klover', t('Kuriositeten: filmbiten fra klipperommet', 'The curiosity: the film scrap from the cutting room'))
    })

    $('ki-complete').addEventListener('click', () => {
      awardCard(8, 'hjerter', t('Plakatkortet fra Kinoen er trykket', 'The Cinema poster card is printed'))
      goTo('lerretet')
    })

    // ═══ ÅNDEN PÅ LERRETET (SPEILGANGEN: ETTERBILDE) ═════════════
    // NB: the stare needs real seconds regardless of prefers-reduced-motion —
    // this is exposure time for the eyes, not animation.
    const LE_STARE_MS = 12000
    let leLit = false

    function leSetFigure(on: boolean) {
      ;(document.getElementById('le-figure') as unknown as SVGGElement).style.display = on ? '' : 'none'
      ;(document.getElementById('le-blank-text') as unknown as SVGTextElement).style.display = on ? 'none' : ''
    }

    $('le-light').addEventListener('click', () => {
      if (leLit) return
      leLit = true
      ;($('le-light') as HTMLButtonElement).disabled = true
      leSetFigure(true)
      let left = LE_STARE_MS / 1000
      const stareLine = (s: number) => t(`Stirr på den hvite prikken … ${s}`, `Stare at the white dot … ${s}`)
      $('le-msg').textContent = stareLine(left)
      const timer = window.setInterval(() => {
        left--
        if (left > 0) {
          $('le-msg').textContent = stareLine(left)
        } else {
          window.clearInterval(timer)
          leSetFigure(false)
          leLit = false
          ;($('le-light') as HTMLButtonElement).disabled = false
          ;($('le-light') as HTMLButtonElement).textContent = t('Tenn lampen igjen 🕯️', 'Light the lamp again 🕯️')
          $('le-msg').textContent = t('Lampen slukker. Se på det tomme lerretet — hva ser du?', 'The lamp goes out. Look at the empty canvas — what do you see?')
          $('le-after').hidden = false
        }
      }, 1000)
    })

    function leFinish(sawIt: boolean) {
      $('le-after').hidden = true
      $('le-controls').hidden = true
      $('le-msg').textContent = sawIt
        ? t(
            'Direktøren smiler i mørket. «Der. Kabinettets billigste spøkelse — og det bor i deg.»',
            'The Director smiles in the dark. “There. The Cabinet’s cheapest ghost — and it lives in you.”',
          )
        : t(
            'Direktøren nikker. «Noen øyne er mer lettlurte enn andre. Her er det du ville sett:»',
            'The Director nods. “Some eyes are more easily fooled than others. Here is what you would have seen:”',
          )
      awardCard(6, 'ruter', t('Illusjonskortet fra Ånden på lerretet', 'The illusion card of the Ghost on the Canvas'))
      renderFacts('le-facts', 'lerretet')
      $('le-reveal').hidden = false
      ;($('le-continue') as HTMLButtonElement).hidden = false
    }

    $('le-saw').addEventListener('click', () => leFinish(true))
    let leNothingCount = 0
    $('le-nothing').addEventListener('click', () => {
      leNothingCount++
      if (leNothingCount < 2) {
        $('le-after').hidden = true
        $('le-msg').textContent = t(
          'Direktøren: «Tenn lampen igjen — og hold blikket helt, helt stille på prikken.»',
          'The Director: “Light the lamp again — and keep your gaze completely, completely still on the dot.”',
        )
      } else {
        leFinish(false)
      }
    })
    $('le-skip').addEventListener('click', () => leFinish(false))
    $('le-continue').addEventListener('click', () => goTo('verkstedet'))

    // ═══ VERKSTEDET ══════════════════════════════════════════════
    interface VsPart { correct: boolean; laerling: string; mester: string }
    const VS_PARTS: VsPart[] = lang === 'en' ? [
      { correct: true,  laerling: 'An S-shaped steel arm (a “gooseneck”) from a column behind the stage curtain',
        mester: 'Steel that curves where no one looks' },
      { correct: false, laerling: 'Thin threads from the fly loft',
        mester: 'What hangs, hangs from something' },
      { correct: true,  laerling: 'A heavy counterweight hidden beneath the stage floor',
        mester: 'What floats rests on what lies' },
      { correct: false, laerling: 'A powerful magnet under the stage',
        mester: 'An iron will beneath the floorboards' },
      { correct: true,  laerling: 'A drape in the same colour as the backdrop, concealing the arm',
        mester: 'Velvet against velvet: nothing to see' },
      { correct: false, laerling: 'An angled mirror in front of the lady',
        mester: 'The house sees what the house should see' },
    ] : [
      { correct: true,  laerling: 'En s-formet stålarm («svanehals») fra en søyle bak sceneteppet',
        mester: 'Stål som svinger seg dit ingen ser' },
      { correct: false, laerling: 'Tynne tråder fra snorloftet',
        mester: 'Det som henger, henger i noe' },
      { correct: true,  laerling: 'En tung motvekt skjult under scenegulvet',
        mester: 'Det som svever, hviler på det som ligger' },
      { correct: false, laerling: 'En kraftig magnet under scenen',
        mester: 'Jernvilje under gulvplankene' },
      { correct: true,  laerling: 'Et draperi i samme farge som bakteppet, som skjuler armen',
        mester: 'Fløyel mot fløyel: intet å se' },
      { correct: false, laerling: 'Et vinklet speil foran damen',
        mester: 'Salen ser det salen bør se' },
    ]
    let vsPath = state.path['verkstedet'] || ''
    let vsHintsUsed = 0
    let vsWrong = 0
    let vsSolved = false

    const VS_HINTS = lang === 'en' ? [
      'Read the commission again. Each requirement kills one solution.',
      'The hoop kills the threads. “The audience see her the entire time” kills the mirror — and a magnet that could carry a lady would seize every tool in the house.',
      'The arm that carries, the weight that holds, the fabric that hides.',
    ] : [
      'Les bestillingen igjen. Hvert krav dreper én løsning.',
      'Ringen dreper trådene. «Salen ser henne hele tiden» dreper speilet — og en magnet som bærer en dame, ville låst hvert verktøy i huset.',
      'Armen som bærer, vekten som holder, stoffet som skjuler.',
    ]
    wireHints('vs-hint-btn', 'vs-hints', VS_HINTS, () => { vsHintsUsed++ })

    function vsRender() {
      const list = $('vs-parts')
      list.innerHTML = ''
      VS_PARTS.forEach((p, i) => {
        const li = document.createElement('li')
        const label = document.createElement('label')
        const box = document.createElement('input')
        box.type = 'checkbox'
        box.value = String(i)
        label.appendChild(box)
        label.appendChild(document.createTextNode(' ' + (vsPath === 'mester' ? p.mester : p.laerling)))
        li.appendChild(label)
        list.appendChild(li)
      })
    }

    document.querySelectorAll<HTMLButtonElement>('.path-btn[data-scene="vs"]').forEach(btn =>
      btn.addEventListener('click', () => {
        vsPath = btn.dataset.path || 'laerling'
        state.path['verkstedet'] = vsPath
        save()
        $('vs-pathchoice').hidden = true
        $('vs-game').hidden = false
        vsRender()
      })
    )

    $('vs-submit').addEventListener('click', () => {
      if (vsSolved) return
      const checked = Array.from(document.querySelectorAll<HTMLInputElement>('#vs-parts input:checked')).map(b => Number(b.value))
      if (checked.length !== 3) {
        $('vs-msg').textContent = t(
          'Illusjonen trenger nøyaktig tre deler — verken flere eller færre.',
          'The illusion needs exactly three parts — no more, no fewer.',
        )
        return
      }
      const correct = checked.filter(i => VS_PARTS[i].correct).length
      if (correct === 3) {
        vsSolved = true
        document.querySelectorAll<HTMLInputElement>('#vs-parts input').forEach(b => { b.disabled = true })
        ;($('vs-submit') as HTMLButtonElement).disabled = true
        $('vs-msg').textContent = t(
          'Delene finner hverandre som om de har ventet: armen, vekten, draperiet. På prøvescenen svever damen.',
          'The parts find each other as if they had been waiting: the arm, the weight, the drape. On the rehearsal stage, the lady floats.',
        )
        const gild = vsPath === 'mester' && vsHintsUsed === 0 && vsWrong === 0
        awardCard(9, 'spar', t('Sigillet fra Verkstedet', 'The seal of the Workshop'))
        if (gild && !state.gilded.includes('9-spar')) {
          state.gilded.push('9-spar')
          save()
        }
        renderFacts('vs-facts', 'verkstedet')
        $('vs-solved').hidden = false
        $('vs-solved').scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'nearest' })
      } else {
        vsWrong++
        $('vs-msg').textContent = vsPath === 'laerling'
          ? (lang === 'en'
              ? `${correct} of three parts match the commission. Check the requirements — the hoop, the open stage, the gaze that never leaves her.`
              : `${correct} av tre deler stemmer med bestillingen. Sjekk kravene — ringen, den åpne scenen, blikket som aldri slipper henne.`)
          : t(
              '«Bygget faller sammen på generalprøven,» sier Direktøren tørt. Prøv igjen.',
              '“The build collapses at the dress rehearsal,” says the Director drily. Try again.',
            )
      }
    })

    $('vs-screw').addEventListener('click', () => {
      $('vs-screw').hidden = true
      awardCard(9, 'klover', t('Kuriositeten: messingskruen fra Sfinks-bordet', 'The curiosity: the brass screw from the Sphinx table'))
    })

    $('vs-complete').addEventListener('click', () => {
      awardCard(9, 'hjerter', t('Plakatkortet fra Verkstedet er trykket', 'The Workshop poster card is printed'))
      goTo('epilog3')
    })

    // ═══ EPILOG AKT III ══════════════════════════════════════════
    function renderEpilog3() {
      const n = state.cards.filter(c => parseInt(c) <= 9).length
      let txt = lang === 'en'
        ? `After three nights in the Cabinet you have ${n} of ${TOTAL_ACT3} cards in your deck`
        : `Etter tre netter i Kabinettet har du ${n} av ${TOTAL_ACT3} kort i kortstokken`
      txt += gildedPhrase(state.gilded.length)
      txt += n >= TOTAL_ACT3 - 3
        ? t(
            'Direktøren stryker over kortene: «Tre netter — og en nesten full stokk. Det trettende rommet har begynt å lytte.»',
            'The Director runs a hand over the cards: “Three nights — and a nearly full deck. The thirteenth room has begun to listen.”',
          )
        : REMEMBER_LINE
      $('ep3-deck-summary').textContent = txt
    }
    $('ep3-poster').addEventListener('click', downloadPoster)
    $('ep3-deck').addEventListener('click', () => { renderDeck(); deckModal.showModal() })
    $('ep3-act4').addEventListener('click', () => goTo('minnet'))

    // ═══ MINNET SOM DIKTER (SPEILGANGEN: FALSKE MINNER) ══════════
    // DRM-style word list: every word points at the lure («søvn»/"sleep")
    // without the lure itself ever appearing. Each language needs its own
    // psychologically coherent list — this is not a translation.
    const MN_WORDS = lang === 'en'
      ? ['bed', 'pillow', 'night', 'dream', 'wake', 'tired', 'blanket', 'yawn', 'rest', 'darkness', 'snore', 'evening']
      : ['seng', 'pute', 'natt', 'drøm', 'våkne', 'trøtt', 'dyne', 'gjespe', 'hvile', 'mørke', 'snorke', 'kveld']
    const MN_PROBES = lang === 'en' ? [
      { word: 'pillow', present: true },
      { word: 'sleep',  present: false, lure: true },
      { word: 'lamp',   present: false },
    ] : [
      { word: 'pute',  present: true },
      { word: 'søvn',  present: false, lure: true },
      { word: 'lampe', present: false },
    ]
    let mnProbe = 0
    let mnFooled = false

    function mnRenderWords(containerId: string) {
      const box = $(containerId)
      box.innerHTML = ''
      for (const w of MN_WORDS) {
        const span = document.createElement('span')
        span.className = 'mn-word'
        span.textContent = w
        box.appendChild(span)
      }
    }

    function mnAsk() {
      const p = MN_PROBES[mnProbe]
      $('mn-q').innerHTML = lang === 'en'
        ? `Was the word <strong>“${p.word}”</strong> on the mirror?`
        : `Sto ordet <strong>«${p.word}»</strong> på speilet?`
    }

    function mnAnswer(saidYes: boolean) {
      const p = MN_PROBES[mnProbe]
      if (p.lure && saidYes) mnFooled = true
      mnProbe++
      if (mnProbe < MN_PROBES.length) {
        mnAsk()
      } else {
        $('mn-quiz').hidden = true
        $('mn-verdict').textContent = mnFooled
          ? t(
