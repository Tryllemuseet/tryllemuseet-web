    document.querySelectorAll<HTMLButtonElement>('.path-btn[data-scene="sr"]').forEach(btn =>
      btn.addEventListener('click', () => {
        srPath = btn.dataset.path || 'laerling'
        state.path['sandrommet'] = srPath
        save()
        $('sr-pathchoice').hidden = true
        $('sr-game').hidden = false
        srStartRound(1)
      })
    )

    function srApplyPositions(animated: boolean) {
      // offsetLeft ignores transforms, so it always gives the original slot
      const slots = srCups.map(c => c.offsetLeft)
      srCups.forEach((cup, idx) => {
        cup.style.transition = animated && !reducedMotion ? 'transform 320ms ease' : 'none'
        cup.style.transform = `translateX(${slots[srPos[idx]] - slots[idx]}px)`
      })
    }

    function srSetCupsEnabled(on: boolean) {
      srCups.forEach(c => { c.disabled = !on })
      srHand.disabled = !on || Boolean(srHand.hidden)
    }

    const POS_NAMES = lang === 'en'
      ? ['on the left', 'in the middle', 'on the right']
      : ['til venstre', 'i midten', 'til høyre']

    async function srSwap(a: number, b: number, delay: number) {
      // a/b are visual positions; find the cups currently there
      const cupA = srPos.indexOf(a)
      const cupB = srPos.indexOf(b)
      const li = document.createElement('li')
      li.textContent = lang === 'en'
        ? `The cup ${POS_NAMES[a]} swaps places with the cup ${POS_NAMES[b]}.`
        : `Koppen ${POS_NAMES[a]} bytter plass med koppen ${POS_NAMES[b]}.`
      srLog.appendChild(li)
      ;[srPos[cupA], srPos[cupB]] = [srPos[cupB], srPos[cupA]]
      srApplyPositions(true)
      await sleep(delay)
    }

    async function srStartRound(round: number) {
      srRound = round
      srPos = [0, 1, 2]
      srApplyPositions(false)
      srLog.innerHTML = ''
      srSetCupsEnabled(false)
      srCups.forEach(c => { (c.querySelector('.cup-ball') as HTMLElement).hidden = true; c.classList.remove('cup--empty') })
      ;($('sr-hint-btn') as HTMLButtonElement).hidden = round < 3
      srHand.hidden = round < 3

      const fast = srPath === 'mester'
      const stepDelay = fast ? 420 : 750

      if (round < 3) {
        $('sr-round-label').textContent = t(`Runde ${round} av 3 — følg kulen`, `Round ${round} of 3 — follow the ball`)
        srBallCup = Math.floor(Math.random() * 3)
        srMsg.textContent = lang === 'en'
          ? `The ball is placed under the cup ${POS_NAMES[srPos[srBallCup]]}. Watch closely …`
          : `Kulen legges under koppen ${POS_NAMES[srPos[srBallCup]]}. Følg nøye med …`
        const ballEl = srCups[srBallCup].querySelector('.cup-ball') as HTMLElement
        ballEl.hidden = false
        await sleep(1300)
        ballEl.hidden = true

        const swapCount = (round === 1 ? 3 : 4) + (fast ? 2 : 0)
        for (let i = 0; i < swapCount; i++) {
          const a = Math.floor(Math.random() * 3)
          let b = Math.floor(Math.random() * 3)
          while (b === a) b = Math.floor(Math.random() * 3)
          if (round === 2 && i === Math.floor(swapCount / 2)) {
            const li = document.createElement('li')
            li.textContent = t('I det samme piler noe blankt over bordet — en skarabé!', 'Just then, something shiny darts across the table — a scarab!')
            srLog.appendChild(li)
            $('sr-scarab').hidden = false
          }
          await srSwap(a, b, stepDelay)
        }
        srMsg.textContent = t('Hvor er kulen? Trykk på koppen.', 'Where is the ball? Press the cup.')
        srSetCupsEnabled(true)
      } else {
        $('sr-round-label').textContent = t('Siste runde — følg kulen. Om du kan.', 'Final round — follow the ball. If you can.')
        srBallCup = -1
        const startCup = Math.floor(Math.random() * 3)
        srMsg.textContent = lang === 'en'
          ? `The ball is placed under the cup ${POS_NAMES[srPos[startCup]]}. The magician’s free hand settles on the edge of the table.`
          : `Kulen legges under koppen ${POS_NAMES[srPos[startCup]]}. Magikerens frie hånd legger seg til ro på bordkanten.`
        const ballEl = srCups[startCup].querySelector('.cup-ball') as HTMLElement
        ballEl.hidden = false
        await sleep(1300)
        ballEl.hidden = true

        const swapCount = fast ? 6 : 4
        for (let i = 0; i < swapCount; i++) {
          const a = Math.floor(Math.random() * 3)
          let b = Math.floor(Math.random() * 3)
          while (b === a) b = Math.floor(Math.random() * 3)
          if (i === 1) {
            const li = document.createElement('li')
            li.textContent = t('Magikerens frie hånd stryker langs bordkanten, rolig som en katt.', 'The magician’s free hand strokes along the table edge, calm as a cat.')
            srLog.appendChild(li)
          }
          await srSwap(a, b, stepDelay)
        }
        srMsg.textContent = t('Hvor er kulen?', 'Where is the ball?')
        srSetCupsEnabled(true)
      }
    }

    srCups.forEach(cup =>
      cup.addEventListener('click', async () => {
        if (cup.disabled) return
        srSetCupsEnabled(false)
        const idx = srCups.indexOf(cup)
        if (srRound < 3) {
          if (idx === srBallCup) {
            ;(cup.querySelector('.cup-ball') as HTMLElement).hidden = false
            srMsg.textContent = t(
              'Riktig! Kulen er der. «Ikke verst,» sier skikkelsen — og stokker videre.',
              'Right! The ball is there. “Not bad,” says the figure — and shuffles on.',
            )
            await sleep(1600)
            srStartRound(srRound + 1)
          } else {
            srWrong++
            ;(srCups[srBallCup].querySelector('.cup-ball') as HTMLElement).hidden = false
            srMsg.textContent = lang === 'en'
              ? `Empty! The ball was ${POS_NAMES[srPos[srBallCup]]}. “Again,” says the figure, gathering the cups.`
              : `Tomt! Kulen lå ${POS_NAMES[srPos[srBallCup]]}. «Igjen,» sier skikkelsen, og samler koppene.`
            await sleep(1900)
            srStartRound(srRound)
          }
        } else {
          srWrong++
          cup.classList.add('cup--empty')
          srMsg.textContent = t(
            'Tomt. Alle koppene klinger hult. Men kulen forsvant jo ikke opp i røyk …',
            'Empty. All the cups ring hollow. But the ball didn’t vanish into smoke …',
          )
          srSetCupsEnabled(true)
        }
      })
    )

    srHand.addEventListener('click', () => {
      if (srHand.disabled) return
      srSetCupsEnabled(false)
      srMsg.textContent = t(
        'Skikkelsen åpner langsomt hånden. Der ligger kulen — den lå der før første bytte.',
        'The figure slowly opens the hand. There lies the ball — it was there before the first swap.',
      )
      const gild = srPath === 'mester' && srHintsUsed === 0 && srWrong === 0
      awardCard(2, 'spar', t('Sigillet fra Sandrommet', 'The seal of the Sand Room'))
      if (gild && !state.gilded.includes('2-spar')) {
        state.gilded.push('2-spar')
        save()
      }
      renderFacts('sr-facts', 'sandrommet')
      $('sr-solved').hidden = false
      $('sr-solved').scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'nearest' })
    })

    $('sr-scarab').addEventListener('click', () => {
      $('sr-scarab').hidden = true
      awardCard(2, 'klover', t('Kuriositeten: skarabeen fra Dedis tid', 'The curiosity: the scarab from Dedi’s time'))
    })

    $('sr-complete').addEventListener('click', () => {
      awardCard(2, 'hjerter', t('Plakatkortet fra Sandrommet er trykket', 'The Sand Room poster card is printed'))
      goTo('speilgangen')
    })

    // ═══ SPEILGANGEN ═════════════════════════════════════════════
    interface PlayCard { rank: string; suit: Suit; label: string }
    const sgRank = (r: 'K' | 'D' | 'Kn') => t(r, { K: 'K', D: 'Q', Kn: 'J' }[r])
    const sgLabel = (r: 'K' | 'D' | 'Kn', suit: Suit) => {
      const names = { K: t('Kongen', 'The king'), D: t('Damen', 'The queen'), Kn: t('Knekten', 'The jack') }
      return `${names[r]} ${t('i', 'of')} ${SUITS[suit].name}`
    }
    const sgCard = (r: 'K' | 'D' | 'Kn', suit: Suit): PlayCard => ({ rank: sgRank(r), suit, label: sgLabel(r, suit) })
    const SG_SET_A: PlayCard[] = [
      sgCard('K', 'hjerter'), sgCard('D', 'spar'), sgCard('Kn', 'ruter'),
      sgCard('K', 'klover'), sgCard('D', 'ruter'), sgCard('Kn', 'spar'),
    ]
    const SG_SET_B: PlayCard[] = [
      sgCard('K', 'spar'), sgCard('D', 'hjerter'), sgCard('Kn', 'klover'),
      sgCard('K', 'ruter'), sgCard('D', 'klover'), sgCard('Kn', 'hjerter'),
    ]
    let sgBefore = SG_SET_A
    let sgAfter = SG_SET_B

    function bigCard(c: PlayCard): HTMLElement {
      const s = SUITS[c.suit]
      const el = document.createElement('span')
      el.className = 'pcard pcard--big' + (s.red ? ' pcard--red' : '')
      el.setAttribute('role', 'img')
      el.setAttribute('aria-label', c.label)
      el.innerHTML = `<span class="pcard-face">${c.rank}</span><span class="pcard-suit">${s.sym}</span>`
      return el
    }

    function sgRenderStep1() {
      const box = $('sg-cards')
      box.innerHTML = ''
      for (const c of sgBefore) box.appendChild(bigCard(c))
      $('sg-step1').hidden = false
      $('sg-step2').hidden = true
      $('sg-step3').hidden = true
    }

    $('sg-memorized').addEventListener('click', async () => {
      $('sg-step1').hidden = true
      $('sg-step2').hidden = false
      await sleep(2300)
      $('sg-step2').hidden = true
      const after = $('sg-cards-after')
      after.innerHTML = ''
      const shown = sgAfter.slice()
      shown.splice(Math.floor(Math.random() * shown.length), 1)
      for (const c of shown) after.appendChild(bigCard(c))
      $('sg-step3').hidden = false
      awardCard(2, 'ruter', t('Illusjonskortet fra Speilgangen', 'The illusion card of the Mirror Passage'))
      ;($('sg-continue') as HTMLButtonElement).hidden = false
    })

    $('sg-again').addEventListener('click', () => {
      ;[sgBefore, sgAfter] = [sgAfter, sgBefore]
      sgBefore = sgBefore.slice().sort(() => Math.random() - 0.5)
      $('sg-reveal').hidden = true
      sgRenderStep1()
    })

    $('sg-reveal-btn').addEventListener('click', () => {
      const cmp = $('sg-compare')
      cmp.innerHTML = ''
      const mk = (title: string, cards: PlayCard[]) => {
        const col = document.createElement('div')
        const h = document.createElement('p')
        h.className = 'reveal-col-title'
        h.textContent = title
        col.appendChild(h)
        const row = document.createElement('div')
        row.className = 'card-row'
        for (const c of cards) row.appendChild(bigCard(c))
        col.appendChild(row)
        return col
      }
      cmp.appendChild(mk(t('Kortene du fikk se:', 'The cards you were shown:'), sgBefore))
      cmp.appendChild(mk(t('Kortene du fikk «igjen»:', 'The cards you got “back”:'), sgAfter))
      renderFacts('sg-facts', 'speilgangen')
      $('sg-reveal').hidden = false
    })

    $('sg-continue').addEventListener('click', () => goTo('markedsplassen'))

    // ═══ MARKEDSPLASSEN ══════════════════════════════════════════
    let mpHintsUsed = 0
    let mpWrong = 0
    let mpPath = state.path['markedsplassen'] || ''

    const MP_HINTS = lang === 'en' ? [
      'The answer is in the verse. All of it is.',
      'Read downwards, not across.',
      'The first letter of every line, apprentice.',
    ] : [
      'Svaret står i verset. Alt sammen gjør det.',
      'Les nedover, ikke bortover.',
      'Første bokstav i hver linje, lærling.',
    ]
    wireHints('mp-hint-btn', 'mp-hints', MP_HINTS, () => { mpHintsUsed++ })

    document.querySelectorAll<HTMLButtonElement>('.path-btn[data-scene="mp"]').forEach(btn =>
      btn.addEventListener('click', () => {
        mpPath = btn.dataset.path || 'laerling'
        state.path['markedsplassen'] = mpPath
        save()
        $('mp-pathchoice').hidden = true
        $('mp-game').hidden = false
        $('mp-pretext').textContent = mpPath === 'laerling'
          ? t(
              'Direktøren lener seg inntil øret ditt: «Gjøglere gjemmer alltid hemmelighetene sine i ordene. Hør på verset — ordentlig.»',
              'The Director leans close to your ear: “Conjurers always hide their secrets in the words. Listen to the verse — properly.”',
            )
          : t('Gjøgleren roper verset sitt én gang. Mer får du ikke.', 'The conjurer shouts his verse once. That is all you get.')
      })
    )

    // .mp-cup is a shared button class — later rooms (Øyet, Salongen, …) use
    // it too, so both the listener and the disable must stay inside #mp-game.
    document.querySelectorAll<HTMLButtonElement>('#mp-game .mp-cup').forEach(btn =>
      btn.addEventListener('click', () => {
        if (btn.dataset.pick === 'midten') {
          document.querySelectorAll<HTMLButtonElement>('#mp-game .mp-cup').forEach(b => { b.disabled = true })
          $('mp-msg').textContent = t(
            'Gjøgleren løfter det midterste kruset: erten! Han bukker dypt. «Endelig én som hører etter!»',
            'The conjurer lifts the middle mug: the pea! He bows deeply. “At last, someone who listens!”',
          )
          const gild = mpPath === 'mester' && mpHintsUsed === 0 && mpWrong === 0
          awardCard(3, 'spar', t('Sigillet fra Markedsplassen', 'The seal of the Market Square'))
          if (gild && !state.gilded.includes('3-spar')) {
            state.gilded.push('3-spar')
            save()
          }
          renderFacts('mp-facts', 'markedsplassen')
          $('mp-solved').hidden = false
          $('mp-solved').scrollIntoView({ behavior: reducedMotion ? 'auto' : 'smooth', block: 'nearest' })
        } else {
          mpWrong++
          $('mp-msg').textContent = t(
            'Gjøgleren løfter kruset: tomt! Han ler rått. «Nei og nei! Hørte du ikke etter? Jeg sa jo hvor den lå!»',
            'The conjurer lifts the mug: empty! He laughs coarsely. “Dear, dear! Weren’t you listening? I told you where it was!”',
          )
        }
      })
    )

    $('mp-mouse').addEventListener('click', () => {
      $('mp-mouse').hidden = true
      awardCard(3, 'klover', t('Kuriositeten: musa med erten i munnen', 'The curiosity: the mouse with the pea in its mouth'))
    })

    $('mp-complete').addEventListener('click', () => {
      awardCard(3, 'hjerter', t('Plakatkortet fra Markedsplassen er trykket', 'The Market Square poster card is printed'))
      goTo('epilog')
    })

    // ═══ EPILOG AKT I ════════════════════════════════════════════
    // Shared epilogue phrasing: "N of M cards — X of them gilded."
    const gildedPhrase = (gilded: number) =>
      gilded > 0
        ? (lang === 'en'
            ? ` — ${gilded === 1 ? 'one of them gilded' : `${gilded} of them gilded`}. `
            : ` — ${gilded === 1 ? 'ett av dem gylt' : `${gilded} av dem gylte`}. `)
        : '. '
    const REMEMBER_LINE = t(
      'Rommene husker deg — det som ennå mangler, kan finnes en annen natt.',
      'The rooms remember you — what is still missing can be found another night.',
    )

    function renderEpilog() {
      const n = state.cards.filter(c => parseInt(c) <= 3).length
      let txt = lang === 'en'
        ? `You leave Act I with ${n} of ${TOTAL_ACT1} cards in your deck`
        : `Du forlater Akt I med ${n} av ${TOTAL_ACT1} kort i kortstokken`
      txt += gildedPhrase(state.gilded.length)
      txt += n >= TOTAL_ACT1 - 1
        ? t('Direktøren hever et øyenbryn: «Imponerende samling, lærling.»', 'The Director raises an eyebrow: “An impressive collection, apprentice.”')
        : REMEMBER_LINE
      $('ep-deck-summary').textContent = txt
    }
    $('ep-poster').addEventListener('click', downloadPoster)
    $('ep-deck').addEventListener('click', () => { renderDeck(); deckModal.showModal() })
    $('ep-act2').addEventListener('click', () => goTo('galleriet'))

    // ═══ GALLERIET (SPEILGANGEN: ENDRINGSBLINDHET) ═══════════════
    interface Painting { title: string; a: string; b: string; descA: string; descB: string }
    const GA_PAINTINGS: Painting[] = lang === 'en' ? [
      { title: 'Ship in a Storm',    a: '🚢', b: '⛵', descA: 'a steamship on a raging sea',     descB: 'a small sailboat on a raging sea' },
      { title: 'Basket of Fruit',    a: '🍎', b: '🍐', descA: 'a red apple at the top of the basket', descB: 'a green pear at the top of the basket' },
      { title: 'The Pet',            a: '🐈‍⬛', b: '🐕', descA: 'a black cat, sleeping',            descB: 'a little dog, sleeping' },
      { title: 'Night over Årvoll',  a: '🌕', b: '🌙', descA: 'a round full moon above the farm', descB: 'a thin crescent moon above the farm' },
      { title: 'Flowers in a Vase',  a: '🌹', b: '🌷', descA: 'red roses in the vase',            descB: 'red tulips in the vase' },
      { title: 'The Director’s Hat', a: '🎩', b: '👒', descA: 'a tall black top hat',             descB: 'a wide-brimmed summer hat' },
    ] : [
      { title: 'Skip i storm',       a: '🚢', b: '⛵', descA: 'et dampskip på opprørt hav',      descB: 'en liten seilbåt på opprørt hav' },
      { title: 'Kurv med frukt',     a: '🍎', b: '🍐', descA: 'et rødt eple øverst i kurven',    descB: 'en grønn pære øverst i kurven' },
      { title: 'Husdyret',           a: '🐈‍⬛', b: '🐕', descA: 'en svart katt som sover',         descB: 'en liten hund som sover' },
      { title: 'Natt over Årvoll',   a: '🌕', b: '🌙', descA: 'en rund fullmåne over gården',    descB: 'en smal månesigd over gården' },
      { title: 'Blomster i vase',    a: '🌹', b: '🌷', descA: 'røde roser i vasen',              descB: 'røde tulipaner i vasen' },
      { title: 'Direktørens hodeplagg', a: '🎩', b: '👒', descA: 'en høy, sort flosshatt',       descB: 'en bredbremmet sommerhatt' },
    ]
    let gaChanged = -1
    let gaShowingB = false
    let gaDone = false
    let gaWrong = 0

    function gaRender() {
      const wall = $('ga-wall')
      wall.innerHTML = ''
      GA_PAINTINGS.forEach((p, i) => {
        const btn = document.createElement('button')
        btn.className = 'painting'
        const showB = gaShowingB && i === gaChanged
        btn.innerHTML = `<span class="painting-art" aria-hidden="true">${showB ? p.b : p.a}</span><span class="painting-title">${p.title}</span>`
        btn.setAttribute('aria-label', lang === 'en'
          ? `Painting “${p.title}”: ${showB ? p.descB : p.descA}`
          : `Maleri «${p.title}»: ${showB ? p.descB : p.descA}`)
        btn.disabled = gaChanged < 0 || gaDone
        if (gaDone && i === gaChanged) btn.classList.add('painting--found')
        btn.addEventListener('click', () => gaPick(i))
        wall.appendChild(btn)
      })
    }

    async function gaBlink() {
      const overlay = $('ga-blink')
      overlay.hidden = false
      await sleep(900)
      if (gaChanged < 0) {
        gaChanged = Math.floor(Math.random() * GA_PAINTINGS.length)
        gaShowingB = true
        $('ga-msg').textContent = t(
          'Noe på veggen er ikke som det var. Trykk på maleriet som endret seg — eller blunk igjen om du trenger å sammenligne.',
          'Something on the wall is not as it was. Press the painting that changed — or blink again if you need to compare.',
        )
        $('ga-blink-btn').textContent = t('Blunk igjen 👁️', 'Blink again 👁️')
      } else {
        gaShowingB = !gaShowingB
      }
      gaRender()
      overlay.hidden = true
    }

    function gaFinish(byGivingUp: boolean) {
      gaDone = true
      gaShowingB = true
      gaRender()
      ;($('ga-blink-btn') as HTMLButtonElement).hidden = true
      ;($('ga-giveup') as HTMLButtonElement).hidden = true
      $('ga-msg').textContent = byGivingUp
        ? (lang === 'en'
            ? `The Director points at “${GA_PAINTINGS[gaChanged].title}”. “You looked at it, apprentice. Twice. That is the whole point.”`
            : `Direktøren peker på «${GA_PAINTINGS[gaChanged].title}». «Du så på det, lærling. To ganger. Det er hele poenget.»`)
        : (lang === 'en'
            ? `Right — “${GA_PAINTINGS[gaChanged].title}” swapped its motif right before your eyes. And most nights, nobody notices.`
            : `Riktig — «${GA_PAINTINGS[gaChanged].title}» byttet motiv rett foran øynene dine. Og de fleste netter går det ingen opp i.`)
      awardCard(3, 'ruter', t('Illusjonskortet fra Galleriet', 'The illusion card of the Gallery'))
      renderFacts('ga-facts', 'galleriet')
      $('ga-reveal').hidden = false
      ;($('ga-continue') as HTMLButtonElement).hidden = false
    }

    function gaPick(i: number) {
      if (gaDone || gaChanged < 0) return
      if (i === gaChanged) {
        gaFinish(false)
      } else {
        gaWrong++
        $('ga-msg').textContent = lang === 'en'
          ? `“${GA_PAINTINGS[i].title}” hangs as it has always hung. Blink again and compare.`
          : `«${GA_PAINTINGS[i].title}» henger som det alltid har hengt. Blunk igjen og sammenlign.`
        if (gaWrong >= 2) ($('ga-giveup') as HTMLButtonElement).hidden = false
      }
    }

    $('ga-blink-btn').addEventListener('click', gaBlink)
    $('ga-giveup').addEventListener('click', () => gaFinish(true))
    $('ga-continue').addEventListener('click', () => goTo('biblioteket'))

    // ═══ BIBLIOTEKET ═════════════════════════════════════════════
    interface BlPair { icon: string; name: string; laerling: string; mester: string }
    const BL_PAIRS: BlPair[] = lang === 'en' ? [
      { icon: '🗡️', name: 'The knife through the arm',
        laerling: 'The blade slides into the handle — the knife was never whole.',
        mester: 'The steel retreats home to where it came from.' },
      { icon: '🍽️', name: 'The head on the platter',
        laerling: 'The table has two holes — and room for two boys.',
        mester: 'The platter is honest. The furniture lies.' },
      { icon: '🪙', name: 'The vanishing coin',
        laerling: 'The coin never leaves the hand — it rests hidden in the grip.',
        mester: 'What vanished never travelled.' },
      { icon: '🪢', name: 'The rope cut and restored',
        laerling: 'An extra piece of rope is switched in — that is the piece sacrificed to the knife.',
        mester: 'The one sacrificed is not the one you saw.' },
    ] : [
      { icon: '🗡️', name: 'Kniven gjennom armen',
        laerling: 'Bladet glir inn i skaftet — kniven var aldri hel.',
        mester: 'Stålet viker hjem dit det kom fra.' },
      { icon: '🍽️', name: 'Hodet på fatet',
        laerling: 'Bordet har to hull — og plass til to gutter.',
        mester: 'Fatet er ærlig. Møbelet lyver.' },
      { icon: '🪙', name: 'Mynten som forsvinner',
        laerling: 'Mynten forlater aldri hånden — den hviler skjult i grepet.',
        mester: 'Det som forsvant, har aldri reist.' },
      { icon: '🪢', name: 'Snoren som deles og heles',
        laerling: 'En ekstra bit snor byttes inn — det er den som ofres for kniven.',
        mester: 'Den som ofres, er ikke den du så.' },
    ]
    const BL_SECRET_ORDER = [2, 0, 3, 1]
    let blPath = state.path['biblioteket'] || ''
    let blHintsUsed = 0
    let blWrong = 0
    let blSelected = -1
    let blMatched: number[] = []

    const BL_HINTS = lang === 'en' ? [
