    // ═══ KINOEN ══════════════════════════════════════════════════
    const KI_STRIPS = [
      'Damen tar plass i stolen',
      'Kledet bres over henne',
      'Kledet rives bort — stolen er tom',
      'Magikeren maner — et skjelett sitter i stolen!',
      'Damen er tilbake, og bukker mot salen',
    ]
    const KI_SHUFFLE = [2, 4, 0, 3, 1]  // fixed scramble of strip indices
    let kiPath = state.path['kinoen'] || ''
    let kiHintsUsed = 0
    let kiWrong = 0
    let kiNext = 0
    let kiPhase = 1

    const KI_HINTS = [
      'Historien er enkel: en dame, et klede, en stol. Begynn der.',
      'Det umulige skjer aldri mens du ser det. Det skjer mellom to bilder.',
      'Kameraet stanset første gang i det kledet lå over stolen.',
    ]
    wireHints('ki-hint-btn', 'ki-hints', KI_HINTS, () => { kiHintsUsed++ })

    function kiRenderStrips() {
      const box = $('ki-strips')
      box.innerHTML = ''
      for (const idx of KI_SHUFFLE) {
        const btn = document.createElement('button')
        btn.className = 'ki-strip'
        btn.innerHTML = `<span class="ki-frame" aria-hidden="true">🎞️</span><span>${KI_STRIPS[idx]}</span><span class="ki-order">${idx < kiNext ? idx + 1 : ''}</span>`
        btn.disabled = idx < kiNext
        if (idx < kiNext) btn.classList.add('ki-strip--placed')
        btn.addEventListener('click', () => {
          if (idx === kiNext) {
            kiNext++
            $('ki-msg').textContent = kiNext === KI_STRIPS.length ? '' : 'Riktig — filmen vokser.'
            kiRenderStrips()
            if (kiNext === KI_STRIPS.length) kiStartPhase2()
          } else {
            kiWrong++
            $('ki-msg').textContent = 'Prosjektoren hakker: den biten hører ikke hjemme der.'
          }
        })
        box.appendChild(btn)
      }
    }

    function kiStartPhase2() {
      kiPhase = 2
      $('ki-phase1').hidden = true
      const gaps = $('ki-gaps')
      gaps.innerHTML = ''
      for (let i = 0; i < KI_STRIPS.length - 1; i++) {
        const btn = document.createElement('button')
        btn.className = 'mp-cup'
        btn.textContent = `Mellom ${i + 1} og ${i + 2}`
        btn.addEventListener('click', () => {
          if (i === 1) {
            document.querySelectorAll<HTMLButtonElement>('#ki-gaps .mp-cup').forEach(b => { b.disabled = true })
