    // ═══ DET FRIE VALGET (SPEILGANGEN: EQUIVOQUE) ════════════════
    const FV_ITEMS = [
      { key: 'lykt',   icon: '🏮', name: 'Lykten' },
      { key: 'speil',  icon: '🪞', name: 'Speilet' },
      { key: 'kort',   icon: '🃏', name: 'Kortstokken' },
    ]
    const FV_TARGET = 'speil'
    let fvPhase: 'pickTwo' | 'pickOne' | 'done' = 'pickTwo'
    let fvPicked: string[] = []
    let fvRemaining = FV_ITEMS.map(i => i.key)
    let fvReceipts: string[] = []

    function fvName(key: string) { return FV_ITEMS.find(i => i.key === key)!.name }

    function fvRender() {
      const box = $('fv-items')
      box.innerHTML = ''
      for (const item of FV_ITEMS) {
        if (!fvRemaining.includes(item.key)) continue
        const btn = document.createElement('button')
        btn.className = 'fv-item' + (fvPicked.includes(item.key) ? ' fv-item--picked' : '')
        btn.innerHTML = `<span class="fv-icon" aria-hidden="true">${item.icon}</span><span>${item.name}</span>`
        btn.disabled = fvPhase === 'done'
        btn.addEventListener('click', () => fvPick(item.key))
        box.appendChild(btn)
      }
    }

    function fvLogLine(text: string) {
      const li = document.createElement('li')
      li.textContent = text
      $('fv-log').appendChild(li)
    }

    async function fvPick(key: string) {
      if (fvPhase === 'pickTwo') {
        if (fvPicked.includes(key)) {
          fvPicked = fvPicked.filter(k => k !== key)
          fvRender()
          return
        }
        fvPicked.push(key)
        fvRender()
        if (fvPicked.length < 2) return
        const keepPair = fvPicked.includes(FV_TARGET)
        const other = FV_ITEMS.map(i => i.key).find(k => !fvPicked.includes(k))!
        if (keepPair) {
          fvLogLine(`Du pekte på ${fvName(fvPicked[0]).toLowerCase()} og ${fvName(fvPicked[1]).toLowerCase()}. «De to beholder vi,» sier Direktøren — og rydder bort ${fvName(other).toLowerCase()}.`)
          fvReceipts.push(`Paret ditt inneholdt speilet → valget ble tolket som «behold».`)
          fvRemaining = [...fvPicked]
        } else {
          fvLogLine(`Du pekte på ${fvName(fvPicked[0]).toLowerCase()} og ${fvName(fvPicked[1]).toLowerCase()}. «De to rydder vi bort,» sier Direktøren.`)
          fvReceipts.push(`Paret ditt inneholdt ikke speilet → valget ble tolket som «fjern».`)
          fvRemaining = [other]
        }
        fvPicked = []
        await sleep(300)
        if (fvRemaining.length === 2) {
          fvPhase = 'pickOne'
          $('fv-msg').innerHTML = 'To gjenstander igjen. <strong>Pek på én av dem</strong> — fortsatt helt fritt.'
        } else {
          fvFinish()
        }
        fvRender()
      } else if (fvPhase === 'pickOne') {
        if (key === FV_TARGET) {
          fvLogLine(`Du pekte på speilet. «Det beholder du,» sier Direktøren — og rydder bort det siste.`)
          fvReceipts.push(`Du pekte på speilet → valget ble tolket som «behold».`)
          fvRemaining = [FV_TARGET]
        } else {
          fvLogLine(`Du pekte på ${fvName(key).toLowerCase()}. «Det rydder vi bort,» sier Direktøren.`)
          fvReceipts.push(`Du pekte på noe annet enn speilet → valget ble tolket som «fjern».`)
          fvRemaining = [FV_TARGET]
        }
        fvFinish()
        fvRender()
      }
    }

    function fvFinish() {
      fvPhase = 'done'
