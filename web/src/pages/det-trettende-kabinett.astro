    async function ghPlay() {
      const log = $('gh-log')
      log.innerHTML = ''
      $('gh-pick').hidden = true
      for (let i = 0; i < GH_BEATS.length; i++) {
        const li = document.createElement('li')
        li.textContent = GH_BEATS[i]
        log.appendChild(li)
        await sleep(ghPath === 'mester' ? 650 : 1000)
      }
      const beats = $('gh-beats')
      beats.innerHTML = ''
      GH_BEATS.forEach((_, i) => {
        const btn = document.createElement('button')
        btn.className = 'mp-cup'
        btn.textContent = `Øyeblikk ${i + 1}`
        btn.addEventListener('click', () => ghGuess(i))
        beats.appendChild(btn)
      })
      $('gh-pick').hidden = false
    }

    function ghGuess(i: number) {
      if (ghSolved) return
      if (i === GH_CORRECT) {
        ghSolved = true
        document.querySelectorAll<HTMLButtonElement>('#gh-beats .mp-cup').forEach(b => { b.disabled = true })
        $('gh-msg').textContent = 'Gatekunstneren stopper midt i bukket og ser på deg. Så åpner han høyrehånden: mynten. Den lå der hele tiden.'
        const gild = ghPath === 'mester' && ghHintsUsed === 0 && ghWrong === 0
        awardCard(11, 'spar', 'Sigillet fra Gatehjørnet')
