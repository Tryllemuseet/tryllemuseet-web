---
// src/components/TriksGodeRad.astro
// Delt popup med gode råd, brukt på hver triks sin egen side
// (web/src/pages/barn/laer-et-triks/[slug].astro). Samme tekst for alle triks.
---

<button type="button" class="godrad-lenke" id="godrad-apne">
  💡 Gode råd
</button>

<dialog id="godrad-modal" class="godrad-modal">
  <div class="godrad-inner">
    <div class="godrad-topbar">
      <h2 class="godrad-title">Gode råd</h2>
      <button class="godrad-lukk" id="godrad-lukk" aria-label="Lukk">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" aria-hidden="true">
          <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div class="godrad-scroll">
      <section class="godrad-seksjon">
        <h3>Til deg som øver</h3>
        <ul>
          <li>Øv mange ganger foran et speil, eller for en voksen du stoler på, før du viser trikset til andre.</li>
          <li>Ta deg god tid — ingen ser at et triks tar litt forberedelse.</li>
          <li>Snakk gjerne mens du gjør trikset. Det gjør det morsommere, og får publikum til å se dit du vil.</li>
          <li>Ikke vis samme triks to ganger på rad til de samme personene — da er det lettere å gjennomskue.</li>
          <li>Avslør aldri hemmeligheten selv. La heller de som ser på få lure litt!</li>
          <li>Det er helt normalt å feile mange ganger under øving — selv de beste tryllekunstnerne øvde utrolig mye før de fikk det til.</li>
        </ul>
      </section>

      <section class="godrad-seksjon">
        <h3>Til voksne</h3>
        <ul>
          <li>La barnet øve i sitt eget tempo. Press for å «få det til» tar bort gleden.</li>
          <li>Noen triks bruker saks eller andre skarpe eller små gjenstander — hjelp til, og følg med underveis.</li>
          <li>Vær et godt publikum: la deg overraske, still spørsmål, og ikke avslør hvordan trikset funker selv om du skjønner det.</li>
          <li>Å lære et triks er en fin måte å øve seg på å snakke foran andre og bygge selvtillit. Ros gjerne innsatsen, ikke bare resultatet.</li>
        </ul>
      </section>
    </div>
  </div>
</dialog>

<style>
  .godrad-lenke {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--burgundy);
    background: var(--cream);
    border: 1px solid var(--cream-dark);
    border-radius: var(--radius);
    padding: 0.5em 1.1em;
    cursor: pointer;
    transition: border-color 150ms ease, color 150ms ease;
  }
  .godrad-lenke:hover { border-color: var(--gold); }

  .godrad-modal {
    padding: 0;
    border: none;
    border-radius: 10px;
    box-shadow: 0 24px 64px rgba(26,18,8,0.45);
    width: min(92vw, 640px);
    max-height: 85dvh;
    overflow: hidden;
    background: white;
  }
  .godrad-modal[open] { display: flex; flex-direction: column; }
  .godrad-modal::backdrop { background: rgba(26,18,8,0.72); backdrop-filter: blur(3px); }

  .godrad-inner { display: flex; flex-direction: column; overflow: hidden; height: 100%; }

  .godrad-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.9rem 0.75rem 0.9rem 1.5rem;
    border-bottom: 1px solid var(--cream-dark);
    background: white;
    flex-shrink: 0;
  }
  .godrad-title { font-family: var(--font-display); font-size: 1.3rem; color: var(--burgundy); }

  .godrad-lukk {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    color: var(--ink-mid);
    background: var(--cream);
    flex-shrink: 0;
    transition: background 150ms, color 150ms;
  }
  .godrad-lukk:hover { background: var(--cream-dark); color: var(--burgundy); }

  .godrad-scroll { overflow-y: auto; padding: 1.5rem; }

  .godrad-seksjon + .godrad-seksjon { margin-top: 1.75rem; }
  .godrad-seksjon h3 {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--burgundy);
    margin-bottom: 0.6rem;
  }
  .godrad-seksjon ul {
    margin: 0;
    padding-left: 1.2rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: #444;
    line-height: 1.65;
  }
  .godrad-seksjon li { margin-bottom: 0.4rem; }

  @media (max-width: 480px) {
    .godrad-modal { width: 100vw; max-height: 100dvh; border-radius: 0; }
  }
</style>

<script>
  const modal = document.getElementById('godrad-modal') as HTMLDialogElement
  const btnApne = document.getElementById('godrad-apne') as HTMLButtonElement
  const btnLukk = document.getElementById('godrad-lukk') as HTMLButtonElement

  btnApne?.addEventListener('click', () => modal.showModal())
  btnLukk?.addEventListener('click', () => modal.close())
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) modal.close()
  })
</script>
