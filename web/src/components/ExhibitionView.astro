---
// src/components/ExhibitionView.astro
// Full page view for an exhibitionShow document (rendered from utstillingen/[slug].astro)
import BaseLayout from '../layouts/BaseLayout.astro'
import { urlFor, type ExhibitionShow } from '../lib/sanity'

interface Props {
  exhibition: ExhibitionShow
}

const { exhibition: ex } = Astro.props

const stations = ex.stations ?? []
const heroUrl = ex.heroImage?.asset
  ? urlFor(ex.heroImage).width(900).format('webp').url()
  : null
const relatedMagician =
  ex.relatedMagician && ex.relatedMagician.isVisible !== false && ex.relatedMagician.slug
    ? ex.relatedMagician
    : null
---

<BaseLayout
  title={`${ex.title} — Tryllemuseet`}
  description={ex.introAdults ?? ex.introKids ?? `Utstillingen «${ex.title}» på Tryllemuseet`}
>

  <!-- HERO ────────────────────────────────────────────────────── -->
  <section class="exhibition-hero">
    <div class="container hero-inner">
      {heroUrl && (
        <div class="hero-image-wrap">
          <img src={heroUrl} alt={ex.heroImage?.alt ?? ex.title} class="hero-image" />
        </div>
      )}
      <div class="hero-text">
        <p class="hero-kicker">Utstilling</p>
        <h1 class="display-title hero-title">{ex.title}</h1>
        {ex.subtitle && <p class="hero-subtitle">{ex.subtitle}</p>}
      </div>
    </div>
  </section>

  <div class="container page-body">

    <!-- INTRO ──────────────────────────────────────────────────── -->
    {ex.introKids && (
      <section class="child-panel" aria-label="For barn">
        <p class="child-label">⭐ For barn</p>
        <p class="child-text">{ex.introKids}</p>
      </section>
    )}

    {ex.introAdults && (
      <section class="intro-section" aria-label="Om utstillingen">
        <p class="intro-text">{ex.introAdults}</p>
      </section>
    )}

    <!-- STASJONER ──────────────────────────────────────────────── -->
    {stations.length > 0 && (
      <section class="stations-section" aria-label="Stasjonene i utstillingen">
        <h2 class="section-heading">Stasjonene i utstillingen</h2>
        <ol class="stations-list">
          {stations.map((s, i) => (
            <li class="station">
              <div class="station-marker" aria-hidden="true">
                <span class="station-number">{i + 1}</span>
                <span class="station-line" />
              </div>
              <div class="station-body">
                <header class="station-header">
                  {s.year && <p class="station-year">{s.year}</p>}
                  <h3 class="station-title">{s.title}</h3>
                </header>
                {s.image?.asset && (
                  <div class="station-image-wrap">
                    <img
                      src={urlFor(s.image).width(800).format('webp').url()}
                      alt={s.image.alt ?? s.title}
                      class="station-image"
                      loading="lazy"
                    />
                  </div>
                )}
                {s.textKids && (
                  <div class="station-kids">
                    <p class="child-label">⭐ For barn</p>
                    <p class="child-text">{s.textKids}</p>
                  </div>
                )}
                {s.textAdults && <p class="station-adults">{s.textAdults}</p>}
                {s.activityPrompt && (
                  <div class="station-activity">
                    <span aria-hidden="true">★</span>
                    {s.activityPrompt}
                  </div>
                )}
              </div>
            </li>
          ))}
        </ol>
      </section>
    )}

    <!-- HVEM ER HVEM ───────────────────────────────────────────── -->
    {relatedMagician && (
      <aside class="related-magician">
        <p>
          Vil du vite mer?
          <a href={`/tryllehistorie/magiens-hvem-er-hvem/${relatedMagician.slug}`}>
            Les om {relatedMagician.name} i Magiens hvem er hvem →
          </a>
        </p>
      </aside>
    )}

    <!-- KILDER ─────────────────────────────────────────────────── -->
    {ex.sources && ex.sources.length > 0 && (
      <section class="sources-section" aria-label="Kilder">
        <h2 class="section-heading">Kilder</h2>
        <ul class="sources-list">
          {ex.sources.map(src => (
            <li>
              {src.url
                ? (
                  <a href={src.url} target="_blank" rel="noopener noreferrer">
                    {src.label}
                    <svg class="ext-icon" viewBox="0 0 12 12" fill="none" aria-label="Åpnes i ny fane">
                      <path d="M2 10L10 2M10 2H5M10 2V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  </a>
                )
                : <span>{src.label}</span>
              }
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- NAVIGASJON ─────────────────────────────────────────────── -->
    <nav class="exhibition-nav" aria-label="Tilbake til utstillingen">
      <a href="/utstillingen" class="btn-nav">← Utstillingen</a>
    </nav>

  </div>
</BaseLayout>

<style>
  /* ── HERO ──────────────────────────────────────────────────────── */
  .exhibition-hero {
    background: var(--burgundy-dk);
    padding: 3.5rem 0 3rem;
    border-bottom: 2px solid var(--gold-dark);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-image-wrap {
    width: 260px;
    flex-shrink: 0;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    border: 2px solid var(--gold-dark);
  }
  .hero-image { width: 100%; display: block; }

  .hero-text { color: var(--cream); }
  .hero-kicker {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }
  .hero-title {
    font-size: clamp(1.8rem, 4vw, 3rem);
    color: var(--cream);
    margin-bottom: 0.5rem;
  }
  .hero-subtitle {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-style: italic;
    color: var(--gold);
  }

  /* ── PAGE BODY ─────────────────────────────────────────────────── */
  .page-body {
    padding-top: 3rem;
    padding-bottom: 5rem;
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* ── BARNETEKST / INTRO ────────────────────────────────────────── */
  .child-panel {
    background: #FFF9E0;
    border: 2px solid #E8C840;
    border-radius: 6px;
    padding: 1.5rem;
  }
  .child-label {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #C47A00;
    margin-bottom: 0.6rem;
  }
  .child-text {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.65;
    color: var(--ink);
  }

  .intro-text {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.75;
    color: var(--ink);
    font-style: italic;
  }

  /* ── STASJONER ─────────────────────────────────────────────────── */
  .stations-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .station {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
  }

  .station-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .station-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    flex-shrink: 0;
    border-radius: 50%;
    background: var(--burgundy);
    border: 2px solid var(--gold-dark);
    color: var(--cream);
    font-family: var(--font-display);
    font-size: 1rem;
  }
  .station-line {
    flex: 1;
    width: 2px;
    margin-top: 0.5rem;
    background: var(--cream-dark);
  }
  .station:last-child .station-line { display: none; }

  .station-body {
    padding-bottom: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-width: 0;
  }
  .station:last-child .station-body { padding-bottom: 0; }

  .station-year {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold-dark);
    margin-bottom: 0.25rem;
  }
  .station-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--burgundy);
    letter-spacing: 0.03em;
    padding-top: 0.3rem;
  }

  .station-image-wrap {
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--cream-dark);
  }
  .station-image { width: 100%; display: block; }

  .station-kids {
    background: #FFF9E0;
    border: 2px solid #E8C840;
    border-radius: 6px;
    padding: 1rem 1.25rem;
  }

  .station-adults {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--ink);
  }

  .station-activity {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    background: #E8C840;
    border-radius: 4px;
    padding: 0.6rem 0.9rem;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--ink);
    align-self: flex-start;
  }

  /* ── HVEM ER HVEM ──────────────────────────────────────────────── */
  .related-magician {
    background: var(--cream);
    border: 1px solid var(--cream-dark);
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
    font-family: var(--font-ui);
    font-size: 0.95rem;
    color: var(--ink);
  }
  .related-magician a {
    color: var(--burgundy);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
    margin-left: 0.35rem;
    transition: color 150ms;
  }
  .related-magician a:hover { color: var(--gold-dark); }

  /* ── KILDER ─────────────────────────────────────────────────────── */
  .sources-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .sources-list li {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    font-family: var(--font-ui);
    font-size: 0.875rem;
  }
  .sources-list li::before { content: '→'; color: var(--gold-dark); flex-shrink: 0; }
  .sources-list a {
    color: #185FA5;
    text-decoration: underline;
    text-underline-offset: 2px;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    transition: color 180ms;
  }
  .sources-list a:hover { color: var(--burgundy); }
  .ext-icon { width: 10px; height: 10px; flex-shrink: 0; opacity: 0.6; }
  .sources-list span { color: var(--grey); font-style: italic; }

  /* ── SECTION HEADING ────────────────────────────────────────────── */
  .section-heading {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--burgundy);
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--cream-dark);
    letter-spacing: 0.04em;
  }

  /* ── NAVIGASJON ─────────────────────────────────────────────────── */
  .exhibition-nav { padding-top: 1.5rem; border-top: 1px solid var(--cream-dark); }
  .btn-nav {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--burgundy);
    padding: 0.5rem 1rem;
    border: 1.5px solid var(--cream-dark);
    border-radius: var(--radius);
    transition: border-color 180ms, color 180ms;
    display: inline-block;
  }
  .btn-nav:hover { border-color: var(--gold); color: var(--gold-dark); }

  /* ── RESPONSIVE ─────────────────────────────────────────────────── */
  @media (max-width: 700px) {
    .hero-inner      { grid-template-columns: 1fr; gap: 1.5rem; }
    .hero-image-wrap { width: 180px; }
    .page-body       { padding-top: 2rem; padding-bottom: 3rem; }
    .station         { gap: 0.9rem; }
  }
</style>
