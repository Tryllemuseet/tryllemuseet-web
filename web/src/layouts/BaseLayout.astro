---
// src/layouts/BaseLayout.astro
import { getSiteConfig } from '../lib/sanity'
import MemberModal from '../components/MemberModal.astro'

export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Tryllemuseet',
  description,
} = Astro.props;

const site = await getSiteConfig()
const metaDescription = description ?? site.seoDescription

// Flat liste for footer og mobil
const allNavLinks = [
  { href: '/besok',                         label: 'Besøk oss'           },
  { href: '/utstillingen',                  label: 'Utstillingen'        },
  { href: '/aktiviteter',                   label: 'Aktiviteter'         },
  { href: '/aktiviteter/tryllekunstnere',   label: 'Bestill tryllekunstner' },
  { href: '/tryllehistorie/got-talent',     label: 'Opptredener'         },
  { href: '/tryllehistorie',                label: 'Arkivet'             },
  { href: '/om-oss',                        label: 'Om oss'              },
  { href: '/om-oss/i-media',               label: 'I media'             },
]

const currentPath = Astro.url.pathname

// Helper: er vi innenfor en seksjon?
const isActive = (href: string) =>
  href !== '/' && currentPath.startsWith(href)
---
<!DOCTYPE html>
<html lang="nb">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={metaDescription} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Lora:ital,wght@0,400;0,600;1,400&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ── HEADER ─────────────────────────────────────────────────── -->
  <header class="site-header">
    <div class="header-inner">

      <!-- Logo -->
      <a href="/" class="logo-link" aria-label="Tryllemuseet — forsiden">
        <img src="/LOGO-bred.png" alt="Tryllemuseet" class="logo-img" width="220" height="44" />
      </a>

      <!-- Venstre nav -->
      <nav class="main-nav main-nav--left" aria-label="Hovednavigasjon venstre">
        <ul>

          <li>
            <a href="/besok" class:list={['nav-link', { active: isActive('/besok') }]}>
              Besøk oss
            </a>
          </li>

          <!-- Utstillingen med dropdown -->
          <li class="has-dropdown">
            <a href="/utstillingen" class:list={['nav-link', { active: isActive('/utstillingen') }]}>
              Utstillingen <span class="nav-chevron">▾</span>
            </a>
            <ul class="dropdown" role="list">
              <li><a href="/utstillingen" class="dropdown-link">Oversikt</a></li>
              <li><a href="/utstillingen/artefakter" class="dropdown-link">Artefakter</a></li>
              <li><a href="/utstillingen/trylleforeningene" class="dropdown-link dropdown-link--soon">Trylleforeningene</a></li>
              <li><a href="/utstillingen/tryllebutikken" class="dropdown-link dropdown-link--soon">Tryllebutikken</a></li>
            </ul>
          </li>

          <!-- Aktiviteter med dropdown -->
          <li class="has-dropdown">
            <a href="/aktiviteter" class:list={['nav-link', { active: isActive('/aktiviteter') || isActive('/arrangementer') || isActive('/barn') }]}>
              Aktiviteter <span class="nav-chevron">▾</span>
            </a>
            <ul class="dropdown" role="list">
              <li><a href="/aktiviteter" class="dropdown-link">Oversikt</a></li>
              <li><a href="/barn" class="dropdown-link">Barn &amp; unge</a></li>
              <li><a href="/aktiviteter/tryllekunstnere" class="dropdown-link">Bestill tryllekunstner</a></li>
            </ul>
          </li>

          <!-- Opptredener med dropdown -->
          <li class="has-dropdown">
            <a href="/tryllehistorie/got-talent" class:list={['nav-link', { active: isActive('/tryllehistorie/got-talent') || isActive('/tryllehistorie/fool-us') || isActive('/tryllehistorie/historiske-opptak') }]}>
              Opptredener <span class="nav-chevron">▾</span>
            </a>
            <ul class="dropdown" role="list">
              <li><a href="/tryllehistorie/got-talent" class="dropdown-link">Got Talent</a></li>
              <li><a href="/tryllehistorie/fool-us" class="dropdown-link">Penn &amp; Teller: Fool Us</a></li>
              <li><a href="/tryllehistorie/historiske-opptak" class="dropdown-link">Historiske opptak</a></li>
            </ul>
          </li>

        </ul>
      </nav>

      <!-- Høyre nav -->
      <nav class="main-nav main-nav--right" aria-label="Hovednavigasjon høyre">
        <ul>

          <!-- Arkivet med dropdown -->
          <li class="has-dropdown">
            <a href="/tryllehistorie" class:list={['nav-link', { active: isActive('/tryllehistorie') || isActive('/bibliotek') }]}>
              Arkivet <span class="nav-chevron">▾</span>
            </a>
            <ul class="dropdown" role="list">
              <li><a href="/tryllehistorie/magiens-hvem-er-hvem" class="dropdown-link">Hvem er hvem</a></li>
              <li><a href="/tryllehistorie/norske-legender" class="dropdown-link">Norske legender</a></li>
              <li><a href="/tryllehistorie/historiske-artikler" class="dropdown-link">Historiske artikler</a></li>
              <li><a href="/bibliotek" class="dropdown-link">Bibliotek</a></li>
            </ul>
          </li>

          <!-- Om oss med dropdown -->
          <li class="has-dropdown">
            <a href="/om-oss" class:list={['nav-link', { active: isActive('/om-oss') }]}>
              Om oss <span class="nav-chevron">▾</span>
            </a>
            <ul class="dropdown" role="list">
              <li><a href="/om-oss" class="dropdown-link">Om museet</a></li>
              <li><a href="/om-oss/i-media" class="dropdown-link">I media</a></li>
            </ul>
          </li>

          <li>
            <button type="button" class="nav-cta" onclick="openMemberModal()">Bli medlem</button>
          </li>

        </ul>
      </nav>

      <button class="hamburger" id="menu-toggle" aria-label="Åpne meny" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>

    </div>

    <!-- Mobilmeny -->
    <nav class="mobile-menu" id="mobile-menu" aria-label="Mobilnavigasjon" aria-hidden="true">
      <ul>
        <li><a href="/besok"       class:list={['mobile-nav-link', { active: isActive('/besok') }]}>Besøk oss</a></li>

        <li class="mobile-section">
          <a href="/utstillingen" class:list={['mobile-nav-link', { active: isActive('/utstillingen') }]}>Utstillingen</a>
          <ul class="mobile-sub">
            <li><a href="/utstillingen/artefakter"        class="mobile-sub-link">Artefakter</a></li>
            <li><a href="/utstillingen/trylleforeningene" class="mobile-sub-link mobile-sub-link--soon">Trylleforeningene</a></li>
            <li><a href="/utstillingen/tryllebutikken"    class="mobile-sub-link mobile-sub-link--soon">Tryllebutikken</a></li>
          </ul>
        </li>

        <li class="mobile-section">
          <a href="/aktiviteter" class:list={['mobile-nav-link', { active: isActive('/aktiviteter') || isActive('/barn') }]}>Aktiviteter</a>
          <ul class="mobile-sub">
            <li><a href="/aktiviteter"                      class="mobile-sub-link">Oversikt</a></li>
            <li><a href="/barn"                             class="mobile-sub-link">Barn &amp; unge</a></li>
            <li><a href="/aktiviteter/tryllekunstnere"      class="mobile-sub-link">Bestill tryllekunstner</a></li>
          </ul>
        </li>

        <li class="mobile-section">
          <a href="/tryllehistorie/got-talent" class:list={['mobile-nav-link', { active: isActive('/tryllehistorie/got-talent') || isActive('/tryllehistorie/fool-us') || isActive('/tryllehistorie/historiske-opptak') }]}>Opptredener</a>
          <ul class="mobile-sub">
            <li><a href="/tryllehistorie/got-talent"        class="mobile-sub-link">Got Talent</a></li>
            <li><a href="/tryllehistorie/fool-us"           class="mobile-sub-link">Penn &amp; Teller: Fool Us</a></li>
            <li><a href="/tryllehistorie/historiske-opptak" class="mobile-sub-link">Historiske opptak</a></li>
          </ul>
        </li>

        <li class="mobile-section">
          <a href="/tryllehistorie" class:list={['mobile-nav-link', { active: isActive('/tryllehistorie') || isActive('/bibliotek') }]}>Arkivet</a>
          <ul class="mobile-sub">
            <li><a href="/tryllehistorie/magiens-hvem-er-hvem"   class="mobile-sub-link">Hvem er hvem</a></li>
            <li><a href="/tryllehistorie/norske-legender"         class="mobile-sub-link">Norske legender</a></li>
            <li><a href="/tryllehistorie/historiske-artikler"     class="mobile-sub-link">Historiske artikler</a></li>
            <li><a href="/bibliotek"                              class="mobile-sub-link">Bibliotek</a></li>
          </ul>
        </li>

        <li class="mobile-section">
          <a href="/om-oss" class:list={['mobile-nav-link', { active: isActive('/om-oss') }]}>Om oss</a>
          <ul class="mobile-sub">
            <li><a href="/om-oss"         class="mobile-sub-link">Om museet</a></li>
            <li><a href="/om-oss/i-media" class="mobile-sub-link">I media</a></li>
          </ul>
        </li>
        <li>
          <button type="button" class="mobile-nav-link mobile-nav-cta" onclick="openMemberModal()">
            Bli medlem →
          </button>
        </li>
      </ul>
    </nav>
  </header>

  <!-- ── MAIN ───────────────────────────────────────────────────── -->
  <main id="main-content">
    <slot />
  </main>

  <!-- ── FOOTER ─────────────────────────────────────────────────── -->
  <footer class="site-footer">
    <div class="footer-inner">

      <div class="footer-brand">
        <span class="footer-name">✦ Tryllemuseet ✦</span>
        <p class="footer-address">{site.addressShort}</p>
        <p class="footer-hours">{site.openingHoursShort} &nbsp;·&nbsp; {site.openingHoursNote}</p>
      </div>

      <div class="footer-links">
        <h3>Utforsk</h3>
        <ul>
          {allNavLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-contact">
        <h3>Kontakt</h3>
        <a href="/kontakt" class="footer-cta">Send oss en melding</a>
        <div class="social-links">
          {site.facebook && (
            <a href={site.facebook} aria-label="Facebook" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          )}
          {site.instagram && (
            <a href={site.instagram} aria-label="Instagram" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/></svg>
            </a>
          )}
        </div>
      </div>

    </div>
    <div class="footer-bottom">
      <p>© {new Date().getFullYear()} Tryllemuseet &nbsp;·&nbsp; <a href="/personvern">Personvern</a></p>
    </div>
  </footer>

  <!-- MEMBER MODAL ────────────────────────────────────────────── -->
  <MemberModal />

  <!-- LIGHTBOX ─────────────────────────────────────────────────── -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Forstørret bilde" hidden>
    <button class="lightbox-close" id="lightbox-close" aria-label="Lukk">✕</button>
    <figure class="lightbox-figure">
      <img id="lightbox-img" src="" alt="" />
      <figcaption id="lightbox-caption" class="lightbox-caption"></figcaption>
    </figure>
  </div>

</body>
</html>

<script>
  // ── Lightbox ──────────────────────────────────────────────────
  const lightbox  = document.getElementById('lightbox') as HTMLElement
  const lbImg     = document.getElementById('lightbox-img') as HTMLImageElement
  const lbCaption = document.getElementById('lightbox-caption') as HTMLElement
  const lbClose   = document.getElementById('lightbox-close') as HTMLButtonElement

  function openLightbox(src: string, alt: string, caption: string) {
    lbImg.src = src
    lbImg.alt = alt
    lbCaption.textContent = caption
    lbCaption.hidden = !caption
    lightbox.hidden = false
    document.body.style.overflow = 'hidden'
    lbClose.focus()
  }

  function closeLightbox() {
    lightbox.hidden = true
    lbImg.src = ''
    document.body.style.overflow = ''
  }

  // Click on images inside .prose, .gallery-grid, .gallery-fig, .sidebar-portrett
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement
    if (target.tagName !== 'IMG') return
    const parent = target.closest('.prose, .gallery-grid, .gallery-fig, .sidebar-portrett, .gallery-section, .gallery-seksjon')
    if (!parent) return
    const img = target as HTMLImageElement
    const caption = target.closest('figure')?.querySelector('figcaption')?.textContent ?? ''
    openLightbox(img.src, img.alt, caption)
  })

  // Close on overlay click, button click, or Escape
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox()
  })
  lbClose.addEventListener('click', closeLightbox)
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !lightbox.hidden) closeLightbox()
  })

  // ── Scroll animations ─────────────────────────────────────────
  ;(function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible')
            observer.unobserve(entry.target)
          }
        })
      },
      { threshold: 0.15 }
    )
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        document.querySelectorAll('[data-animate]').forEach(el => {
          const r = el.getBoundingClientRect()
          if (r.top < window.innerHeight && r.bottom > 0) {
            el.classList.add('visible')
          }
        })
        document.documentElement.classList.add('js-animate')
        document.querySelectorAll('[data-animate]:not(.visible)').forEach(el =>
          observer.observe(el)
        )
      })
    })
  })()

  // ── Hamburger

  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(open));
    menu?.setAttribute('aria-hidden', String(!open));
  });
  menu?.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => {
      menu.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
    })
  );

  // Desktop dropdowns — åpnes ved hover via CSS,
  // men tastatur/klikk håndteres her for tilgjengelighet
  document.querySelectorAll('.has-dropdown').forEach(item => {
    const link     = item.querySelector('.nav-link');
    const dropdown = item.querySelector('.dropdown') as HTMLElement | null;
    if (!link || !dropdown) return;

    // Klikk på selve nav-lenken navigerer — dropdown lukkes
    link.addEventListener('click', () => {
      dropdown.classList.remove('open');
    });
  });
</script>

<style is:global>
  :root {
    --gold:        #D4A843;
    --gold-light:  #E8C870;
    --gold-dark:   #A07820;
    --burgundy:    #6B0F1A;
    --burgundy-dk: #4A0A12;
    --cream:       #FBF7EF;
    --cream-dark:  #F0E8D8;
    --ink:         #1A1208;
    --ink-mid:     #3D2E1A;
    --grey:        #8A8A8A;
    --grey-light:  #D0C8B8;
    --font-display: 'Cinzel', 'Times New Roman', serif;
    --font-body:    'Lora', Georgia, serif;
    --font-ui:      'Source Sans 3', system-ui, sans-serif;
    --header-h:    72px;
    --max-w:       1200px;
    --radius:      4px;
    --shadow:      0 2px 16px rgba(26,18,8,0.12);
    --shadow-lg:   0 8px 40px rgba(26,18,8,0.18);
    --transition:  200ms ease;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
  body { font-family: var(--font-body); font-size: 1rem; line-height: 1.7; color: var(--ink); background: var(--cream); min-height: 100dvh; display: flex; flex-direction: column; }
  img, svg { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }
  ul { list-style: none; }
  button { cursor: pointer; border: none; background: none; font: inherit; }
  main { flex: 1; padding-top: var(--header-h); }

  /* ── HEADER ── */
  .site-header { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: var(--burgundy); border-bottom: 2px solid var(--gold-dark); box-shadow: 0 2px 20px rgba(0,0,0,0.35); }
  .header-inner { max-width: var(--max-w); margin: 0 auto; padding: 0 1.5rem; height: var(--header-h); display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 1rem; }
  .logo-link { display: flex; justify-content: center; align-items: center; text-decoration: none; flex-shrink: 0; }
  .logo-img { height: 44px; width: auto; display: block; object-fit: contain; }
  @media (max-width: 560px) { .logo-img { height: 40px; } }

  /* Nav */
  .main-nav ul { display: flex; align-items: center; gap: 0.25rem; }
  .main-nav--left ul  { justify-content: flex-start; }
  .main-nav--right ul { justify-content: flex-start; }

  .nav-link { font-family: var(--font-ui); font-size: 0.875rem; font-weight: 600; color: var(--cream); letter-spacing: 0.04em; padding: 0.4rem 0.75rem; border-radius: var(--radius); transition: color var(--transition), background var(--transition); position: relative; white-space: nowrap; }
  .nav-link::after { content: ''; position: absolute; bottom: 0; left: 50%; right: 50%; height: 2px; background: var(--gold); transition: left var(--transition), right var(--transition); }
  .nav-link:hover  { color: var(--gold); }
  .nav-link:hover::after { left: 0.75rem; right: 0.75rem; }
  .nav-link.active { color: var(--gold); }
  .nav-link.active::after { left: 0.75rem; right: 0.75rem; }

  .nav-chevron { font-size: 0.65rem; opacity: 0.7; margin-left: 0.15rem; }

  .nav-cta { font-family: var(--font-ui); font-size: 0.8rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--burgundy); background: var(--gold); padding: 0.4rem 1rem; border-radius: var(--radius); margin-left: 0.5rem; transition: background var(--transition), color var(--transition); white-space: nowrap; }
  .nav-cta:hover { background: var(--gold-light); color: var(--burgundy-dk); }

  /* ── DROPDOWN ── */
  .has-dropdown { position: relative; }

  .dropdown {
    position: absolute;
    top: calc(100% + 2px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 220px;
    background: var(--burgundy-dk);
    border: 1px solid var(--gold-dark);
    border-radius: 6px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.35);
    padding: 0.5rem 0;
    /* Hidden by default */
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateX(-50%) translateY(-6px);
    /* Åpner raskt, lukker med 120ms forsinkelse så musen rekker å nå menyen */
    transition: opacity 160ms ease, transform 160ms ease,
                visibility 0ms 120ms;
  }

  /* Usynlig bro mellom nav-lenke og dropdown — hindrer at menyen forsvinner i gapet */
  .dropdown::after {
    content: '';
    position: absolute;
    top: -14px;
    left: 0; right: 0;
    height: 14px;
  }

  /* Arrow tip */
  .dropdown::before {
    content: '';
    position: absolute;
    top: -6px; left: 50%;
    transform: translateX(-50%);
    border-left: 6px solid transparent;
    border-right: 6px solid transparent;
    border-bottom: 6px solid var(--gold-dark);
  }

  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
    /* Ingen forsinkelse ved åpning */
    transition: opacity 160ms ease, transform 160ms ease,
                visibility 0ms 0ms;
  }

  .dropdown-link {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--cream);
    padding: 0.55rem 1.1rem;
    transition: background var(--transition), color var(--transition);
    white-space: nowrap;
  }
  .dropdown-link:hover { background: rgba(212,168,67,0.12); color: var(--gold-light); }

  /* Kommer snart — dempet */
  .dropdown-link--soon {
    opacity: 0.45;
    pointer-events: none;
  }
  .dropdown-link--soon::after {
    content: ' ·';
    font-size: 0.7rem;
    opacity: 0.6;
  }

  /* Hamburger */
  .hamburger { display: none; flex-direction: column; gap: 5px; padding: 8px; grid-column: 3; justify-self: end; margin-left: auto; }
  .hamburger span { display: block; width: 24px; height: 2px; background: var(--cream); border-radius: 2px; transition: transform var(--transition), opacity var(--transition); }

  /* ── MOBILMENY ── */
  .mobile-menu { display: none; background: var(--burgundy-dk); border-top: 1px solid var(--gold-dark); }
  .mobile-menu.open { display: block; }
  .mobile-menu > ul { max-width: var(--max-w); margin: 0 auto; padding: 0.75rem 1.5rem 1rem; display: flex; flex-direction: column; gap: 0.1rem; }

  .mobile-nav-link { display: block; font-family: var(--font-ui); font-size: 1rem; font-weight: 600; color: var(--cream); padding: 0.6rem 0.75rem; border-radius: var(--radius); transition: color var(--transition), background var(--transition); letter-spacing: 0.03em; }
  .mobile-nav-link:hover, .mobile-nav-link.active { color: var(--gold); background: rgba(212,168,67,0.1); }
  .mobile-nav-cta { color: var(--gold); border: 1px solid var(--gold-dark); margin-top: 0.5rem; }
  .mobile-nav-cta:hover { background: var(--gold); color: var(--burgundy-dk); }

  .mobile-sub { padding: 0.1rem 0 0.3rem 1.25rem; display: flex; flex-direction: column; gap: 0; }
  .mobile-sub-link { display: block; font-family: var(--font-ui); font-size: 0.875rem; color: var(--cream); opacity: 0.7; padding: 0.35rem 0.75rem; border-radius: var(--radius); transition: opacity var(--transition), color var(--transition); }
  .mobile-sub-link:hover { opacity: 1; color: var(--gold-light); }
  .mobile-sub-link--soon { opacity: 0.35; pointer-events: none; }

  /* ── FOOTER ── */
  .site-footer { background: var(--burgundy-dk); border-top: 2px solid var(--gold-dark); color: var(--cream); margin-top: auto; }
